
# Puerto del servidor (por defecto 3000)
PORT=3001

# ============================================
# CONFIGURACION DE MYSQL
# ============================================
# Host de la base de datos (localhost si es local)
DB_HOST=localhost

# Puerto de MySQL (por defecto 3306)
DB_PORT=3306

# Usuario de MySQL
DB_USER=root

# Contrasena de MySQL
DB_PASSWORD=Eduardo2403_

# Nombre de la base de datos
DB_NAME=excel_validator

# ============================================
# CONFIGURACION DE SEGURIDAD
# ============================================

JWT_SECRET=canyon-ankle-lazy

# Tiempo de expiracion del token (ej: 24h, 7d, 30d)
JWT_EXPIRES_IN=24h

# ============================================
# CONFIGURACION DE ARCHIVOS
# ============================================
MAX_FILE_SIZE_MB=50

# Carpeta donde se guardan los archivos (relativa al backend)
UPLOAD_FOLDER=./uploads
