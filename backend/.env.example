PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=24h
JWT_COOKIE_MAX_AGE_MS=86400000
MFA_ENCRYPTION_KEY=replace_with_another_long_random_secret
MFA_ISSUER=XBFS Operations Hub

AUTH_MAX_FAILED_ATTEMPTS=7
AUTH_LOCK_WINDOW_MINUTES=15

FRONTEND_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

REQUEST_BODY_LIMIT=10mb
MAX_FILE_SIZE_MB=50
UPLOAD_FOLDER=./uploads
PROFILE_UPLOAD_DIR=./uploads/perfiles
PROFILE_PHOTO_MAX_MB=3
PROPERTY_MANAGEMENT_FILE_SIZE_MB=75
PROPERTY_MANAGEMENT_SCHEDULE_UPLOAD_DIR=./uploads/schedules
PREPAID_FILE_SIZE_MB=75
PREPAID_SCHEDULE_UPLOAD_DIR=./uploads/prepaid-schedules
