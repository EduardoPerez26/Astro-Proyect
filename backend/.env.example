PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h
JWT_SESSION_HOURS=8
JWT_REMEMBER_EXPIRES_IN=30d
JWT_REMEMBER_HOURS=720
MFA_ENCRYPTION_KEY=replace_with_another_long_random_secret
MFA_ISSUER=XBFS Operations Hub

AUTH_MAX_FAILED_ATTEMPTS=7
AUTH_LOCK_WINDOW_MINUTES=15

API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=40


FRONTEND_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

REQUEST_BODY_LIMIT=10mb
MAX_FILE_SIZE_MB=50
UPLOAD_FOLDER=./uploads
PROFILE_UPLOAD_DIR=./uploads/perfiles
PROFILE_PHOTO_MAX_MB=3
PROPERTY_MANAGEMENT_FILE_SIZE_MB=75
PROPERTY_MANAGEMENT_SCHEDULE_UPLOAD_DIR=./uploads/schedules
PREPAID_FILE_SIZE_MB=75
PREPAID_SCHEDULE_UPLOAD_DIR=./uploads/prepaid-schedules


# Scheduled report delivery
CORPORATE_REPORT_OUTPUT_DIR=./generated/reports
SENDGRID_API_KEY=
SENDGRID_FROM=

# Sage Intacct integration
# Leave blank until Web Services is enabled and credentials are issued.
INTACCT_SENDER_ID=
INTACCT_SENDER_PASSWORD=
INTACCT_COMPANY_ID=
INTACCT_USER_ID=
INTACCT_USER_PASSWORD=
INTACCT_ENTITY_ID=
INTACCT_REPORTING_BOOK=ACCRUAL
INTACCT_ENDPOINT_URL=https://api.intacct.com/ia/xml/xmlgw.phtml
INTACCT_TIMEOUT_MS=30000


# Microsoft Entra ID readiness
# Register an application in the customer tenant before enabling SSO.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=
ENTRA_FRONTEND_RETURN_URL=
ENTRA_ALLOWED_DOMAINS=

# Floating AI assistant
# Keep this key only on the backend. Never expose it in public/js or Astro pages.
AI_PROVIDER=gemini

# Free-tier alternative with a Google AI Studio API key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# OpenAI alternative.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Claude alternative. Requires Anthropic API key and available credits.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=800

# Local free alternative. Requires Ollama running on the backend machine.
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=llama3.2
