---
interface Props {
  title: string;
  includeSheetJS?: boolean;
  stylesheets?: string[];
}

const { title, includeSheetJS = false, stylesheets = [] } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/styles/app.css?v=20260714-style-repair-v2">
    <link rel="stylesheet" href="/styles/alerts.css?v=20260714-style-repair-v2">
    <link rel="stylesheet" href="/styles/modals.css?v=20260714-style-repair-v2">
    <link rel="stylesheet" href="/styles/components/card-interactions.css?v=20260714-card-hover-v1">
    {stylesheets.map((stylesheet) => (
        <link rel="stylesheet" href={stylesheet} />
    ))}
    <script is:inline>
        try {
            if (
                localStorage.getItem('sidebarCollapsed') === 'true' &&
                (!window.matchMedia || !window.matchMedia('(max-width: 1024px)').matches)
            ) {
                document.documentElement.classList.add('sidebar-collapsed-preset');
            }
        } catch (error) {
            document.documentElement.classList.remove('sidebar-collapsed-preset');
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    {includeSheetJS && (
        <>
            <script is:inline src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
            <script is:inline src="https://cdn.jsdelivr.net/npm/xlsx-calc@0.9.2/xlsx-calc.min.js"></script>
        </>
    )}
    <script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script is:inline src="/js/i18n.js?v=20260626-enterprise-ui"></script>
    <script is:inline src="/js/swal-guard.js?v=20260714-style-repair-v2"></script>
    <script is:inline src="/js/sticky-table-headers.js?v=20260713-floating-header-style-match"></script>
    <script is:inline src="/js/card-interactions.js?v=20260714-card-hover-v1"></script>
    <link rel="stylesheet" href="/styles/layout/view-standardization.css?v=20260714-view-standard-v1">
    <link rel="stylesheet" href="/styles/components/page-heroes.css?v=20260714-standard-heroes-v1">
    <link rel="stylesheet" href="/styles/screens/login-session.css?v=20260714-remember-session-v1">
    <script is:inline src="/js/session-persistence.js?v=20260714-remember-session-v1"></script>
    <link rel="stylesheet" href="/styles/modal-premium-fixes.css?v=20260714-modal-premium-fixes-v2">
</head>
<body>
    <slot />
</body>
</html>
