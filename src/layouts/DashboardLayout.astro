---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import { BUILD_ID } from '../buildId.js';

interface Props {
  title: string;
  includeSheetJS?: boolean;
}

const { title, includeSheetJS = false } = Astro.props;
const v = BUILD_ID;
---

<BaseLayout title={title} includeSheetJS={includeSheetJS}>
    <Sidebar />
    <main class="main" id="mainContent">
        <Topbar title={title} />
        <slot />
    </main>
    <script is:inline src={`/js/sidebar-loader.js?v=${v}`}></script>
</BaseLayout>
