---
interface Props {
  title: string;
  includeSheetJS?: boolean;
}

const { title, includeSheetJS = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/styles/styles.css?v=20260626-profile-settings">
    <link rel="stylesheet" href="/styles/modern-blue.css?v=20260629-modern-blue">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    {includeSheetJS && (
        <>
            <script is:inline src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
            <script is:inline src="https://cdn.jsdelivr.net/npm/xlsx-calc@0.9.2/xlsx-calc.min.js"></script>
        </>
    )}
    <script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script is:inline src="/js/i18n.js?v=20260626-enterprise-ui"></script>
    <script is:inline src="/js/swal-guard.js?v=20260626-enterprise-ui"></script>
</head>
<body>
    <slot />
</body>
</html>
