---
interface Props {
    title: string;
    includeSheetJS?: boolean;
    stylesheets?: string[];
}

const { title, includeSheetJS = false } = Astro.props;
---

<!doctype html>
<html lang="en" data-platform-version="2.0">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <script is:inline>
            (function () {
                try {
                    var stored = localStorage.getItem("xbfsTheme");
                    var theme =
                        stored === "dark" || stored === "light"
                            ? stored
                            : window.matchMedia &&
                                window.matchMedia(
                                    "(prefers-color-scheme: dark)",
                                ).matches
                              ? "dark"
                              : "light";
                    document.documentElement.setAttribute("data-theme", theme);
                } catch (error) {
                    document.documentElement.setAttribute(
                        "data-theme",
                        "light",
                    );
                }
            })();
        </script>
        <title>{title}</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link
            rel="stylesheet"
            href="/styles/consolidated-main.css?v=20260720-consolidated-v2"
        />
        <link
            rel="stylesheet"
            href="/styles/consolidated-dark.css?v=20260720-consolidated-v2"
        />
        <script is:inline>
            try {
                if (
                    localStorage.getItem("sidebarCollapsed") === "true" &&
                    (!window.matchMedia ||
                        !window.matchMedia("(max-width: 1024px)").matches)
                ) {
                    document.documentElement.classList.add(
                        "sidebar-collapsed-preset",
                    );
                }
            } catch (error) {
                document.documentElement.classList.remove(
                    "sidebar-collapsed-preset",
                );
            }
        </script>
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
            rel="stylesheet"
        />
        {
            includeSheetJS && (
                <>
                    <script
                        is:inline
                        src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"
                    />
                    <script
                        is:inline
                        src="https://cdn.jsdelivr.net/npm/xlsx-calc@0.9.2/xlsx-calc.min.js"
                    />
                </>
            )
        }
        <script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"
        ></script>
        <script is:inline src="/js/config.js?v=20260716-global-config-v1"
        ></script>
        <script is:inline src="/js/swal-guard.js?v=20260715-alerts-clean-v6"
        ></script>
        <script is:inline src="/js/i18n.js?v=20260626-enterprise-ui"></script>
        <script
            is:inline
            src="/js/sticky-table-headers.js?v=20260713-floating-header-style-match"
        ></script>
        <script
            is:inline
            src="/js/card-interactions.js?v=20260714-card-hover-v1"></script>
        <script src="/js/corporate-ux.js?v=20260717-corporate-v1" defer
        ></script>
        <script
            is:inline
            src="/js/session-persistence.js?v=20260714-remember-session-v1"
        ></script>
        <script
            src="/js/sidebar-premium.js?v=20260716-system-errors-permission-guard-v1"
            defer></script>
    </head>
    <body>
        <slot />
        <script
            is:inline
            src="/js/ui-final-polish.js?v=20260716-ui-final-polish-v3"></script>
        <script
            is:inline
            src="/js/floating-chatbot.js?v=20260716-floating-chatbot-v1"
        ></script>
    </body>
</html>
