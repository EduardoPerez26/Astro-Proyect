---
// Componente Sidebar - Barra lateral de navegacion con control de permisos
---

<aside class="sidebar sidebar-permissions-pending" id="sidebar">
    <div class="sidebar-header">
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Abrir/cerrar menu">
            <i class="fa-solid fa-bars"></i>
        </button>
        <div class="sidebar-logo">
            <span class="sidebar-logo-text">XBFS</span>
        </div>
    </div>
    <div class="sidebar-department-card" title="Departamento activo">
        <span data-department-label>AR</span>
        <strong data-department-name>Accounts Receivable</strong>
    </div>
    <nav class="sidebar-nav">
        <!-- GENERAL -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">General</div>
            <ul class="sidebar-menu" id="menuGeneral">
                <li class="sidebar-menu-item" data-permission="tiendas">
                    <a class="sidebar-menu-link" href="/views/tiendas">
                        <i class="fa-solid fa-shop"></i>
                        <span>Tiendas</span>
                    </a>
                </li>
                <li class="sidebar-menu-item" data-permission="documentos">
                    <a class="sidebar-menu-link" href="/views/documentos">
                        <i class="fa-solid fa-file-excel"></i>
                        <span>Documentos</span>
                    </a>
                </li>
                <li class="sidebar-menu-item" data-permission="historial">
                    <a class="sidebar-menu-link" href="/views/historial">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        <span>Historial</span>
                    </a>
                </li>
            </ul>
        </div>
        
        <!-- ADMINISTRACION -->
        <div class="sidebar-section" id="sectionAdmin">
            <div class="sidebar-section-title">Administracion</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item" data-permission="dashboardAdmin" data-admin-only>
                    <a class="sidebar-menu-link" href="/views/dashboard-admin">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-menu-item" data-permission="usuarios" data-admin-only>
                    <a class="sidebar-menu-link" href="/views/usuarios">
                        <i class="fa-solid fa-users"></i>
                        <span>Usuarios</span>
                    </a>
                </li>
                <li class="sidebar-menu-item" data-permission="controlRestaurantes" data-admin-only>
                    <a class="sidebar-menu-link" href="/views/restaurantes">
                        <i class="fa-solid fa-screwdriver-wrench"></i>
                        <span>Control de restaurantes</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="sidebar-footer">
        <button class="sidebar-logout" id="logoutBtn">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Cerrar sesion</span>
        </button>
    </div>
</aside>
