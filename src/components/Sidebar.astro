---
// Componente Sidebar - Barra lateral de navegacion
---

<aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Abrir/cerrar menu">
            <i class="fa-solid fa-bars"></i>
        </button>
        <div class="sidebar-logo">
            <span class="sidebar-logo-text">XBFS</span>
        </div>
    </div>

    <div class="sidebar-profile">
        <div class="header-user" id="sidebarProfileToggle" aria-expanded="false" role="button" tabindex="0">
            <div class="avatar" id="sidebarAvatar">EP</div>
            <div class="profile-info">
                <div class="header-user-name" id="sidebarUserName">Cargando...</div>
                <div class="header-user-role" id="sidebarUserRole">...</div>
            </div>
        </div>
    </div>

    <nav class="sidebar-nav">
        <!-- GENERAL -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">General</div>
            <ul class="sidebar-menu">
               
                <li class="sidebar-menu-item">
                    <a class="sidebar-menu-link" href="/views/perfil">
                        <i class="fa-solid fa-user"></i>
                        <span>Perfil</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a class="sidebar-menu-link" href="/views/tiendas">
                        <i class="fa-solid fa-shop"></i>
                        <span>Tiendas</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a class="sidebar-menu-link" href="/views/documentos">
                        <i class="fa-solid fa-folder-open"></i>
                        <span>Documentos</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a class="sidebar-menu-link" href="/views/historial">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        <span>Historial</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="sidebar-footer">
        <button class="sidebar-logout" id="logoutBtn">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Cerrar sesion</span>
        </button>
    </div>
</aside>
