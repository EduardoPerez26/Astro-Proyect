---
// Sidebar component with permission-aware navigation.
---

<aside class="sidebar sidebar-permissions-pending" id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <span class="sidebar-logo-text">XBFS</span>
        </div>
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Open or close menu">
            <i class="fa-solid fa-bars"></i>
        </button>
    </div>
    <div class="sidebar-search" role="search">
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
        <input id="sidebarSearch" type="search" placeholder="Search..." autocomplete="off" aria-label="Search menu">
    </div>
    <nav class="sidebar-nav">
        <!-- GENERAL -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">Accounts Receivable</div>
            <ul class="sidebar-menu" id="menuGeneral">
                <li class="sidebar-menu-item" data-permission="tiendas">
                    <a class="sidebar-menu-link" href="/views/tiendas">
                        <i class="fa-solid fa-shop"></i>
                        <span>Stores</span>
                    </a>
                </li>
                <li class="sidebar-menu-item" data-permission="documentos">
                    <a class="sidebar-menu-link" href="/views/documentos">
                        <i class="fa-solid fa-file-excel"></i>
                        <span>Documents</span>
                    </a>
                </li>
                <li class="sidebar-menu-item" data-permission="historial">
                    <a class="sidebar-menu-link" href="/views/historial">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        <span>History</span>
                    </a>
                </li>
            </ul>
        </div>

        <!-- DEPARTMENTS -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">Property Management</div>
            <ul class="sidebar-menu" id="menuDepartments">
                <li class="sidebar-menu-item" data-permission="propertyManagement">
                    <a class="sidebar-menu-link" href="/views/departments/property-management">
                        <i class="fa-solid fa-building-user"></i>
                        <span>Schedules</span>
                    </a>
                </li>
                <li class="sidebar-menu-item" data-permission="propertyManagementDocuments">
                    <a class="sidebar-menu-link" href="/views/departments/property-management-documents">
                        <i class="fa-solid fa-folder-tree"></i>
                        <span>Documents</span>
                    </a>
                </li>
            </ul>
        </div>
        
        <!-- ADMINISTRACION -->
        <div class="sidebar-section" id="sectionAdmin">
            <div class="sidebar-section-title">Information Technology</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item" data-permission="dashboardAdmin" data-admin-only>
                    <a class="sidebar-menu-link" href="/views/dashboard-admin">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-menu-item" data-permission="usuarios" data-admin-only>
                    <a class="sidebar-menu-link" href="/views/usuarios">
                        <i class="fa-solid fa-users"></i>
                        <span>Users</span>
                    </a>
                </li>
                <li class="sidebar-menu-item" data-permission="controlRestaurants" data-admin-only>
                    <a class="sidebar-menu-link" href="/views/restaurantes">
                        <i class="fa-solid fa-screwdriver-wrench"></i>
                        <span>Restaurant control</span>
                    </a>
                </li>
            </ul>
        </div>

        <!-- ACCOUNT -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">Account</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item" data-permission="perfil">
                    <a class="sidebar-menu-link sidebar-profile-link" href="/views/perfil" aria-label="Profile and security">
                        <i class="fa-solid fa-user-gear"></i>
                        <span>Profile and security</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-user-card">
            <span class="avatar sidebar-user-avatar" id="sidebarUserAvatar">--</span>
            <span class="sidebar-user-copy">
                <strong id="sidebarUserName">User</strong>
                <small id="sidebarUserRole">Role</small>
            </span>
        </div>
        <button class="sidebar-logout" id="logoutBtn">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Log out</span>
        </button>
    </div>
</aside>
<script is:inline>
    (function () {
        try {
            var isDesktop = !window.matchMedia || !window.matchMedia('(max-width: 1024px)').matches;
            if (!isDesktop || localStorage.getItem('sidebarCollapsed') !== 'true') return;

            document.documentElement.classList.add('sidebar-collapsed-preset');
            document.body.classList.add('sidebar-collapsed');

            var sidebar = document.getElementById('sidebar');
            if (sidebar) {
                sidebar.classList.add('collapsed');
                sidebar.style.transition = 'none';
            }
        } catch (error) {
            document.documentElement.classList.remove('sidebar-collapsed-preset');
        }
    })();
</script>
