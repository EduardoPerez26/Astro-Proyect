---
interface Props {
    label: string;
    value?: string | number;
    meta?: string;
    icon?: string;
    valueId?: string;
    metaId?: string;
    tone?: 'success' | 'warning' | 'danger' | 'info';
}

const {
    label,
    value = '0',
    meta = '',
    icon = 'fa-chart-simple',
    valueId,
    metaId,
    tone
} = Astro.props;
---

<article class="xb-metric-card" data-tone={tone}>
    <span class="xb-metric-card__icon">
        <i class={`fa-solid ${icon}`} aria-hidden="true"></i>
    </span>
    <div>
        <small>{label}</small>
        <strong id={valueId}>{value}</strong>
        <span id={metaId}>{meta}</span>
    </div>
</article>
