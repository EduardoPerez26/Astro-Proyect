---
// Componente Topbar - Barra superior con busqueda y perfil
interface Props {
  placeholder?: string;
}

const { placeholder = "Buscar..." } = Astro.props;
---

<div class="topbar">
    <div class="topbar-left">
        <div class="header-user" id="topbarProfileToggle" aria-expanded="false" role="button" tabindex="0">
            <div class="avatar">EP</div>
            <div class="header-user-info">
                <div class="header-user-name">Usuario</div>
                <div class="header-user-role">Rol</div>
            </div>
        </div>
    </div>
    <div class="topbar-right">
        <span class="topbar-badge">Perfil</span>
    </div>

    <div class="profile-menu" id="profileMenu" role="menu" aria-label="Perfil">
        <a href="/views/perfil" class="btn btn-outline">
            <i class="fa-solid fa-user"></i>
            Ver perfil
        </a>
        <button type="button" class="btn btn-outline" id="topbarLogoutBtn">
            <i class="fa-solid fa-right-from-bracket"></i>
            Cerrar sesión
        </button>
    </div>
</div>
