---
// Componente Topbar - Barra superior con busqueda y perfil
interface Props {
  placeholder?: string;
}

const { placeholder = "Buscar..." } = Astro.props;
---

<div class="topbar">
    <div class="search-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder={placeholder}>
    </div>
    <div class="profile">
        <div class="notification">
            <i class="fa-solid fa-bell"></i>
        </div>
        <div class="header-user">
            <div class="header-user-info">
                <div class="header-user-name">Eduardo Perez</div>
                <div class="header-user-role">Administrador</div>
            </div>
            <div class="avatar">EP</div>
        </div>
    </div>
</div>
