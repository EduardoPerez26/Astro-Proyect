---
interface Props {
  id: number;
  name: string;
  description: string;
  icon: string;
  colorClass: string;
  restaurant: string;
  logoUrl?: string;
  badge?: string;
  files?: string[];
  enabled?: boolean;
}

const {
  id,
  name,
  description,
  icon,
  colorClass,
  restaurant,
  logoUrl,
  badge = '',
  files = [],
  enabled = true
} = Astro.props;
---

<article
    class:list={[
        'store-card',
        `store-card-${colorClass}`,
        { 'store-card-disabled': !enabled }
    ]}
    data-store-card
    data-store-id={id}
    data-store-code={restaurant}
    data-store-name={`${name} ${restaurant}`.toLowerCase()}
    data-store-status={enabled ? 'active' : 'paused'}
    data-default-enabled={String(enabled)}
>
    <div class="store-card-accent" aria-hidden="true"></div>

    <div class="store-card-body">
        <header class="store-card-header">
            <div class="store-brand-mark">
                {logoUrl && (
                    <img
                        src={logoUrl}
                        alt=""
                        loading="lazy"
                        onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';"
                    />
                )}
                <i
                    class={`fa-solid ${icon} store-logo-fallback`}
                    style={logoUrl ? 'display:none;' : ''}
                    aria-hidden="true"
                ></i>
            </div>

            <span
                class:list={['store-status', { 'is-active': enabled, 'is-paused': !enabled }]}
                data-store-status-badge
            >
                <span class="store-status-dot"></span>
                <span data-store-status-label>{enabled ? 'Available' : 'In preparation'}</span>
            </span>
        </header>

        <div class="store-card-copy">
            <span class="store-card-kicker">Reconciliation flow</span>
            <h2>{name}</h2>
            <p data-store-description data-default-description={description}>{description}</p>
        </div>

        <div class="store-requirements">
            <span class="store-requirements-label">Required files</span>
            <div class="store-file-list">
                {files.map((file) => (
                    <span><i class="fa-regular fa-file-excel" aria-hidden="true"></i>{file}</span>
                ))}
            </div>
        </div>

        <footer class="store-card-footer">
            <span class="store-file-count">{badge}</span>
            <a
                class="store-action"
                href={`/views/conciliacion?restaurante=${id}`}
                data-store-action
                hidden={!enabled}
            >
                Start reconciliation
                <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
            </a>
            <span class="store-action-disabled" data-store-disabled-action hidden={enabled}>
                <i class="fa-solid fa-lock" aria-hidden="true"></i>
                <span data-store-disabled-label>Not available</span>
            </span>
        </footer>
    </div>
</article>
