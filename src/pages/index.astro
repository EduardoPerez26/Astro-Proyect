---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Login">
    <div class="login-screen">
        <div class="login-card">
            <!-- Encabezado -->
            <div class="login-header">
                <h1>Sistema de Validación de Excel</h1>
                <p class="login-subtitle">
                    Ingresa tus credenciales para acceder
                </p>
            </div>

            <!-- Formulario -->
            <form class="login-form" id="loginForm">
                <div class="form-group">
                    <label class="form-label" for="username">Usuario</label>
                    <input
                        type="text"
                        id="username"
                        class="form-control"
                        placeholder="Ingresa tu usuario"
                        required
                    />
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">Contraseña</label>
                    <input
                        type="password"
                        id="password"
                        class="form-control"
                        placeholder="Ingresa tu contraseña"
                        required
                    />
                </div>

                <button type="button" id="loginBtn" class="btn btn-log">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    Iniciar sesión
                </button>
            </form>

            <!-- Pie de login opcional -->
            <p
                class="login-subtitle"
                style="text-align:center; margin-top:16px; font-size:13px;"
            >
                ¿Olvidaste tu contraseña? <a
                    href="#"
                    style="color: var(--primary);">Recuperar</a
                >
            </p>
        </div>
    </div>
    <script is:inline src="/js/login.js"></script>
</BaseLayout>
