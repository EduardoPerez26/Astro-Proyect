---
import BaseLayout from "../layouts/BaseLayout.astro";

const currentYear = new Date().getFullYear();
---

<BaseLayout title="Sign in | XBFS Operations Hub">
    <main class="login-screen">
        <div class="login-shell">
            <section class="login-brand-panel" aria-label="System overview">
                <div class="login-brand">
                    <span
                        class="login-brand-icon login-brand-monogram"
                        aria-hidden="true"
                    >
                        <span class="login-brand-monogram-text">XB</span>
                    </span>
                    <span class="login-brand-copy">
                        <strong>XBFS</strong>
                        <small>Operations Hub</small>
                    </span>
                </div>

                <div class="login-brand-message">
                    <span class="login-eyebrow">XB Franchise Solutions</span>
                    <h1>XB Operations Hub</h1>
                    <p>
                        Centralized access for reconciliations, documents, and
                        internal controls across XBFS-operated brands.
                    </p>
                </div>
                <div class="login-brand-footnote">
                    <i class="fa-solid fa-lock" aria-hidden="true"></i>
                    <span>Restricted access for authorized personnel.</span>
                </div>
            </section>

            <section class="login-form-panel">
                <button
                    type="button"
                    class="lang-toggle lang-toggle--login"
                    data-lang-toggle
                    aria-label="Switch to English"
                    title="Switch to English"
                    hidden
                >
                    <i class="fa-solid fa-language" aria-hidden="true"></i>
                    <span data-lang-label>EN</span>
                </button>

                <div class="login-form-wrap">
                    <div class="login-mobile-brand" aria-hidden="true">
                        <span class="login-brand-icon login-brand-monogram">
                            <span class="login-brand-monogram-text">XB</span>
                        </span>
                        <span class="login-mobile-brand-copy">
                            <strong>XBFS</strong>
                            <small>Operations Hub</small>
                        </span>
                    </div>

                    <div class="login-access-card">
                        <div class="login-header">
                            <span class="login-status">
                                <span class="login-status-dot"></span>
                                Secure access
                            </span>
                            <h2>Sign in</h2>
                            <p>Enter your credentials to continue.</p>
                        </div>

                        <form class="login-form" id="loginForm">
                            <div class="login-field">
                                <label for="username">Username</label>
                                <div class="login-input-wrap">
                                    <i
                                        class="fa-regular fa-user"
                                        aria-hidden="true"></i>
                                    <input
                                        type="text"
                                        id="username"
                                        name="username"
                                        placeholder="username"
                                        autocomplete="username"
                                        required
                                        autofocus
                                    />
                                </div>
                            </div>

                            <div class="login-field">
                                <label for="password">Password</label>
                                <div class="login-input-wrap">
                                    <i
                                        class="fa-solid fa-lock"
                                        aria-hidden="true"></i>
                                    <input
                                        type="password"
                                        id="password"
                                        name="password"
                                        placeholder="password"
                                        autocomplete="current-password"
                                        required
                                    />
                                    <button
                                        class="login-password-toggle"
                                        id="passwordToggle"
                                        type="button"
                                        aria-label="Show password"
                                        aria-pressed="false"
                                    >
                                        <i
                                            class="fa-regular fa-eye"
                                            aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="login-session-options">
                                <label class="login-remember-control">
                                    <input
                                        type="checkbox"
                                        id="rememberSession"
                                        name="rememberSession"
                                        value="true"
                                    />
                                    <span
                                        class="login-remember-check"
                                        aria-hidden="true"
                                    >
                                        <i class="fa-solid fa-check"></i>
                                    </span>
                                    <span class="login-remember-copy">
                                        <strong>Mantener sesión abierta</strong>
                                        <small>
                                            Conserva el acceso en este
                                            dispositivo.
                                        </small>
                                    </span>
                                </label>
                            </div>

                            <button
                                type="submit"
                                id="loginBtn"
                                class="login-submit"
                            >
                                <span>Enter the hub</span>
                                <i
                                    class="fa-solid fa-arrow-right"
                                    aria-hidden="true"></i>
                            </button>
                        </form>

                        <div class="login-enterprise-access" id="entraLoginBlock" hidden>
                            <div class="login-enterprise-divider"><span>or use corporate access</span></div>
                            <button type="button" class="login-enterprise-button" id="entraLoginBtn">
                                <i class="fa-brands fa-microsoft" aria-hidden="true"></i>
                                <span>Continue with Microsoft</span>
                            </button>
                            <small>Uses your organization account and Microsoft Entra ID policies.</small>
                        </div>

                        <form
                            class="login-form login-mfa-form"
                            id="mfaForm"
                            hidden
                        >
                            <div class="login-mfa-summary">
                                <span class="login-mfa-icon">
                                    <i
                                        class="fa-solid fa-mobile-screen-button"
                                        aria-hidden="true"></i>
                                </span>
                                <div>
                                    <strong>Authenticator required</strong>
                                    <p>
                                        Enter the 6-digit code from Microsoft
                                        Authenticator.
                                    </p>
                                </div>
                            </div>

                            <div class="login-field">
                                <label for="mfaCode">Authentication code</label>
                                <div class="login-input-wrap">
                                    <i
                                        class="fa-solid fa-key"
                                        aria-hidden="true"></i>
                                    <input
                                        type="text"
                                        id="mfaCode"
                                        name="mfaCode"
                                        placeholder="000000"
                                        autocomplete="one-time-code"
                                        inputmode="numeric"
                                        maxlength="6"
                                        pattern="[0-9]{6}"
                                    />
                                </div>
                            </div>

                            <button
                                type="submit"
                                id="mfaBtn"
                                class="login-submit"
                            >
                                <span>Verify code</span>
                                <i
                                    class="fa-solid fa-shield-halved"
                                    aria-hidden="true"></i>
                            </button>

                            <button
                                type="button"
                                id="mfaBackBtn"
                                class="login-secondary-action"
                            >
                                Use another account
                            </button>
                        </form>

                        <div class="login-security-note">
                            <i
                                class="fa-solid fa-shield-halved"
                                aria-hidden="true"></i>
                            <span
                                >Your access is logged for internal audit.</span
                            >
                        </div>
                    </div>
                </div>

                <p class="login-copyright">
                    &copy; {currentYear} XB Franchise Solutions
                </p>
            </section>
        </div>
    </main>

    <script src="/js/config.js" is:inline></script>
    <script src="/js/login.js?v=20260717-entra-sso-v1" is:inline></script>
    </BaseLayout>
