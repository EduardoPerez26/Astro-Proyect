---
import BaseLayout from "../layouts/BaseLayout.astro";

const currentYear = new Date().getFullYear();
---

<BaseLayout title="Iniciar sesión | Conciliación+">
    <main class="login-screen">
        <div class="login-glow login-glow--top" aria-hidden="true"></div>
        <div class="login-glow login-glow--bottom" aria-hidden="true"></div>

        <div class="login-shell">
            <section class="login-brand-panel" aria-label="Acerca del sistema">
                <div class="login-brand">
                    <span class="login-brand-icon" aria-hidden="true">
                        <i class="fa-solid fa-scale-balanced"></i>
                    </span>
                    <span class="login-brand-copy">
                        <strong>Conciliación<span>+</span></strong>
                        <small>Control financiero</small>
                    </span>
                </div>

                <div class="login-brand-message">
                    <h1>XBFS<br />Conciliations</h1>
                    <p>
                        Centraliza tus archivos, valida diferencias y mantén cada
                        conciliación lista para revisión.
                    </p>
                </div>

                
            </section>

            <section class="login-form-panel">
                <button
                    type="button"
                    class="lang-toggle lang-toggle--login"
                    data-lang-toggle
                    aria-label="Switch to English"
                    title="Switch to English"
                >
                    <i class="fa-solid fa-language" aria-hidden="true"></i>
                    <span data-lang-label>EN</span>
                </button>
                <div class="login-form-wrap">
                    <div class="login-mobile-brand" aria-hidden="true">
                        <span class="login-brand-icon">
                            <i class="fa-solid fa-scale-balanced"></i>
                        </span>
                        <strong>Conciliación<span>+</span></strong>
                    </div>

                    <div class="login-header">
                        <span class="login-status">
                            <span class="login-status-dot"></span>
                            Acceso seguro
                        </span>
                        <h2>Bienvenido de nuevo</h2>
                        <p>Ingresa tus credenciales para continuar al sistema.</p>
                    </div>

                    <form class="login-form" id="loginForm">
                        <div class="login-field">
                            <label for="username">Usuario</label>
                            <div class="login-input-wrap">
                                <i class="fa-regular fa-user" aria-hidden="true"></i>
                                <input
                                    type="text"
                                    id="username"
                                    name="username"
                                    placeholder="Ingresa tu usuario"
                                    autocomplete="username"
                                    required
                                    autofocus
                                />
                            </div>
                        </div>

                        <div class="login-field">
                            <label for="password">Contraseña</label>
                            <div class="login-input-wrap">
                                <i class="fa-solid fa-lock" aria-hidden="true"></i>
                                <input
                                    type="password"
                                    id="password"
                                    name="password"
                                    placeholder="Ingresa tu contraseña"
                                    autocomplete="current-password"
                                    required
                                />
                                <button
                                    class="login-password-toggle"
                                    id="passwordToggle"
                                    type="button"
                                    aria-label="Mostrar contraseña"
                                    aria-pressed="false"
                                >
                                    <i class="fa-regular fa-eye" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>

                        <button type="submit" id="loginBtn" class="login-submit">
                            <span>Iniciar sesión</span>
                            <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                        </button>
                    </form>

                    <p class="login-help">
                        ¿Problemas para ingresar? Contacta a tu administrador.
                    </p>
                </div>

                <p class="login-copyright">
                    © {currentYear} Sistema de Conciliación
                </p>
            </section>
        </div>
    </main>

    <script src="/js/config.js" is:inline></script>
    <script src="/js/login.js" is:inline></script>
</BaseLayout>
