---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Admin dashboard" stylesheets={["/styles/pages/views/dashboard-admin.css?v=20260714-style-refactor-v1"]}>
    <div class="page-container admin-dashboard-page">
        <header class="admin-dashboard-header">
            <div>
                <span class="admin-dashboard-eyebrow">GENERAL SYSTEM CONTROL</span>
                <h1>Admin dashboard</h1>
                <p>Monitor access, user activity, files, and recent movements.</p>
            </div>
            <div class="admin-dashboard-header-actions">
                <span id="adminDashboardUpdated">Not refreshed</span>
                <button class="btn btn-primary" id="refreshAdminDashboard">
                    <i class="fa-solid fa-rotate"></i>
                    Refresh
                </button>
            </div>
        </header>

        <section class="admin-metrics" aria-label="Admin summary">
            <article class="admin-metric-card">
                <span class="admin-metric-icon users"><i class="fa-solid fa-users"></i></span>
                <div><strong id="adminUsersTotal">0</strong><span>Active users</span><small id="adminUsersMeta">0 registered</small></div>
            </article>
            <article class="admin-metric-card">
                <span class="admin-metric-icon sessions"><i class="fa-solid fa-right-to-bracket"></i></span>
                <div><strong id="adminActiveSessions">0</strong><span>Active sessions</span><small id="adminLoginsToday">0 logins today</small></div>
            </article>
            <article class="admin-metric-card">
                <span class="admin-metric-icon files"><i class="fa-solid fa-file-arrow-up"></i></span>
                <div><strong id="adminFilesToday">0</strong><span>Files today</span><small id="adminFilesMeta">0 in the last 7 days</small></div>
            </article>
            <article class="admin-metric-card">
                <span class="admin-metric-icon validations"><i class="fa-solid fa-shield-halved"></i></span>
                <div><strong id="adminValidationsToday">0</strong><span>Validations today</span><small id="adminValidationMeta">0 with issues</small></div>
            </article>
            <article class="admin-metric-card">
                <span class="admin-metric-icon departments"><i class="fa-solid fa-building"></i></span>
                <div><strong id="adminDepartmentsActive">0</strong><span>Active departments</span><small id="adminDepartmentsMeta">0 registered</small></div>
            </article>
            <a class="admin-metric-card admin-metric-link" href="/views/system-errors" aria-label="Open system errors screen">
                <span class="admin-metric-icon errors"><i class="fa-solid fa-bug"></i></span>
                <div><strong id="adminSystemErrorsOpen">0</strong><span>Open errors</span><small id="adminSystemErrorsMeta">Loading system health</small></div>
            </a>
        </section>

        <section class="admin-dashboard-panel database-tables-panel">
            <header class="admin-panel-header">
                <div><span>TRACEABILITY</span><h2>Activity log</h2></div>
                <i class="fa-solid fa-list-check"></i>
            </header>
            <div class="admin-database-tables" id="adminDatabaseTables">
                <div class="admin-loading">Loading security audit...</div>
            </div>
        </section>

        <div class="admin-dashboard-grid">
            <section class="admin-dashboard-panel sessions-panel">
                <header class="admin-panel-header">
                    <div><span>SECURITY</span><h2>Logins</h2></div>
                    <i class="fa-solid fa-fingerprint"></i>
                </header>
                <div class="admin-session-list" id="adminSessionsList">
                    <div class="admin-loading">Loading sessions...</div>
                </div>
            </section>
        </div>

        <section class="admin-dashboard-panel user-activity-panel">
            <header class="admin-panel-header">
                <div><span>SYSTEM USAGE</span><h2>User activity</h2></div>
                <i class="fa-solid fa-chart-column"></i>
            </header>
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead><tr><th>User</th><th>Department</th><th>Role</th><th>Sessions</th><th>Files</th><th>Last access</th></tr></thead>
                    <tbody id="adminUserActivityBody"><tr><td colspan="6" class="admin-loading">Loading activity...</td></tr></tbody>
                </table>
            </div>
        </section>
    </div>
<script src="/js/config.js" is:inline></script>
    <script src="/js/dashboard-admin.js" is:inline></script>
</DashboardLayout>

