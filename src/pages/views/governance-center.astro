---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import PageHeader from '../../components/corporate/PageHeader.astro';
---

<DashboardLayout title="Governance settings">
    <div class="page-container corporate-page" data-corporate-center="governance">
        <PageHeader eyebrow="Information Technology" title="Governance settings" description="Define approval ownership, SLA expectations, required review levels, rejection evidence, and separation-of-duties controls by workflow." icon="fa-scale-balanced">
            <button slot="actions" id="governanceRefresh" type="button"><i class="fa-solid fa-rotate"></i> Refresh</button>
        </PageHeader>

        <section class="xb-split-grid">
            <article class="xb-panel">
                <header class="xb-panel__header"><div><span class="xb-panel__eyebrow">Approval matrix</span><h2>Workflow rules</h2><p>Global defaults can later be overridden by department or entity.</p></div></header>
                <div class="xb-table-wrap"><table class="xb-table"><thead><tr><th>Workflow</th><th>Scope</th><th>Preparer</th><th>Reviewer</th><th>Approver</th><th>Levels</th><th>SLA</th><th>Controls</th><th>Status</th></tr></thead><tbody id="governanceBody"><tr><td colspan="9"><div class="xb-loading-state"><div><i class="fa-solid fa-spinner fa-spin"></i><strong>Loading governance rules</strong></div></div></td></tr></tbody></table></div>
            </article>

            <aside class="xb-panel">
                <header class="xb-panel__header"><div><span class="xb-panel__eyebrow">Rule editor</span><h2>Add or update rule</h2><p>The same workflow and scope updates the existing rule.</p></div></header>
                <div class="xb-panel__body">
                    <form id="governanceForm" class="xb-stack" data-track-changes>
                        <label class="xb-field"><span>Workflow type</span><select name="workflow_type" required><option value="">Select workflow</option><option value="reconciliation">Reconciliation</option><option value="prepaid_schedule">Prepaid schedule</option><option value="tax_adjustment">Tax adjustment</option><option value="user_permissions">User permissions</option><option value="document_lifecycle">Document lifecycle</option></select></label>
                        <div class="xb-form-grid">
                            <label class="xb-field"><span>Preparer role</span><select name="preparer_role"><option value="usuario">User</option><option value="supervisor">Supervisor</option><option value="admin">Admin</option></select></label>
                            <label class="xb-field"><span>Reviewer role</span><select name="reviewer_role"><option value="supervisor">Supervisor</option><option value="admin">Admin</option><option value="superadmin">Superadmin</option></select></label>
                            <label class="xb-field"><span>Approver role</span><select name="approver_role"><option value="admin">Admin</option><option value="superadmin">Superadmin</option></select></label>
                            <label class="xb-field"><span>Approval levels</span><input name="approval_levels" type="number" min="1" max="5" value="2" /></label>
                            <label class="xb-field"><span>SLA hours</span><input name="sla_hours" type="number" min="1" max="720" value="48" /></label>
                        </div>
                        <label class="xb-callout"><input name="require_rejection_comment" type="checkbox" checked /> Require a comment for rejection or requested changes.</label>
                        <label class="xb-callout"><input name="separation_of_duties" type="checkbox" checked /> Enforce separation of duties between preparation and approval.</label>
                        <label class="xb-callout"><input name="active" type="checkbox" checked /> Rule is active.</label>
                        <button class="xb-button xb-button--primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save governance rule</button>
                    </form>
                </div>
            </aside>
        </section>
    </div>
    <script src="/js/corporate-centers.js?v=20260717-corporate-v1" is:inline></script>
</DashboardLayout>
