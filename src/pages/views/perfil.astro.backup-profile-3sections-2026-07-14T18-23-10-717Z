---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout
    title="Profile & Security"
    stylesheets={["/styles/pages/views/perfil.css?v=20260714-profile-security-v2-contrast"]}
>
    <div class="page-container profile-page profile-security-v2">
        <header class="profile-settings-hero">
            <div class="profile-hero-copy">
                <span class="profile-eyebrow">Account center</span>
                <h1>Profile &amp; security</h1>
                <p>
                    Manage your identity, profile photo, password, and two-step verification from one protected workspace.
                </p>
            </div>

            <div class="profile-hero-overview" aria-label="Account overview">
                <article>
                    <span class="profile-hero-icon"><i class="fa-solid fa-user-shield" aria-hidden="true"></i></span>
                    <div>
                        <small>Access level</small>
                        <strong id="profileHeroRole">Loading...</strong>
                    </div>
                </article>
                <article>
                    <span class="profile-hero-icon"><i class="fa-solid fa-building" aria-hidden="true"></i></span>
                    <div>
                        <small>Department</small>
                        <strong id="profileHeroDepartment">Loading...</strong>
                    </div>
                </article>
            </div>
        </header>

        <section class="profile-shell" aria-labelledby="profileTitle">
            <aside class="profile-summary-card" data-card-interactive>
                <div class="profile-summary-cover">
                    <span class="profile-card-kicker">Account owner</span>
                    <span class="profile-summary-shield" aria-hidden="true">
                        <i class="fa-solid fa-shield-halved"></i>
                    </span>
                </div>

                <div class="profile-summary-top">
                    <div class="profile-photo-frame">
                        <div class="profile-avatar-preview" id="profileAvatarPreview">--</div>
                        <label class="profile-photo-action" for="profilePhoto">
                            <i class="fa-solid fa-camera" aria-hidden="true"></i>
                            <span>Change photo</span>
                        </label>
                        <input
                            type="file"
                            id="profilePhoto"
                            name="foto"
                            accept="image/png,image/jpeg,image/webp"
                            hidden
                        />
                    </div>
                </div>

                <div class="profile-summary-text">
                    <h2 id="profileDisplayName">Loading...</h2>
                    <p id="profileDisplayEmail">---</p>
                </div>

                <div class="profile-account-state" aria-label="Account status">
                    <span>
                        <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                        Active profile
                    </span>
                    <span>
                        <i class="fa-solid fa-lock" aria-hidden="true"></i>
                        Protected access
                    </span>
                </div>

                <section class="profile-completion-card" aria-label="Profile completion">
                    <div>
                        <span>Account readiness</span>
                        <strong id="profileCompletionValue">0%</strong>
                    </div>
                    <div class="profile-completion-track" aria-hidden="true">
                        <span id="profileCompletionBar"></span>
                    </div>
                    <small id="profileCompletionLabel">Checking account setup...</small>
                </section>

                <dl class="profile-facts">
                    <div>
                        <dt><i class="fa-solid fa-user-shield" aria-hidden="true"></i> Role</dt>
                        <dd id="profileRoleLabel">---</dd>
                    </div>
                    <div>
                        <dt><i class="fa-solid fa-building" aria-hidden="true"></i> Department</dt>
                        <dd id="profileDepartmentLabel">---</dd>
                    </div>
                    <div>
                        <dt><i class="fa-solid fa-at" aria-hidden="true"></i> Username</dt>
                        <dd id="profileUsernameLabel">---</dd>
                    </div>
                </dl>
            </aside>

            <form class="profile-form-grid" id="profileForm" autocomplete="off">
                <div class="profile-form-intro">
                    <div>
                        <span>Account settings</span>
                        <h2 id="profileTitle">Profile preferences</h2>
                        <p>Update only the information that belongs to your account.</p>
                    </div>
                    <div class="profile-form-security-note">
                        <i class="fa-solid fa-lock" aria-hidden="true"></i>
                        <span>Changes are sent through a protected connection.</span>
                    </div>
                </div>

                <div class="profile-settings-tabs" role="tablist" aria-label="Profile settings tabs">
                    <button
                        type="button"
                        class="profile-settings-tab is-active"
                        id="profileConfigTab"
                        data-profile-tab-target="profileConfigPanel"
                        role="tab"
                        aria-selected="true"
                        aria-controls="profileConfigPanel"
                    >
                        <span class="profile-tab-icon"><i class="fa-solid fa-user-pen" aria-hidden="true"></i></span>
                        <span class="profile-tab-copy">
                            <strong>Profile</strong>
                            <small>Personal information</small>
                        </span>
                    </button>
                    <button
                        type="button"
                        class="profile-settings-tab"
                        id="profilePasswordTab"
                        data-profile-tab-target="profilePasswordPanel"
                        role="tab"
                        aria-selected="false"
                        aria-controls="profilePasswordPanel"
                    >
                        <span class="profile-tab-icon"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i></span>
                        <span class="profile-tab-copy">
                            <strong>Security</strong>
                            <small>Password and authenticator</small>
                        </span>
                    </button>
                </div>

                <div class="profile-settings-tab-panels">
                    <section
                        class="profile-panel profile-tab-panel profile-panel-identity is-active"
                        id="profileConfigPanel"
                        data-profile-tab-panel
                        role="tabpanel"
                        aria-labelledby="profileConfigTab"
                    >
                        <div class="profile-section-heading">
                            <span class="profile-section-icon"><i class="fa-solid fa-address-card" aria-hidden="true"></i></span>
                            <div>
                                <span>Identity</span>
                                <h2>Personal information</h2>
                                <p>Your name and profile photo are visible throughout the operations hub.</p>
                            </div>
                        </div>

                        <div class="profile-field-grid profile-field-grid-primary">
                            <div class="form-group profile-field-card">
                                <label class="form-label" for="profileName">Full name</label>
                                <div class="profile-input-shell">
                                    <i class="fa-solid fa-user" aria-hidden="true"></i>
                                    <input
                                        type="text"
                                        id="profileName"
                                        class="form-control"
                                        maxlength="100"
                                        placeholder="Enter your full name"
                                        required
                                    />
                                </div>
                                <small>Used in activity records and system notifications.</small>
                            </div>

                            <div class="form-group profile-field-card">
                                <label class="form-label" for="profileEmail">Email</label>
                                <div class="profile-input-shell is-readonly">
                                    <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                                    <input
                                        type="email"
                                        id="profileEmail"
                                        class="form-control profile-readonly"
                                        readonly
                                    />
                                    <span class="profile-field-lock" title="Managed by an administrator">
                                        <i class="fa-solid fa-lock" aria-hidden="true"></i>
                                    </span>
                                </div>
                                <small>Contact an administrator to change the registered email.</small>
                            </div>
                        </div>

                        <div class="profile-readonly-section">
                            <header>
                                <div>
                                    <span>System assignment</span>
                                    <h3>Access information</h3>
                                </div>
                                <span class="profile-managed-badge">
                                    <i class="fa-solid fa-shield" aria-hidden="true"></i>
                                    Administrator managed
                                </span>
                            </header>

                            <div class="profile-field-grid">
                                <div class="form-group profile-field-card">
                                    <label class="form-label" for="profileUsername">Username</label>
                                    <div class="profile-input-shell is-readonly">
                                        <i class="fa-solid fa-at" aria-hidden="true"></i>
                                        <input
                                            type="text"
                                            id="profileUsername"
                                            class="form-control profile-readonly"
                                            readonly
                                        />
                                    </div>
                                </div>

                                <div class="form-group profile-field-card">
                                    <label class="form-label" for="profileDepartment">Department</label>
                                    <div class="profile-input-shell is-readonly">
                                        <i class="fa-solid fa-building" aria-hidden="true"></i>
                                        <input
                                            type="text"
                                            id="profileDepartment"
                                            class="form-control profile-readonly"
                                            readonly
                                        />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section
                        class="profile-panel profile-tab-panel profile-panel-security"
                        id="profilePasswordPanel"
                        data-profile-tab-panel
                        role="tabpanel"
                        aria-labelledby="profilePasswordTab"
                        hidden
                    >
                        <div class="profile-security-overview">
                            <span class="profile-security-overview-icon">
                                <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                            </span>
                            <div>
                                <span>Security status</span>
                                <h2 id="profileSecurityStatusTitle">Password protection active</h2>
                                <p id="profileSecurityStatusText">
                                    Enable Microsoft Authenticator to add a second sign-in verification step.
                                </p>
                            </div>
                            <span class="profile-security-status-dot" id="profileSecurityStatusDot" aria-hidden="true"></span>
                        </div>

                        <div class="profile-security-grid">
                            <section class="profile-password-card">
                                <div class="profile-section-heading is-compact">
                                    <span class="profile-section-icon"><i class="fa-solid fa-key" aria-hidden="true"></i></span>
                                    <div>
                                        <span>Password</span>
                                        <h2>Change password</h2>
                                        <p>Enter your current password before creating a new one.</p>
                                    </div>
                                </div>

                                <div class="profile-password-fields">
                                    <div class="form-group">
                                        <label class="form-label" for="currentPassword">Current password</label>
                                        <div class="profile-input-shell profile-password-shell">
                                            <i class="fa-solid fa-lock" aria-hidden="true"></i>
                                            <input
                                                type="password"
                                                id="currentPassword"
                                                class="form-control"
                                                autocomplete="current-password"
                                                placeholder="Enter current password"
                                            />
                                            <button type="button" data-password-toggle="currentPassword" aria-label="Show password" aria-pressed="false">
                                                <i class="fa-solid fa-eye" aria-hidden="true"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label" for="newPassword">New password</label>
                                        <div class="profile-input-shell profile-password-shell">
                                            <i class="fa-solid fa-key" aria-hidden="true"></i>
                                            <input
                                                type="password"
                                                id="newPassword"
                                                class="form-control"
                                                autocomplete="new-password"
                                                minlength="6"
                                                placeholder="Create a new password"
                                            />
                                            <button type="button" data-password-toggle="newPassword" aria-label="Show password" aria-pressed="false">
                                                <i class="fa-solid fa-eye" aria-hidden="true"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <div class="profile-label-row">
                                            <label class="form-label" for="confirmPassword">Confirm new password</label>
                                            <span id="profilePasswordMatchStatus" data-state="idle">Confirmation pending</span>
                                        </div>
                                        <div class="profile-input-shell profile-password-shell">
                                            <i class="fa-solid fa-check-double" aria-hidden="true"></i>
                                            <input
                                                type="password"
                                                id="confirmPassword"
                                                class="form-control"
                                                autocomplete="new-password"
                                                minlength="6"
                                                placeholder="Repeat the new password"
                                            />
                                            <button type="button" data-password-toggle="confirmPassword" aria-label="Show password" aria-pressed="false">
                                                <i class="fa-solid fa-eye" aria-hidden="true"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="profile-password-strength" id="profilePasswordStrength" data-level="empty">
                                    <div>
                                        <span>Password strength</span>
                                        <strong id="profilePasswordStrengthText">Enter a new password</strong>
                                    </div>
                                    <div class="profile-password-strength-track" aria-hidden="true">
                                        <span id="profilePasswordStrengthBar"></span>
                                    </div>
                                </div>
                            </section>

                            <aside class="profile-password-guidance">
                                <span class="profile-guidance-icon"><i class="fa-solid fa-list-check" aria-hidden="true"></i></span>
                                <span>Recommended quality</span>
                                <h3>Create a resilient password</h3>
                                <p>Use a password that is unique to this account and difficult to predict.</p>

                                <ul class="profile-password-rules">
                                    <li id="profileRuleLength"><i class="fa-regular fa-circle" aria-hidden="true"></i> At least 8 characters</li>
                                    <li id="profileRuleCase"><i class="fa-regular fa-circle" aria-hidden="true"></i> Uppercase and lowercase letters</li>
                                    <li id="profileRuleNumber"><i class="fa-regular fa-circle" aria-hidden="true"></i> At least one number</li>
                                    <li id="profileRuleSpecial"><i class="fa-regular fa-circle" aria-hidden="true"></i> At least one special character</li>
                                    <li id="profileRuleMatch"><i class="fa-regular fa-circle" aria-hidden="true"></i> Confirmation matches</li>
                                </ul>

                                <div class="profile-security-tip">
                                    <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
                                    <span>Leave all password fields empty when you only need to update your profile.</span>
                                </div>
                            </aside>
                        </div>

                        <section class="profile-mfa-card" aria-labelledby="profileMfaTitle">
                            <div class="profile-mfa-copy">
                                <span class="profile-mfa-icon">
                                    <i class="fa-solid fa-mobile-screen-button" aria-hidden="true"></i>
                                </span>
                                <div>
                                    <span class="profile-mfa-kicker">Two-step verification</span>
                                    <h3 id="profileMfaTitle">Microsoft Authenticator</h3>
                                    <p id="profileMfaStatusText">
                                        Add a 6-digit Microsoft Authenticator code after your password.
                                    </p>
                                </div>
                            </div>
                            <div class="profile-mfa-actions">
                                <span class="profile-mfa-status" id="profileMfaStatusBadge">Not enabled</span>
                                <button class="btn btn-primary btn-sm" type="button" id="mfaSetupBtn">
                                    <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                                    Enable authenticator
                                </button>
                                <button class="btn btn-secondary btn-sm" type="button" id="mfaDisableBtn" hidden>
                                    <i class="fa-solid fa-ban" aria-hidden="true"></i>
                                    Disable authenticator
                                </button>
                            </div>
                        </section>
                    </section>
                </div>

                <div class="profile-actions">
                    <div class="profile-action-copy">
                        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
                        <span>Only changed fields will be updated.</span>
                    </div>
                    <div class="profile-action-buttons">
                        <button class="btn btn-secondary" type="button" id="profileResetBtn">
                            <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
                            Reset
                        </button>
                        <button class="btn btn-primary" type="submit" id="profileSaveBtn">
                            <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                            Save changes
                        </button>
                    </div>
                </div>
            </form>
        </section>

        <div
            class="profile-crop-modal"
            id="profileCropPanel"
            role="dialog"
            aria-modal="true"
            aria-labelledby="profileCropTitle"
            hidden
        >
            <button
                type="button"
                class="profile-crop-backdrop"
                id="profileCropBackdrop"
                aria-label="Cancel photo framing"
            ></button>

            <div class="profile-crop-dialog">
                <header class="profile-crop-header">
                    <div>
                        <span>Profile photo</span>
                        <strong id="profileCropTitle">Adjust framing</strong>
                    </div>
                    <button
                        type="button"
                        class="profile-crop-close"
                        id="profileCropCancelBtn"
                        aria-label="Cancel photo framing"
                    >
                        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                    </button>
                </header>

                <div
                    class="profile-crop-stage"
                    id="profileCropStage"
                    aria-label="Profile photo framing area"
                >
                    <img id="profileCropImage" alt="" />
                    <span class="profile-crop-ring" aria-hidden="true"></span>
                </div>

                <div class="profile-crop-controls">
                    <label for="profileCropZoom">Zoom</label>
                    <input
                        type="range"
                        id="profileCropZoom"
                        min="1"
                        max="3"
                        step="0.01"
                        value="1"
                    />
                </div>

                <div class="profile-crop-actions">
                    <button class="btn btn-secondary btn-sm" type="button" id="profileCropResetBtn">
                        <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
                        Reset
                    </button>
                    <button class="btn btn-primary btn-sm" type="button" id="profileCropApplyBtn">
                        <i class="fa-solid fa-check" aria-hidden="true"></i>
                        Use framing
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/config.js" is:inline></script>
    <script src="/js/perfil.js?v=20260714-profile-security-v2-contrast" is:inline></script>
</DashboardLayout>
