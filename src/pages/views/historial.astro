---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Comparison history">
    <div class="page-container comparison-history-page">
        <header class="comparison-history-hero">
            <div>
                <span>REVIEW CONTROL</span>
                <h1>Comparison history</h1>
                <p>
                    See when a file changed, which stores were affected, and
                    which amounts were modified.
                </p>
            </div>
            <button
                class="btn comparison-export-button"
                type="button"
                onclick="exportarHistorial()"
                data-permission-module="historial"
                data-permission-action="exportar"
            >
                <i class="fa-solid fa-file-export"></i>
                Export summary
            </button>
        </header>

        <section
            class="comparison-history-stats"
            aria-label="Comparison summary"
        >
            <article>
                <span class="history-stat-icon total"
                    ><i class="fa-solid fa-code-compare"></i></span
                ><div><strong id="statTotal">0</strong><p>Comparisons</p></div>
            </article>
            <article>
                <span class="history-stat-icon changed"
                    ><i class="fa-solid fa-triangle-exclamation"></i></span
                ><div>
                    <strong id="statCambios">0</strong><p>With differences</p>
                </div>
            </article>
            <article>
                <span class="history-stat-icon equal"
                    ><i class="fa-solid fa-circle-check"></i></span
                ><div>
                    <strong id="statSinCambios">0</strong><p>No changes</p>
                </div>
            </article>
            <article>
                <span class="history-stat-icon stores"
                    ><i class="fa-solid fa-shop"></i></span
                ><div>
                    <strong id="statStores">0</strong><p>Affected stores</p>
                </div>
            </article>
        </section>

        <section class="comparison-history-filters">
            <div class="comparison-filter search">
                <label for="searchInput">Search</label>
                <div>
                    <i class="fa-solid fa-magnifying-glass"></i><input
                        id="searchInput"
                        type="search"
                        placeholder="Restaurant, user, or date..."
                    />
                </div>
            </div>
            <div class="comparison-filter">
                <label for="filterRestaurant">Restaurant</label><select
                    id="filterRestaurant"><option value="">All</option></select>
            </div>
            <div class="comparison-filter">
                <label for="filterStatus">Result</label><select
                    id="filterStatus"
                    ><option value="">All</option><option value="con_cambios"
                        >With differences</option
                    ><option value="sin_cambios">No changes</option><option
                        value="primera_carga">First load</option
                    ><option value="referencia_incompatible"
                        >Incompatible reference</option
                    ></select>
            </div>
            <div class="comparison-filter">
                <label for="filterDesde">From</label><input
                    id="filterDesde"
                    type="date"
                />
            </div>
            <div class="comparison-filter">
                <label for="filterHasta">To</label><input
                    id="filterHasta"
                    type="date"
                />
            </div>
            <div class="comparison-filter">
                <label for="filterMontoMinimo">Min. difference</label><input
                    id="filterMontoMinimo"
                    type="number"
                    min="0"
                    step="0.01"
                    placeholder="$0"
                />
            </div>
            <button
                type="button"
                class="comparison-clear-button"
                onclick="limpiarFiltros()"
                ><i class="fa-solid fa-xmark"></i> Clear</button
            >
        </section>

        <section
            id="comparisonBulkBar"
            class="comparison-bulk-bar"
            hidden
        >
            <label class="comparison-bulk-select-all">
                <input type="checkbox" id="selectAllComparisons" />
                <span id="bulkSelectionCount">0 selected</span>
            </label>
            <div class="comparison-bulk-actions">
                <button
                    type="button"
                    class="btn btn-secondary"
                    onclick="exportarSeleccionadas()"
                    ><i class="fa-solid fa-file-export"></i> Export selected</button
                >
                <button
                    type="button"
                    id="bulkDeleteButton"
                    class="btn comparison-bulk-delete-button"
                    onclick="eliminarSeleccionadas()"
                    data-permission-module="historial"
                    data-permission-action="eliminar"
                    ><i class="fa-solid fa-trash"></i> Delete selected</button
                >
            </div>
        </section>

        <div id="historyLoading" class="comparison-history-message">
            <i class="fa-solid fa-spinner fa-spin"></i><p>
                Loading comparisons...
            </p>
        </div>
        <div id="historyError" class="comparison-history-message error" hidden>
            <i class="fa-solid fa-database"></i><h3>History unavailable</h3><p>
            </p>
        </div>
        <div id="historyEmpty" class="comparison-history-message" hidden>
            <i class="fa-solid fa-folder-open"></i><h3>No comparisons</h3><p>
                No records match the selected filters.
            </p>
        </div>
        <div id="comparisonHistoryGroups" class="comparison-history-groups">
        </div>
    </div>

    <div
        id="comparisonDetailModal"
        class="comparison-detail-overlay"
        onclick="if (event.target === this) cerrarDetalleComparacion()"
    >
        <section
            class="comparison-detail-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="comparisonDetailTitle"
        >
            <header>
                <div>
                    <span>DIFFERENCE DETAIL</span><h2
                        id="comparisonDetailTitle"
                    >
                        Comparison
                    </h2><p id="comparisonDetailSubtitle"></p>
                </div>
                <button
                    type="button"
                    onclick="cerrarDetalleComparacion()"
                    aria-label="Close"><i class="fa-solid fa-xmark"></i></button
                >
            </header>
            <div id="comparisonDetailBody" class="comparison-detail-body"></div>
            <footer>
                <button
                    type="button"
                    class="btn btn-secondary"
                    onclick="cerrarDetalleComparacion()">Close</button>
            </footer>
        </section>
    </div>

    <script src="/js/departments/ar/historial.js" is:inline></script>

</DashboardLayout>
