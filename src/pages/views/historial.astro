---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Historial de Validaciones">
    <div class="page-container">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Historial de Validaciones</h1>
                <p>Registro de todas las validaciones realizadas en el sistema</p>
            </div>
            <button class="btn btn-secondary" onclick="exportarHistorial()">
                <i class="fa-solid fa-file-export"></i>
                Exportar CSV
            </button>
        </div>

        <!-- Stats cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon green">
                    <i class="fa-solid fa-check-circle"></i>
                </div>
                <div class="stat-info">
                    <h3 id="statExitosas">0</h3>
                    <p>Exitosas</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon yellow">
                    <i class="fa-solid fa-exclamation-triangle"></i>
                </div>
                <div class="stat-info">
                    <h3 id="statConErrores">0</h3>
                    <p>Con Errores</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon red">
                    <i class="fa-solid fa-times-circle"></i>
                </div>
                <div class="stat-info">
                    <h3 id="statFallidas">0</h3>
                    <p>Fallidas</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue">
                    <i class="fa-solid fa-clock"></i>
                </div>
                <div class="stat-info">
                    <h3 id="statTiempoPromedio">0s</h3>
                    <p>Tiempo Promedio</p>
                </div>
            </div>
        </div>

        <!-- Filtros -->
        <div class="filters-bar history-filters">
            <div class="filter-group search-filter">
                <label for="searchInput">Buscar validación</label>
                <div class="search-field">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    <input type="search" id="searchInput" placeholder="Archivo o usuario..." autocomplete="off">
                </div>
            </div>
            
            <div class="filter-group">
                <label>Resultado:</label>
                <select id="filterResultado">
                    <option value="">Todos</option>
                    <option value="exitoso">Exitoso</option>
                    <option value="con_errores">Con errores</option>
                    <option value="fallido">Fallido</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label>Tipo:</label>
                <select id="filterTipo">
                    <option value="">Todos</option>
                    <option value="formato">Formato</option>
                    <option value="datos">Datos</option>
                    <option value="formulas">Formulas</option>
                    <option value="completa">Completa</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label>Fecha:</label>
                <input type="date" id="filterFecha">
            </div>
            
            <button type="button" class="btn btn-secondary btn-sm clear-filters" onclick="limpiarFiltros()">
                <i class="fa-solid fa-times"></i>
                Limpiar
            </button>
        </div>

        <!-- Tabla de validaciones -->
        <div class="table-container">
            <div class="table-header">
                <h3>Historial de validaciones</h3>
            </div>
            
            <table class="data-table" id="validacionesTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Archivo</th>
                        <th>Tipo</th>
                        <th>Resultado</th>
                        <th>Errores</th>
                        <th>Duracion</th>
                        <th>Usuario</th>
                        <th>Fecha</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="validacionesBody">
                    <!-- Se llena con JavaScript -->
                </tbody>
            </table>
            
            <div id="emptyState" class="empty-state" style="display: none;">
                <i class="fa-solid fa-clipboard-list"></i>
                <h4>No hay validaciones</h4>
                <p>No se encontraron validaciones con los filtros seleccionados</p>
            </div>
            
            <div id="loadingState" class="empty-state">
                <i class="fa-solid fa-spinner fa-spin"></i>
                <h4>Cargando...</h4>
                <p>Obteniendo historial del servidor</p>
            </div>
            
            <!-- Paginacion -->
            <div class="pagination" id="pagination" style="display: none;">
                <div class="pagination-info">
                    Mostrando <span id="showingFrom">1</span> - <span id="showingTo">10</span> de <span id="totalItems">0</span> validaciones
                </div>
                <div class="pagination-buttons">
                    <button class="pagination-btn" id="btnPrev" onclick="cambiarPagina(-1)">
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <span class="pagination-btn active" id="currentPage">1</span>
                    <button class="pagination-btn" id="btnNext" onclick="cambiarPagina(1)">
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de errores -->
    <div id="modalErrores" class="modal-overlay">
        <div class="modal modal-lg">
            <div class="modal-header">
                <h3>Detalle de Errores</h3>
                <button class="modal-close" onclick="cerrarModal()">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
            <div class="modal-body" id="modalBody">
                <!-- Contenido dinamico -->
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="cerrarModal()">Cerrar</button>
            </div>
        </div>
    </div>
    <script src="/js/config.js" is:inline></script>

    <script is:inline src="/js/historial.js"></script>

    <style>
        .history-filters {
            display: grid;
            grid-template-columns: minmax(280px, 1.7fr) repeat(3, minmax(150px, .75fr)) auto;
            gap: 12px;
            align-items: end;
            margin-bottom: 18px;
            padding: 14px;
            border: 1px solid #cfd9e3;
            border-radius: 5px;
            background: #fff;
            box-shadow: none;
        }

        .history-filters .filter-group {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .history-filters label {
            color: #52667a;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .045em;
            text-transform: uppercase;
        }

        .search-field { position: relative; width: 100%; }
        .search-field i {
            position: absolute;
            top: 50%;
            left: 12px;
            z-index: 1;
            transform: translateY(-50%);
            color: #718096;
            font-size: 13px;
            pointer-events: none;
        }

        .search-field input,
        .history-filters select,
        .history-filters input[type="date"] {
            width: 100%;
            height: 40px;
            min-height: 40px;
            border: 1px solid #cbd6e1;
            border-radius: 4px;
            color: #243b53;
            background: #fff;
            font-size: 13px;
        }

        .search-field input { padding: 0 12px 0 36px; }
        .history-filters select,
        .history-filters input[type="date"] { padding: 0 10px; }

        .search-field input:focus,
        .history-filters select:focus,
        .history-filters input[type="date"]:focus {
            outline: 0;
            border-color: #174a75;
            box-shadow: 0 0 0 3px rgba(23, 74, 117, .11);
        }

        .clear-filters { height: 40px; white-space: nowrap; }

        @media (max-width: 1050px) {
            .history-filters { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @media (max-width: 650px) {
            .history-filters { grid-template-columns: 1fr; }
            .clear-filters { width: 100%; }
        }
    </style>
</DashboardLayout>
