---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout
    title="Profile & Security"
    stylesheets={["/styles/pages/views/perfil.css?v=20260714-profile-3sections-v1"]}
>
    <div class="profile-page page-container">
        <header class="profile-settings-hero">
            <div class="profile-hero-copy">
                <span class="profile-eyebrow">
                    <i class="fa-solid fa-id-badge"></i>
                    account center
                </span>

                <h1>Profile &amp; security</h1>
                <p>
                    Manage your identity, personal settings, password, and two-step verification
                    from a single protected workspace.
                </p>
            </div>

            <div class="profile-hero-overview">
                <article>
                    <span class="profile-hero-icon">
                        <i class="fa-solid fa-user-shield"></i>
                    </span>

                    <div>
                        <small>Access level</small>
                        <strong id="hero-role-value">Super administrator</strong>
                    </div>
                </article>

                <article>
                    <span class="profile-hero-icon">
                        <i class="fa-solid fa-building"></i>
                    </span>

                    <div>
                        <small>Department</small>
                        <strong id="hero-department-value">Information Technology</strong>
                    </div>
                </article>
            </div>
        </header>

        <section class="profile-shell">
            <aside class="profile-sidebar-card">
                <div class="profile-cover">
                    <span class="profile-cover-badge">
                        <i class="fa-solid fa-shield-halved"></i>
                    </span>
                </div>

                <div class="profile-avatar-wrap">
                    <img
                        id="profile-avatar"
                        class="profile-avatar"
                        src="https://placehold.co/160x160/png"
                        alt="Profile photo"
                    />
                </div>

                <div class="profile-sidebar-body">
                    <button type="button" id="change-photo-btn" class="btn btn-outline profile-photo-btn">
                        <i class="fa-solid fa-camera"></i>
                        Change photo
                    </button>

                    <h2 id="profile-display-name">Eduardo</h2>
                    <p id="profile-display-email" class="profile-email">
                        eduardo.sis26@outlook.com
                    </p>

                    <div class="profile-status-chips">
                        <span class="profile-chip profile-chip--success">
                            <i class="fa-solid fa-circle-check"></i>
                            Active profile
                        </span>

                        <span class="profile-chip profile-chip--info">
                            <i class="fa-solid fa-lock"></i>
                            Protected access
                        </span>
                    </div>

                    <div class="profile-readiness">
                        <div class="profile-readiness-head">
                            <span>Account readiness</span>
                            <strong id="readiness-value">80%</strong>
                        </div>

                        <div class="progress-track">
                            <div id="readiness-bar" class="progress-fill" style="width: 80%;"></div>
                        </div>

                        <p id="readiness-note">1 recommended item remaining</p>
                    </div>

                    <div class="profile-facts">
                        <article>
                            <small>Role</small>
                            <strong id="sidebar-role-value">Super administrator</strong>
                        </article>

                        <article>
                            <small>Department</small>
                            <strong id="sidebar-department-value">Information Technology</strong>
                        </article>

                        <article>
                            <small>Username</small>
                            <strong id="sidebar-username-value">Admin12</strong>
                        </article>
                    </div>
                </div>
            </aside>

            <main class="profile-main-card">
                <div class="profile-main-head">
                    <div>
                        <span class="panel-kicker">account settings</span>
                        <h2>Profile preferences</h2>
                        <p>Use the three sections below to manage your profile, password, and two-step verification.</p>
                    </div>

                    <div class="profile-main-status">
                        <i class="fa-solid fa-lock"></i>
                        Changes are sent through a protected connection.
                    </div>
                </div>

                <nav class="profile-tabs" aria-label="Profile sections">
                    <button type="button" class="profile-tab is-active" data-profile-tab="profile" aria-selected="true">
                        <span class="profile-tab-icon"><i class="fa-solid fa-user-pen"></i></span>
                        <span><strong>Profile</strong><small>Personal information</small></span>
                    </button>

                    <button type="button" class="profile-tab" data-profile-tab="password" aria-selected="false">
                        <span class="profile-tab-icon"><i class="fa-solid fa-key"></i></span>
                        <span><strong>Password</strong><small>Credentials and access</small></span>
                    </button>

                    <button type="button" class="profile-tab" data-profile-tab="verification" aria-selected="false">
                        <span class="profile-tab-icon"><i class="fa-solid fa-mobile-screen-button"></i></span>
                        <span><strong>2-step verification</strong><small>Authenticator protection</small></span>
                    </button>
                </nav>

                <section class="profile-section is-active" data-profile-panel="profile">
                    <div class="section-head">
                        <div class="section-head-icon"><i class="fa-solid fa-address-card"></i></div>
                        <div>
                            <span class="panel-kicker">identity</span>
                            <h3>Personal information</h3>
                            <p>Your name and profile photo are visible throughout the operations hub.</p>
                        </div>
                    </div>

                    <div class="profile-grid">
                        <label class="field">
                            <span>Full name</span>
                            <div class="field-control">
                                <i class="fa-solid fa-user"></i>
                                <input type="text" id="profile-full-name" value="Eduardo" />
                            </div>
                            <small>Used in activity records and system notifications.</small>
                        </label>

                        <label class="field">
                            <span>Email</span>
                            <div class="field-control is-readonly">
                                <i class="fa-solid fa-envelope"></i>
                                <input type="email" id="profile-email" value="eduardo.sis26@outlook.com" readonly />
                                <i class="fa-solid fa-lock field-lock"></i>
                            </div>
                            <small>Contact an administrator to change the registered email.</small>
                        </label>
                    </div>

                    <div class="profile-subcard">
                        <div class="subcard-head">
                            <div>
                                <span class="panel-kicker">system assignment</span>
                                <h4>Access information</h4>
                            </div>
                            <span class="profile-chip profile-chip--neutral">
                                <i class="fa-solid fa-shield"></i>
                                Administrator managed
                            </span>
                        </div>

                        <div class="profile-grid">
                            <label class="field">
                                <span>Username</span>
                                <div class="field-control is-readonly">
                                    <i class="fa-solid fa-at"></i>
                                    <input type="text" id="profile-username" value="Admin12" readonly />
                                </div>
                            </label>

                            <label class="field">
                                <span>Department</span>
                                <div class="field-control is-readonly">
                                    <i class="fa-solid fa-building"></i>
                                    <input type="text" id="profile-department" value="Information Technology" readonly />
                                </div>
                            </label>
                        </div>
                    </div>

                    <footer class="section-actions">
                        <span class="section-note">
                            <i class="fa-solid fa-circle-info"></i>
                            Only changed fields will be updated.
                        </span>

                        <div class="section-actions-buttons">
                            <button type="button" class="btn btn-secondary" id="reset-profile-btn">
                                <i class="fa-solid fa-rotate-left"></i>
                                Reset
                            </button>

                            <button type="button" class="btn btn-primary" id="save-profile-btn">
                                <i class="fa-solid fa-floppy-disk"></i>
                                Save profile
                            </button>
                        </div>
                    </footer>
                </section>

                <section class="profile-section" data-profile-panel="password" hidden>
                    <div class="section-head">
                        <div class="section-head-icon"><i class="fa-solid fa-key"></i></div>
                        <div>
                            <span class="panel-kicker">security</span>
                            <h3>Password change</h3>
                            <p>Create a strong password to protect the account and connected modules.</p>
                        </div>
                    </div>

                    <div class="profile-grid">
                        <label class="field">
                            <span>Current password</span>
                            <div class="field-control">
                                <i class="fa-solid fa-lock"></i>
                                <input type="password" id="current-password" placeholder="Enter your current password" />
                                <button type="button" class="field-toggle" data-toggle-password="#current-password">
                                    <i class="fa-regular fa-eye"></i>
                                </button>
                            </div>
                        </label>

                        <div class="password-strength-card">
                            <span class="panel-kicker">strength check</span>
                            <strong id="password-strength-label">Not evaluated</strong>
                            <div class="progress-track">
                                <div id="password-strength-bar" class="progress-fill progress-fill--password" style="width: 0%;"></div>
                            </div>

                            <ul id="password-rules" class="password-rules">
                                <li data-rule="length">At least 8 characters</li>
                                <li data-rule="upper">At least 1 uppercase letter</li>
                                <li data-rule="number">At least 1 number</li>
                                <li data-rule="special">At least 1 special character</li>
                            </ul>
                        </div>

                        <label class="field">
                            <span>New password</span>
                            <div class="field-control">
                                <i class="fa-solid fa-key"></i>
                                <input type="password" id="new-password" placeholder="Create a new password" />
                                <button type="button" class="field-toggle" data-toggle-password="#new-password">
                                    <i class="fa-regular fa-eye"></i>
                                </button>
                            </div>
                        </label>

                        <label class="field">
                            <span>Confirm new password</span>
                            <div class="field-control">
                                <i class="fa-solid fa-check-double"></i>
                                <input type="password" id="confirm-password" placeholder="Repeat the new password" />
                                <button type="button" class="field-toggle" data-toggle-password="#confirm-password">
                                    <i class="fa-regular fa-eye"></i>
                                </button>
                            </div>
                            <small id="password-match-message">Passwords must match before saving.</small>
                        </label>
                    </div>

                    <footer class="section-actions">
                        <span class="section-note">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            Your current session may require a fresh sign-in after a password change.
                        </span>

                        <div class="section-actions-buttons">
                            <button type="button" class="btn btn-secondary" id="reset-password-btn">
                                <i class="fa-solid fa-rotate-left"></i>
                                Reset
                            </button>

                            <button type="button" class="btn btn-primary" id="save-password-btn">
                                <i class="fa-solid fa-key"></i>
                                Update password
                            </button>
                        </div>
                    </footer>
                </section>

                <section class="profile-section" data-profile-panel="verification" hidden>
                    <div class="section-head">
                        <div class="section-head-icon"><i class="fa-solid fa-mobile-screen-button"></i></div>
                        <div>
                            <span class="panel-kicker">two-step verification</span>
                            <h3>Microsoft Authenticator</h3>
                            <p>Protect the account with an authenticator code required after the password.</p>
                        </div>
                    </div>

                    <div class="verification-layout">
                        <article class="verification-card">
                            <div class="verification-card-head">
                                <h4>Current protection</h4>
                                <span id="two-step-status" class="profile-chip profile-chip--warning">
                                    <i class="fa-solid fa-shield-halved"></i>
                                    Not enabled
                                </span>
                            </div>

                            <ol class="verification-steps">
                                <li>Install Microsoft Authenticator on your mobile device.</li>
                                <li>Scan the QR code or copy the setup key.</li>
                                <li>Enter the 6-digit verification code to confirm activation.</li>
                            </ol>

                            <div class="verification-key">
                                <span>Setup key</span>
                                <strong id="two-step-key">XBFS-IT-ADMIN-2026</strong>
                            </div>
                        </article>

                        <article class="verification-card verification-card--center">
                            <div class="fake-qr"><div class="fake-qr-grid"></div></div>
                            <p class="fake-qr-caption">
                                QR placeholder for your existing Authenticator setup flow.
                            </p>
                        </article>
                    </div>

                    <div class="profile-grid">
                        <label class="field">
                            <span>Verification code</span>
                            <div class="field-control">
                                <i class="fa-solid fa-hashtag"></i>
                                <input type="text" id="two-step-code" inputmode="numeric" maxlength="6" placeholder="000000" />
                            </div>
                            <small>Enter the 6-digit code from Microsoft Authenticator.</small>
                        </label>

                        <div class="verification-summary">
                            <span class="panel-kicker">security summary</span>
                            <ul>
                                <li>Department: <strong id="verification-department">Information Technology</strong></li>
                                <li>Access level: <strong id="verification-role">Super administrator</strong></li>
                                <li>Backup recommendation: <strong>Store recovery codes offline</strong></li>
                            </ul>
                        </div>
                    </div>

                    <footer class="section-actions">
                        <span class="section-note">
                            <i class="fa-solid fa-circle-info"></i>
                            This redesign does not modify your existing backend endpoints for MFA.
                        </span>

                        <div class="section-actions-buttons">
                            <button type="button" class="btn btn-secondary" id="disable-two-step-btn">
                                <i class="fa-solid fa-ban"></i>
                                Disable
                            </button>

                            <button type="button" class="btn btn-primary" id="enable-two-step-btn">
                                <i class="fa-solid fa-shield"></i>
                                Enable verification
                            </button>
                        </div>
                    </footer>
                </section>
            </main>
        </section>
    </div>
    <script src="/js/config.js" is:inline></script>
    <script src="/js/perfil.js?v=20260714-profile-security-v2-contrast" is:inline></script>
</DashboardLayout>
