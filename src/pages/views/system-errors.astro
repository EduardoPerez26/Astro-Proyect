---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="System errors">
    <div class="page-container system-errors-page">
        <header class="system-errors-hero">
            <div class="system-errors-hero-copy">
                <span class="system-errors-eyebrow">
                    <i class="fa-solid fa-shield-halved"></i>
                    ADMIN MONITORING
                </span>
                <h1>System error center</h1>
                <p>Track backend incidents, inspect failure context, and document resolutions from one admin console.</p>
            </div>

            <div class="system-errors-actions">
                <span id="systemErrorsUpdated">Not refreshed</span>
                <a class="system-errors-action-link" href="/views/dashboard-admin">
                    <i class="fa-solid fa-arrow-left"></i>
                    Admin dashboard
                </a>
                <button class="system-errors-action-primary" id="refreshSystemErrors" type="button">
                    <i class="fa-solid fa-rotate"></i>
                    Refresh
                </button>
            </div>
        </header>

        <section class="system-error-metrics" aria-label="System error summary">
            <article class="system-error-card is-open">
                <span class="system-error-card-icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
                <div>
                    <small>Requires review</small>
                    <strong id="systemErrorsOpen">0</strong>
                    <span>Open errors</span>
                </div>
            </article>

            <article class="system-error-card is-critical">
                <span class="system-error-card-icon"><i class="fa-solid fa-fire-flame-curved"></i></span>
                <div>
                    <small>HTTP 500+</small>
                    <strong id="systemErrorsCritical">0</strong>
                    <span>Critical open</span>
                </div>
            </article>

            <article class="system-error-card is-total">
                <span class="system-error-card-icon"><i class="fa-solid fa-database"></i></span>
                <div>
                    <small>All logged incidents</small>
                    <strong id="systemErrorsTotal">0</strong>
                    <span>Total logged</span>
                </div>
            </article>

            <article class="system-error-card is-resolved">
                <span class="system-error-card-icon"><i class="fa-solid fa-circle-check"></i></span>
                <div>
                    <small>Closed incidents</small>
                    <strong id="systemErrorsResolved">0</strong>
                    <span>Resolved</span>
                </div>
            </article>
        </section>

        <section class="system-errors-panel">
            <header class="system-errors-panel-header">
                <div>
                    <span>INCIDENT LOG</span>
                    <h2>Backend failures</h2>
                    <p>Use filters to isolate the exact route, method, user, IP, or error hash.</p>
                </div>

                <label class="system-errors-autorefresh">
                    <input type="checkbox" id="systemErrorsAutoRefresh" />
                    <span>Auto-refresh</span>
                </label>
            </header>

            <div class="system-errors-toolbar">
                <label class="system-error-filter system-error-filter-search">
                    <span>Search</span>
                    <input id="systemErrorsSearch" type="search" placeholder="Route, message, user, IP, hash..." autocomplete="off" />
                </label>

                <label class="system-error-filter">
                    <span>Status</span>
                    <select id="systemErrorsStatus">
                        <option value="open">Open</option>
                        <option value="resolved">Resolved</option>
                        <option value="all">All</option>
                    </select>
                </label>

                <label class="system-error-filter">
                    <span>Severity</span>
                    <select id="systemErrorsSeverity">
                        <option value="all">All</option>
                        <option value="critical">Critical</option>
                        <option value="server">Server</option>
                        <option value="upload">Upload</option>
                        <option value="client">Client</option>
                    </select>
                </label>

                <label class="system-error-filter">
                    <span>Method</span>
                    <select id="systemErrorsMethod">
                        <option value="">All</option>
                        <option value="GET">GET</option>
                        <option value="POST">POST</option>
                        <option value="PUT">PUT</option>
                        <option value="PATCH">PATCH</option>
                        <option value="DELETE">DELETE</option>
                    </select>
                </label>

                <label class="system-error-filter">
                    <span>Limit</span>
                    <select id="systemErrorsLimit">
                        <option value="25">25</option>
                        <option value="50" selected>50</option>
                        <option value="100">100</option>
                    </select>
                </label>

                <button class="system-error-clear" id="clearSystemErrorFilters" type="button">
                    <i class="fa-solid fa-filter-circle-xmark"></i>
                    Clear
                </button>
            </div>

            <div class="system-errors-table-wrap">
                <table class="system-errors-table">
                    <thead>
                        <tr>
                            <th>Severity</th>
                            <th>Route</th>
                            <th>Error</th>
                            <th>User / IP</th>
                            <th>Occurrences</th>
                            <th>Last seen</th>
                            <th>Status / resolution</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="systemErrorsBody">
                        <tr><td colspan="8" class="system-errors-loading">Loading errors...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
    <script src="/js/system-errors.js?v=20260713-system-error-custom-modal" is:inline></script>
</DashboardLayout>
