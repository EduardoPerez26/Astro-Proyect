            function installPropertyManagementCleanStyles() {
                const old = document.getElementById('pm-clean-runtime-fix');
                if (old) old.remove();
                const style = document.createElement('style');
                style.id = 'pm-clean-runtime-fix';
                style.textContent = css;
                document.head.appendChild(style);
            }

            installPropertyManagementCleanStyles();
            document.addEventListener('DOMContentLoaded', installPropertyManagementCleanStyles, { once: true });
            window.addEventListener('load', installPropertyManagementCleanStyles, { once: true });
        })();
    </script>
</DashboardLayout>

<style>
    .property-management-page {
        display: grid;
        gap: 18px;
        padding: 18px 24px 28px;
    }

    .pm-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 24px 26px;
        border: 1px solid #cfdae5;
        border-left: 4px solid #0f766e;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 18px 44px -38px rgba(8, 31, 51, .55);
    }

    .pm-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #344f67;
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
    }

    .pm-hero h1 {
        margin: 6px 0 6px;
        color: #082033;
        font-size: 31px;
        font-weight: 900;
        letter-spacing: 0;
    }

    .pm-hero p {
        margin: 0;
        color: #415a70;
        font-size: 14px;
        font-weight: 650;
    }

    .pm-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(110px, 1fr));
        gap: 10px;
        min-width: min(460px, 100%);
    }

    .pm-metrics div {
        min-height: 82px;
        padding: 14px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #f8fbfd;
    }

    .pm-metrics strong {
