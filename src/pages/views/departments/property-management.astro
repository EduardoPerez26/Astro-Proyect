    .pm-simple-stat-copy {
        display: grid;
        gap: 2px;
        min-width: 0;
    }

    .pm-simple-stat-copy strong {
        display: block;
        color: #082033;
        font-size: 24px;
        line-height: 1;
        font-weight: 950;
        letter-spacing: -0.03em;
        font-variant-numeric: tabular-nums;
        word-break: break-word;
    }

    .pm-simple-stat-copy span {
        display: block;
        color: #102a43;
        font-size: 12px;
        font-weight: 900;
        text-transform: none;
    }

    .pm-simple-stat-copy small {
        display: block;
        color: #6b8094;
        font-size: 11px;
        font-weight: 700;
    }

    .pm-quarter-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    :global(.pm-qc-card) {
        display: grid;
        gap: 10px;
        min-width: 0;
        padding: 14px 16px;
        border: 1px solid #d7e3ef;
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 10px 28px -26px rgba(7, 31, 52, 0.45);
    }

    :global(.pm-qc-header) {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    :global(.pm-qc-quarter) {
        color: #173a59;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0.02em;
        text-transform: uppercase;
    }

    :global(.pm-qc-status) {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        min-height: 24px;
        padding: 0 8px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        white-space: nowrap;
    }

    :global(.pm-qc-status.is-open) {
        background: #fff4e5;
        color: #946200;
    }

    :global(.pm-qc-status.is-balanced) {
        background: #e8f7f3;
        color: #0f665f;
    }

    :global(.pm-qc-status i) {
        font-size: 9px;
    }

    :global(.pm-qc-value-row) {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    :global(.pm-qc-label) {
        display: block;
        margin-bottom: 3px;
        color: #6b8094;
        font-size: 10px;
        font-weight: 850;
        text-transform: uppercase;
    }

    :global(.pm-qc-value) {
        display: block;
        color: #082033;
        font-size: 18px;
        line-height: 1.05;
        font-weight: 950;
        letter-spacing: -0.03em;
        font-variant-numeric: tabular-nums;
    }

    :global(.pm-qc-card.is-open .pm-qc-value) {
        color: #8a5a00;
    }

    :global(.pm-qc-card.is-balanced .pm-qc-value) {
        color: #0f665f;
    }

    :global(.pm-qc-button) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 62px;
        min-height: 36px;
        padding: 0 14px;
        border: 1px solid #bfd2e3;
        border-radius: 10px;
        background: #f8fbfe;
        color: #0b3a67;
        font-size: 12px;
        font-weight: 900;
        cursor: pointer;
        transition:
            background 0.18s ease,
            border-color 0.18s ease;
    }

    :global(.pm-qc-button:hover) {
        background: #edf5fc;
        border-color: #9fbad3;
    }

    :global(.pm-qc-metrics) {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        border: 1px solid #dfe9f2;
        border-radius: 10px;
        overflow: hidden;
        background: #f8fbfe;
    }

    :global(.pm-qc-metrics div) {
        display: grid;
        gap: 4px;
        min-width: 0;
        padding: 10px 10px;
        border-right: 1px solid #dfe9f2;
