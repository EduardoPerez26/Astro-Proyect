    .pm-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 24px 26px;
        border: 1px solid #cfdae5;
        border-left: 4px solid #0f766e;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 18px 44px -38px rgba(8, 31, 51, 0.55);
    }

