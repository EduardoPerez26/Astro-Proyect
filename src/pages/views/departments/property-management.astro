---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Property Management" includeSheetJS={true}>
<section class="property-management-page page-container" aria-labelledby="propertyManagementTitle">
        <div class="page-header">
            <div class="page-header-info">
                <span class="pm-eyebrow">
                    Department workspace
                </span>
                <h1 id="propertyManagementTitle">Property Management</h1>
            </div>
        </div>

        <section id="pmUploadSection" class="upload-section pm-upload-section" aria-labelledby="pmScheduleTitle">
            <div class="section-heading">
                <span class="step-badge">1</span>
                <div>
                    <h2 id="pmScheduleTitle">Sales tax payable schedule</h2>
                    <p>Upload the source reports once, then keep adding monthly activity to the saved schedule.</p>
                </div>

            </div>

            <div class="pm-schedule-actions">
                <button type="button" class="btn btn-secondary" id="pmRefreshSavedBtn">
                    <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
                    Refresh saved
                </button>
                <button type="button" class="btn btn-secondary" id="pmSaveScheduleBtn" disabled>
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                    Save
                </button>
                <button type="button" class="btn btn-secondary" id="pmClearScheduleBtn">
                    <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
                    Reset
                </button>
                <button type="button" class="btn btn-primary" id="pmExportScheduleBtn" disabled>
                    <i class="fa-solid fa-download" aria-hidden="true"></i>
                    Export Schedule 2026
                </button>
            </div>

            <div class="multi-upload-container">
                <div class="upload-card" id="salesUploadCard">
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-scale-balanced"></i>
                            Dimension Balance report
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill required">Required</span>
                        </span>
                    </div>
                    <label class="reconciliation-dropzone" for="pmDimensionBalanceFile">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <strong>Drag & drop Dimension Balance report here</strong>
                        <span>or click to browse</span>
                    </label>
                    <small class="upload-format-hint">Accepted formats: .xlsx, .xls</small>
                    <input id="pmDimensionBalanceFile" type="file" accept=".xlsx,.xls" class="reconciliation-file-input" />
                    <button type="button" class="btn btn-primary" id="pmLoadDimensionBalancesBtn">
                        <i class="fa-solid fa-table-list"></i>
                        Load opening balances
                    </button>
                </div>

                <div class="upload-card" id="salesDetailUploadCard">
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-calendar-days"></i>
                            Monthly files
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill">Optional</span>
                        </span>
                    </div>
                    <label class="reconciliation-dropzone" for="pmMonthlyLedgerFile">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <strong>Drag & drop monthly files here</strong>
                        <span>or click to browse</span>
                    </label>
                    <small class="upload-format-hint">Select one or more monthly GL exports. The system fills each store automatically.</small>
                    <input id="pmMonthlyLedgerFile" type="file" accept=".xls,.xlsx,.html,.htm" multiple class="reconciliation-file-input" />
                    <button type="button" class="btn btn-primary" id="pmAddMonthlyFileBtn">
                        <i class="fa-solid fa-file-import"></i>
                        Import selected files
                    </button>
                </div>
            </div>

            <div class="pm-alert-stack" id="pmAlertStack" aria-live="polite" aria-atomic="false"></div>

            <div class="pm-tab-panel is-active" id="pmEditorTab" role="tabpanel" aria-labelledby="pmEditorTabButton">
                <div class="pm-schedule-management">
                    <section class="pm-manager-card summary-card" aria-labelledby="pmSavedScheduleTitle">
                        <div class="pm-manager-card-header">
                            <span class="pm-manager-icon">
                                <i class="fa-solid fa-database" aria-hidden="true"></i>
                            </span>
                            <div>
                                <span>Saved work</span>
                                <h3 id="pmSavedScheduleTitle">Property Management schedules</h3>
                            </div>
                        </div>

                        <label class="pm-field">
                            <span>Schedule name</span>
                            <input id="pmScheduleName" type="text" value="Schedule 2026" />
                        </label>

                        <div class="pm-inline-controls">
                            <select id="pmSavedScheduleSelect" aria-label="Saved Property Management schedules">
                                <option value="">No saved schedules loaded</option>
                            </select>
                            <button type="button" class="btn btn-secondary" id="pmLoadScheduleBtn">
                                <i class="fa-solid fa-folder-open" aria-hidden="true"></i>
                                Open
                            </button>
                        </div>
                    </section>
                </div>

                <div class="pm-schedule-preview" id="pmSchedulePreview" hidden>
                    <div class="pm-preview-summary">
                        <div><strong id="pmScheduleStores">0</strong><span>Stores</span></div>
                        <div><strong id="pmScheduleRows">0</strong><span>Rows</span></div>
                        <div><strong id="pmScheduleBalance">$0.00</strong><span>YTD balance</span></div>
                    </div>

                    <div class="pm-table-toolbar" aria-label="Schedule filters">
                        <div class="pm-table-toolbar-head">
                            <div>
                                <span class="pm-eyebrow">
                                    <i class="fa-solid fa-filter" aria-hidden="true"></i>
                                    Working view
                                </span>
                                <h3>Schedule filters</h3>
                            </div>
                            <strong id="pmScheduleFilterCount">Showing all rows</strong>
                        </div>

                        <div class="pm-filter-grid">
                            <label class="pm-field">
                                <span>Search</span>
                                <input
                                    id="pmScheduleSearch"
                                    type="search"
                                    placeholder="Store, entry, entity, reference"
                                    data-pm-filter="search"
                                />
                            </label>

                            <label class="pm-field">
                                <span>Store</span>
                                <select id="pmScheduleStoreFilter" data-pm-filter="store">
                                    <option value="">All stores</option>
                                </select>
                            </label>

                            <label class="pm-field">
                                <span>Entity</span>
                                <select id="pmScheduleEntityFilter" data-pm-filter="entity">
                                    <option value="">All entities</option>
                                </select>
                            </label>

                            <label class="pm-field">
                                <span>Month</span>
                                <select id="pmScheduleMonthFilter" data-pm-filter="month">
                                    <option value="">All months</option>
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9">September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                            </label>

                            <label class="pm-field">
                                <span>Rows</span>
                                <select id="pmScheduleRowTypeFilter" data-pm-filter="rowType">
                                    <option value="">All rows</option>
                                    <option value="summary">Store summaries</option>
                                    <option value="detail">Detail rows</option>
                                    <option value="manual">Manual rows</option>
                                    <option value="activity">Rows with activity</option>
                                </select>
                            </label>

                            <button type="button" class="btn btn-secondary pm-filter-reset" id="pmClearScheduleFiltersBtn">
                                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                                Clear filters
                            </button>
                        </div>
                    </div>

                    <div class="pm-schedule-table-wrap">
                        <table class="pm-schedule-table" id="pmScheduleTable"></table>
                    </div>
                </div>
            </div>

            <div class="pm-tab-panel" id="pmDepartmentDocumentsTab" role="tabpanel" aria-labelledby="pmDocumentsTabButton" hidden>
                <div class="pm-documents-workspace">
                    <section class="pm-documents-panel" aria-labelledby="pmSavedDocsTitle">
                        <div class="pm-documents-panel-header">
                            <div>
                                <span class="pm-eyebrow">
                                    <i class="fa-solid fa-file-pen" aria-hidden="true"></i>
                                    Editable schedules
                                </span>
                                <h3 id="pmSavedDocsTitle">Department schedules</h3>
                            </div>
                            <button type="button" class="btn btn-secondary" id="pmDocsRefreshBtn">
                                <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
                                Refresh
                            </button>
                        </div>

                        <div class="pm-documents-table-wrap">
                            <table class="pm-documents-table">
                                <thead>
                                    <tr>
                                        <th>Schedule</th>
                                        <th>Period</th>
                                        <th>Stores</th>
                                        <th>Rows</th>
                                        <th>Balance</th>
                                        <th>Updated</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="pmDepartmentSchedulesTable">
                                    <tr><td colspan="7">Loading schedules...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <section class="pm-documents-panel" aria-labelledby="pmSourceDocsTitle">
                        <div class="pm-documents-panel-header">
                            <div>
                                <span class="pm-eyebrow">
                                    <i class="fa-solid fa-file-shield" aria-hidden="true"></i>
                                    Source files
                                </span>
                                <h3 id="pmSourceDocsTitle">Uploaded department documents</h3>
                            </div>
                        </div>

                        <div class="pm-documents-table-wrap">
                            <table class="pm-documents-table">
                                <thead>
                                    <tr>
                                        <th>File</th>
                                        <th>Type</th>
                                        <th>Size</th>
                                        <th>Uploaded</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="pmDepartmentFilesTable">
                                    <tr><td colspan="5">Loading documents...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </section>
                </div>
            </div>
        </section>

        
    </section>

    <script src="/js/config.js" is:inline></script>
    <script is:inline src="/js/departments/property-management.js?v=20260701-schedule-table-restore"></script>
</DashboardLayout>

<style>
    .property-management-page {
        display: grid;
        gap: 18px;
        padding: 18px 24px 28px;
    }

    .pm-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 24px 26px;
        border: 1px solid #cfdae5;
        border-left: 4px solid #0f766e;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 18px 44px -38px rgba(8, 31, 51, .55);
    }

    .pm-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #344f67;
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
    }

    .pm-hero h1 {
        margin: 6px 0 6px;
        color: #082033;
        font-size: 31px;
        font-weight: 900;
        letter-spacing: 0;
    }

    .pm-hero p {
        margin: 0;
        color: #415a70;
        font-size: 14px;
        font-weight: 650;
    }

    .pm-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(110px, 1fr));
        gap: 10px;
        min-width: min(460px, 100%);
    }

    .pm-metrics div {
        min-height: 82px;
        padding: 14px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #f8fbfd;
    }

    .pm-metrics strong {
        display: block;
        color: #09243b;
        font-size: 28px;
        font-weight: 900;
        line-height: 1;
    }

    .pm-metrics span {
        display: block;
        margin-top: 8px;
        color: #415a70;
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
    }

    .pm-layout {
        display: grid;
        grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
        gap: 18px;
        align-items: start;
    }

    .pm-schedule-panel {
        display: grid;
        gap: 16px;
        padding: 20px;
        border: 1px solid #cfdae5;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 18px 44px -40px rgba(8, 31, 51, .62);
    }

    .pm-schedule-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
    }

    .pm-schedule-header h2 {
        margin: 6px 0;
        color: #082033;
        font-size: 22px;
        font-weight: 900;
    }

    .pm-schedule-header p {
        margin: 0;
        color: #415a70;
        font-size: 13px;
        font-weight: 650;
    }

    .pm-schedule-actions,
    .pm-builder-card {
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
        justify-content: flex-end;
    }

    .pm-upload-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .pm-upload-card,
    .pm-builder-card {
        min-height: 286px;
        padding: 20px;
        border: 1px solid #d7e2ec;
        border-radius: 14px;
        background: #f8fbfd;
    }

    .pm-upload-card {
        display: grid;
        grid-template-rows: auto minmax(128px, 1fr) auto;
        gap: 14px;
        overflow: hidden;
        cursor: pointer;
    }

    .pm-upload-card-head {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
    }

    .pm-upload-icon {
        display: grid;
        width: 42px;
        height: 42px;
        flex: 0 0 auto;
        place-items: center;
        border-radius: 8px;
        background: #102a43;
        color: #ffffff;
    }

    .pm-upload-card strong,
    .pm-builder-card strong {
        color: #082033;
        font-size: 15px;
        font-weight: 900;
    }

    .pm-upload-card small,
    .pm-builder-card small {
        color: #526b82;
        font-size: 12px;
        font-weight: 650;
        line-height: 1.45;
    }

    .pm-upload-dropzone,
    .pm-builder-illustration {
        display: grid;
        min-height: 128px;
        place-items: center;
        padding: 22px;
        border: 1px dashed #b5c8db;
        border-radius: 14px;
        text-align: center;
    }

    .pm-upload-dropzone i,
    .pm-builder-illustration i {
        display: block;
        margin-bottom: 8px;
        font-size: 28px;
    }

    .pm-upload-dropzone span,
    .pm-upload-dropzone em {
        display: block;
        font-style: normal;
    }

    .pm-upload-card input[type="file"] {
        position: absolute;
        width: 1px;
        height: 1px;
        opacity: 0;
        pointer-events: none;
    }

    .pm-builder-card {
        display: grid;
        grid-template-rows: auto minmax(128px, 1fr) auto auto;
        gap: 14px;
        align-content: space-between;
    }

    .pm-builder-actions {
        display: grid;
        gap: 8px;
    }

    .pm-builder-actions .btn {
        justify-content: center;
        width: 100%;
    }

    .pm-builder-card .pm-upload-card-head em {
        display: block;
        margin-bottom: 4px;
        color: #344f67;
        font-size: 11px;
        font-style: normal;
        font-weight: 850;
        text-transform: uppercase;
    }

    .pm-upload-card > .btn,
    .pm-builder-card > .btn {
        width: 100%;
        justify-content: center;
    }

    .pm-schedule-status {
        padding: 12px 14px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #fbfdff;
        color: #415a70;
        font-size: 13px;
        font-weight: 700;
    }

    .pm-schedule-status.is-error {
        border-color: #f0c9c9;
        background: #fff8f8;
        color: #9f1d1d;
    }

    .pm-schedule-status.is-success {
        border-color: #b7ded6;
        background: #f0fbf7;
        color: #0f665f;
    }

    .pm-schedule-status.is-warning {
        border-color: #f2d3a2;
        background: #fff8ed;
        color: #875a0a;
    }

    .pm-alert-stack {
        display: grid;
        gap: 9px;
    }

    .pm-alert-stack:empty {
        display: none;
    }

    :global(.pm-alert) {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: 10px;
        align-items: center;
        padding: 12px 13px;
        border: 1px solid #d7e2ec;
        border-left-width: 4px;
        border-radius: 8px;
        background: #ffffff;
        color: #173a59;
        box-shadow: 0 14px 32px -30px rgba(8, 31, 51, .55);
    }

    :global(.pm-alert > i) {
        display: grid;
        width: 30px;
        height: 30px;
        place-items: center;
        border-radius: 8px;
        background: #edf4f9;
        color: #173a59;
    }

    :global(.pm-alert strong) {
        display: block;
        color: #082033;
        font-size: 13px;
        font-weight: 900;
        line-height: 1.25;
    }

    :global(.pm-alert span) {
        display: block;
        margin-top: 2px;
        color: #415a70;
        font-size: 12px;
        font-weight: 700;
        line-height: 1.35;
    }

    :global(.pm-alert button) {
        display: grid;
        width: 30px;
        height: 30px;
        place-items: center;
        border: 1px solid #cbd9e6;
        border-radius: 7px;
        background: #ffffff;
        color: #173a59;
        cursor: pointer;
    }

    :global(.pm-alert.is-success) {
        border-color: #b7ded6;
        border-left-color: #0f766e;
        background: #f0fbf7;
    }

    :global(.pm-alert.is-success > i) {
        background: #dff5ef;
        color: #0f665f;
    }

    :global(.pm-alert.is-error) {
        border-color: #f0c9c9;
        border-left-color: #b42318;
        background: #fff8f8;
    }

    :global(.pm-alert.is-error > i) {
        background: #fee4e2;
        color: #9f1d1d;
    }

    :global(.pm-alert.is-warning) {
        border-color: #f2d3a2;
        border-left-color: #b7791f;
        background: #fff8ed;
    }

    :global(.pm-alert.is-warning > i) {
        background: #fff1d6;
        color: #875a0a;
    }

    .pm-tabs {
        display: inline-flex;
        width: fit-content;
        max-width: 100%;
        gap: 4px;
        padding: 4px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #f8fbfd;
    }

    .pm-tab {
        display: inline-flex;
        min-height: 40px;
        align-items: center;
        gap: 8px;
        padding: 0 13px;
        border: 1px solid transparent;
        border-radius: 7px;
        background: transparent;
        color: #344f67;
        font-size: 12px;
        font-weight: 900;
        cursor: pointer;
    }

    .pm-tab.is-active {
        border-color: #cbd9e6;
        background: #ffffff;
        color: #082033;
        box-shadow: 0 10px 24px -22px rgba(8, 31, 51, .65);
    }

    .pm-tab-panel {
        display: grid;
        gap: 16px;
    }

    .pm-tab-panel[hidden] {
        display: none;
    }

    .pm-schedule-management {
        display: grid;
        grid-template-columns: minmax(270px, .95fr) minmax(360px, 1.35fr) minmax(270px, 1fr);
        gap: 12px;
        align-items: stretch;
    }

    .pm-manager-card {
        display: grid;
        align-content: start;
        gap: 14px;
        min-width: 0;
        padding: 16px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #fbfdff;
    }

    .pm-manager-card[hidden] {
        display: none;
    }

    .pm-manager-card-header {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .pm-manager-icon {
        display: grid;
        width: 38px;
        height: 38px;
        flex: 0 0 auto;
        place-items: center;
        border-radius: 8px;
        background: #102a43;
        color: #ffffff;
    }

    .pm-manager-card-header span:not(.pm-manager-icon) {
        display: block;
        color: #344f67;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
    }

    .pm-manager-card-header h3 {
        margin: 2px 0 0;
        color: #082033;
        font-size: 15px;
        font-weight: 900;
    }

    .pm-field {
        display: grid;
        gap: 7px;
        min-width: 0;
    }

    .pm-field span {
        color: #344f67;
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
    }

    .pm-field input,
    .pm-field select,
    .pm-inline-controls select {
        width: 100%;
        min-width: 0;
        height: 40px;
        padding: 0 11px;
        border: 1px solid #bfd0df;
        border-radius: 7px;
        background: #ffffff;
        color: #082033;
        font: inherit;
        font-size: 13px;
        font-weight: 700;
    }

    .pm-field input:focus,
    .pm-field select:focus,
    .pm-inline-controls select:focus {
        border-color: #174a75;
        outline: 0;
        box-shadow: 0 0 0 3px rgba(23, 74, 117, .12);
    }

    .pm-inline-controls {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
    }

    .pm-month-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .pm-full-action {
        justify-content: center;
        width: 100%;
    }

    .pm-editor-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 9px;
    }

    .pm-editor-actions .btn {
        justify-content: center;
        min-width: 0;
        width: 100%;
    }

    .pm-card-note {
        margin: 0;
        color: #526b82;
        font-size: 12px;
        font-weight: 650;
        line-height: 1.45;
    }

    .pm-documents-list {
        display: grid;
        gap: 8px;
        max-height: 236px;
        overflow: auto;
        color: #415a70;
        font-size: 12px;
        font-weight: 700;
    }

    :global(.pm-document-item) {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        padding: 10px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #ffffff;
    }

    :global(.pm-document-item strong) {
        display: block;
        overflow: hidden;
        color: #082033;
        font-size: 12px;
        font-weight: 900;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    :global(.pm-document-item span) {
        display: block;
        margin-top: 4px;
        color: #526b82;
        font-size: 11px;
        font-weight: 750;
    }

