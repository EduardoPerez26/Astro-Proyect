    .pm-metrics div {
        min-height: 82px;
        padding: 14px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #f8fbfd;
    }

    .pm-metrics strong {
        display: block;
        color: #09243b;
        font-size: 28px;
        font-weight: 900;
        line-height: 1;
    }

    .pm-metrics span {
        display: block;
        margin-top: 8px;
        color: #415a70;
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
    }

    .pm-layout {
        display: grid;
        grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
        gap: 18px;
        align-items: start;
    }

    .pm-schedule-panel {
        display: grid;
        gap: 16px;
        padding: 20px;
        border: 1px solid #cfdae5;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 18px 44px -40px rgba(8, 31, 51, 0.62);
    }

    .pm-schedule-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
    }

    .pm-schedule-header h2 {
        margin: 6px 0;
        color: #082033;
        font-size: 22px;
        font-weight: 900;
    }

    .pm-schedule-header p {
        margin: 0;
        color: #415a70;
        font-size: 13px;
        font-weight: 650;
    }

    .pm-schedule-actions,
    .pm-builder-card {
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
        justify-content: flex-end;
    }

    .pm-upload-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .pm-upload-card,
    .pm-builder-card {
        min-height: 286px;
        padding: 20px;
        border: 1px solid #d7e2ec;
        border-radius: 14px;
        background: #f8fbfd;
    }

    .pm-upload-card {
        display: grid;
        grid-template-rows: auto minmax(128px, 1fr) auto;
        gap: 14px;
        overflow: hidden;
        cursor: pointer;
    }

    .pm-upload-card-head {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
    }

    .pm-upload-icon {
        display: grid;
        width: 42px;
        height: 42px;
        flex: 0 0 auto;
        place-items: center;
        border-radius: 8px;
        background: #102a43;
        color: #ffffff;
    }

    .pm-upload-card strong,
    .pm-builder-card strong {
        color: #082033;
        font-size: 15px;
        font-weight: 900;
    }

    .pm-upload-card small,
    .pm-builder-card small {
        color: #526b82;
        font-size: 12px;
        font-weight: 650;
        line-height: 1.45;
    }

    .pm-upload-dropzone,
    .pm-builder-illustration {
        display: grid;
        min-height: 128px;
        place-items: center;
        padding: 22px;
        border: 1px dashed #b5c8db;
        border-radius: 14px;
        text-align: center;
    }

    .pm-upload-dropzone i,
    .pm-builder-illustration i {
        display: block;
        margin-bottom: 8px;
        font-size: 28px;
    }

    .pm-upload-dropzone span,
    .pm-upload-dropzone em {
        display: block;
        font-style: normal;
    }

    .pm-upload-card input[type="file"] {
        position: absolute;
        width: 1px;
        height: 1px;
        opacity: 0;
        pointer-events: none;
    }

    .pm-builder-card {
        display: grid;
        grid-template-rows: auto minmax(128px, 1fr) auto auto;
        gap: 14px;
        align-content: space-between;
    }

    .pm-builder-actions {
        display: grid;
        gap: 8px;
    }

    .pm-builder-actions .btn {
        justify-content: center;
        width: 100%;
    }

    .pm-builder-card .pm-upload-card-head em {
        display: block;
        margin-bottom: 4px;
        color: #344f67;
        font-size: 11px;
        font-style: normal;
        font-weight: 850;
        text-transform: uppercase;
    }

    .pm-upload-card > .btn,
    .pm-builder-card > .btn {
        width: 100%;
        justify-content: center;
    }

    .pm-schedule-status {
        padding: 12px 14px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #fbfdff;
        color: #415a70;
        font-size: 13px;
        font-weight: 700;
    }

    .pm-schedule-status.is-error {
        border-color: #f0c9c9;
        background: #fff8f8;
        color: #9f1d1d;
    }

    .pm-schedule-status.is-success {
        border-color: #b7ded6;
        background: #f0fbf7;
        color: #0f665f;
    }

    .pm-schedule-status.is-warning {
        border-color: #f2d3a2;
        background: #fff8ed;
        color: #875a0a;
    }

    .pm-alert-stack {
        display: grid;
        gap: 9px;
    }

    .pm-alert-stack:empty {
        display: none;
    }

    :global(.pm-alert) {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: 10px;
        align-items: center;
        padding: 12px 13px;
        border: 1px solid #d7e2ec;
        border-left-width: 4px;
        border-radius: 8px;
        background: #ffffff;
        color: #173a59;
        box-shadow: 0 14px 32px -30px rgba(8, 31, 51, 0.55);
    }

    :global(.pm-alert > i) {
        display: grid;
        width: 30px;
        height: 30px;
        place-items: center;
        border-radius: 8px;
        background: #edf4f9;
        color: #173a59;
    }

    :global(.pm-alert strong) {
        display: block;
        color: #082033;
        font-size: 13px;
        font-weight: 900;
        line-height: 1.25;
    }

    :global(.pm-alert span) {
        display: block;
        margin-top: 2px;
        color: #415a70;
        font-size: 12px;
        font-weight: 700;
        line-height: 1.35;
    }

    :global(.pm-alert button) {
        display: grid;
        width: 30px;
        height: 30px;
        place-items: center;
        border: 1px solid #cbd9e6;
        border-radius: 7px;
        background: #ffffff;
        color: #173a59;
        cursor: pointer;
    }

    :global(.pm-alert.is-success) {
        border-color: #b7ded6;
        border-left-color: #0f766e;
        background: #f0fbf7;
    }

    :global(.pm-alert.is-success > i) {
        background: #dff5ef;
        color: #0f665f;
    }

    :global(.pm-alert.is-error) {
        border-color: #f0c9c9;
        border-left-color: #b42318;
        background: #fff8f8;
    }

    :global(.pm-alert.is-error > i) {
        background: #fee4e2;
        color: #9f1d1d;
    }

    :global(.pm-alert.is-warning) {
        border-color: #f2d3a2;
        border-left-color: #b7791f;
        background: #fff8ed;
    }

    :global(.pm-alert.is-warning > i) {
        background: #fff1d6;
        color: #875a0a;
    }

    .pm-tabs {
        display: inline-flex;
        width: fit-content;
        max-width: 100%;
        gap: 4px;
        padding: 4px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #f8fbfd;
    }

    .pm-tab {
        display: inline-flex;
        min-height: 40px;
        align-items: center;
        gap: 8px;
        padding: 0 13px;
        border: 1px solid transparent;
        border-radius: 7px;
        background: transparent;
        color: #344f67;
        font-size: 12px;
        font-weight: 900;
        cursor: pointer;
    }

    .pm-tab.is-active {
        border-color: #cbd9e6;
        background: #ffffff;
        color: #082033;
        box-shadow: 0 10px 24px -22px rgba(8, 31, 51, 0.65);
    }

    .pm-tab-panel {
        display: grid;
        gap: 16px;
    }

    .pm-tab-panel[hidden] {
        display: none;
    }

    .pm-schedule-management {
        display: grid;
        grid-template-columns:
            minmax(270px, 0.95fr) minmax(360px, 1.35fr)
            minmax(270px, 1fr);
        gap: 12px;
        align-items: stretch;
    }

    .pm-manager-card {
        display: grid;
        align-content: start;
        gap: 14px;
        min-width: 0;
        padding: 16px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #fbfdff;
    }

    .pm-manager-card[hidden] {
        display: none;
    }

    .pm-manager-card-header {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .pm-manager-icon {
        display: grid;
        width: 38px;
        height: 38px;
        flex: 0 0 auto;
        place-items: center;
        border-radius: 8px;
        background: #102a43;
        color: #ffffff;
    }

    .pm-manager-card-header span:not(.pm-manager-icon) {
        display: block;
        color: #344f67;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
    }

    .pm-manager-card-header h3 {
        margin: 2px 0 0;
        color: #082033;
        font-size: 15px;
        font-weight: 900;
    }

    .pm-field {
        display: grid;
        gap: 7px;
        min-width: 0;
    }

    .pm-field span {
        color: #344f67;
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
    }

    .pm-field input,
    .pm-field select,
    .pm-inline-controls select {
        width: 100%;
        min-width: 0;
        height: 40px;
        padding: 0 11px;
        border: 1px solid #bfd0df;
        border-radius: 7px;
        background: #ffffff;
        color: #082033;
        font: inherit;
        font-size: 13px;
        font-weight: 700;
    }

    .pm-field input:focus,
    .pm-field select:focus,
    .pm-inline-controls select:focus {
        border-color: #174a75;
        outline: 0;
        box-shadow: 0 0 0 3px rgba(23, 74, 117, 0.12);
    }

    .pm-inline-controls {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
    }

    .pm-month-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .pm-full-action {
        justify-content: center;
        width: 100%;
    }

    .pm-editor-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 9px;
    }

    .pm-editor-actions .btn {
        justify-content: center;
        min-width: 0;
        width: 100%;
    }

    .pm-card-note {
        margin: 0;
        color: #526b82;
        font-size: 12px;
        font-weight: 650;
        line-height: 1.45;
    }

    .pm-documents-list {
        display: grid;
        gap: 8px;
        max-height: 236px;
        overflow: auto;
        color: #415a70;
        font-size: 12px;
        font-weight: 700;
    }

    :global(.pm-document-item) {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        padding: 10px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #ffffff;
    }

    :global(.pm-document-item strong) {
        display: block;
        overflow: hidden;
        color: #082033;
        font-size: 12px;
        font-weight: 900;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    :global(.pm-document-item span) {
        display: block;
        margin-top: 4px;
        color: #526b82;
        font-size: 11px;
        font-weight: 750;
    }

    :global(.pm-document-item small) {
        display: block;
        margin-top: 4px;
        color: #526b82;
        font-size: 11px;
        font-weight: 750;
    }

    :global(.pm-document-item small + span) {
        display: none;
    }

    :global(.pm-document-download) {
        align-self: center;
        min-height: 32px;
        padding: 0 10px;
        border: 1px solid #cbd9e6;
        border-radius: 7px;
        background: #ffffff;
        color: #173a59;
        font-size: 11px;
        font-weight: 850;
        cursor: pointer;
    }

    :global(.pm-empty-state) {
        display: grid;
        min-height: 76px;
        place-items: center;
        border: 1px dashed #cbd9e6;
        border-radius: 8px;
        color: #526b82;
        text-align: center;
    }

    .pm-schedule-preview {
        display: grid;
        gap: 14px;
    }

    .pm-preview-summary.pm-simple-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .pm-simple-stat-card {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
        min-height: 82px;
        padding: 16px 18px;
        border: 1px solid #d7e3ef;
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 10px 28px -26px rgba(7, 31, 52, 0.45);
    }

    .pm-simple-stat-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        min-width: 42px;
        border-radius: 11px;
        background: #eef5fc;
        color: #0b3a67;
