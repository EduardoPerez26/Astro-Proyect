    .pm-table-toolbar {
        display: grid;
        gap: 13px;
        padding: 14px;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #fbfdff;
    }

    .pm-table-toolbar-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
    }

    .pm-table-toolbar-head h3 {
        margin: 4px 0 0;
        color: #082033;
        font-size: 17px;
        font-weight: 900;
    }

    .pm-table-toolbar-head strong {
        display: inline-flex;
        min-height: 30px;
        align-items: center;
        padding: 0 10px;
        border: 1px solid #d7e2ec;
        border-radius: 7px;
        background: #ffffff;
        color: #344f67;
        font-size: 12px;
        font-weight: 850;
        white-space: nowrap;
    }

    .pm-filter-grid {
        display: grid;
        grid-template-columns:
            minmax(220px, 1.4fr) repeat(4, minmax(140px, 1fr))
            auto;
        gap: 10px;
        align-items: end;
    }

    .pm-filter-reset {
        justify-content: center;
        min-height: 40px;
        white-space: nowrap;
    }

    .pm-schedule-table-wrap {
        max-height: 520px;
        overflow: auto;
        border: 1px solid #d7e2ec;
        border-radius: 8px;
        background: #ffffff;
    }

    .pm-schedule-table {
        width: max-content;
        min-width: 100%;
        border-collapse: collapse;
        color: #082033;
        font-size: 12px;
    }

    .pm-schedule-table th,
    .pm-schedule-table td {
        padding: 8px 10px;
        border-bottom: 1px solid #e1ebf3;
        border-right: 1px solid #e1ebf3;
        white-space: nowrap;
    }

    .pm-schedule-table th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #102a43;
        color: #ffffff;
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
    }

    .pm-schedule-table td.is-number {
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .pm-schedule-table td.is-editable {
        background-image: linear-gradient(
            0deg,
            rgba(15, 118, 110, 0.08),
            rgba(15, 118, 110, 0.08)
        );
        cursor: text;
    }

    .pm-schedule-table td.is-editable:focus {
        position: relative;
