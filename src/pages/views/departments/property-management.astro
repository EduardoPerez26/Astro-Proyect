    .pm-hero h1 {
        margin: 6px 0 6px;
        color: #082033;
        font-size: 31px;
        font-weight: 900;
        letter-spacing: 0;
    }

    .pm-hero p {
        margin: 0;
        color: #415a70;
        font-size: 14px;
        font-weight: 650;
    }

    .pm-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(110px, 1fr));
        gap: 10px;
        min-width: min(460px, 100%);
