        border-right: 0;
    }

    :global(.pm-qc-metrics span) {
        color: #6b8094;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
    }

    :global(.pm-qc-metrics strong) {
        overflow: hidden;
        color: #173a59;
        font-size: 12px;
        font-weight: 900;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
