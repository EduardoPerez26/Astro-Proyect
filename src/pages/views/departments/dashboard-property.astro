---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Property Schedules">
    <section class="schedule-dashboard" aria-labelledby="scheduleDashboardTitle">
        <header class="schedule-header">
            <div>
                <span class="schedule-eyebrow">Schedules</span>
                <h1 id="scheduleDashboardTitle">Schedule dashboard</h1>
                <p>
                    Review saved schedules, monthly periods, store coverage, and
                    recent schedule activity.
                </p>
            </div>

            <div class="schedule-actions">
                <a class="schedule-btn is-secondary" href="/views/departments/property-management-documents">
                    <i class="fa-solid fa-folder-open" aria-hidden="true"></i>
                    Source files
                </a>
                <a class="schedule-btn" href="/views/departments/property-management">
                    <i class="fa-solid fa-plus" aria-hidden="true"></i>
                    New schedule
                </a>
            </div>
        </header>

        <div class="schedule-metrics" aria-label="Schedule metrics">
            <article>
                <span>Saved schedules</span>
                <strong id="scheduleMetricTotal">0</strong>
                <small id="scheduleMetricLatest">Loading activity...</small>
            </article>

            <article>
                <span>Latest period</span>
                <strong id="scheduleMetricPeriod">-</strong>
                <small id="scheduleMetricPeriodMeta">No saved period yet</small>
            </article>

            <article>
                <span>Stores covered</span>
                <strong id="scheduleMetricStores">0</strong>
                <small>Across saved schedule versions</small>
            </article>

            <article>
                <span>Total balance</span>
                <strong id="scheduleMetricBalance">$0.00</strong>
                <small>Sum of saved balances</small>
            </article>
        </div>

        <section class="schedule-panel" aria-labelledby="recentSchedulesTitle">
            <div class="schedule-panel-header">
                <div>
                    <span>Saved workbooks</span>
                    <h2 id="recentSchedulesTitle">Recent schedules</h2>
                </div>
                <small id="scheduleTableMeta">Loading...</small>
            </div>

            <div class="schedule-table-wrap">
                <table class="schedule-table">
                    <thead>
                        <tr>
                            <th>Schedule</th>
                            <th>Period</th>
                            <th>Stores</th>
                            <th>Rows</th>
                            <th>Balance</th>
                            <th>Updated</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="scheduleRecentBody">
                        <tr>
                            <td colspan="7" class="schedule-empty">
                                Loading recent schedules...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </section>

    <style>
        .schedule-dashboard {
            display: grid;
            gap: 16px;
            width: 100%;
            min-width: 0;
            padding-bottom: 18px;
        }

        .schedule-header,
        .schedule-metrics article,
        .schedule-panel {
            border: 1px solid #dfe8f2;
            border-radius: 14px;
            background: #ffffff;
            box-shadow: 0 18px 42px -38px rgba(8, 28, 46, 0.64);
        }

        .schedule-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 24px;
            padding: 28px 34px;
        }

        .schedule-eyebrow,
        .schedule-metrics span,
        .schedule-panel-header span {
            display: block;
            color: #0b1d31;
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 0;
            text-transform: uppercase;
        }

        .schedule-header h1 {
            margin: 10px 0 0;
            color: #0d2238;
            font-size: clamp(30px, 4vw, 44px);
            line-height: 1.02;
            font-weight: 950;
        }

        .schedule-header p {
            max-width: 680px;
            margin: 12px 0 0;
            color: #60768d;
            font-size: 14px;
            line-height: 1.6;
            font-weight: 700;
        }

        .schedule-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: flex-end;
        }

        .schedule-btn,
        .schedule-open-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 42px;
            padding: 0 15px;
            border-radius: 10px;
            background: #101122;
            color: #ffffff;
            font-size: 13px;
            font-weight: 900;
            text-decoration: none;
            white-space: nowrap;
        }

        .schedule-btn.is-secondary {
            border: 1px solid #d7e3ef;
            background: #ffffff;
            color: #101122;
        }

        .schedule-btn:hover,
        .schedule-open-link:hover {
            background: #173a59;
        }

        .schedule-btn.is-secondary:hover {
            background: #f7fbff;
        }

        .schedule-metrics {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 10px;
        }

        .schedule-metrics article {
            min-width: 0;
            min-height: 96px;
            padding: 16px 18px;
            background: #f8fbff;
        }

        .schedule-metrics strong {
            display: block;
            margin-top: 10px;
            overflow: hidden;
            color: #0d3d68;
            font-size: 30px;
            line-height: 1;
            font-weight: 950;
            white-space: nowrap;
            text-overflow: ellipsis;
        }

        .schedule-metrics small {
            display: block;
            margin-top: 8px;
            color: #60768d;
            font-size: 12px;
            font-weight: 750;
        }

        .schedule-panel {
            min-width: 0;
            overflow: hidden;
        }

        .schedule-panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 18px 20px;
            border-bottom: 1px solid #e3ecf5;
        }

        .schedule-panel-header h2 {
            margin: 6px 0 0;
            color: #0d2238;
            font-size: 20px;
            line-height: 1.1;
            font-weight: 950;
        }

        .schedule-panel-header small {
            color: #60768d;
            font-size: 12px;
            font-weight: 800;
            text-align: right;
        }

        .schedule-table-wrap {
            max-height: 520px;
            overflow: auto;
        }

        .schedule-table {
            width: 100%;
            min-width: 840px;
            border-collapse: collapse;
            font-size: 13px;
        }

        .schedule-table th {
            position: sticky;
            top: 0;
            z-index: 1;
            padding: 12px;
            background: #101122;
            color: #ffffff;
            font-size: 11px;
            font-weight: 950;
            text-align: left;
            text-transform: uppercase;
        }

        .schedule-table td {
            padding: 12px;
            border-bottom: 1px solid #e3ecf5;
            color: #0d2238;
            font-weight: 750;
            vertical-align: middle;
        }

        .schedule-table tr:nth-child(even) td {
            background: #f8fbff;
        }

        .schedule-table .is-number {
            text-align: right;
            font-variant-numeric: tabular-nums;
        }

        .schedule-table small {
            color: #60768d;
            font-size: 11px;
            font-weight: 750;
        }

        .schedule-open-link {
            min-height: 30px;
            padding: 0 10px;
            border-radius: 9px;
            font-size: 12px;
        }

        .schedule-empty {
            padding: 30px !important;
            color: #60768d !important;
            text-align: center;
        }

        @media (max-width: 1100px) {
            .schedule-metrics {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 780px) {
            .schedule-header {
                flex-direction: column;
                padding: 24px;
            }

            .schedule-actions {
                justify-content: stretch;
                width: 100%;
            }

            .schedule-btn {
                flex: 1 1 180px;
            }
        }

        @media (max-width: 560px) {
            .schedule-metrics {
                grid-template-columns: 1fr;
            }

            .schedule-panel-header {
                align-items: flex-start;
                flex-direction: column;
            }
        }
    </style>

    <script src="/js/config.js" is:inline></script>
    <script is:inline>
        const MONTH_NAMES = [
            "",
            "January",
            "February",
            "March",
            "April",
            "May",
            "June",
            "July",
            "August",
            "September",
            "October",
            "November",
            "December",
        ];

        document.addEventListener("DOMContentLoaded", loadScheduleDashboard);

        async function loadScheduleDashboard() {
            try {
                const schedules = await fetchSchedules();
                renderScheduleDashboard(schedules);
            } catch (error) {
                console.error(error);
                renderScheduleDashboardError(error);
            }
        }

        async function fetchSchedules() {
            const apiBase = String(window.API_URL || "").replace(/\/$/, "");
            const token = localStorage.getItem("token");

            if (!apiBase) throw new Error("API_URL is not configured");
            if (!token) throw new Error("Your session token was not found. Sign in again.");

            const response = await fetch(`${apiBase}/property-management/schedules`, {
                headers: { Authorization: `Bearer ${token}` },
            });
            const data = await response.json();

            if (!response.ok || data.success === false) {
                throw new Error(data.message || "Schedules could not be loaded");
            }

            return Array.isArray(data.schedules) ? data.schedules : [];
        }

        function renderScheduleDashboard(schedules) {
            const stats = buildDashboardStats(schedules);

            setText("scheduleMetricTotal", formatInteger(stats.totalSchedules));
            setText("scheduleMetricStores", formatInteger(stats.totalStores));
            setText("scheduleMetricBalance", formatCurrency(stats.totalBalance));
            setText("scheduleMetricPeriod", stats.latestPeriodShort || "-");
            setText("scheduleMetricLatest", stats.latest ? `Latest update: ${formatShortDate(stats.latest.fecha_actualizacion || stats.latest.fecha_creacion)}` : "No schedules saved yet");
            setText("scheduleMetricPeriodMeta", stats.periodCount ? `${formatInteger(stats.periodCount)} saved period${stats.periodCount === 1 ? "" : "s"}` : "No saved period yet");
            setText("scheduleTableMeta", `${formatInteger(schedules.length)} schedule${schedules.length === 1 ? "" : "s"}`);

            renderRecentSchedules(schedules.slice(0, 12));
        }

        function buildDashboardStats(schedules) {
            const periods = new Set();
            let totalStores = 0;
            let totalBalance = 0;

            schedules.forEach((schedule) => {
                const stores = Number(schedule.total_tiendas || 0);
                const balance = Number(schedule.balance_total || 0);
                const period = getPeriodKey(schedule);

                totalStores += stores;
                totalBalance += Number.isFinite(balance) ? balance : 0;
                if (period) periods.add(period);
            });

            const latestPeriodKey = Array.from(periods).sort().reverse()[0] || "";

            return {
                totalSchedules: schedules.length,
                totalStores,
                totalBalance,
                periodCount: periods.size,
                latestPeriodShort: latestPeriodKey ? formatPeriodKey(latestPeriodKey) : "",
                latest: schedules[0] || null,
            };
        }

        function renderRecentSchedules(schedules) {
            const tbody = document.getElementById("scheduleRecentBody");
            if (!tbody) return;

            if (!schedules.length) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="schedule-empty">
                            No schedules saved yet. Create the first schedule from the builder.
                        </td>
                    </tr>
                `;
                return;
            }

            tbody.innerHTML = schedules
                .map((schedule) => `
                    <tr>
                        <td>
                            <strong>${escapeHtml(schedule.nombre || "Schedule")}</strong>
                            <br />
                            <small>${escapeHtml(schedule.estado || "draft")}</small>
                        </td>
                        <td>${escapeHtml(formatSchedulePeriod(schedule))}</td>
                        <td class="is-number">${formatInteger(schedule.total_tiendas)}</td>
                        <td class="is-number">${formatInteger(schedule.total_filas)}</td>
                        <td class="is-number">${formatCurrency(schedule.balance_total)}</td>
                        <td>${escapeHtml(formatShortDate(schedule.fecha_actualizacion || schedule.fecha_creacion))}</td>
                        <td>
                            <a class="schedule-open-link" href="/views/departments/property-management">
                                Open
                            </a>
                        </td>
                    </tr>
                `)
                .join("");
        }

        function renderScheduleDashboardError(error) {
            setText("scheduleMetricLatest", error.message || "Schedules could not be loaded");
            setText("scheduleTableMeta", "Unavailable");

            const tbody = document.getElementById("scheduleRecentBody");
            if (!tbody) return;

            tbody.innerHTML = `
                <tr>
                    <td colspan="7" class="schedule-empty">
                        ${escapeHtml(error.message || "Schedules could not be loaded")}
                    </td>
                </tr>
            `;
        }

        function getPeriodKey(schedule) {
            const year = Number(schedule.periodo_anio || 0);
            const month = Number(schedule.periodo_mes || 0);

            if (!year || !month) return "";
            return `${year}-${String(month).padStart(2, "0")}`;
        }

        function formatPeriodKey(key) {
            const [year, month] = key.split("-");
            return `${MONTH_NAMES[Number(month)] || month} ${year}`;
        }

        function formatSchedulePeriod(schedule) {
            const year = Number(schedule.periodo_anio || 0);
            const month = Number(schedule.periodo_mes || 0);

            if (!year && !month) return "No period";
            if (!month) return String(year);
            return `${MONTH_NAMES[month] || month} ${year || ""}`.trim();
        }

        function formatShortDate(value) {
            if (!value) return "No date";
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return "No date";

            return new Intl.DateTimeFormat("en-US", {
                month: "short",
                day: "2-digit",
                year: "numeric",
            }).format(date);
        }

        function formatCurrency(value) {
            const number = Number(value || 0);

            return new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: "USD",
                maximumFractionDigits: 2,
            }).format(Number.isFinite(number) ? number : 0);
        }

        function formatInteger(value) {
            const number = Number(value || 0);
            return new Intl.NumberFormat("en-US").format(Number.isFinite(number) ? number : 0);
        }

        function setText(id, value) {
            const element = document.getElementById(id);
            if (element) element.textContent = value;
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }
    </script>
</DashboardLayout>
