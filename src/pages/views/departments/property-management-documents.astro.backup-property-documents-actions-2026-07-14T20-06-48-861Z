---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Property Documents" includeSheetJS={true} stylesheets={["/styles/pages/views/departments/property-management-documents.css?v=20260714-style-refactor-v1"]}>
    <div class="page-container property-documents-page">
        <div class="page-header">
            <div class="page-header-info">
                <h1>Property Documents</h1>
                <p>Schedules and source files saved for Property Management.</p>
            </div>

            <div class="page-header-actions property-documents-actions">
                <button
                    type="button"
                    class="btn btn-secondary"
                    id="pmDocsRefreshBtn"
                >
                    <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
                    Refresh
                </button>
            </div>
        </div>

        <div class="filters-bar documents-filters property-documents-filters">
            <div class="filter-group search-filter">
                <label for="pmDocumentSearchInput">Search document</label>
                <div class="search-field">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"
                    ></i>
                    <input
                        type="search"
                        id="pmDocumentSearchInput"
                        placeholder="Schedule, file, type, or period..."
                        autocomplete="off"
                    />
                </div>
            </div>

            <div class="filter-group">
                <label for="pmDocumentKindFilter">Category:</label>
                <select id="pmDocumentKindFilter">
                    <option value="">All</option>
                    <option value="schedule">Schedules</option>
                    <option value="prepaidSchedule">Prepaid schedules</option>
                    <option value="source">Source files</option>
                </select>
            </div>

            <div class="filter-group">
                <label for="pmFileTypeFilter">File type:</label>
                <select id="pmFileTypeFilter">
                    <option value="">All types</option>
                </select>
            </div>

            <div class="filter-group">
                <label for="pmDateFromFilter">From:</label>
                <input type="date" id="pmDateFromFilter" />
            </div>

            <div class="filter-group">
                <label for="pmDateToFilter">To:</label>
                <input type="date" id="pmDateToFilter" />
            </div>

            <button
                type="button"
                class="btn btn-secondary btn-sm clear-filters"
                id="pmClearFiltersBtn"
            >
                <i class="fa-solid fa-times" aria-hidden="true"></i>
                Clear
            </button>
        </div>

        <div
            class="documents-type-tabs property-documents-tabs"
            role="tablist"
            aria-label="Property document categories"
        >
            <button
                type="button"
                class="documents-type-tab active"
                data-pm-document-tab=""
                aria-selected="true"
            >
                <span class="documents-type-icon">
                    <i class="fa-solid fa-layer-group" aria-hidden="true"></i>
                </span>
                <span class="documents-type-copy">
                    <strong>All</strong>
                    <small>Every property document</small>
                </span>
                <span class="documents-type-count" id="pmAllDocumentsCount"
                    >0</span
                >
            </button>
            <button
                type="button"
                class="documents-type-tab"
                data-pm-document-tab="schedule"
                aria-selected="false"
            >
                <span class="documents-type-icon">
                    <i class="fa-solid fa-file-pen" aria-hidden="true"></i>
                </span>
                <span class="documents-type-copy">
                    <strong>Schedules</strong>
                    <small>Standard property schedules</small>
                </span>
                <span class="documents-type-count" id="pmSchedulesCount">0</span>
            </button>
            <button
                type="button"
                class="documents-type-tab"
                data-pm-document-tab="prepaidSchedule"
                aria-selected="false"
            >
                <span class="documents-type-icon">
                    <i class="fa-solid fa-calendar-days" aria-hidden="true"></i>
                </span>
                <span class="documents-type-copy">
                    <strong>Prepaid</strong>
                    <small>Saved prepaid amortization schedules</small>
                </span>
                <span class="documents-type-count" id="pmPrepaidSchedulesCount"
                    >0</span
                >
            </button>
            <button
                type="button"
                class="documents-type-tab"
                data-pm-document-tab="source"
                aria-selected="false"
            >
                <span class="documents-type-icon">
                    <i class="fa-solid fa-file-excel" aria-hidden="true"></i>
                </span>
                <span class="documents-type-copy">
                    <strong>Source files</strong>
                    <small>Uploaded support files</small>
                </span>
                <span class="documents-type-count" id="pmSourceFilesCount"
                    >0</span
                >
            </button>
        </div>

        <div class="table-container">
            <table class="data-table" id="pmDocumentsTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Document</th>
                        <th>Category</th>
                        <th>Period</th>
                        <th>Details</th>
                        <th>Status</th>
                        <th>Updated</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="pmUnifiedDocumentsBody">
                    <tr>
                        <td colspan="8">Loading documents...</td>
                    </tr>
                </tbody>
            </table>

            <div
                id="pmDocsEmptyState"
                class="empty-state"
                style="display: none;"
            >
                <i class="fa-solid fa-folder-open" aria-hidden="true"></i>
                <h4>No Property Management documents</h4>
                <p>No schedules or source files match the selected filters.</p>
            </div>

            <div id="pmDocsLoadingState" class="empty-state">
                <i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i>
                <h4>Loading...</h4>
                <p>Fetching Property Management documents from the server.</p>
            </div>

            <div
                class="pagination"
                id="pmDocsPagination"
                style="display: none;"
            >
                <div class="pagination-info">
                    Showing <span id="pmShowingFrom">1</span> - <span
                        id="pmShowingTo">10</span
                    >
                    of <span id="pmTotalItems">0</span> department documents
                </div>
                <div class="pagination-buttons">
                    <button
                        class="pagination-btn"
                        type="button"
                        id="pmDocsPrevBtn"
                    >
                        <i class="fa-solid fa-chevron-left" aria-hidden="true"
                        ></i>
                    </button>
                    <span class="pagination-btn active" id="pmDocsCurrentPage"
                        >1</span
                    >
                    <button
                        class="pagination-btn"
                        type="button"
                        id="pmDocsNextBtn"
                    >
                        <i class="fa-solid fa-chevron-right" aria-hidden="true"
                        ></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/config.js" is:inline></script>
    <script
        is:inline
        src="/js/departments/property-management-documents.js?v=20260714-property-documents-actions-v1"
    ></script>
    <link rel="stylesheet" href="/styles/pages/views/property-management-documents-fix.css?v=20260714-property-documents-actions-v1" />
</DashboardLayout>
