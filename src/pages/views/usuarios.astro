---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Users">
    <div class="page-container admin-users-page">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>User administration</h1>
                <p>Manage system users</p>
            </div>
            <button class="btn btn-primary" id="btnNuevoUser" onclick="openUserModal()" data-permission-module="usuarios" data-permission-action="crear">
                <i class="fa-solid fa-user-plus"></i>
                New user
            </button>
            <button class="btn btn-primary" id="btnNuevoDepartment" onclick="openDepartmentModal()" data-permission-module="usuarios" data-permission-action="crear" hidden>
                <i class="fa-solid fa-building-circle-check"></i>
                New department
            </button>
        </div>

        <div class="admin-view-tabs" role="tablist" aria-label="Access administration">
            <button class="admin-view-tab active" id="tabUsers" onclick="switchAdminView('usuarios')">
                <i class="fa-solid fa-users"></i>
                Users
            </button>
            <button class="admin-view-tab" id="tabDepartments" onclick="switchAdminView('departamentos')">
                <i class="fa-solid fa-building"></i>
                Departments
            </button>
        </div>

        <section id="usuariosPanel">

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3 id="totalUsers">0</h3>
                    <p>Total users</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">
                    <i class="fa-solid fa-user-check"></i>
                </div>
                <div class="stat-info">
                    <h3 id="usuariosActivos">0</h3>
                    <p>Active</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon red">
                    <i class="fa-solid fa-user-xmark"></i>
                </div>
                <div class="stat-info">
                    <h3 id="usuariosInactivos">0</h3>
                    <p>Inactive</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple">
                    <i class="fa-solid fa-user-shield"></i>
                </div>
                <div class="stat-info">
                    <h3 id="usuariosAdmin">0</h3>
                    <p>Administrators</p>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-bar">
            <div class="filter-group">
                <label>Search:</label>
                <input type="text" id="searchUsers" placeholder="Name, email, or username..." oninput="filterUsers()">
            </div>
            <div class="filter-group">
                <label>Role:</label>
                <select id="filterRole" onchange="filterUsers()">
                    <option value="">All</option>
                    <option value="superadmin">Super administrator</option>
                    <option value="admin">Administrator</option>
                    <option value="supervisor">Supervisor</option>
                    <option value="usuario">User</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Status:</label>
                <select id="filterStatus" onchange="filterUsers()">
                    <option value="">All</option>
                    <option value="activo">Active</option>
                    <option value="inactivo">Inactive</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Department:</label>
                <select id="filterDepartment" onchange="filterUsers()">
                    <option value="">All</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        <div class="table-container">
            <table class="data-table" id="usersTable">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Department</th>
                        <th>Status</th>
                        <th>Registration date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fa-solid fa-spinner fa-spin"></i>
                                <p>Loading users...</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
            <div class="pagination">
                <div class="pagination-info" id="paginationInfo">Showing 0 users</div>
                <div class="pagination-buttons" id="paginationButtons"></div>
            </div>
        </div>
        </section>

        <section id="departamentosPanel" hidden>
            <div class="department-intro">
                <div>
                    <span>ACCESS STRUCTURE</span>
                    <h2>Organization departments</h2>
                    <p>Classify users by area. Windows and the initial screen are assigned only from Permissions.</p>
                </div>
                <div class="department-count">
                    <strong id="totalDepartments">0</strong>
                    <span>departments</span>
                </div>
            </div>

            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Department</th>
                            <th>Code</th>
                            <th>Users</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="departmentsTableBody">
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="fa-solid fa-spinner fa-spin"></i>
                                    <p>Loading departments...</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <!-- Create/edit user modal -->
    <div class="modal-overlay" id="userModal">
        <div class="modal admin-form-modal admin-user-modal">
            <div class="modal-header">
                <span class="admin-modal-kicker">Account</span>
                <h3 id="modalTitle">New user</h3>
                <p class="admin-modal-summary">Identity, credentials, role, and department access.</p>
                <div class="admin-modal-badge">
                    <i class="fa-solid fa-user-shield"></i>
                    <span>User access</span>
                </div>
                <button class="modal-close" onclick="closeUserModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <input type="hidden" id="userId" value="">
                    
                    <div class="form-group">
                        <label class="form-label" for="userName">Full name</label>
                        <input type="text" id="userName" class="form-control" placeholder="E.g. John Doe" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="userEmail">Email</label>
                        <input type="email" id="userEmail" class="form-control" placeholder="E.g. john@company.com" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="userUsername">Username</label>
                        <input type="text" id="userUsername" class="form-control" placeholder="E.g. jdoe" required>
                    </div>
                    
                    <div class="form-group" id="passwordGroup">
                        <label class="form-label" for="userPassword">Password</label>
                        <input type="password" id="userPassword" class="form-control" placeholder="Minimum 6 characters">
                        <small class="form-text" id="passwordHelp">Leave empty to keep the current password</small>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="userRole">Role</label>
                            <select id="userRole" class="form-control" required>
                                <option value="">Select...</option>
                                <option value="superadmin" data-privileged-role>Super administrator</option>
                                <option value="admin" data-privileged-role>Administrator</option>
                                <option value="supervisor">Supervisor</option>
                                <option value="usuario">User</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label" for="userStatus">Status</label>
                            <select id="userStatus" class="form-control" required>
                                <option value="activo">Active</option>
                                <option value="inactivo">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="userDepartment">Department</label>
                        <select id="userDepartment" class="form-control">
                            <option value="">No department</option>
                        </select>
                        <small class="form-text">The department defines visible windows for non-admin users.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeUserModal()">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveUser()">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save
                </button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="departmentModal">
        <div class="modal department-modal admin-form-modal admin-department-modal">
            <div class="modal-header">
                <span class="admin-modal-kicker">Department</span>
                <h3 id="departmentModalTitle">New department</h3>
                <p class="admin-modal-summary">Group users and control visible work areas.</p>
                <div class="admin-modal-badge">
                    <i class="fa-solid fa-building"></i>
                    <span>Workspace group</span>
                </div>
                <button class="modal-close" onclick="closeDepartmentModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="departmentForm">
                    <input type="hidden" id="departmentId" value="">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="departmentName">Name</label>
                            <input id="departmentName" class="form-control" placeholder="E.g. Accounting" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="departmentCode">Code</label>
                            <input id="departmentCode" class="form-control" placeholder="accounting" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="departmentDescription">Description</label>
                        <textarea id="departmentDescription" class="form-control" rows="3" placeholder="Department primary responsibility"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="departmentStatus">Status</label>
                        <select id="departmentStatus" class="form-control">
                            <option value="activo">Active</option>
                            <option value="inactivo">Inactive</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeDepartmentModal()">Cancel</button>
                <button class="btn btn-primary" onclick="saveDepartment()">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save department
                </button>
            </div>
        </div>
    </div>

    <!-- Delete confirmation modal -->
    <div class="modal-overlay" id="deleteModal">
        <div class="modal" style="max-width: 400px;">
            <div class="modal-header">
                <h3>Confirm deletion</h3>
                <button class="modal-close" onclick="closeDeleteModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body" style="text-align: center;">
                <div class="stat-icon red" style="width: 64px; height: 64px; font-size: 28px; margin: 0 auto 16px;">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <p>Are you sure you want to delete this user?</p>
                <p style="font-weight: 600;" id="deleteUserName"></p>
                <p class="form-text">This action cannot be undone.</p>
            </div>
            <div class="modal-footer" style="justify-content: center;">
                <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">
                    <i class="fa-solid fa-trash"></i>
                    Delete
                </button>
            </div>
        </div>
    </div>
    <style>
        .admin-view-tabs {
            display: inline-flex;
            gap: 4px;
            margin: 0 0 20px;
            padding: 4px;
            border: 1px solid #cfdae6;
            border-radius: 8px;
            background: #eaf0f6;
        }

        .admin-view-tab {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 38px;
            padding: 8px 15px;
            border: 0;
            border-radius: 6px;
            background: transparent;
            color: #52687c;
            font-weight: 700;
            cursor: pointer;
        }

        .admin-view-tab.active {
            background: #102f4c;
            color: #fff;
            box-shadow: 0 3px 8px rgba(16, 47, 76, .18);
        }

        .department-intro {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 18px;
            padding: 22px 24px;
            border: 1px solid #cbd8e5;
            border-left: 4px solid #173f67;
            border-radius: 8px;
            background: #fff;
        }

        .department-intro span {
            color: #60758a;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .08em;
        }

        .department-intro h2 { margin: 5px 0; color: #102f4c; font-size: 20px; }
        .department-intro p { margin: 0; color: #61758a; }
        .department-count { min-width: 130px; text-align: center; }
        .department-count strong { display: block; color: #102f4c; font-size: 30px; }

        .department-badge,
        .module-chip {
            display: inline-flex;
            align-items: center;
            margin: 2px 4px 2px 0;
            padding: 4px 8px;
            border: 1px solid #cbd9e7;
            border-radius: 999px;
            background: #f4f7fa;
            color: #284b6b;
            font-size: 11px;
            font-weight: 700;
        }

        .department-modal { max-width: 720px; }

        #userModal.modal-overlay,
        #departmentModal.modal-overlay {
            padding: 24px;
            background: rgba(8, 31, 51, .6);
            backdrop-filter: blur(7px);
        }

        #userModal .admin-form-modal,
        #departmentModal .admin-form-modal {
            position: relative;
            display: grid;
            grid-template-columns: minmax(270px, 315px) minmax(0, 1fr);
            grid-template-rows: minmax(0, 1fr) auto;
            width: min(1040px, calc(100vw - 48px));
            max-width: none;
            max-height: min(86vh, 820px);
            overflow: hidden;
            border: 1px solid #c8d7e4;
            border-radius: 16px;
            background: #eef3f7;
            box-shadow: 0 34px 90px -34px rgba(8, 31, 51, .86);
        }

        #departmentModal .admin-form-modal {
            width: min(1060px, calc(100vw - 48px));
        }

        #userModal .admin-form-modal .modal-header,
        #departmentModal .admin-form-modal .modal-header {
            grid-column: 1;
            grid-row: 1 / 3;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: flex-start;
            gap: 12px;
            padding: 28px 22px;
            border: 0;
            color: #ffffff !important;
        }

        .admin-modal-kicker {
            color: #b9dcf8;
            font-size: 10px;
            font-weight: 900;
            letter-spacing: .14em;
            text-transform: uppercase;
        }

        #userModal .admin-form-modal .modal-header h3,
        #departmentModal .admin-form-modal .modal-header h3 {
            margin: 0;
            color: #000000 !important;
            font-size: 28px;
            font-weight: 900;
            line-height: 1.08;
        }

        .admin-modal-summary {
            margin: 0;
            color: #dcecf7;
            font-size: 13px;
            line-height: 1.5;
            font-weight: 650;
        }

        .admin-modal-badge {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            margin-top: auto;
            width: 100%;
            min-height: 48px;
            padding: 0 12px;
            border: 1px solid rgba(255, 255, 255, .28);
            border-radius: 12px;
            background: rgba(255, 255, 255, .16);
            color: #ffffff;
            font-size: 13px;
            font-weight: 850;
        }

        .admin-modal-badge i {
            display: grid;
            width: 30px;
            height: 30px;
            place-items: center;
            border-radius: 8px;
            background: rgba(143, 199, 240, .24);
            color: #d2ecff;
        }

        #userModal .admin-form-modal .modal-close,
        #departmentModal .admin-form-modal .modal-close {
            position: absolute;
            top: 18px;
            right: 18px;
            z-index: 2;
            width: 38px;
            height: 38px;
            border: 1px solid #cbd9e6;
            border-radius: 10px;
            background: #fff;
            color: #173a59;
            box-shadow: 0 12px 26px -24px rgba(8, 31, 51, .75);
        }

        #userModal .admin-form-modal .modal-close:hover,
        #departmentModal .admin-form-modal .modal-close:hover,
        #userModal .admin-form-modal .modal-close:focus-visible,
        #departmentModal .admin-form-modal .modal-close:focus-visible {
            border-color: #9fb4c7;
            background: #eef4f9;
            color: #09243b;
        }

        #userModal .admin-form-modal .modal-body,
        #departmentModal .admin-form-modal .modal-body {
            grid-column: 2;
            grid-row: 1;
            min-height: 0;
            overflow: auto;
            padding: 58px 30px 24px;
            background: #fff;
        }

        #userForm,
        #departmentForm {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }

        #departmentForm {
            grid-template-columns: 1fr;
        }

        #userForm > .form-row,
        #departmentForm > .form-row {
            display: grid;
            grid-column: 1 / -1;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }

        #userForm > .form-group:last-child,
        #departmentForm > .form-group {
            grid-column: 1 / -1;
        }

        #userModal .admin-form-modal .form-group,
        #departmentModal .admin-form-modal .form-group {
            min-width: 0;
            margin: 0;
        }

        #userModal .admin-form-modal .form-label,
        #departmentModal .admin-form-modal .form-label {
            margin-bottom: 7px;
            color: #344f67;
            font-size: 10px;
            font-weight: 900;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        #userModal .admin-form-modal .form-control,
        #departmentModal .admin-form-modal .form-control {
            min-height: 42px;
            border: 1px solid #cbd9e6;
            border-radius: 9px;
            background: #fff;
            color: #0d2f4c;
            font-size: 14px;
            box-shadow: inset 0 1px 0 rgba(8, 31, 51, .03);
        }

        #departmentDescription.form-control {
            min-height: 104px;
            resize: vertical;
        }

        #userModal .admin-form-modal .form-control:focus,
        #departmentModal .admin-form-modal .form-control:focus {
            border-color: #2f6f9f;
            outline: 3px solid rgba(47, 111, 159, .14);
            outline-offset: 0;
        }

        #userModal .admin-form-modal .form-control::placeholder,
        #departmentModal .admin-form-modal .form-control::placeholder {
            color: #687f94;
            opacity: 1;
        }

        #userModal .admin-form-modal .form-text,
        #departmentModal .admin-form-modal .form-text {
            display: block;
            margin-top: 7px;
            color: #415a70;
            font-size: 12px;
            font-weight: 650;
            line-height: 1.35;
        }

        #userModal .admin-form-modal .modal-footer,
        #departmentModal .admin-form-modal .modal-footer {
            grid-column: 2;
            grid-row: 2;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding: 16px 28px;
            border: 0;
            border-top: 1px solid #d7e2ec;
            background: #f8fbfd;
        }

        #userModal .admin-form-modal .modal-footer .btn,
        #departmentModal .admin-form-modal .modal-footer .btn {
            min-height: 38px;
            min-width: 120px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 850;
        }

        :global(.action-btn.department-state.is-disable) { color: #a46612; }
        :global(.action-btn.department-state.is-disable:hover) { background: #fff1d6; color: #7c4a08; }
        :global(.action-btn.department-state.is-enable) { color: #16834b; }
        :global(.action-btn.department-state.is-enable:hover) { background: #e2f5e9; color: #0f683a; }

        :global(.department-actions) {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            flex-wrap: nowrap;
            white-space: nowrap;
            vertical-align: middle;
        }

        :global(.department-actions .action-btn) {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            flex: 0 0 auto;
        }

        @media (max-width: 720px) {
            .department-intro { align-items: flex-start; flex-direction: column; }
            .admin-view-tabs { display: flex; }
            .admin-view-tab { flex: 1; justify-content: center; }

            #userModal.modal-overlay,
            #departmentModal.modal-overlay {
                padding: 10px;
            }

            #userModal .admin-form-modal,
            #departmentModal .admin-form-modal {
                grid-template-columns: 1fr;
                grid-template-rows: auto minmax(0, 1fr) auto;
                width: calc(100vw - 20px);
                max-height: calc(100vh - 20px);
            }

            #userModal .admin-form-modal .modal-header,
            #departmentModal .admin-form-modal .modal-header {
                grid-column: 1;
                grid-row: 1;
                padding: 22px 58px 20px 18px;
            }

            .admin-modal-badge {
                margin-top: 4px;
            }

            #userModal .admin-form-modal .modal-body,
            #departmentModal .admin-form-modal .modal-body {
                grid-column: 1;
                grid-row: 2;
                padding: 20px 18px;
            }

            #userForm,
            #departmentForm,
            #userForm > .form-row,
            #departmentForm > .form-row {
                grid-template-columns: 1fr;
            }

            #userModal .admin-form-modal .modal-footer,
            #departmentModal .admin-form-modal .modal-footer {
                grid-column: 1;
                grid-row: 3;
                flex-direction: column-reverse;
                padding: 14px 18px;
            }

            #userModal .admin-form-modal .modal-footer .btn,
            #departmentModal .admin-form-modal .modal-footer .btn {
                width: 100%;
            }
        }
    </style>
    <style is:inline>
        #userModal.modal-overlay,
        #departmentModal.modal-overlay {
            padding: 34px !important;
            background: rgba(12, 31, 50, .48) !important;
            backdrop-filter: blur(8px) !important;
        }

        #userModal .admin-form-modal,
        #departmentModal .admin-form-modal {
            display: flex !important;
            flex-direction: column !important;
            grid-template-columns: none !important;
            grid-template-rows: none !important;
            width: min(920px, calc(100vw - 68px)) !important;
            max-width: min(920px, calc(100vw - 68px)) !important;
            max-height: calc(100vh - 68px) !important;
            overflow: hidden !important;
            border: 0 !important;
            border-radius: 24px !important;
            background: #ffffff !important;
            box-shadow: 0 34px 90px -50px rgba(8, 28, 46, .88) !important;
            animation: appModalLift .22s cubic-bezier(.2, .8, .2, 1) both;
        }

        #departmentModal .admin-form-modal {
            width: min(980px, calc(100vw - 68px)) !important;
            max-width: min(980px, calc(100vw - 68px)) !important;
        }

        #userModal .admin-form-modal .modal-header,
        #departmentModal .admin-form-modal .modal-header {
            position: relative !important;
            grid-column: auto !important;
            grid-row: auto !important;
            display: block !important;
            padding: 34px 92px 18px 34px !important;
