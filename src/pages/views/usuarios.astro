---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Users">
    <div class="access-admin-page access-users-page">
        <section class="access-command-hero">
            <div class="access-hero-copy">
                <span class="access-eyebrow">
                    <i class="fa-solid fa-shield-halved"></i>
                    Identity & access management
                </span>
                <h1>Users and departments</h1>
                <p>
                    Manage identities, operational roles, department assignments,
                    account status, and access governance from one administrative workspace.
                </p>

                <div class="access-hero-tags" aria-label="Access management capabilities">
                    <span><i class="fa-solid fa-user-lock"></i> Role-based access</span>
                    <span><i class="fa-solid fa-building"></i> Department structure</span>
                    <span><i class="fa-solid fa-key"></i> Granular permissions</span>
                </div>
            </div>

            <div class="access-hero-actions">
                <div class="access-governance-status">
                    <span class="access-status-dot"></span>
                    <div>
                        <strong>Access governance</strong>
                        <small id="accessUpdatedAt">Loading directory…</small>
                    </div>
                </div>

                <div class="access-primary-actions">
                    <button
                        class="access-button access-button-secondary"
                        type="button"
                        onclick="window.location.href='/views/dashboard-admin'"
                    >
                        <i class="fa-solid fa-chart-line"></i>
                        Admin dashboard
                    </button>

                    <button
                        class="access-button access-button-primary"
                        id="btnNuevoUser"
                        type="button"
                        onclick="openUserModal()"
                        data-permission-module="usuarios"
                        data-permission-action="crear"
                    >
                        <i class="fa-solid fa-user-plus"></i>
                        New user
                    </button>

                    <button
                        class="access-button access-button-primary"
                        id="btnNuevoDepartment"
                        type="button"
                        onclick="openDepartmentModal()"
                        data-permission-module="usuarios"
                        data-permission-action="crear"
                        hidden
                    >
                        <i class="fa-solid fa-building-circle-check"></i>
                        New department
                    </button>
                </div>
            </div>
        </section>

        <section class="access-view-switcher" aria-label="Access administration sections">
            <div>
                <span class="access-section-kicker">Directory</span>
                <strong>Administration workspace</strong>
            </div>

            <div class="access-segmented-tabs" role="tablist" aria-label="Access administration">
                <button
                    class="access-segmented-tab active"
                    id="tabUsers"
                    type="button"
                    role="tab"
                    aria-selected="true"
                    onclick="switchAdminView('usuarios')"
                >
                    <i class="fa-solid fa-users"></i>
                    Users
                </button>
                <button
                    class="access-segmented-tab"
                    id="tabDepartments"
                    type="button"
                    role="tab"
                    aria-selected="false"
                    onclick="switchAdminView('departamentos')"
                >
                    <i class="fa-solid fa-building"></i>
                    Departments
                </button>
            </div>
        </section>

        <section id="usuariosPanel" class="access-view-panel">
            <div class="access-metric-grid">
                <article class="access-metric-card access-metric-neutral">
                    <div class="access-metric-icon">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <div>
                        <span>Total directory</span>
                        <strong id="totalUsers">0</strong>
                        <small>Registered user accounts</small>
                    </div>
                </article>

                <article class="access-metric-card access-metric-success">
                    <div class="access-metric-icon">
                        <i class="fa-solid fa-user-check"></i>
                    </div>
                    <div>
                        <span>Active accounts</span>
                        <strong id="usuariosActivos">0</strong>
                        <small id="activeUsersCaption">0% of directory</small>
                    </div>
                </article>

                <article class="access-metric-card access-metric-danger">
                    <div class="access-metric-icon">
                        <i class="fa-solid fa-user-xmark"></i>
                    </div>
                    <div>
                        <span>Inactive accounts</span>
                        <strong id="usuariosInactivos">0</strong>
                        <small>Restricted from signing in</small>
                    </div>
                </article>

                <article class="access-metric-card access-metric-privileged">
                    <div class="access-metric-icon">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <div>
                        <span>Privileged users</span>
                        <strong id="usuariosAdmin">0</strong>
                        <small id="adminUsersCaption">Admin access exposure</small>
                    </div>
                </article>
            </div>

            <div class="access-layout-grid">
                <div class="access-directory-panel">
                    <div class="access-panel-heading">
                        <div>
                            <span class="access-section-kicker">User directory</span>
                            <h2>Identity records</h2>
                            <p>
                                Search, filter, edit, and review permission assignments.
                            </p>
                        </div>
                        <div class="access-result-counter">
                            <strong id="userResultCount">0</strong>
                            <span>results</span>
                        </div>
                    </div>

                    <div class="access-filter-toolbar">
                        <label class="access-search-field">
                            <span>Search directory</span>
                            <div>
                                <i class="fa-solid fa-magnifying-glass"></i>
                                <input
                                    type="search"
                                    id="searchUsers"
                                    placeholder="Name, email, username, or department"
                                    oninput="filterUsers()"
                                    autocomplete="off"
                                />
                            </div>
                        </label>

                        <label class="access-filter-field">
                            <span>Role</span>
                            <select id="filterRole" onchange="filterUsers()">
                                <option value="">All roles</option>
                                <option value="superadmin">Super administrator</option>
                                <option value="admin">Administrator</option>
                                <option value="supervisor">Supervisor</option>
                                <option value="usuario">User</option>
                            </select>
                        </label>

                        <label class="access-filter-field">
                            <span>Status</span>
                            <select id="filterStatus" onchange="filterUsers()">
                                <option value="">All statuses</option>
                                <option value="activo">Active</option>
                                <option value="inactivo">Inactive</option>
                            </select>
                        </label>

                        <label class="access-filter-field">
                            <span>Department</span>
                            <select id="filterDepartment" onchange="filterUsers()">
                                <option value="">All departments</option>
                            </select>
                        </label>

                        <button
                            class="access-filter-reset"
                            type="button"
                            onclick="resetUserFilters()"
                            title="Clear all directory filters"
                        >
                            <i class="fa-solid fa-filter-circle-xmark"></i>
                            Clear
                        </button>
                    </div>

                    <div class="access-filter-summary" id="userFilterState">
                        Showing the complete user directory.
                    </div>

                    <div class="access-table-shell">
                        <div class="access-table-scroll">
                            <table class="access-data-table" id="usersTable">
                                <thead>
                                    <tr>
                                        <th>Identity</th>
                                        <th>Contact</th>
                                        <th>Role</th>
                                        <th>Department</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th class="access-actions-column">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="usersTableBody">
                                    <tr>
                                        <td colspan="7">
                                            <div class="access-empty-state">
                                                <i class="fa-solid fa-spinner fa-spin"></i>
                                                <strong>Loading directory</strong>
                                                <span>Retrieving user accounts and assignments…</span>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="access-table-footer">
                            <div class="pagination-info" id="paginationInfo">
                                Directory results update automatically.
                            </div>
                            <div class="pagination-buttons" id="paginationButtons"></div>
                        </div>
                    </div>
                </div>

                <aside class="access-governance-panel">
                    <div class="access-panel-heading access-panel-heading-compact">
                        <div>
                            <span class="access-section-kicker">Governance</span>
                            <h2>Directory health</h2>
                        </div>
                        <i class="fa-solid fa-shield-check"></i>
                    </div>

                    <div class="access-governance-list">
                        <article>
                            <div class="access-governance-icon">
                                <i class="fa-solid fa-building-user"></i>
                            </div>
                            <div>
                                <span>Department coverage</span>
                                <strong id="departmentCoverageValue">0%</strong>
                                <small>Users assigned to an organizational area</small>
                            </div>
                        </article>

                        <article>
                            <div class="access-governance-icon">
                                <i class="fa-solid fa-user-clock"></i>
                            </div>
                            <div>
                                <span>Unassigned accounts</span>
                                <strong id="unassignedUsers">0</strong>
                                <small>Accounts without a department</small>
                            </div>
                        </article>

                        <article>
                            <div class="access-governance-icon">
                                <i class="fa-solid fa-building-circle-check"></i>
                            </div>
                            <div>
                                <span>Active departments</span>
                                <strong id="activeDepartmentsCount">0</strong>
                                <small>Available operational groups</small>
                            </div>
                        </article>
                    </div>

                    <div class="access-governance-note">
                        <i class="fa-solid fa-circle-info"></i>
                        <p>
                            Department membership defines operational context. Final
                            module access and the initial page are configured in Permissions.
                        </p>
                    </div>
                </aside>
            </div>
        </section>

        <section id="departamentosPanel" class="access-view-panel" hidden>
            <div class="access-department-hero">
                <div class="access-department-icon">
                    <i class="fa-solid fa-sitemap"></i>
                </div>
                <div>
                    <span class="access-section-kicker">Organization structure</span>
                    <h2>Departments</h2>
                    <p>
                        Maintain the organizational groups used to classify users and
                        establish their operational context.
                    </p>
                </div>
                <div class="access-department-total">
                    <strong id="totalDepartments">0</strong>
                    <span>Total departments</span>
                </div>
            </div>

            <div class="access-department-summary-grid">
                <article>
                    <span>Active departments</span>
                    <strong id="departmentPanelActiveCount">0</strong>
                    <small>Available for user assignment</small>
                </article>
                <article>
                    <span>Assigned users</span>
                    <strong id="departmentAssignedUsersCount">0</strong>
                    <small>Users represented in department totals</small>
                </article>
                <article>
                    <span>Structure policy</span>
                    <strong>Centralized</strong>
                    <small>Permissions remain user-specific</small>
                </article>
            </div>

            <div class="access-directory-panel">
                <div class="access-panel-heading">
                    <div>
                        <span class="access-section-kicker">Department directory</span>
                        <h2>Organizational groups</h2>
                        <p>Create, rename, disable, or remove user classification groups.</p>
                    </div>
                </div>

                <div class="access-table-shell">
                    <div class="access-table-scroll">
                        <table class="access-data-table">
                            <thead>
                                <tr>
                                    <th>Department</th>
                                    <th>Code</th>
                                    <th>Users</th>
                                    <th>Status</th>
                                    <th class="access-actions-column">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="departmentsTableBody">
                                <tr>
                                    <td colspan="5">
                                        <div class="access-empty-state">
                                            <i class="fa-solid fa-spinner fa-spin"></i>
                                            <strong>Loading departments</strong>
                                            <span>Retrieving organizational structure…</span>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <div class="modal-overlay access-modal-overlay" id="userModal">
        <div class="modal access-form-modal access-user-modal">
            <div class="modal-header access-modal-header">
                <span class="access-modal-kicker">Account configuration</span>
                <h3 id="modalTitle">New user</h3>
                <p class="access-modal-summary">
                    Define identity, credentials, role, status, and department assignment.
                </p>
                <div class="access-modal-badge">
                    <i class="fa-solid fa-user-shield"></i>
                    Identity record
                </div>
                <button class="modal-close" type="button" onclick="closeUserModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="modal-body access-modal-body">
                <form id="userForm" class="access-form-grid">
                    <input type="hidden" id="userId" value="" />

                    <div class="form-group">
                        <label class="form-label" for="userName">Full name</label>
                        <input
                            type="text"
                            id="userName"
                            class="form-control"
                            placeholder="E.g. John Doe"
                            autocomplete="name"
                            required
                        />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="userEmail">Email</label>
                        <input
                            type="email"
                            id="userEmail"
                            class="form-control"
                            placeholder="E.g. john@company.com"
                            autocomplete="email"
                            required
                        />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="userUsername">Username</label>
                        <input
                            type="text"
                            id="userUsername"
                            class="form-control"
                            placeholder="E.g. jdoe"
                            autocomplete="username"
                            required
                        />
                    </div>

                    <div class="form-group" id="passwordGroup">
                        <label class="form-label" for="userPassword">Password</label>
                        <input
                            type="password"
                            id="userPassword"
                            class="form-control"
                            placeholder="Minimum 6 characters"
                            autocomplete="new-password"
                        />
                        <small class="form-text" id="passwordHelp">
                            Leave empty to keep the current password.
                        </small>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="userRole">Role</label>
                        <select id="userRole" class="form-control" required>
                            <option value="">Select a role</option>
                            <option value="superadmin" data-privileged-role>Super administrator</option>
                            <option value="admin" data-privileged-role>Administrator</option>
                            <option value="supervisor">Supervisor</option>
                            <option value="usuario">User</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="userStatus">Status</label>
                        <select id="userStatus" class="form-control" required>
                            <option value="activo">Active</option>
                            <option value="inactivo">Inactive</option>
                        </select>
                    </div>

                    <div class="form-group access-form-full">
                        <label class="form-label" for="userDepartment">Department</label>
                        <select id="userDepartment" class="form-control">
                            <option value="">No department</option>
                        </select>
                        <small class="form-text">
                            Department defines the operational context. Module access is
                            configured separately in Permissions.
                        </small>
                    </div>
                </form>
            </div>

            <div class="modal-footer access-modal-footer">
                <button
                    type="button"
                    class="btn btn-secondary"
                    onclick="closeUserModal()"
                >
                    Cancel
                </button>
                <button
                    type="button"
                    class="btn btn-primary"
                    onclick="saveUser()"
                >
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save user
                </button>
            </div>
        </div>
    </div>

    <div class="modal-overlay access-modal-overlay" id="departmentModal">
        <div class="modal access-form-modal access-department-modal">
            <div class="modal-header access-modal-header">
                <span class="access-modal-kicker">Organization structure</span>
                <h3 id="departmentModalTitle">New department</h3>
                <p class="access-modal-summary">
                    Create a classification group for operational teams.
                </p>
                <div class="access-modal-badge">
                    <i class="fa-solid fa-building"></i>
                    Department record
                </div>
                <button
                    class="modal-close"
                    type="button"
                    onclick="closeDepartmentModal()"
                >
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="modal-body access-modal-body">
                <form id="departmentForm" class="access-form-grid">
                    <input type="hidden" id="departmentId" value="" />

                    <div class="form-group">
                        <label class="form-label" for="departmentName">Name</label>
                        <input
                            id="departmentName"
                            class="form-control"
                            placeholder="E.g. Accounting"
                            required
                        />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="departmentCode">Code</label>
                        <input
                            id="departmentCode"
                            class="form-control"
                            placeholder="accounting"
                            required
                        />
                    </div>

                    <div class="form-group access-form-full">
                        <label class="form-label" for="departmentDescription">
                            Description
                        </label>
                        <textarea
                            id="departmentDescription"
                            class="form-control"
                            rows="4"
                            placeholder="Department responsibilities and scope"
                        ></textarea>
                    </div>

                    <div class="form-group access-form-full">
                        <label class="form-label" for="departmentStatus">Status</label>
                        <select id="departmentStatus" class="form-control">
                            <option value="activo">Active</option>
                            <option value="inactivo">Inactive</option>
                        </select>
                    </div>
                </form>
            </div>

            <div class="modal-footer access-modal-footer">
                <button
                    type="button"
                    class="btn btn-secondary"
                    onclick="closeDepartmentModal()"
                >
                    Cancel
                </button>
                <button
                    type="button"
                    class="btn btn-primary"
                    onclick="saveDepartment()"
                >
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save department
                </button>
            </div>
        </div>
    </div>

    <div class="modal-overlay access-modal-overlay" id="deleteModal">
        <div class="modal access-delete-modal">
            <div class="modal-header access-delete-header">
                <div class="access-delete-icon">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div>
                    <span class="access-modal-kicker">Destructive action</span>
                    <h3>Delete user</h3>
                    <p>This account will be removed permanently.</p>
                </div>
                <button
                    class="modal-close"
                    type="button"
                    onclick="closeDeleteModal()"
                >
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="modal-body access-delete-body">
                <p>Confirm deletion of:</p>
                <strong id="deleteUserName"></strong>
                <small>This action cannot be undone.</small>
            </div>

            <div class="modal-footer access-modal-footer">
                <button
                    type="button"
                    class="btn btn-secondary"
                    onclick="closeDeleteModal()"
                >
                    Cancel
                </button>
                <button
                    type="button"
                    class="btn btn-danger"
                    onclick="confirmDelete()"
                >
                    <i class="fa-solid fa-trash"></i>
                    Delete permanently
                </button>
            </div>
        </div>
    </div>

    <script is:inline src="/js/usuarios.js?v=20260716-access-admin-v1"></script>
</DashboardLayout>
