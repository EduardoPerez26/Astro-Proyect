---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Usuarios">
    <div class="page-container">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Administracion de Usuarios</h1>
                <p>Gestiona los usuarios del sistema</p>
            </div>
            <button class="btn btn-primary" id="btnNuevoUsuario" onclick="openUserModal()">
                <i class="fa-solid fa-user-plus"></i>
                Nuevo Usuario
            </button>
            <button class="btn btn-primary" id="btnNuevoDepartamento" onclick="openDepartmentModal()" hidden>
                <i class="fa-solid fa-building-circle-check"></i>
                Nuevo departamento
            </button>
        </div>

        <div class="admin-view-tabs" role="tablist" aria-label="Administracion de acceso">
            <button class="admin-view-tab active" id="tabUsuarios" onclick="switchAdminView('usuarios')">
                <i class="fa-solid fa-users"></i>
                Usuarios
            </button>
            <button class="admin-view-tab" id="tabDepartamentos" onclick="switchAdminView('departamentos')">
                <i class="fa-solid fa-building"></i>
                Departamentos
            </button>
        </div>

        <section id="usuariosPanel">

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3 id="totalUsuarios">0</h3>
                    <p>Total Usuarios</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">
                    <i class="fa-solid fa-user-check"></i>
                </div>
                <div class="stat-info">
                    <h3 id="usuariosActivos">0</h3>
                    <p>Activos</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon red">
                    <i class="fa-solid fa-user-xmark"></i>
                </div>
                <div class="stat-info">
                    <h3 id="usuariosInactivos">0</h3>
                    <p>Inactivos</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple">
                    <i class="fa-solid fa-user-shield"></i>
                </div>
                <div class="stat-info">
                    <h3 id="usuariosAdmin">0</h3>
                    <p>Administradores</p>
                </div>
            </div>
        </div>

        <!-- Filtros -->
        <div class="filters-bar">
            <div class="filter-group">
                <label>Buscar:</label>
                <input type="text" id="searchUsers" placeholder="Nombre, email o usuario..." oninput="filterUsers()">
            </div>
            <div class="filter-group">
                <label>Rol:</label>
                <select id="filterRole" onchange="filterUsers()">
                    <option value="">Todos</option>
                    <option value="admin">Administrador</option>
                    <option value="supervisor">Supervisor</option>
                    <option value="usuario">Usuario</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Estado:</label>
                <select id="filterStatus" onchange="filterUsers()">
                    <option value="">Todos</option>
                    <option value="activo">Activo</option>
                    <option value="inactivo">Inactivo</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Departamento:</label>
                <select id="filterDepartment" onchange="filterUsers()">
                    <option value="">Todos</option>
                </select>
            </div>
        </div>

        <!-- Tabla -->
        <div class="table-container">
            <table class="data-table" id="usersTable">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Departamento</th>
                        <th>Estado</th>
                        <th>Fecha registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fa-solid fa-spinner fa-spin"></i>
                                <p>Cargando usuarios...</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
            <div class="pagination">
                <div class="pagination-info" id="paginationInfo">Mostrando 0 usuarios</div>
                <div class="pagination-buttons" id="paginationButtons"></div>
            </div>
        </div>
        </section>

        <section id="departamentosPanel" hidden>
            <div class="department-intro">
                <div>
                    <span>ESTRUCTURA DE ACCESO</span>
                    <h2>Departamentos de la organizacion</h2>
                    <p>Clasifica a los usuarios por area. Las ventanas y la pantalla inicial se asignan unicamente desde Permisos.</p>
                </div>
                <div class="department-count">
                    <strong id="totalDepartamentos">0</strong>
                    <span>departamentos</span>
                </div>
            </div>

            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Departamento</th>
                            <th>Codigo</th>
                            <th>Usuarios</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="departmentsTableBody">
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="fa-solid fa-spinner fa-spin"></i>
                                    <p>Cargando departamentos...</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <!-- Modal Crear/Editar Usuario -->
    <div class="modal-overlay" id="userModal">
        <div class="modal">
            <div class="modal-header">
                <h3 id="modalTitle">Nuevo Usuario</h3>
                <button class="modal-close" onclick="closeUserModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <input type="hidden" id="userId" value="">
                    
                    <div class="form-group">
                        <label class="form-label" for="userName">Nombre completo</label>
                        <input type="text" id="userName" class="form-control" placeholder="Ej: Juan Perez" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="userEmail">Email</label>
                        <input type="email" id="userEmail" class="form-control" placeholder="Ej: juan@empresa.com" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="userUsername">Usuario</label>
                        <input type="text" id="userUsername" class="form-control" placeholder="Ej: jperez" required>
                    </div>
                    
                    <div class="form-group" id="passwordGroup">
                        <label class="form-label" for="userPassword">Contrasena</label>
                        <input type="password" id="userPassword" class="form-control" placeholder="Minimo 6 caracteres">
                        <small class="form-text" id="passwordHelp">Deja vacio para mantener la contrasena actual</small>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="userRole">Rol</label>
                            <select id="userRole" class="form-control" required>
                                <option value="">Seleccionar...</option>
                                <option value="admin">Administrador</option>
                                <option value="supervisor">Supervisor</option>
                                <option value="usuario">Usuario</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label" for="userStatus">Estado</label>
                            <select id="userStatus" class="form-control" required>
                                <option value="activo">Activo</option>
                                <option value="inactivo">Inactivo</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="userDepartment">Departamento</label>
                        <select id="userDepartment" class="form-control">
                            <option value="">Sin departamento</option>
                        </select>
                        <small class="form-text">El departamento define las ventanas visibles para usuarios no administradores.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeUserModal()">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="saveUser()">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Guardar
                </button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="departmentModal">
        <div class="modal department-modal">
            <div class="modal-header">
                <h3 id="departmentModalTitle">Nuevo departamento</h3>
                <button class="modal-close" onclick="closeDepartmentModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="departmentForm">
                    <input type="hidden" id="departmentId" value="">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="departmentName">Nombre</label>
                            <input id="departmentName" class="form-control" placeholder="Ej: Contabilidad" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="departmentCode">Codigo</label>
                            <input id="departmentCode" class="form-control" placeholder="contabilidad" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="departmentDescription">Descripcion</label>
                        <textarea id="departmentDescription" class="form-control" rows="3" placeholder="Responsabilidad principal del departamento"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="departmentStatus">Estado</label>
                        <select id="departmentStatus" class="form-control">
                            <option value="activo">Activo</option>
                            <option value="inactivo">Inactivo</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeDepartmentModal()">Cancelar</button>
                <button class="btn btn-primary" onclick="saveDepartment()">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Guardar departamento
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Confirmar Eliminacion -->
    <div class="modal-overlay" id="deleteModal">
        <div class="modal" style="max-width: 400px;">
            <div class="modal-header">
                <h3>Confirmar eliminacion</h3>
                <button class="modal-close" onclick="closeDeleteModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body" style="text-align: center;">
                <div class="stat-icon red" style="width: 64px; height: 64px; font-size: 28px; margin: 0 auto 16px;">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <p>Estas seguro de eliminar al usuario:</p>
                <p style="font-weight: 600;" id="deleteUserName"></p>
                <p class="form-text">Esta accion no se puede deshacer.</p>
            </div>
            <div class="modal-footer" style="justify-content: center;">
                <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">Cancelar</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">
                    <i class="fa-solid fa-trash"></i>
                    Eliminar
                </button>
            </div>
        </div>
    </div>
    <style>
        .admin-view-tabs {
            display: inline-flex;
            gap: 4px;
            margin: 0 0 20px;
            padding: 4px;
            border: 1px solid #cfdae6;
            border-radius: 8px;
            background: #eaf0f6;
        }

        .admin-view-tab {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 38px;
            padding: 8px 15px;
            border: 0;
            border-radius: 6px;
            background: transparent;
            color: #52687c;
            font-weight: 700;
            cursor: pointer;
        }

        .admin-view-tab.active {
            background: #102f4c;
            color: #fff;
            box-shadow: 0 3px 8px rgba(16, 47, 76, .18);
        }

        .department-intro {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 18px;
            padding: 22px 24px;
            border: 1px solid #cbd8e5;
            border-left: 4px solid #173f67;
            border-radius: 8px;
            background: #fff;
        }

        .department-intro span {
            color: #60758a;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .08em;
        }

        .department-intro h2 { margin: 5px 0; color: #102f4c; font-size: 20px; }
        .department-intro p { margin: 0; color: #61758a; }
        .department-count { min-width: 130px; text-align: center; }
        .department-count strong { display: block; color: #102f4c; font-size: 30px; }

        .department-badge,
        .module-chip {
            display: inline-flex;
            align-items: center;
            margin: 2px 4px 2px 0;
            padding: 4px 8px;
            border: 1px solid #cbd9e7;
            border-radius: 999px;
            background: #f4f7fa;
            color: #284b6b;
            font-size: 11px;
            font-weight: 700;
        }

        .department-modal { max-width: 720px; }

        :global(.action-btn.department-state.is-disable) { color: #a46612; }
        :global(.action-btn.department-state.is-disable:hover) { background: #fff1d6; color: #7c4a08; }
        :global(.action-btn.department-state.is-enable) { color: #16834b; }
        :global(.action-btn.department-state.is-enable:hover) { background: #e2f5e9; color: #0f683a; }

        :global(.department-actions) {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            flex-wrap: nowrap;
            white-space: nowrap;
            vertical-align: middle;
        }

        :global(.department-actions .action-btn) {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            flex: 0 0 auto;
        }

        @media (max-width: 720px) {
            .department-intro { align-items: flex-start; flex-direction: column; }
            .admin-view-tabs { display: flex; }
            .admin-view-tab { flex: 1; justify-content: center; }
        }
    </style>

<script src="/js/config.js" is:inline></script>
    <script is:inline src="/js/usuarios.js"></script>
</DashboardLayout>
