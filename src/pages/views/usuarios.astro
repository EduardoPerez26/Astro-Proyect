---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Users" stylesheets={["/styles/pages/views/usuarios.css?v=20260714-style-refactor-v1"]}>
    <div class="page-container admin-users-page">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>User administration</h1>
                <p>Manage system users</p>
            </div>
            <div class="page-header-actions">
                <button class="btn btn-primary" id="btnNuevoUser" onclick="openUserModal()" data-permission-module="usuarios" data-permission-action="crear">
                    <i class="fa-solid fa-user-plus"></i>
                    New user
                </button>
                <button class="btn btn-primary" id="btnNuevoDepartment" onclick="openDepartmentModal()" data-permission-module="usuarios" data-permission-action="crear" hidden>
                    <i class="fa-solid fa-building-circle-check"></i>
                    New department
                </button>
            </div>
        </div>

        <div class="admin-view-tabs" role="tablist" aria-label="Access administration">
            <button class="admin-view-tab active" id="tabUsers" onclick="switchAdminView('usuarios')">
                <i class="fa-solid fa-users"></i>
                Users
            </button>
            <button class="admin-view-tab" id="tabDepartments" onclick="switchAdminView('departamentos')">
                <i class="fa-solid fa-building"></i>
                Departments
            </button>
        </div>

        <section id="usuariosPanel">

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3 id="totalUsers">0</h3>
                    <p>Total users</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">
                    <i class="fa-solid fa-user-check"></i>
                </div>
                <div class="stat-info">
                    <h3 id="usuariosActivos">0</h3>
                    <p>Active</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon red">
                    <i class="fa-solid fa-user-xmark"></i>
                </div>
                <div class="stat-info">
                    <h3 id="usuariosInactivos">0</h3>
                    <p>Inactive</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple">
                    <i class="fa-solid fa-user-shield"></i>
                </div>
                <div class="stat-info">
                    <h3 id="usuariosAdmin">0</h3>
                    <p>Administrators</p>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-bar">
            <div class="filter-group">
                <label>Search:</label>
                <input type="text" id="searchUsers" placeholder="Name, email, or username..." oninput="filterUsers()">
            </div>
            <div class="filter-group">
                <label>Role:</label>
                <select id="filterRole" onchange="filterUsers()">
                    <option value="">All</option>
                    <option value="superadmin">Super administrator</option>
                    <option value="admin">Administrator</option>
                    <option value="supervisor">Supervisor</option>
                    <option value="usuario">User</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Status:</label>
                <select id="filterStatus" onchange="filterUsers()">
                    <option value="">All</option>
                    <option value="activo">Active</option>
                    <option value="inactivo">Inactive</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Department:</label>
                <select id="filterDepartment" onchange="filterUsers()">
                    <option value="">All</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        <div class="table-container">
            <table class="data-table" id="usersTable">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Department</th>
                        <th>Status</th>
                        <th>Registration date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="fa-solid fa-spinner fa-spin"></i>
                                <p>Loading users...</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
            <div class="pagination">
                <div class="pagination-info" id="paginationInfo">Showing 0 users</div>
                <div class="pagination-buttons" id="paginationButtons"></div>
            </div>
        </div>
        </section>

        <section id="departamentosPanel" hidden>
            <div class="department-intro">
                <div>
                    <span>ACCESS STRUCTURE</span>
                    <h2>Organization departments</h2>
                    <p>Classify users by area. Windows and the initial screen are assigned only from Permissions.</p>
                </div>
                <div class="department-count">
                    <strong id="totalDepartments">0</strong>
                    <span>departments</span>
                </div>
            </div>

            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Department</th>
                            <th>Code</th>
                            <th>Users</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="departmentsTableBody">
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="fa-solid fa-spinner fa-spin"></i>
                                    <p>Loading departments...</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <!-- Create/edit user modal -->
    <div class="modal-overlay" id="userModal">
        <div class="modal admin-form-modal admin-user-modal">
            <div class="modal-header">
                <span class="admin-modal-kicker">Account</span>
                <h3 id="modalTitle">New user</h3>
                <p class="admin-modal-summary">Identity, credentials, role, and department access.</p>
                <div class="admin-modal-badge">
                    <i class="fa-solid fa-user-shield"></i>
                    <span>User access</span>
                </div>
                <button class="modal-close" onclick="closeUserModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <input type="hidden" id="userId" value="">
                    
                    <div class="form-group">
                        <label class="form-label" for="userName">Full name</label>
                        <input type="text" id="userName" class="form-control" placeholder="E.g. John Doe" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="userEmail">Email</label>
                        <input type="email" id="userEmail" class="form-control" placeholder="E.g. john@company.com" required>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="userUsername">Username</label>
                        <input type="text" id="userUsername" class="form-control" placeholder="E.g. jdoe" required>
                    </div>
                    
                    <div class="form-group" id="passwordGroup">
                        <label class="form-label" for="userPassword">Password</label>
                        <input type="password" id="userPassword" class="form-control" placeholder="Minimum 6 characters">
                        <small class="form-text" id="passwordHelp">Leave empty to keep the current password</small>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="userRole">Role</label>
                            <select id="userRole" class="form-control" required>
                                <option value="">Select...</option>
                                <option value="superadmin" data-privileged-role>Super administrator</option>
                                <option value="admin" data-privileged-role>Administrator</option>
                                <option value="supervisor">Supervisor</option>
                                <option value="usuario">User</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label" for="userStatus">Status</label>
                            <select id="userStatus" class="form-control" required>
                                <option value="activo">Active</option>
                                <option value="inactivo">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="userDepartment">Department</label>
                        <select id="userDepartment" class="form-control">
                            <option value="">No department</option>
                        </select>
                        <small class="form-text">The department defines visible windows for non-admin users.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeUserModal()">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveUser()">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save
                </button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="departmentModal">
        <div class="modal department-modal admin-form-modal admin-department-modal">
            <div class="modal-header">
                <span class="admin-modal-kicker">Department</span>
                <h3 id="departmentModalTitle">New department</h3>
                <p class="admin-modal-summary">Group users and control visible work areas.</p>
                <div class="admin-modal-badge">
                    <i class="fa-solid fa-building"></i>
                    <span>Workspace group</span>
                </div>
                <button class="modal-close" onclick="closeDepartmentModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="departmentForm">
                    <input type="hidden" id="departmentId" value="">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="departmentName">Name</label>
                            <input id="departmentName" class="form-control" placeholder="E.g. Accounting" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="departmentCode">Code</label>
                            <input id="departmentCode" class="form-control" placeholder="accounting" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="departmentDescription">Description</label>
                        <textarea id="departmentDescription" class="form-control" rows="3" placeholder="Department primary responsibility"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="departmentStatus">Status</label>
                        <select id="departmentStatus" class="form-control">
                            <option value="activo">Active</option>
                            <option value="inactivo">Inactive</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeDepartmentModal()">Cancel</button>
                <button class="btn btn-primary" onclick="saveDepartment()">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save department
                </button>
            </div>
        </div>
    </div>

    <!-- Delete confirmation modal -->
    <div class="modal-overlay" id="deleteModal">
        <div class="modal" style="max-width: 400px;">
            <div class="modal-header">
                <h3>Confirm deletion</h3>
                <button class="modal-close" onclick="closeDeleteModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body" style="text-align: center;">
                <div class="stat-icon red" style="width: 64px; height: 64px; font-size: 28px; margin: 0 auto 16px;">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <p>Are you sure you want to delete this user?</p>
                <p style="font-weight: 600;" id="deleteUserName"></p>
                <p class="form-text">This action cannot be undone.</p>
            </div>
            <div class="modal-footer" style="justify-content: center;">
                <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">
                    <i class="fa-solid fa-trash"></i>
                    Delete
                </button>
            </div>
        </div>
    </div>

<script src="/js/config.js" is:inline></script>
    <script is:inline src="/js/usuarios.js"></script>
</DashboardLayout>
