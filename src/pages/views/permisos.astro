---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Permissions">
    <div class="page-container">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Permission settings</h1>
                <p>Assign section access for this user</p>
            </div>
            <button class="btn btn-secondary" onclick="window.history.back()">
                <i class="fa-solid fa-arrow-left"></i>
                Back
            </button>
        </div>

        <!-- Info User -->
        <div class="permissions-container" id="userInfoCard">
            <div class="permissions-header">
                <div class="permissions-user-avatar" id="userAvatar">--</div>
                <div class="permissions-user-info">
                    <h2 id="permUserName">Loading...</h2>
                    <p id="permUserEmail">---</p>
                    <span class="status-badge" id="permUserRole">---</span>
                </div>
            </div>
            
            <!-- Permissions Grid -->
            <div class="permissions-grid" id="permissionsList">
                <!-- Se genera dinamicamente -->
            </div>

            <div class="permission-start-panel">
                <div class="permission-start-icon">
                    <i class="fa-solid fa-house-laptop"></i>
                </div>
                <div class="permission-start-copy">
                    <strong>Initial window</strong>
                    <span>Select the screen this user sees after signing in.</span>
                </div>
                <select id="initialWindow" class="form-control" onchange="changeInitialWindow(this.value)"></select>
            </div>
        </div>

        <!-- Actions -->
        <div class="permission-actions">
            <button class="btn btn-secondary" onclick="resetPermissions()">
                <i class="fa-solid fa-rotate-left"></i>
                Reset
            </button>
            <button class="btn btn-primary" onclick="savePermissions()">
                <i class="fa-solid fa-floppy-disk"></i>
                Save permissions
            </button>
        </div>
    </div>
    <style>
        .permissions-container {
            border-radius: 8px;
            border-color: #d7e1ea;
            box-shadow: 0 18px 44px -40px rgba(8,31,51,.65);
        }

        .permissions-header {
            align-items: center;
            padding: 22px 24px;
            background:
                linear-gradient(90deg, rgba(16,42,67,.08), transparent 46%),
                #ffffff;
        }

        .permissions-user-avatar {
            border-radius: 8px;
            background: #0b2943;
        }

        .permissions-grid {
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 14px;
            padding: 20px;
            background: #f8fafc;
        }

        .permission-card {
            min-height: 92px;
            padding: 16px;
            border-color: #d8e3ec;
            border-radius: 8px;
            background: #fff;
        }

        .permission-card:hover {
            border-color: #b9c8d6;
            background: #ffffff;
            box-shadow: 0 16px 36px -34px rgba(8,31,51,.58);
        }

        .permission-icon {
            border-radius: 8px;
            color: #173a59;
            background: #eef4f9;
        }

        .permission-details h4 {
            color: #0b2943;
        }

        .permission-tags span {
            border-color: #d7e1ea;
            background: #f7fafc;
        }

        .permission-start-panel {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) minmax(220px, 300px);
            align-items: center;
            gap: 14px;
            margin-top: 20px;
            padding: 18px;
            border: 1px solid #cbd8e5;
            border-left: 4px solid #173f67;
            border-radius: 8px;
            background: #f8fafc;
        }

        .permission-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 18px;
        }

        .permission-start-icon {
            display: grid;
            width: 42px;
            height: 42px;
            place-items: center;
            border-radius: 7px;
            background: #e4edf6;
            color: #123a5c;
        }

        .permission-start-copy strong { display: block; color: #102f4c; }
        .permission-start-copy span { display: block; margin-top: 3px; color: #65798d; font-size: 12px; }

        @media (max-width: 720px) {
            .permission-start-panel { grid-template-columns: auto 1fr; }
            .permission-start-panel select { grid-column: 1 / -1; }
            .permission-actions { flex-direction: column; }
            .permission-actions .btn { width: 100%; }
            .permissions-grid { grid-template-columns: 1fr; padding: 14px; }
        }
    </style>
<script src="/js/config.js" is:inline></script>
    <script is:inline src="/js/permisos.js"></script>
</DashboardLayout>

