---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Permissions">
    <div class="access-admin-page permissions-admin-page">
        <section class="access-command-hero access-permissions-hero">
            <div class="access-hero-copy">
                <span class="access-eyebrow">
                    <i class="fa-solid fa-key"></i>
                    Permission governance
                </span>
                <h1>Access policy editor</h1>
                <p>
                    Configure module visibility, operational actions, and the initial
                    workspace assigned to an individual account.
                </p>

                <div class="access-hero-tags">
                    <span><i class="fa-solid fa-eye"></i> Module visibility</span>
                    <span><i class="fa-solid fa-sliders"></i> Action-level controls</span>
                    <span><i class="fa-solid fa-house-laptop"></i> Initial workspace</span>
                </div>
            </div>

            <div class="access-hero-actions">
                <div class="access-governance-status">
                    <span class="access-status-dot"></span>
                    <div>
                        <strong>Policy editor</strong>
                        <small id="permissionSaveState">Loading account policy…</small>
                    </div>
                </div>

                <div class="access-primary-actions">
                    <button
                        class="access-button access-button-secondary"
                        type="button"
                        onclick="window.location.href='/views/usuarios'"
                    >
                        <i class="fa-solid fa-arrow-left"></i>
                        Users
                    </button>
                    <button
                        class="access-button access-button-primary"
                        type="button"
                        onclick="savePermissions()"
                    >
                        <i class="fa-solid fa-floppy-disk"></i>
                        Save policy
                    </button>
                </div>
            </div>
        </section>

        <section class="permission-identity-card" id="userInfoCard">
            <div class="permission-identity-main">
                <div class="permissions-user-avatar" id="userAvatar">--</div>
                <div class="permissions-user-info">
                    <span class="access-section-kicker">Target account</span>
                    <h2 id="permUserName">Loading account…</h2>
                    <p id="permUserEmail">---</p>
                    <span class="status-badge" id="permUserRole">---</span>
                </div>
            </div>

            <div class="permission-identity-policy">
                <i class="fa-solid fa-shield-halved"></i>
                <div>
                    <strong>Least-privilege policy</strong>
                    <span>
                        Grant only the actions required for the user’s operational role.
                    </span>
                </div>
            </div>
        </section>

        <section class="permission-summary-grid" aria-label="Permission overview">
            <article>
                <div class="permission-summary-icon">
                    <i class="fa-solid fa-window-restore"></i>
                </div>
                <div>
                    <span>Enabled modules</span>
                    <strong id="enabledModulesCount">0</strong>
                    <small>Visible application areas</small>
                </div>
            </article>

            <article>
                <div class="permission-summary-icon">
                    <i class="fa-solid fa-list-check"></i>
                </div>
                <div>
                    <span>Granted actions</span>
                    <strong id="enabledActionsCount">0</strong>
                    <small>View, create, edit, delete, export</small>
                </div>
            </article>

            <article>
                <div class="permission-summary-icon">
                    <i class="fa-solid fa-lock"></i>
                </div>
                <div>
                    <span>Locked controls</span>
                    <strong id="lockedPermissionsCount">0</strong>
                    <small>Required or protected by policy</small>
                </div>
            </article>

            <article>
                <div class="permission-summary-icon">
                    <i class="fa-solid fa-house-laptop"></i>
                </div>
                <div>
                    <span>Initial workspace</span>
                    <strong id="initialWindowSummary">Not selected</strong>
                    <small>First page after authentication</small>
                </div>
            </article>
        </section>

        <section class="permission-workspace">
            <div class="permission-workspace-header">
                <div>
                    <span class="access-section-kicker">Policy matrix</span>
                    <h2>Modules and actions</h2>
                    <p>
                        Use filters to review the account policy by department or status.
                    </p>
                </div>

                <div class="permission-result-counter">
                    <strong id="permissionResultCount">0</strong>
                    <span>modules shown</span>
                </div>
            </div>

            <div class="permission-toolbar">
                <label class="access-search-field permission-search-field">
                    <span>Search modules</span>
                    <div>
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input
                            id="permissionSearch"
                            type="search"
                            placeholder="Search by module or description"
                            autocomplete="off"
                            oninput="applyPermissionFilters()"
                        />
                    </div>
                </label>

                <label class="access-filter-field">
                    <span>Area</span>
                    <select id="permissionGroupFilter" onchange="applyPermissionFilters()">
                        <option value="">All areas</option>
                        <option value="Accounts Receivable">Accounts Receivable</option>
                        <option value="Property Management">Property Management</option>
                        <option value="Information Technology">Information Technology</option>
                        <option value="Account">Account</option>
                    </select>
                </label>

                <label class="access-filter-field">
                    <span>Access</span>
                    <select id="permissionStatusFilter" onchange="applyPermissionFilters()">
                        <option value="">All modules</option>
                        <option value="enabled">Enabled</option>
                        <option value="disabled">Disabled</option>
                        <option value="locked">Locked</option>
                    </select>
                </label>

                <button
                    class="access-filter-reset"
                    type="button"
                    onclick="resetPermissionFilters()"
                >
                    <i class="fa-solid fa-filter-circle-xmark"></i>
                    Clear
                </button>
            </div>

            <div class="permission-bulk-toolbar">
                <div>
                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                    <span>Bulk policy actions and templates apply only to editable modules.</span>
                </div>

                <div>
                    <label class="permission-template-control">
                        <span>Template</span>
                        <select id="permissionTemplateSelect">
                            <option value="">Select policy</option>
                            <option value="supervisor">Supervisor review</option>
                            <option value="arOperator">AR operator</option>
                            <option value="propertyManagement">Property management</option>
                            <option value="itAdmin">IT administration</option>
                            <option value="readOnly">Read only</option>
                        </select>
                    </label>
                    <button
                        type="button"
                        class="permission-bulk-button"
                        onclick="applyPermissionTemplate()"
                    >
                        <i class="fa-solid fa-stamp"></i>
                        Apply template
                    </button>
                    <button
                        type="button"
                        class="permission-bulk-button"
                        onclick="enableVisiblePermissions()"
                    >
                        <i class="fa-solid fa-eye"></i>
                        Enable visible
                    </button>
                    <button
                        type="button"
                        class="permission-bulk-button"
                        onclick="clearOptionalPermissions()"
                    >
                        <i class="fa-solid fa-eraser"></i>
                        Clear optional
                    </button>
                </div>
            </div>

            <div class="access-policy-matrix" id="permissionsList">
                <div class="access-empty-state">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                    <strong>Loading permission policy</strong>
                    <span>Retrieving modules and action controls…</span>
                </div>
            </div>
        </section>

        <section class="permission-start-panel">
            <div class="permission-start-icon">
                <i class="fa-solid fa-house-laptop"></i>
            </div>
            <div class="permission-start-copy">
                <span class="access-section-kicker">Authentication routing</span>
                <strong>Initial workspace</strong>
                <p>
                    Select the first enabled screen shown after this user signs in.
                </p>
            </div>
            <label class="permission-start-select">
                <span>Startup page</span>
                <select
                    id="initialWindow"
                    class="form-control"
                    onchange="changeInitialWindow(this.value)"
                ></select>
            </label>
        </section>

        <section class="permission-sticky-actions">
            <div class="permission-change-state">
                <span class="permission-change-dot"></span>
                <div>
                    <strong>Policy changes</strong>
                    <small id="permissionFooterState">No unsaved changes</small>
                </div>
            </div>

            <div>
                <button
                    class="access-button access-button-light"
                    type="button"
                    onclick="resetPermissions()"
                >
                    <i class="fa-solid fa-rotate-left"></i>
                    Reset
                </button>
                <button
                    class="access-button access-button-primary"
                    type="button"
                    onclick="savePermissions()"
                >
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save permissions
                </button>
            </div>
        </section>
    </div>

    <script is:inline src="/js/permisos.js?v=20260716-corporate-templates-v1"></script>
</DashboardLayout>
