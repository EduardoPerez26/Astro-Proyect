---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Permissions" stylesheets={["/styles/pages/views/permisos.css?v=20260714-style-refactor-v1"]}>
    <div class="page-container">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Permission settings</h1>
                <p>Assign section access for this user</p>
            </div>
            <button class="btn btn-secondary" onclick="window.history.back()">
                <i class="fa-solid fa-arrow-left"></i>
                Back
            </button>
        </div>

        <!-- Info User -->
        <div class="permissions-container" id="userInfoCard">
            <div class="permissions-header">
                <div class="permissions-user-avatar" id="userAvatar">--</div>
                <div class="permissions-user-info">
                    <h2 id="permUserName">Loading...</h2>
                    <p id="permUserEmail">---</p>
                    <span class="status-badge" id="permUserRole">---</span>
                </div>
            </div>

            <!-- Permissions Grid -->
            <div class="permissions-grid" id="permissionsList">
                <!-- Se genera dinamicamente -->
            </div>

            <div class="permission-start-panel">
                <div class="permission-start-icon">
                    <i class="fa-solid fa-house-laptop"></i>
                </div>
                <div class="permission-start-copy">
                    <strong>Initial window</strong>
                    <span
                        >Select the screen this user sees after signing in.</span
                    >
                </div>
                <select
                    id="initialWindow"
                    class="form-control"
                    onchange="changeInitialWindow(this.value)"></select>
            </div>
        </div>

        <!-- Actions -->
        <div class="permission-actions">
            <button class="btn btn-secondary" onclick="resetPermissions()">
                <i class="fa-solid fa-rotate-left"></i>
                Reset
            </button>
            <button class="btn btn-primary" onclick="savePermissions()">
                <i class="fa-solid fa-floppy-disk"></i>
                Save permissions
            </button>
        </div>
    </div>
<script src="/js/config.js" is:inline></script>
    <script is:inline src="/js/permisos.js?v=20260707-chat-permissions"
    ></script>
</DashboardLayout>
