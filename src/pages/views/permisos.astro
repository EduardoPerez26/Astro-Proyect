---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Permisos y Roles">
    <section class="tab active" id="permisos">
        <!-- Page Header -->
        <section class="page-header">
            <div class="page-header-left">
                <div class="header-icon-wrapper">
                    <i class="fas fa-shield-halved"></i>
                </div>
                <div>
                    <h1 class="page-title">Gestión de Permisos</h1>
                    <p class="page-subtitle">
                        Administra permisos, roles y asignaciones del sistema de
                        seguridad
                    </p>
                </div>
            </div>
            <div class="page-header-actions">
                <button class="btn btn-outline" onclick="exportPermissions()">
                    <i class="fas fa-download"></i> Exportar
                </button>
                <button class="btn btn-primary" onclick="refreshData()">
                    <i class="fas fa-rotate-right"></i> Actualizar
                </button>
            </div>
        </section>

        <!-- Stats Cards -->
        <div class="stats-grid" id="permisosStats">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-key"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="totalPermisos">0</span>
                    <span class="stat-label">Permisos Totales</span>
                    <span class="stat-trend positive"
                        ><i class="fas fa-arrow-up"></i> Activos</span
                    >
                </div>
            </div>
            <div class="stat-card stat-card-success">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-folder-open"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="totalCategorias">0</span>
                    <span class="stat-label">Categorías</span>
                    <span class="stat-trend"
                        ><i class="fas fa-layer-group"></i> Organizadas</span
                    >
                </div>
            </div>
            <div class="stat-card stat-card-warning">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-user-shield"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="totalRoles">0</span>
                    <span class="stat-label">Roles</span>
                    <span class="stat-trend"
                        ><i class="fas fa-users-gear"></i> Configurados</span
                    >
                </div>
            </div>
            <div class="stat-card stat-card-info">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-link"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="totalAsignaciones">0</span>
                    <span class="stat-label">Asignaciones</span>
                    <span class="stat-trend"
                        ><i class="fas fa-check-circle"></i> Activas</span
                    >
                </div>
            </div>
        </div>

        <!-- Main Content Grid -->
        <div class="permisos-layout">
            <!-- Left Panel: Permisos por Categoría -->
            <div class="card permisos-categories-panel">
                <div class="card-header-modern">
                    <div class="card-header-title">
                        <i class="fas fa-sitemap"></i>
                        <h2>Permisos del Sistema</h2>
                    </div>
                    <div class="card-header-actions">
                        <select
                            id="categoriaFilter"
                            class="filter-select-modern"
                        >
                            <option value="">Todas las categorías</option>
                        </select>
                    </div>
                </div>
                <div class="card-body-modern">
                    <div id="permisosPorCategoria" class="permissions-list">
                        <div class="loading-state">
                            <div class="spinner"></div>
                            <span>Cargando permisos...</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Gestión de Roles -->
            <div class="card roles-panel">
                <div class="card-header-modern">
                    <div class="card-header-title">
                        <i class="fas fa-user-gear"></i>
                        <h2>Asignación de Roles</h2>
                    </div>
                </div>
                <div class="card-body-modern">
                    <!-- Role Selector -->
                    <div class="role-selector-modern">
                        <label for="roleSelect">
                            <i class="fas fa-user-tag"></i>
                            Seleccionar Rol
                        </label>
                        <select id="roleSelect" class="role-select-modern">
                            <option value="">Cargando roles...</option>
                        </select>
                    </div>

                    <!-- Role Info Card -->
                    <div
                        class="role-info-card-modern"
                        id="roleInfoCard"
                        style="display: none;"
                    >
                        <div class="role-badge-modern" id="roleBadge">
                            admin
                        </div>
                        <div class="role-stats-modern">
                            <div class="role-stat-item">
                                <span
                                    class="role-stat-value"
                                    id="rolePermisosCount">0</span
                                >
                                <span class="role-stat-label">permisos</span>
                            </div>
                        </div>
                    </div>

                    <!-- Permissions Matrix by Category -->
                    <div id="rolePermsMatrix" class="role-permissions-matrix">
                        <div class="loading-state">
                            <div class="spinner"></div>
                            <span>Cargando...</span>
                        </div>
                    </div>

                    <!-- Save Button -->
                    <div class="role-actions-modern">
                        <button
                            id="saveRolePermsBtn"
                            class="btn btn-primary btn-block btn-modern"
                        >
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Section: Create Permission & History -->
        <div class="bottom-section-modern">
            <!-- Create Permission Form -->
            <div class="card create-permission-card">
                <div class="card-header-modern">
                    <div class="card-header-title">
                        <i class="fas fa-plus-circle"></i>
                        <h2>Crear Nuevo Permiso</h2>
                    </div>
                </div>
                <div class="card-body-modern">
                    <form
                        id="createPermissionForm"
                        class="permission-form-modern"
                    >
                        <div class="form-grid">
                            <div class="form-group-modern">
                                <label for="permName">
                                    <i class="fas fa-tag"></i>
                                    Nombre del Permiso *
                                </label>
                                <input
                                    type="text"
                                    id="permName"
                                    placeholder="ej: view_reports"
                                    required
                                    pattern="[a-z_]+"
                                    title="Solo letras minúsculas y guiones bajos"
                                />
                                <small class="form-hint"
                                    >Usa solo letras minúsculas y guiones bajos</small
                                >
                            </div>
                            <div class="form-group-modern">
                                <label for="permDesc">
                                    <i class="fas fa-align-left"></i>
                                    Descripción
                                </label>
                                <input
                                    type="text"
                                    id="permDesc"
                                    placeholder="Descripción del permiso"
                                />
                            </div>
                            <div class="form-group-modern">
                                <label for="permCategoria">
                                    <i class="fas fa-folder"></i>
                                    Categoría
                                </label>
                                <select id="permCategoria">
                                    <option value="">Sin categoría</option>
                                </select>
                            </div>
                            <div class="form-group-modern">
                                <label for="permIcono">
                                    <i class="fas fa-icons"></i>
                                    Icono
                                </label>
                                <div class="icon-select-wrapper">
                                    <select id="permIcono">
                                        <option value="fa-key">🔑 fa-key</option
                                        >
                                        <option value="fa-eye">👁️ fa-eye</option
                                        >
                                        <option value="fa-eye-slash"
                                            >🙈 fa-eye-slash</option
                                        >
                                        <option value="fa-plus"
                                            >➕ fa-plus</option
                                        >
                                        <option value="fa-pen">✏️ fa-pen</option
                                        >
                                        <option value="fa-trash"
                                            >🗑️ fa-trash</option
                                        >
                                        <option value="fa-download"
                                            >⬇️ fa-download</option
                                        >
                                        <option value="fa-upload"
                                            >⬆️ fa-upload</option
                                        >
                                        <option value="fa-file-export"
                                            >📤 fa-file-export</option
                                        >
                                        <option value="fa-file-import"
                                            >📥 fa-file-import</option
                                        >
                                        <option value="fa-gear"
                                            >⚙️ fa-gear</option
                                        >
                                        <option value="fa-users"
                                            >👥 fa-users</option
                                        >
                                        <option value="fa-chart-bar"
                                            >📊 fa-chart-bar</option
                                        >
                                        <option value="fa-shield-halved"
                                            >🛡️ fa-shield-halved</option
                                        >
                                        <option value="fa-lock"
                                            >🔒 fa-lock</option
                                        >
                                        <option value="fa-unlock"
                                            >🔓 fa-unlock</option
                                        >
                                    </select>
                                    <i
                                        class="fas fa-key preview-icon"
                                        id="iconPreview"></i>
                                </div>
                            </div>
                            <div class="form-group-modern">
                                <label for="permNivel">
                                    <i class="fas fa-layer-group"></i>
                                    Nivel de Acceso
                                </label>
                                <select id="permNivel">
                                    <option value="1">Nivel 1 - Básico</option>
                                    <option value="2"
                                        >Nivel 2 - Intermedio</option
                                    >
                                    <option value="3">Nivel 3 - Avanzado</option
                                    >
                                </select>
                            </div>
                        </div>
                        <div class="form-actions-modern">
                            <button
                                type="submit"
                                id="createPermBtn"
                                class="btn btn-primary btn-modern"
                            >
                                <i class="fas fa-plus-circle"></i> Crear Permiso
                            </button>
                            <button
                                type="reset"
                                class="btn btn-outline btn-modern"
                            >
                                <i class="fas fa-eraser"></i> Limpiar
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- History Panel -->
            <div class="card history-card">
                <div class="card-header-modern">
                    <div class="card-header-title">
                        <i class="fas fa-clock-rotate-left"></i>
                        <h2>Historial de Cambios</h2>
                    </div>
                    <div class="card-header-actions">
                        <button
                            class="btn btn-sm btn-outline"
                            onclick="loadHistory()"
                        >
                            <i class="fas fa-rotate-right"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body-modern">
                    <div id="permisosHistory" class="history-timeline">
                        <div class="loading-state">
                            <div class="spinner"></div>
                            <span>Cargando historial...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- User Management Section (New Tab) -->
    <section class="tab" id="usuarios">
        <!-- Page Header -->
        <section class="page-header">
            <div class="page-header-left">
                <div class="header-icon-wrapper">
                    <i class="fas fa-users-gear"></i>
                </div>
                <div>
                    <h1 class="page-title">Gestión de Usuarios</h1>
                    <p class="page-subtitle">
                        Administra usuarios, roles y estados del sistema
                    </p>
                </div>
            </div>
            <div class="page-header-actions">
                <button class="btn btn-primary" onclick="showCreateUserModal()">
                    <i class="fas fa-user-plus"></i> Nuevo Usuario
                </button>
            </div>
        </section>

        <!-- Users Stats -->
        <div class="stats-grid">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="totalUsuarios">0</span>
                    <span class="stat-label">Usuarios Totales</span>
                </div>
            </div>
            <div class="stat-card stat-card-success">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-user-check"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="usuariosActivos">0</span>
                    <span class="stat-label">Activos</span>
                </div>
            </div>
            <div class="stat-card stat-card-warning">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-user-shield"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="adminCount">0</span>
                    <span class="stat-label">Administradores</span>
                </div>
            </div>
            <div class="stat-card stat-card-info">
                <div class="stat-icon-wrapper">
                    <i class="fas fa-user-clock"></i>
                </div>
                <div class="stat-content">
                    <span class="stat-value" id="ultimoRegistro">-</span>
                    <span class="stat-label">Último Registro</span>
                </div>
            </div>
        </div>

        <!-- Users Table -->
        <div class="card">
            <div class="card-header-modern">
                <div class="card-header-title">
                    <i class="fas fa-table"></i>
                    <h2>Listado de Usuarios</h2>
                </div>
                <div class="card-header-actions">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input
                            type="text"
                            id="searchUser"
                            placeholder="Buscar usuario..."
                        />
                    </div>
                    <select id="filterRole" class="filter-select-modern">
                        <option value="">Todos los roles</option>
                        <option value="admin">Administrador</option>
                        <option value="supervisor">Supervisor</option>
                        <option value="usuario">Usuario</option>
                    </select>
                </div>
            </div>
            <div class="card-body-modern no-padding">
                <div class="table-responsive">
                    <table class="table-modern" id="usersTable">
                        <thead>
                            <tr>
                                <th>Usuario</th>
                                <th>Nombre Completo</th>
                                <th>Email</th>
                                <th>Rol</th>
                                <th>Estado</th>
                                <th>Fecha Registro</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="usersTableBody">
                            <tr>
                                <td colspan="7" class="text-center">
                                    <div class="loading-state">
                                        <div class="spinner"></div>
                                        <span>Cargando usuarios...</span>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- Create User Modal -->
    <div class="modal-overlay" id="createUserModal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-user-plus"></i> Crear Nuevo Usuario</h3>
                <button class="modal-close" onclick="closeCreateUserModal()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="createUserForm">
                    <div class="form-grid">
                        <div class="form-group-modern">
                            <label for="newUsername">
                                <i class="fas fa-user"></i>
                                Nombre de Usuario *
                            </label>
                            <input
                                type="text"
                                id="newUsername"
                                required
                                placeholder="ej: juan.perez"
                            />
                        </div>
                        <div class="form-group-modern">
                            <label for="newFullName">
                                <i class="fas fa-id-card"></i>
                                Nombre Completo *
                            </label>
                            <input
                                type="text"
                                id="newFullName"
                                required
                                placeholder="ej: Juan Pérez García"
                            />
                        </div>
                        <div class="form-group-modern">
                            <label for="newEmail">
                                <i class="fas fa-envelope"></i>
                                Correo Electrónico *
                            </label>
                            <input
                                type="email"
                                id="newEmail"
                                required
                                placeholder="ej: juan@empresa.com"
                            />
                        </div>
                        <div class="form-group-modern">
                            <label for="newPassword">
                                <i class="fas fa-lock"></i>
                                Contraseña *
                            </label>
                            <div class="password-input-wrapper">
                                <input
                                    type="password"
                                    id="newPassword"
                                    required
                                    placeholder="Mínimo 8 caracteres"
                                />
                                <button
                                    type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('newPassword')"
                                >
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <small class="form-hint">Mínimo 8 caracteres</small>
                        </div>
                        <div class="form-group-modern">
                            <label for="newRole">
                                <i class="fas fa-user-shield"></i>
                                Rol *
                            </label>
                            <select id="newRole">
                                <option value="usuario">Usuario</option>
                                <option value="supervisor">Supervisor</option>
                                <option value="admin">Administrador</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button
                    class="btn btn-outline"
                    onclick="closeCreateUserModal()"
                >
                    <i class="fas fa-times"></i> Cancelar
                </button>
                <button class="btn btn-primary" onclick="createUser()">
                    <i class="fas fa-user-plus"></i> Crear Usuario
                </button>
            </div>
        </div>
    </div>

    <script type="module" src="/js/permissions.js"></script>
    <script type="module" src="/js/users.js"></script>
</DashboardLayout>

<style>
    /* ============================================
       MODERN DASHBOARD STYLES
       ============================================ */
    :root {
        --primary: #3b82f6;
        --primary-dark: #2563eb;
        --primary-light: rgba(59, 130, 246, 0.15);

        --success: #22c55e;
        --success-light: rgba(34, 197, 94, 0.15);

        --warning: #f59e0b;
        --warning-light: rgba(245, 158, 11, 0.15);

        --danger: #ef4444;
        --danger-light: rgba(239, 68, 68, 0.15);

        --info: #06b6d4;
        --info-light: rgba(6, 182, 212, 0.15);

        --white: #fff;

        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;

        --radius: 12px;
        --radius-lg: 18px;

        --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
    }
    /* Page Header Modern */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 0;
        margin-bottom: 24px;
        border-bottom: 1px solid var(--gray-200);
    }

    .page-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon-wrapper {
        width: 56px;
        height: 56px;
        border-radius: var(--radius-lg);
        background: linear-gradient(
            135deg,
            var(--primary),
            var(--primary-dark)
        );
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: var(--white);
        box-shadow: 0 4px 12px var(--primary-light);
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--gray-900);
        margin: 0;
        line-height: 1.2;
    }

    .page-subtitle {
        font-size: 14px;
        color: var(--gray-500);
        margin-top: 4px;
    }

    .page-header-actions {
        display: flex;
        gap: 12px;
    }

    /* Stats Grid Modern */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: var(--white);
        border-radius: var(--radius-lg);
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--gray-100);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .stat-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
    }

    .stat-card-primary::before {
        background: var(--primary);
    }
    .stat-card-success::before {
        background: var(--success);
    }
    .stat-card-warning::before {
        background: var(--warning);
    }
    .stat-card-info::before {
        background: var(--info);
    }

    .stat-card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }

    .stat-icon-wrapper {
        width: 56px;
        height: 56px;
        border-radius: var(--radius);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .stat-card-primary .stat-icon-wrapper {
        background: var(--primary-light);
        color: var(--primary);
    }
    .stat-card-success .stat-icon-wrapper {
        background: var(--success-light);
        color: var(--success);
    }
    .stat-card-warning .stat-icon-wrapper {
        background: var(--warning-light);
        color: var(--warning);
    }
    .stat-card-info .stat-icon-wrapper {
        background: var(--info-light);
        color: var(--info);
    }

    .stat-content {
        display: flex;
        flex-direction: column;
    }

    .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: var(--gray-900);
        line-height: 1;
    }

    .stat-label {
        font-size: 13px;
        color: var(--gray-500);
        margin-top: 4px;
    }

    .stat-trend {
        font-size: 12px;
        color: var(--gray-400);
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .stat-trend.positive {
        color: var(--success);
    }

    /* Card Modern Styles */
    .card-header-modern {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 24px;
        border-bottom: 1px solid var(--gray-100);
        background: var(--white);
    }

    .card-header-title {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .card-header-title i {
        font-size: 18px;
        color: var(--primary);
    }

    .card-header-title h2 {
        font-size: 16px;
        font-weight: 600;
        color: var(--gray-800);
        margin: 0;
    }

    .card-header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .card-body-modern {
        padding: 24px;
    }

    .card-body-modern.no-padding {
        padding: 0;
    }

    /* Search Box Modern */
    .search-box {
        position: relative;
        display: flex;
        align-items: center;
    }

    .search-box i {
        position: absolute;
        left: 12px;
        color: var(--gray-400);
        font-size: 14px;
    }

    .search-box input {
        padding: 8px 12px 8px 36px;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius);
        font-size: 13px;
        width: 200px;
        transition: all 0.2s;
        background: var(--gray-50);
    }

    .search-box input:focus {
        outline: none;
