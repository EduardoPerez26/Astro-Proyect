---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Documentos">
    <div class="page-container">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Documentos</h1>
                <p>Todos los archivos Excel subidos al sistema</p>
            </div>
        </div>

        <!-- Filtros -->
        <div class="filters-bar documents-filters">
            <div class="filter-group search-filter">
                <label for="searchInput">Buscar archivo</label>
                <div class="search-field">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    <input type="search" id="searchInput" placeholder="Nombre o restaurante..." autocomplete="off">
                </div>
            </div>
            
            <div class="filter-group">
                <label>Restaurante:</label>
                <select id="filterRestaurante">
                    <option value="">Todos</option>
                    <option value="taco-bell">Taco Bell</option>
                    <option value="burger-king">Burger King</option>
                    <option value="popeyes">Popeyes</option>
                    <option value="kfc">KFC</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label>Estado:</label>
                <select id="filterEstado">
                    <option value="">Todos</option>
                    <option value="pendiente">Pendiente</option>
                    <option value="validado">Validado</option>
                    <option value="con_errores">Con errores</option>
                    <option value="procesado">Procesado</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label>Desde:</label>
                <input type="date" id="filterFechaDesde">
            </div>
            
            <div class="filter-group">
                <label>Hasta:</label>
                <input type="date" id="filterFechaHasta">
            </div>
            
            <button type="button" class="btn btn-secondary btn-sm clear-filters" onclick="limpiarFiltros()">
                <i class="fa-solid fa-times"></i>
                Limpiar
            </button>
        </div>

        <!-- Tabla de documentos -->
        <div class="table-container">
            <div class="table-header">
                <h3>Lista de documentos</h3>
                <div class="table-actions">
                    <button class="btn btn-secondary btn-sm" onclick="exportarCSV()">
                        <i class="fa-solid fa-download"></i>
                        Exportar
                    </button>
                </div>
            </div>
            
            <table class="data-table" id="documentosTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Archivo</th>
                        <th>Restaurante</th>
                        <th>Tamano</th>
                        <th>Estado</th>
                        <th>Subido por</th>
                        <th>Fecha</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="documentosBody">
                    <!-- Se llena con JavaScript -->
                </tbody>
            </table>
            
            <div id="emptyState" class="empty-state" style="display: none;">
                <i class="fa-solid fa-folder-open"></i>
                <h4>No hay documentos</h4>
                <p>No se encontraron documentos con los filtros seleccionados</p>
            </div>
            
            <div id="loadingState" class="empty-state">
                <i class="fa-solid fa-spinner fa-spin"></i>
                <h4>Cargando...</h4>
                <p>Obteniendo documentos del servidor</p>
            </div>
            
            <!-- Paginacion -->
            <div class="pagination" id="pagination" style="display: none;">
                <div class="pagination-info">
                    Mostrando <span id="showingFrom">1</span> - <span id="showingTo">10</span> de <span id="totalItems">0</span> documentos
                </div>
                <div class="pagination-buttons">
                    <button class="pagination-btn" id="btnPrev" onclick="cambiarPagina(-1)">
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <span class="pagination-btn active" id="currentPage">1</span>
                    <button class="pagination-btn" id="btnNext" onclick="cambiarPagina(1)">
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de detalles -->
    <div id="modalDetalles" class="modal-overlay">
        <div class="modal modal-lg">
            <div class="modal-header">
                <h3 id="modalTitulo">Detalles del documento</h3>
                <button class="modal-close" onclick="cerrarModal()">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
            <div class="modal-body" id="modalBody">
                <!-- Contenido dinamico -->
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="cerrarModal()">Cerrar</button>
                <button class="btn btn-primary" id="btnDescargar">
                    <i class="fa-solid fa-download"></i>
                    Descargar
                </button>
            </div>
        </div>
    </div>

    <script src="/js/config.js" is:inline></script>
    <script is:inline src="/js/documentos.js"></script>

    <style>
        .documents-filters {
            display: grid;
            grid-template-columns: minmax(260px, 1.6fr) repeat(4, minmax(130px, .72fr)) auto;
            gap: 12px;
            align-items: end;
            margin-bottom: 18px;
            padding: 14px;
            border: 1px solid #cfd9e3;
            border-radius: 5px;
            background: #fff;
            box-shadow: none;
        }

        .documents-filters .filter-group {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .documents-filters label {
            color: #52667a;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .045em;
            text-transform: uppercase;
        }

        .search-field {
            position: relative;
            width: 100%;
        }

        .search-field i {
            position: absolute;
            top: 50%;
            left: 12px;
            z-index: 1;
            transform: translateY(-50%);
            color: #718096;
            font-size: 13px;
            pointer-events: none;
        }

        .search-field input,
        .documents-filters select,
        .documents-filters input[type="date"] {
            width: 100%;
            height: 40px;
            min-height: 40px;
            border: 1px solid #cbd6e1;
            border-radius: 4px;
            color: #243b53;
            background: #fff;
            font-size: 13px;
        }

        .search-field input { padding: 0 12px 0 36px; }
        .documents-filters select,
        .documents-filters input[type="date"] { padding: 0 10px; }

        .search-field input:focus,
        .documents-filters select:focus,
        .documents-filters input[type="date"]:focus {
            outline: 0;
            border-color: #174a75;
            box-shadow: 0 0 0 3px rgba(23, 74, 117, .11);
        }

        .clear-filters {
            height: 40px;
            white-space: nowrap;
        }

        @media (max-width: 1250px) {
            .documents-filters { grid-template-columns: repeat(3, minmax(0, 1fr)); }
            .search-filter { grid-column: span 2; }
        }

        @media (max-width: 760px) {
            .documents-filters { grid-template-columns: 1fr; }
            .search-filter { grid-column: auto; }
            .clear-filters { width: 100%; }
        }
    </style>
</DashboardLayout>
