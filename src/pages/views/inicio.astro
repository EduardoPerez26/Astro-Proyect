---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Dashboard">
    <section class="dashboard-view" aria-labelledby="dashboardTitle">
        <header class="dashboard-heading">
            <div>
                <span class="dashboard-kicker">Operacion general</span>
                <h1 id="dashboardTitle">Resumen operativo</h1>
                <p id="dashboardPeriodLabel">Actividad de los ultimos 12 meses</p>
            </div>

            <div class="dashboard-heading-actions">
                <div class="dashboard-period" aria-label="Periodo del dashboard">
                    <button type="button" data-period="30d">30 dias</button>
                    <button type="button" data-period="12m" class="active">12 meses</button>
                    <button type="button" data-period="all">Todo</button>
                </div>

                <button
                    class="dashboard-icon-button"
                    id="refreshDashboard"
                    type="button"
                    title="Actualizar datos"
                    aria-label="Actualizar datos"
                >
                    <i class="fa-solid fa-rotate"></i>
                </button>

                <a class="dashboard-primary-action" href="/views/conciliacion">
                    <i class="fa-solid fa-plus"></i>
                    Nueva conciliacion
                </a>
            </div>
        </header>

        <div class="dashboard-alert" id="dashboardAlert" role="status" hidden></div>

        <div class="dashboard-kpi-grid" aria-live="polite">
            <article class="dashboard-kpi">
                <div class="dashboard-kpi-icon is-primary">
                    <i class="fa-solid fa-file-excel"></i>
                </div>
                <div>
                    <span class="dashboard-kpi-label">Archivos registrados</span>
                    <strong id="kpiArchivos">--</strong>
                    <small id="kpiArchivosMeta">Sin datos cargados</small>
                </div>
            </article>

            <article class="dashboard-kpi">
                <div class="dashboard-kpi-icon is-success">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div>
                    <span class="dashboard-kpi-label">Tasa de validacion</span>
                    <strong id="kpiTasa">--</strong>
                    <small id="kpiTasaMeta">0 archivos validados</small>
                </div>
            </article>

            <article class="dashboard-kpi">
                <div class="dashboard-kpi-icon is-warning">
                    <i class="fa-solid fa-clock"></i>
                </div>
                <div>
                    <span class="dashboard-kpi-label">Pendientes</span>
                    <strong id="kpiPendientes">--</strong>
                    <small>Esperando revision o procesamiento</small>
                </div>
            </article>

            <article class="dashboard-kpi">
                <div class="dashboard-kpi-icon is-danger">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div>
                    <span class="dashboard-kpi-label">Requieren atencion</span>
                    <strong id="kpiIncidencias">--</strong>
                    <small id="kpiIncidenciasMeta">0 errores detectados</small>
                </div>
            </article>
        </div>

        <div class="dashboard-chart-grid">
            <section class="dashboard-panel dashboard-trend-panel">
                <div class="dashboard-panel-heading">
                    <div>
                        <h2>Actividad de archivos</h2>
                        <p>Archivos registrados y resultado de validacion</p>
                    </div>
                    <span class="dashboard-panel-icon">
                        <i class="fa-solid fa-chart-column"></i>
                    </span>
                </div>
                <div class="dashboard-chart dashboard-chart-wide">
                    <canvas id="inventoryChart"></canvas>
                </div>
                <div class="dashboard-empty" id="trendEmpty" hidden>
                    No hay actividad para este periodo.
                </div>
            </section>

            <section class="dashboard-panel dashboard-status-panel">
                <div class="dashboard-panel-heading">
                    <div>
                        <h2>Estado de archivos</h2>
                        <p>Distribucion del periodo</p>
                    </div>
                    <span class="dashboard-panel-icon">
                        <i class="fa-solid fa-chart-pie"></i>
                    </span>
                </div>
                <div class="dashboard-chart dashboard-chart-donut">
                    <canvas id="statusChart"></canvas>
                </div>
                <div class="dashboard-status-legend" id="statusLegend"></div>
                <div class="dashboard-empty" id="statusEmpty" hidden>
                    No hay archivos para clasificar.
                </div>
            </section>
        </div>

        <div class="dashboard-detail-grid">
            <section class="dashboard-panel">
                <div class="dashboard-panel-heading">
                    <div>
                        <h2>Restaurantes</h2>
                        <p id="restaurantCoverage">Actividad por marca</p>
                    </div>
                    <a class="dashboard-text-link" href="/views/tiendas">
                        Ver tiendas
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
                <div class="dashboard-restaurant-list" id="restaurantList"></div>
            </section>

            <section class="dashboard-panel">
                <div class="dashboard-panel-heading">
                    <div>
                        <h2>Actividad reciente</h2>
                        <p>Ultimos archivos registrados</p>
                    </div>
                    <a class="dashboard-text-link" href="/views/documentos">
                        Ver documentos
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
                <div class="dashboard-table-wrap">
                    <table class="dashboard-table">
                        <thead>
                            <tr>
                                <th>Archivo</th>
                                <th>Restaurante</th>
                                <th>Estado</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>
                        <tbody id="recentActivityBody"></tbody>
                    </table>
                </div>
            </section>
        </div>

        <footer class="dashboard-footer">
            <span id="dashboardUpdated">Esperando datos</span>
            <span id="dashboardValidationMeta"></span>
        </footer>
    </section>

    <script src="/js/config.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
    <script src="/js/dashboard.js" defer></script>
</DashboardLayout>

<style is:global>
    .dashboard-view {
        width: 100%;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .dashboard-heading {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 24px;
    }

    .dashboard-kicker {
        display: block;
        margin-bottom: 4px;
        color: var(--primary);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .dashboard-heading h1 {
        margin: 0;
        color: var(--gray-900);
        font-size: 28px;
        line-height: 1.2;
        letter-spacing: 0;
    }

    .dashboard-heading p,
    .dashboard-panel-heading p {
        margin: 5px 0 0;
        color: var(--gray-500);
        font-size: 13px;
    }

    .dashboard-heading-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .dashboard-period {
        display: inline-grid;
        grid-template-columns: repeat(3, minmax(72px, 1fr));
        padding: 3px;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        background: var(--gray-100);
    }

    .dashboard-period button {
        min-height: 34px;
        padding: 0 10px;
        border-radius: var(--radius);
        color: var(--gray-600);
        font-size: 12px;
        font-weight: 700;
    }

    .dashboard-period button:hover {
        color: var(--gray-900);
    }

    .dashboard-period button.active {
        color: var(--primary-dark);
        background: var(--white);
        box-shadow: var(--shadow-sm);
    }

    .dashboard-icon-button,
    .dashboard-primary-action {
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        font-weight: 700;
    }

    .dashboard-icon-button {
        width: 42px;
        color: var(--gray-600);
        background: var(--white);
    }

    .dashboard-icon-button:hover {
        color: var(--primary);
        border-color: #99D5CE;
    }

    .dashboard-icon-button.is-loading i {
        animation: dashboard-spin .8s linear infinite;
    }

    .dashboard-primary-action {
        gap: 8px;
        padding: 0 16px;
        color: var(--white);
        border-color: var(--primary);
        background: var(--primary);
    }

    .dashboard-primary-action:hover {
        background: var(--primary-dark);
    }

    .dashboard-alert {
        padding: 12px 14px;
        border: 1px solid #F3B5B5;
        border-radius: var(--radius-lg);
        color: var(--danger);
        background: var(--danger-light);
        font-weight: 600;
    }

    .dashboard-kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .dashboard-kpi {
        min-width: 0;
        min-height: 124px;
        display: grid;
        grid-template-columns: 46px minmax(0, 1fr);
        align-items: start;
        gap: 14px;
        padding: 18px;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-xl);
        background: var(--white);
        box-shadow: var(--shadow-sm);
    }

    .dashboard-kpi-icon {
        width: 46px;
        height: 46px;
        display: grid;
        place-items: center;
        border-radius: var(--radius-lg);
        font-size: 18px;
    }

    .dashboard-kpi-icon.is-primary {
        color: var(--primary-dark);
        background: var(--primary-light);
    }

    .dashboard-kpi-icon.is-success {
        color: var(--success);
        background: var(--success-light);
    }

    .dashboard-kpi-icon.is-warning {
        color: var(--warning);
        background: var(--warning-light);
    }

    .dashboard-kpi-icon.is-danger {
        color: var(--danger);
        background: var(--danger-light);
    }

    .dashboard-kpi-label,
    .dashboard-kpi small {
        display: block;
    }

    .dashboard-kpi-label {
        color: var(--gray-600);
        font-size: 12px;
        font-weight: 700;
    }

    .dashboard-kpi strong {
        display: block;
        margin: 3px 0;
        color: var(--gray-900);
        font-size: 28px;
        line-height: 1.15;
        letter-spacing: 0;
    }

    .dashboard-kpi small {
        overflow: hidden;
        color: var(--gray-500);
        font-size: 11px;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .dashboard-chart-grid,
    .dashboard-detail-grid {
        display: grid;
        gap: 14px;
        min-width: 0;
    }

    .dashboard-chart-grid {
        grid-template-columns: minmax(0, 1.8fr) minmax(280px, .8fr);
    }

    .dashboard-detail-grid {
        grid-template-columns: minmax(300px, .8fr) minmax(0, 1.4fr);
    }

    .dashboard-panel {
        min-width: 0;
        padding: 18px;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-xl);
        background: var(--white);
        box-shadow: var(--shadow-sm);
    }

    .dashboard-panel-heading {
        min-height: 44px;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
    }

    .dashboard-panel-heading h2 {
        margin: 0;
        color: var(--gray-900);
        font-size: 15px;
        line-height: 1.3;
        letter-spacing: 0;
    }

    .dashboard-panel-icon {
        width: 34px;
        height: 34px;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        border-radius: var(--radius);
        color: var(--gray-500);
        background: var(--gray-100);
    }

    .dashboard-chart {
        position: relative;
        width: 100%;
    }

    .dashboard-chart-wide {
        height: 270px;
    }

    .dashboard-chart-donut {
        height: 200px;
    }

    .dashboard-status-legend {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
        margin-top: 12px;
    }

    .dashboard-legend-item {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--gray-600);
        font-size: 11px;
    }

    .dashboard-legend-item strong {
        margin-left: auto;
        color: var(--gray-900);
    }

    .dashboard-legend-dot {
        width: 8px;
        height: 8px;
        flex: 0 0 auto;
        border-radius: 50%;
    }

    .dashboard-empty {
        min-height: 120px;
        display: grid;
        place-items: center;
        color: var(--gray-500);
        font-size: 13px;
        text-align: center;
    }

    .dashboard-restaurant-list {
        display: flex;
        flex-direction: column;
        gap: 13px;
    }

    .dashboard-restaurant-row {
        display: grid;
        grid-template-columns: 36px minmax(0, 1fr) auto;
        align-items: center;
        gap: 11px;
    }

    .dashboard-brand-icon {
        width: 36px;
        height: 36px;
        display: grid;
        place-items: center;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius);
        color: var(--primary-dark);
        background: var(--gray-50);
    }

    .dashboard-restaurant-name {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 6px;
        color: var(--gray-800);
        font-size: 12px;
        font-weight: 700;
    }

    .dashboard-progress {
        height: 5px;
        overflow: hidden;
        border-radius: 3px;
        background: var(--gray-100);
    }

    .dashboard-progress span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: var(--success);
    }

    .dashboard-restaurant-state {
        color: var(--gray-500);
        font-size: 11px;
        text-align: right;
        white-space: nowrap;
    }

    .dashboard-text-link {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        color: var(--primary);
        font-size: 12px;
        font-weight: 700;
    }

    .dashboard-table-wrap {
        width: 100%;
        overflow-x: auto;
    }

    .dashboard-table {
        width: 100%;
        min-width: 620px;
        border-collapse: collapse;
    }

    .dashboard-table th {
        padding: 0 10px 10px;
        color: var(--gray-500);
        font-size: 10px;
        font-weight: 800;
        text-align: left;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .dashboard-table td {
        padding: 11px 10px;
        border-top: 1px solid var(--gray-100);
        color: var(--gray-700);
        font-size: 12px;
        vertical-align: middle;
    }

    .dashboard-file-cell {
        max-width: 270px;
    }

    .dashboard-file-name {
        display: block;
        overflow: hidden;
        color: var(--gray-900);
        font-weight: 700;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .dashboard-file-meta {
        color: var(--gray-500);
        font-size: 10px;
    }

    .dashboard-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 7px;
        border-radius: var(--radius);
        font-size: 10px;
        font-weight: 800;
        white-space: nowrap;
    }

    .dashboard-status::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    .dashboard-status.validado {
        color: var(--success);
        background: var(--success-light);
    }

    .dashboard-status.con_errores {
        color: var(--danger);
        background: var(--danger-light);
    }

    .dashboard-status.pendiente {
        color: var(--warning);
        background: var(--warning-light);
    }

    .dashboard-status.procesado {
        color: var(--info);
        background: var(--info-light);
    }

    .dashboard-footer {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        color: var(--gray-500);
        font-size: 11px;
    }

    @keyframes dashboard-spin {
        to { transform: rotate(360deg); }
    }

    @media (max-width: 1180px) {
        .dashboard-kpi-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .dashboard-chart-grid,
        .dashboard-detail-grid {
            grid-template-columns: minmax(0, 1fr);
        }

        .dashboard-status-panel {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(220px, .7fr);
            column-gap: 20px;
        }

        .dashboard-status-panel .dashboard-panel-heading {
            grid-column: 1 / -1;
        }
    }

    @media (max-width: 760px) {
        .dashboard-heading {
            align-items: flex-start;
            flex-direction: column;
        }

        .dashboard-heading-actions {
            width: 100%;
            justify-content: flex-start;
        }

        .dashboard-period {
            flex: 1 1 240px;
        }

        .dashboard-primary-action {
            flex: 1 1 auto;
        }

        .dashboard-kpi-grid {
            grid-template-columns: minmax(0, 1fr);
        }

        .dashboard-kpi {
            min-height: 106px;
        }

        .dashboard-status-panel {
            display: block;
        }

        .dashboard-chart-wide {
            height: 230px;
        }

        .dashboard-footer {
            flex-direction: column;
        }
    }

    @media (max-width: 480px) {
        .dashboard-heading h1 {
            font-size: 24px;
        }

        .dashboard-heading-actions {
            display: grid;
            grid-template-columns: 1fr 42px;
        }

        .dashboard-period,
        .dashboard-primary-action {
            grid-column: 1 / -1;
            width: 100%;
        }

        .dashboard-icon-button {
            grid-row: 1;
            grid-column: 2;
            justify-self: end;
        }

        .dashboard-period {
            grid-row: 1;
            grid-column: 1;
        }

        .dashboard-primary-action {
            grid-row: 2;
        }

        .dashboard-panel,
        .dashboard-kpi {
            padding: 15px;
        }
    }
</style>
