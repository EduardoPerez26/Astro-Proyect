---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout
    title="Profile & Security"
    stylesheets={["/styles/pages/views/perfil.css?v=20260714-profile-professional-v3"]}
>
    <div class="page-container profile-page profile-professional-v3">
        <header class="profile-account-hero">
            <div class="profile-hero-identity">
                <span class="profile-hero-eyebrow">
                    <i class="fa-solid fa-id-badge" aria-hidden="true"></i>
                    Account center
                </span>

                <h1 id="profileDisplayName">Loading...</h1>
                <p id="profileDisplayEmail">---</p>

                <div class="profile-hero-security">
                    <span>
                        <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                        Active account
                    </span>
                    <span>
                        <i class="fa-solid fa-lock" aria-hidden="true"></i>
                        Protected connection
                    </span>
                </div>
            </div>

            <div class="profile-hero-avatar-wrap">
                <div class="profile-avatar-preview" id="profileAvatarPreview" aria-label="Profile photo">--</div>

                <label class="profile-avatar-action" for="profilePhoto" title="Change profile photo">
                    <i class="fa-solid fa-camera" aria-hidden="true"></i>
                    <span class="sr-only">Change profile photo</span>
                </label>

                <input
                    type="file"
                    id="profilePhoto"
                    name="foto"
                    accept="image/png,image/jpeg,image/webp"
                    hidden
                />
            </div>

            <div class="profile-hero-summary" aria-label="Account summary">
                <article>
                    <span class="profile-hero-summary-icon">
                        <i class="fa-solid fa-user-shield" aria-hidden="true"></i>
                    </span>
                    <div>
                        <small>Access level</small>
                        <strong id="profileHeroRole">Loading...</strong>
                    </div>
                </article>

                <article>
                    <span class="profile-hero-summary-icon">
                        <i class="fa-solid fa-building" aria-hidden="true"></i>
                    </span>
                    <div>
                        <small>Department</small>
                        <strong id="profileHeroDepartment">Loading...</strong>
                    </div>
                </article>

                <article class="profile-hero-readiness">
                    <div class="profile-hero-readiness-head">
                        <span>Account readiness</span>
                        <strong id="profileCompletionValue">0%</strong>
                    </div>
                    <div class="profile-completion-track" aria-hidden="true">
                        <span id="profileCompletionBar"></span>
                    </div>
                    <small id="profileCompletionLabel">Checking account setup...</small>
                </article>
            </div>
        </header>

        <form class="profile-workspace" id="profileForm" autocomplete="off">
            <header class="profile-workspace-header">
                <div>
                    <span class="profile-section-kicker">Account settings</span>
                    <h2 id="profileTitle">Profile preferences</h2>
                    <p>
                        Manage your personal information, password, and Microsoft Authenticator
                        in three clearly separated sections.
                    </p>
                </div>

                <div class="profile-connection-note">
                    <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                    <span>
                        <strong>Protected workspace</strong>
                        Changes are encrypted in transit.
                    </span>
                </div>
            </header>

            <nav class="profile-settings-tabs" role="tablist" aria-label="Profile settings sections">
                <button
                    type="button"
                    class="profile-settings-tab is-active"
                    id="profileConfigTab"
                    data-profile-tab-target="profileConfigPanel"
                    role="tab"
                    aria-selected="true"
                    aria-controls="profileConfigPanel"
                >
                    <span class="profile-tab-number">01</span>
                    <span class="profile-tab-icon">
                        <i class="fa-solid fa-user-pen" aria-hidden="true"></i>
                    </span>
                    <span class="profile-tab-copy">
                        <strong>Profile</strong>
                        <small>Identity and account details</small>
                    </span>
                </button>

                <button
                    type="button"
                    class="profile-settings-tab"
                    id="profilePasswordTab"
                    data-profile-tab-target="profilePasswordPanel"
                    role="tab"
                    aria-selected="false"
                    aria-controls="profilePasswordPanel"
                >
                    <span class="profile-tab-number">02</span>
                    <span class="profile-tab-icon">
                        <i class="fa-solid fa-key" aria-hidden="true"></i>
                    </span>
                    <span class="profile-tab-copy">
                        <strong>Password</strong>
                        <small>Credentials and access</small>
                    </span>
                </button>

                <button
                    type="button"
                    class="profile-settings-tab"
                    id="profileMfaTab"
                    data-profile-tab-target="profileMfaPanel"
                    role="tab"
                    aria-selected="false"
                    aria-controls="profileMfaPanel"
                >
                    <span class="profile-tab-number">03</span>
                    <span class="profile-tab-icon">
                        <i class="fa-solid fa-mobile-screen-button" aria-hidden="true"></i>
                    </span>
                    <span class="profile-tab-copy">
                        <strong>2-step verification</strong>
                        <small>Microsoft Authenticator</small>
                    </span>
                </button>
            </nav>

            <div class="profile-settings-tab-panels">
                <section
                    class="profile-panel profile-tab-panel is-active"
                    id="profileConfigPanel"
                    data-profile-tab-panel
                    role="tabpanel"
                    aria-labelledby="profileConfigTab"
                >
                    <header class="profile-panel-heading">
                        <span class="profile-panel-heading-icon">
                            <i class="fa-solid fa-address-card" aria-hidden="true"></i>
                        </span>
                        <div>
                            <span class="profile-section-kicker">Personal profile</span>
                            <h3>Identity and account information</h3>
                            <p>Update the information that identifies you throughout the operations hub.</p>
                        </div>
                    </header>

                    <div class="profile-content-grid profile-content-grid--profile">
                        <section class="profile-card profile-card--editable">
                            <header class="profile-card-header">
                                <div>
                                    <span class="profile-section-kicker">Editable information</span>
                                    <h4>Personal details</h4>
                                </div>
                                <span class="profile-card-badge">
                                    <i class="fa-solid fa-pen" aria-hidden="true"></i>
                                    Editable
                                </span>
                            </header>

                            <div class="profile-field-grid">
                                <div class="form-group profile-field profile-field--wide">
                                    <label class="form-label" for="profileName">Full name</label>
                                    <div class="profile-input-shell">
                                        <i class="fa-solid fa-user" aria-hidden="true"></i>
                                        <input
                                            type="text"
                                            id="profileName"
                                            class="form-control"
                                            maxlength="100"
                                            placeholder="Enter your full name"
                                            required
                                        />
                                    </div>
                                    <small>Used in activity records, approvals, and system notifications.</small>
                                </div>

                                <div class="form-group profile-field profile-field--wide">
                                    <label class="form-label" for="profileEmail">Email address</label>
                                    <div class="profile-input-shell is-readonly">
                                        <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                                        <input
                                            type="email"
                                            id="profileEmail"
                                            class="form-control profile-readonly"
                                            readonly
                                        />
                                        <span class="profile-field-lock" title="Managed by an administrator">
                                            <i class="fa-solid fa-lock" aria-hidden="true"></i>
                                        </span>
                                    </div>
                                    <small>Contact an administrator to change the registered email.</small>
                                </div>
                            </div>

                            <div class="profile-photo-guidance">
                                <i class="fa-solid fa-image" aria-hidden="true"></i>
                                <div>
                                    <strong>Profile photo</strong>
                                    <span>Use the camera button in the header to upload and crop a new photo.</span>
                                </div>
                            </div>
                        </section>

                        <aside class="profile-card profile-card--assignment">
                            <header class="profile-card-header">
                                <div>
                                    <span class="profile-section-kicker">System assignment</span>
                                    <h4>Access information</h4>
                                </div>
                                <span class="profile-card-badge profile-card-badge--managed">
                                    <i class="fa-solid fa-shield" aria-hidden="true"></i>
                                    Managed
                                </span>
                            </header>

                            <div class="profile-assignment-list">
                                <article>
                                    <span class="profile-assignment-icon">
                                        <i class="fa-solid fa-user-shield" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <small>Role</small>
                                        <strong id="profileRoleLabel">---</strong>
                                    </div>
                                </article>

                                <article>
                                    <span class="profile-assignment-icon">
                                        <i class="fa-solid fa-building" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <small>Department</small>
                                        <strong id="profileDepartmentLabel">---</strong>
                                    </div>
                                </article>

                                <article>
                                    <span class="profile-assignment-icon">
                                        <i class="fa-solid fa-at" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <small>Username</small>
                                        <strong id="profileUsernameLabel">---</strong>
                                    </div>
                                </article>
                            </div>

                            <div class="profile-hidden-system-fields" aria-hidden="true">
                                <input type="text" id="profileUsername" class="profile-readonly" readonly tabindex="-1" />
                                <input type="text" id="profileDepartment" class="profile-readonly" readonly tabindex="-1" />
                            </div>

                            <div class="profile-managed-note">
                                <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
                                Role, department, username, and email are controlled by administrators.
                            </div>
                        </aside>
                    </div>
                </section>

                <section
                    class="profile-panel profile-tab-panel"
                    id="profilePasswordPanel"
                    data-profile-tab-panel
                    role="tabpanel"
                    aria-labelledby="profilePasswordTab"
                    hidden
                >
                    <header class="profile-panel-heading">
                        <span class="profile-panel-heading-icon">
                            <i class="fa-solid fa-key" aria-hidden="true"></i>
                        </span>
                        <div>
                            <span class="profile-section-kicker">Account credentials</span>
                            <h3>Password security</h3>
                            <p>Create a strong password and confirm it before saving your changes.</p>
                        </div>
                    </header>

                    <div class="profile-content-grid profile-content-grid--password">
                        <section class="profile-card profile-card--password">
                            <header class="profile-card-header">
                                <div>
                                    <span class="profile-section-kicker">Password change</span>
                                    <h4>Update credentials</h4>
                                </div>
                            </header>

                            <div class="profile-password-fields">
                                <div class="form-group profile-field">
                                    <label class="form-label" for="currentPassword">Current password</label>
                                    <div class="profile-input-shell profile-password-shell">
                                        <i class="fa-solid fa-lock" aria-hidden="true"></i>
                                        <input
                                            type="password"
                                            id="currentPassword"
                                            class="form-control"
                                            autocomplete="current-password"
                                            placeholder="Enter current password"
                                        />
                                        <button
                                            type="button"
                                            data-password-toggle="currentPassword"
                                            aria-label="Show password"
                                            aria-pressed="false"
                                        >
                                            <i class="fa-solid fa-eye" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="form-group profile-field">
                                    <label class="form-label" for="newPassword">New password</label>
                                    <div class="profile-input-shell profile-password-shell">
                                        <i class="fa-solid fa-key" aria-hidden="true"></i>
                                        <input
                                            type="password"
                                            id="newPassword"
                                            class="form-control"
                                            autocomplete="new-password"
                                            minlength="6"
                                            placeholder="Create a new password"
                                        />
                                        <button
                                            type="button"
                                            data-password-toggle="newPassword"
                                            aria-label="Show password"
                                            aria-pressed="false"
                                        >
                                            <i class="fa-solid fa-eye" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="form-group profile-field">
                                    <div class="profile-label-row">
                                        <label class="form-label" for="confirmPassword">Confirm new password</label>
                                        <span id="profilePasswordMatchStatus" data-state="idle">Confirmation pending</span>
                                    </div>
                                    <div class="profile-input-shell profile-password-shell">
                                        <i class="fa-solid fa-check-double" aria-hidden="true"></i>
                                        <input
                                            type="password"
                                            id="confirmPassword"
                                            class="form-control"
                                            autocomplete="new-password"
                                            minlength="6"
                                            placeholder="Repeat the new password"
                                        />
                                        <button
                                            type="button"
                                            data-password-toggle="confirmPassword"
                                            aria-label="Show password"
                                            aria-pressed="false"
                                        >
                                            <i class="fa-solid fa-eye" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="profile-password-strength" id="profilePasswordStrength" data-level="empty">
                                <div>
                                    <span>Password strength</span>
                                    <strong id="profilePasswordStrengthText">Enter a new password</strong>
                                </div>
                                <div class="profile-password-strength-track" aria-hidden="true">
                                    <span id="profilePasswordStrengthBar"></span>
                                </div>
                            </div>
                        </section>

                        <aside class="profile-card profile-card--guidance">
                            <span class="profile-guidance-icon">
                                <i class="fa-solid fa-shield-heart" aria-hidden="true"></i>
                            </span>
                            <span class="profile-section-kicker">Recommended quality</span>
                            <h4>Create a resilient password</h4>
                            <p>Use a password that is unique to this account and difficult to predict.</p>

                            <ul class="profile-password-rules">
                                <li id="profileRuleLength">
                                    <i class="fa-regular fa-circle" aria-hidden="true"></i>
                                    At least 8 characters
                                </li>
                                <li id="profileRuleCase">
                                    <i class="fa-regular fa-circle" aria-hidden="true"></i>
                                    Uppercase and lowercase letters
                                </li>
                                <li id="profileRuleNumber">
                                    <i class="fa-regular fa-circle" aria-hidden="true"></i>
                                    At least one number
                                </li>
                                <li id="profileRuleSpecial">
                                    <i class="fa-regular fa-circle" aria-hidden="true"></i>
                                    At least one special character
                                </li>
                                <li id="profileRuleMatch">
                                    <i class="fa-regular fa-circle" aria-hidden="true"></i>
                                    Confirmation matches
                                </li>
                            </ul>

                            <div class="profile-security-tip">
                                <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
                                Leave all password fields empty when you only need to update your profile.
                            </div>
                        </aside>
                    </div>
                </section>

                <section
                    class="profile-panel profile-tab-panel"
                    id="profileMfaPanel"
                    data-profile-tab-panel
                    role="tabpanel"
                    aria-labelledby="profileMfaTab"
                    hidden
                >
                    <header class="profile-panel-heading">
                        <span class="profile-panel-heading-icon">
                            <i class="fa-solid fa-mobile-screen-button" aria-hidden="true"></i>
                        </span>
                        <div>
                            <span class="profile-section-kicker">Sign-in protection</span>
                            <h3>Two-step verification</h3>
                            <p>Manage the Microsoft Authenticator verification step for this account.</p>
                        </div>
                    </header>

                    <div class="profile-security-overview">
                        <span class="profile-security-overview-icon">
                            <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                        </span>
                        <div>
                            <span>Security status</span>
                            <h4 id="profileSecurityStatusTitle">Password protection active</h4>
                            <p id="profileSecurityStatusText">
                                Enable Microsoft Authenticator to add a second sign-in verification step.
                            </p>
                        </div>
                        <span class="profile-security-status-dot" id="profileSecurityStatusDot" aria-hidden="true"></span>
                    </div>

                    <section class="profile-mfa-card" aria-labelledby="profileMfaTitle">
                        <div class="profile-mfa-copy">
                            <span class="profile-mfa-icon">
                                <i class="fa-solid fa-mobile-screen-button" aria-hidden="true"></i>
                            </span>
                            <div>
                                <span class="profile-section-kicker">Microsoft Authenticator</span>
                                <h4 id="profileMfaTitle">Authenticator verification</h4>
                                <p id="profileMfaStatusText">
                                    Add a 6-digit Microsoft Authenticator code after your password.
                                </p>
                            </div>
                        </div>

                        <div class="profile-mfa-actions">
                            <span class="profile-mfa-status" id="profileMfaStatusBadge">Not enabled</span>

                            <button class="btn btn-primary" type="button" id="mfaSetupBtn">
                                <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                                Enable authenticator
                            </button>

                            <button class="btn btn-secondary" type="button" id="mfaDisableBtn" hidden>
                                <i class="fa-solid fa-ban" aria-hidden="true"></i>
                                Disable authenticator
                            </button>
                        </div>
                    </section>

                    <div class="profile-mfa-benefits">
                        <article>
                            <i class="fa-solid fa-mobile-screen" aria-hidden="true"></i>
                            <div>
                                <strong>Authenticator app</strong>
                                <span>Use a rotating six-digit code from your mobile device.</span>
                            </div>
                        </article>
                        <article>
                            <i class="fa-solid fa-user-lock" aria-hidden="true"></i>
                            <div>
                                <strong>Additional identity check</strong>
                                <span>A password alone will not be sufficient to access the account.</span>
                            </div>
                        </article>
                        <article>
                            <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
                            <div>
                                <strong>Protected setup flow</strong>
                                <span>Activation and deactivation require explicit verification.</span>
                            </div>
                        </article>
                    </div>
                </section>
            </div>

            <footer class="profile-actions" id="profileActionBar">
                <span class="profile-action-note" id="profileActionHint">
                    <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
                    Only changed fields will be updated.
                </span>

                <div>
                    <button class="btn btn-secondary" type="button" id="profileResetBtn">
                        <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
                        Reset
                    </button>

                    <button class="btn btn-primary" type="submit" id="profileSaveBtn">
                        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                        Save profile
                    </button>
                </div>
            </footer>
        </form>

        <div
            class="profile-crop-modal"
            id="profileCropPanel"
            role="dialog"
            aria-modal="true"
            aria-labelledby="profileCropTitle"
            hidden
        >
            <button
                type="button"
                class="profile-crop-backdrop"
                id="profileCropBackdrop"
                aria-label="Cancel photo framing"
            ></button>

            <div class="profile-crop-dialog">
                <header class="profile-crop-header">
                    <div>
                        <span>Profile photo</span>
                        <strong id="profileCropTitle">Adjust framing</strong>
                    </div>
                    <button
                        type="button"
                        class="profile-crop-close"
                        id="profileCropCancelBtn"
                        aria-label="Cancel photo framing"
                    >
                        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                    </button>
                </header>

                <div class="profile-crop-stage" id="profileCropStage" aria-label="Profile photo framing area">
                    <img id="profileCropImage" alt="" />
                    <span class="profile-crop-ring" aria-hidden="true"></span>
                </div>

                <div class="profile-crop-controls">
                    <label for="profileCropZoom">Zoom</label>
                    <input type="range" id="profileCropZoom" min="1" max="3" step="0.01" value="1" />
                </div>

                <div class="profile-crop-actions">
                    <button class="btn btn-secondary" type="button" id="profileCropResetBtn">
                        <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i>
                        Reset
                    </button>
                    <button class="btn btn-primary" type="button" id="profileCropApplyBtn">
                        <i class="fa-solid fa-check" aria-hidden="true"></i>
                        Use photo
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/perfil.js?v=20260714-profile-segmented-premium-v6" is:inline></script>
</DashboardLayout>
