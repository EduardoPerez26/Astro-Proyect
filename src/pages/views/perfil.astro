---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Perfil de Usuario - Sistema de Inventario">
    <div class="page-header">
        <div class="page-header-left">
            <h1 class="page-title">Perfil de Usuario</h1>
            <p class="page-subtitle">Gestiona tu información, revisa actividades recientes y cambia entre vistas de usuario.</p>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-primary" type="button" id="editProfileBtn">Editar Perfil</button>
        </div>
    </div>

    <div class="profile-summary card">
        <div class="card-body profile-card">
            <div class="profile-row">
                <strong>Nombre completo</strong>
                <span id="profileName">Cargando...</span>
            </div>
            <div class="profile-row">
                <strong>Usuario</strong>
                <span id="profileUsername">Cargando...</span>
            </div>
            <div class="profile-row">
                <strong>Email</strong>
                <span id="profileEmail">Cargando...</span>
            </div>
            <div class="profile-row">
                <strong>Rol</strong>
                <span id="profileRole">Cargando...</span>
            </div>
            <div class="profile-row">
                <strong>Último inicio</strong>
                <span id="profileLastLogin">No disponible</span>
            </div>
        </div>
    </div>

    <div class="card profile-card">
        <div class="card-body">
            <div class="profile-tabs">
                <button class="profile-tab active" data-tab="tab-info">Información</button>
                <button class="profile-tab" data-tab="tab-security">Seguridad</button>
            </div>

            <div class="profile-tab-panel active" id="tab-info">
                <h2 class="profile-section-title">Detalles del perfil</h2>
                <p class="profile-section-text">Revisa los datos de tu cuenta y asegúrate de que estén actualizados.</p>
                <div class="profile-tab-list">
                    <div class="profile-activity-card">
                        <div>
                            <strong>Nombre completo</strong>
                            <small id="infoName">-</small>
                        </div>
                        <span class="badge badge-approved">Activo</span>
                    </div>
                    <div class="profile-activity-card">
                        <div>
                            <strong>Email</strong>
                            <small id="infoEmail">-</small>
                        </div>
                        <span class="badge badge-approved">Verificado</span>
                    </div>
                </div>
            </div>

            <div class="profile-tab-panel" id="tab-security">
                <h2 class="profile-section-title">Seguridad y acceso</h2>
                <p class="profile-section-text">Controla tu contraseña, sesión activa y métodos de autenticación.</p>
                <div class="profile-tab-list">
                    <div class="profile-activity-card">
                        <div>
                            <strong>Contraseña</strong>
                            <small>Actualizada recientemente</small>
                        </div>
                        <button class="btn btn-secondary">Cambiar</button>
                    </div>
                    <div class="profile-activity-card">
                        <div>
                            <strong>Sesiones activas</strong>
                            <small>1 sesión en este navegador</small>
                        </div>
                        <button class="btn btn-secondary">Cerrar otras</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script type="module">
        const API_URL = 'http://localhost:3001/api';
        const token = localStorage.getItem('token');
        const modoOffline = localStorage.getItem('modoOffline');

        function setProfileData(usuario) {
            const profileMap = {
                profileName: usuario.nombre_completo || usuario.nombre || 'No disponible',
                profileUsername: usuario.username || 'No disponible',
                profileEmail: usuario.email || 'No disponible',
                profileRole: usuario.rol || 'Usuario',
                infoName: usuario.nombre_completo || usuario.nombre || 'No disponible',
                infoEmail: usuario.email || 'No disponible'
            };

            Object.entries(profileMap).forEach(([id, value]) => {
                const element = document.getElementById(id);
                if (element) element.textContent = value;
            });
        }

        function loadLocalProfile() {
            const usuario = JSON.parse(localStorage.getItem('usuario') || '{}');
            setProfileData(usuario);
        }

        async function loadProfileFromServer() {
            if (!token || modoOffline) {
                loadLocalProfile();
                return;
            }

            try {
                const response = await fetch(`${API_URL}/auth/profile`, {
                    method: 'GET',
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (!response.ok) {
                    loadLocalProfile();
                    return;
                }

                const data = await response.json();
                if (data.error) {
                    loadLocalProfile();
                    return;
                }

                setProfileData(data.usuario);
            } catch (error) {
                console.error('Error cargando perfil:', error);
                loadLocalProfile();
            }
        }

        loadProfileFromServer();

        const tabs = document.querySelectorAll('.profile-tab');
        const panels = document.querySelectorAll('.profile-tab-panel');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(btn => btn.classList.remove('active'));
                panels.forEach(panel => panel.classList.remove('active'));
                tab.classList.add('active');
                const target = document.getElementById(tab.dataset.tab);
                if (target) target.classList.add('active');
            });
        });

        const editProfileBtn = document.getElementById('editProfileBtn');
        if (editProfileBtn) {
            editProfileBtn.addEventListener('click', () => {
                const perfilTab = document.querySelector('[data-tab="tab-info"]');
                if (perfilTab) perfilTab.click();
            });
        }
    </script>
</DashboardLayout>
