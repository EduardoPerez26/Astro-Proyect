---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Chat">
    <div class="chat-page">
        <section class="chat-shell">
            <aside class="chat-sidebar">
                <div class="chat-sidebar-header">
                    <div>
                        <span>Messages</span>
                        <h2>Conversations</h2>
                    </div>
                    <button
                        class="chat-new-icon-btn"
                        type="button"
                        onclick="openNewChatModal()"
                        data-permission-module="chat"
                        data-permission-action="crear"
                        aria-label="Start new chat"
                        title="Start new chat"
                    >
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </div>

                <div class="chat-search">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input
                        type="text"
                        id="chatSearchInput"
                        placeholder="Search conversations..."
                        autocomplete="off"
                    />
                </div>

                <div id="chatConversations" class="chat-conversations">
                    <div class="chat-empty">
                        <i class="fa-solid fa-spinner fa-spin"></i>
                        Loading conversations...
                    </div>
                </div>
            </aside>

            <main class="chat-main">
                <div id="chatEmptyState" class="chat-empty-state">
                    <div class="chat-empty-icon">
                        <i class="fa-solid fa-comments"></i>
                    </div>
                    <h2>Select a conversation</h2>
                    <p>
                        Choose a chat from the left side or create a new
                        conversation.
                    </p>
                    <button
                        class="btn btn-primary"
                        type="button"
                        onclick="openNewChatModal()"
                        data-permission-module="chat"
                        data-permission-action="crear"
                    >
                        <i class="fa-solid fa-plus"></i>
                        Start new chat
                    </button>
                </div>

                <div id="chatWindow" class="chat-window" hidden>
                    <div class="chat-window-header">
                        <div class="chat-current-user">
                            <div
                                class="chat-current-avatar"
                                id="chatCurrentAvatar"
                            >
                                <i class="fa-solid fa-user"></i>
                            </div>

                            <div>
                                <span>Conversation</span>
                                <h2 id="chatTitle">Chat</h2>
                                <p id="chatSubtitle">Internal message thread</p>
                            </div>
                        </div>
                    </div>

                    <div id="chatMessages" class="chat-messages"></div>

                    <div
                        id="chatTypingIndicator"
                        class="chat-typing-indicator"
                        hidden
                    >
                        <span id="chatTypingText">Someone is typing</span>
                        <span class="typing-dots">
                            <i></i>
                            <i></i>
                            <i></i>
                        </span>
                    </div>

                    <form id="chatForm" class="chat-form" data-permission-module="chat" data-permission-action="crear">
                        <div class="chat-input-wrap">
                            <input
                                type="text"
                                id="chatMessageInput"
                                placeholder="Write a message..."
                                autocomplete="off"
                                maxlength="1000"
                            />
                        </div>

                        <button
                            class="btn btn-primary chat-send-btn"
                            type="submit"
                        >
                            <i class="fa-solid fa-paper-plane"></i>
                            Send
                        </button>
                    </form>
                </div>
            </main>
        </section>
    </div>
    <script src="/js/chat.js?v=20260723-typing-poll-throttle" is:inline></script>
</DashboardLayout>
