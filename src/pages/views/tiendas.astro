---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StoreCard from '../../components/StoreCard.astro';

const stores = [
    {
        id: 1,
        name: "Taco Bell",
        description: "Comida rapida mexicana",
        icon: "fa-utensils",
        colorClass: "primary",
        restaurant: "taco-bell"
    },
    {
        id: 2,
        name: "Burger King",
        description: "Hamburguesas y mas",
        icon: "fa-burger",
        colorClass: "warning",
        restaurant: "burger-king"
    },
    {
        id: 3,
        name: "Popeyes",
        description: "Pollo frito estilo Louisiana",
        icon: "fa-drumstick-bite",
        colorClass: "danger",
        restaurant: "popeyes"
    },
    {
        id: 4,
        name: "KFC",
        description: "Kentucky Fried Chicken",
        icon: "fa-bowl-food",
        colorClass: "success",
        restaurant: "kfc"
    }
];
---

<DashboardLayout title="Tiendas - Sistema de Inventario">
    <section class="tab active" id="tiendas">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left">
                <h1 class="page-title">Tiendas</h1>
                <p class="page-subtitle">Gestiona y supervisa todas las sucursales del sistema</p>
            </div>
        </div>

        <!-- Store Cards Grid -->
        <div class="cards-grid" style="grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));">
            {stores.map((store) => (
                <StoreCard {...store} />
            ))}
        </div>
    </section>
</DashboardLayout>
