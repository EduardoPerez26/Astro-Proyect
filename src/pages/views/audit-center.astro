---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import PageHeader from '../../components/corporate/PageHeader.astro';
import MetricCard from '../../components/corporate/MetricCard.astro';
---

<DashboardLayout title="Operational audit">
    <div class="page-container corporate-page" data-corporate-center="audit">
        <PageHeader eyebrow="Information Technology" title="Operational audit" description="Immutable, request-correlated traceability for business workflow changes, security-sensitive operations, and administrative decisions." icon="fa-timeline">
            <button slot="actions" id="auditRefresh" type="button"><i class="fa-solid fa-rotate"></i> Refresh</button>
            <button slot="actions" id="auditExport" type="button"><i class="fa-solid fa-file-csv"></i> Export</button>
        </PageHeader>

        <section class="xb-metric-grid">
            <MetricCard label="Total events" value="0" meta="Operational audit records" icon="fa-list" valueId="auditTotal" />
            <MetricCard label="Last 24 hours" value="0" meta="Recent controlled changes" icon="fa-clock-rotate-left" valueId="audit24h" />
            <MetricCard label="Users" value="0" meta="Distinct actors" icon="fa-users" valueId="auditUsers" />
            <MetricCard label="Resource types" value="0" meta="Audited domains" icon="fa-cubes" valueId="auditResources" />
        </section>

        <article class="xb-panel">
            <header class="xb-panel__header"><div><span class="xb-panel__eyebrow">Traceability</span><h2>Audit events</h2><p>Search by action, resource, user, request ID, or business record.</p></div></header>
            <div class="xb-toolbar" data-saved-view-module="audit">
                <label class="xb-field xb-field--grow"><span>Search</span><input id="auditSearch" type="search" placeholder="User, resource, request ID..." /></label>
                <label class="xb-field"><span>Action</span><input id="auditAction" type="text" placeholder="exception_updated" /></label>
            </div>
            <div class="xb-table-wrap">
                <table class="xb-table"><thead><tr><th>Date</th><th>Actor</th><th>Action</th><th>Resource</th><th>Department</th><th>Request ID</th><th>Change</th></tr></thead><tbody id="auditBody"><tr><td colspan="7"><div class="xb-loading-state"><div><i class="fa-solid fa-spinner fa-spin"></i><strong>Loading audit events</strong></div></div></td></tr></tbody></table>
            </div>
        </article>
    </div>
    <script src="/js/corporate-centers.js?v=20260717-corporate-v1" is:inline></script>
</DashboardLayout>
