        <script is:inline src="/js/conciliacion-burgerking.js"></script>

        <script is:inline src="/js/conciliacion.js"></script>
        <script is:inline>
            (() => {
                if (window.__taxStoreModalDelegateReady) return;
                window.__taxStoreModalDelegateReady = true;

                const configs = [
                    {
                        dialogId: 'popeyesTaxStoreDialog',
                        addId: 'pyTaxAddStore',
                        saveId: 'pyTaxSaveStore',
                        clearId: 'pyTaxClearStore',
                        numberId: 'pyTaxStoreNumber',
                        formModeId: 'pyTaxFormMode',
                        editSelector: '[data-py-tax-edit]',
                        editDataset: 'pyTaxEdit',
                        clearFn: 'limpiarFormularioTiendaTaxPopeyes',
                        loadFn: 'cargarFormularioTiendaTaxPopeyes',
                        readFn: 'leerFormularioTiendaTaxPopeyes',
                        upsertFn: 'upsertTiendaTaxPopeyes',
                        renderFn: 'renderTiendasTaxPopeyes',
                        statusFn: 'mostrarEstadoTaxPopeyes',
                        recalcFn: 'recalcularTaxReviewPopeyesSiAplica'
                    },
                    {
                        dialogId: 'tacoBellTaxStoreDialog',
                        addId: 'tbTaxAddStore',
                        saveId: 'tbTaxSaveStore',
                        clearId: 'tbTaxClearStore',
                        numberId: 'tbTaxStoreNumber',
                        formModeId: 'tbTaxFormMode',
                        editSelector: '[data-tb-tax-edit]',
                        editDataset: 'tbTaxEdit',
                        clearFn: 'limpiarFormularioTiendaTaxTacoBell',
                        loadFn: 'cargarFormularioTiendaTaxTacoBell',
                        readFn: 'leerFormularioTiendaTaxTacoBell',
                        upsertFn: 'upsertTiendaTaxTacoBell',
                        renderFn: 'renderTiendasTaxTacoBell',
                        statusFn: 'mostrarEstadoTaxTacoBell',
                        recalcFn: 'recalcularTaxReviewTacoBellSiAplica'
                    },
                    {
                        dialogId: 'burgerKingTaxStoreDialog',
                        addId: 'bkTaxAddStore',
                        saveId: 'bkTaxSaveStore',
                        clearId: 'bkTaxClearStore',
                        numberId: 'bkTaxStoreNumber',
                        formModeId: 'bkTaxFormMode',
                        editSelector: '[data-bk-tax-edit]',
                        editDataset: 'bkTaxEdit',
                        clearFn: 'limpiarFormularioTiendaTaxBurgerKing',
                        loadFn: 'cargarFormularioTiendaTaxBurgerKing',
                        readFn: 'leerFormularioTiendaTaxBurgerKing',
                        upsertFn: 'upsertTiendaTaxBurgerKing',
                        renderFn: 'renderTiendasTaxBurgerKing',
                        statusFn: 'mostrarEstadoTaxBurgerKing'
                    }
                ];

                const callTaxFn = (name, ...args) => {
                    const fn = window[name];
                    return typeof fn === 'function' ? fn(...args) : undefined;
                };

                const setTaxFormOpen = (config, isOpen) => {
                    const dialog = document.getElementById(config.dialogId);
                    const form = dialog?.querySelector('.bk-tax-store-form');

                    dialog?.classList.toggle('is-form-open', isOpen);

                    if (form) {
                        form.style.display = isOpen ? 'grid' : '';
                    }

                    if (isOpen) {
                        requestAnimationFrame(() => {
                            document.getElementById(config.numberId)?.focus();
                        });
                    }
                };

                const setTaxFormMode = (config, text) => {
                    const mode = document.getElementById(config.formModeId);

                    if (mode) {
                        mode.textContent = text;
                    }
                };

                document.addEventListener('click', event => {
                    const target =
                        event.target instanceof Element
                            ? event.target
                            : null;

                    if (!target) return;

                    for (const config of configs) {
                        const addButton = target.closest(`#${config.addId}`);
                        const saveButton = target.closest(`#${config.saveId}`);
                        const clearButton = target.closest(`#${config.clearId}`);
                        const editButton = target.closest(config.editSelector);

                        if (!addButton && !saveButton && !clearButton && !editButton) {
                            continue;
                        }

                        event.preventDefault();
                        event.stopPropagation();
                        event.stopImmediatePropagation();

                        if (addButton) {
                            callTaxFn(config.clearFn);
                            setTaxFormMode(config, 'Nueva tienda');
                            setTaxFormOpen(config, true);
                            callTaxFn(
                                config.statusFn,
                                'Captura los datos de la tienda nueva.'
                            );
                            return;
                        }

                        if (editButton) {
                            const store = editButton.dataset[config.editDataset];
                            callTaxFn(
                                config.loadFn,
                                store
                            );
                            setTaxFormMode(config, `Editando tienda ${store}`);
                            setTaxFormOpen(config, true);
                            callTaxFn(
                                config.statusFn,
                                'Editando tienda seleccionada.'
                            );
                            return;
                        }

                        if (clearButton) {
                            callTaxFn(config.clearFn);
                            setTaxFormMode(config, 'Nueva tienda');
                            setTaxFormOpen(config, false);
                            callTaxFn(config.statusFn, 'Edicion cancelada.');
                            return;
                        }

                        if (saveButton) {
                            try {
                                const storeData = callTaxFn(config.readFn);
                                callTaxFn(config.upsertFn, storeData);
                                callTaxFn(config.renderFn);
                                callTaxFn(config.recalcFn);
                                callTaxFn(
                                    config.statusFn,
                                    'Tienda guardada correctamente.',
                                    'success'
                                );
                                callTaxFn(config.clearFn);
                                setTaxFormMode(config, 'Nueva tienda');
                                setTaxFormOpen(config, false);
                            } catch (error) {
                                callTaxFn(config.statusFn, error.message, 'error');

                                if (window.Swal) {
                                    Swal.fire(
                                        'Revisa la tienda',
                                        error.message,
                                        'warning'
                                    );
                                }
                            }

                            return;
                        }
                    }
                }, true);
            })();
        </script>
