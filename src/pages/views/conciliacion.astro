---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Conciliacion">
    <div class="page-container">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Libro de conciliación de ventas</h1>
                <p>
                    Carga fuentes operativas, valida diferencias y prepara el
                    asiento para revisión contable.
                </p>
            </div>
        </div>

        <!-- Selector de Restaurante y Template -->
        <div class="conciliacion-config">
            <div class="section-heading">
                <span class="step-badge">1</span>
                <div>
                    <h2>Seleccion</h2>
                    <p>Define restaurante y template.</p>
                </div>
            </div>
            <div class="config-card">
                <div class="config-row">
                    <div class="form-group">
                        <label for="selectRestaurante">Restaurante</label>
                        <select id="selectRestaurante" class="form-select">
                            <option value=""
                                >Selecciona un restaurante...</option
                            >
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="selectTemplate">Template</label>
                        <select
                            id="selectTemplate"
                            class="form-select"
                            disabled
                        >
                            <option value=""
                                >Selecciona primero un restaurante</option
                            >
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Zona de Upload -->
        <div class="upload-section" id="uploadSection">
            <div class="section-heading">
                <span class="step-badge">2</span>
                <div>
                    <h2>Archivos</h2>
                    <p>Los campos cambian segun el restaurante seleccionado.</p>
                </div>
                <span class="mode-badge" id="uploadModeBadge"
                    >Selecciona restaurante</span
                >
            </div>

            <div class="multi-upload-container">
                <div class="upload-card" id="salesUploadCard">
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-file-excel"></i>
                            Archivo principal
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill required">Requerido</span>
                            <button
                                class="upload-remove-btn"
                                id="removeSalesFile"
                                type="button"
                                title="Eliminar archivo principal"
                                aria-label="Eliminar archivo principal"
                                hidden
                            >
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </span>
                    </div>

                    <input
                        type="file"
                        id="salesFile"
                        accept=".xlsx,.xls,.csv"
                    />

                    <select
                        id="salesDateFilter"
                        class="form-select upload-date-filter"
                    >
                        <option value="">Todas las fechas</option>
                    </select>
                </div>

                <div
                    class="upload-card taco-bell-extra-upload"
                    id="salesDetailUploadCard"
                    style="display:none;"
                >
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-table-list"></i>
                            Sales Detail Export
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill">Taco Bell</span>
                            <button
                                class="upload-remove-btn"
                                id="removeSalesDetailFile"
                                type="button"
                                title="Eliminar Sales Detail Export"
                                aria-label="Eliminar Sales Detail Export"
                                hidden
                            >
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </span>
                    </div>

                    <input
                        type="file"
                        id="salesDetailFile"
                        accept=".xlsx,.xls"
                    />

                    <select
                        id="salesDetailDateFilter"
                        class="form-select upload-date-filter"
                    >
                        <option value="">Todas las fechas</option>
                    </select>
                </div>

                <div
                    class="upload-card taco-bell-extra-upload"
                    id="ebtUploadCard"
                    style="display:none;"
                >
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-credit-card"></i>
                            Archivo EBT
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill optional">Opcional</span>
                            <button
                                class="upload-remove-btn"
                                id="removeEbtFile"
                                type="button"
                                title="Eliminar archivo EBT"
                                aria-label="Eliminar archivo EBT"
                                hidden
                            >
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </span>
                    </div>

                    <input type="file" id="ebtFile" accept=".xlsx,.xls" />

                    <select
                        id="ebtDateFilter"
                        class="form-select upload-date-filter"
                    >
                        <option value="">Todas las fechas</option>
                    </select>
                </div>
            </div>

            <!-- Archivo cargado -->
            <div class="file-loaded" id="fileLoaded" style="display: none;">
                <div class="file-loaded-info">
                    <div class="file-loaded-icon">
                        <i class="fa-solid fa-file-excel"></i>
                    </div>
                    <div class="file-loaded-details">
                        <span class="file-loaded-name" id="fileName"
                            >archivo.xlsx</span
                        >
                        <span class="file-loaded-size" id="fileSize">0 KB</span>
                    </div>
                </div>
                <button class="btn btn-danger btn-sm" id="btnRemoveFile">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
        </div>

        <!-- Tabla de Conciliacion -->
        <div
            class="conciliacion-results"
            id="resultsSection"
            style="display: none;"
        >
            <!-- Resumen -->
            <div class="section-heading results-heading">
                <span class="step-badge">3</span>
                <div>
                    <h2>Revision</h2>
                    <p>
                        Revisa totales, filtra tiendas y exporta el resultado.
                    </p>
                </div>
            </div>

            <div class="results-summary">
                <div class="summary-card total">
                    <div class="summary-icon">
                        <i class="fa-solid fa-list-check"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="totalConceptos">0</span>
                        <span class="summary-label">Conceptos</span>
                    </div>
                </div>
                <div class="summary-card success">
                    <div class="summary-icon">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="conceptosOk">0</span>
                        <span class="summary-label">Correctos</span>
                    </div>
                </div>
                <div class="summary-card warning">
                    <div class="summary-icon">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="conceptosDiferencia"
                            >0</span
                        >
                        <span class="summary-label">Con Diferencia</span>
                    </div>
                </div>
                <div class="summary-card status is-clear" id="osStatusCard">
                    <div class="summary-icon">
                        <i class="fa-solid fa-scale-balanced" id="osStatusIcon"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value summary-status-value" id="osDifferenceStatus">Sin diferencias</span>
                        <span class="summary-label" id="osDifferenceMeta">O/S balanceado</span>
                    </div>
                </div>
                <div class="summary-card danger">
                    <div class="summary-icon">
                        <i class="fa-solid fa-dollar-sign"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="totalDiferencia"
                            >$0.00</span
                        >
                        <span class="summary-label">Total Diferencia</span>
                    </div>
                </div>
            </div>

            <section
                class="reconciliation-compare-panel"
                id="conciliationComparisonPanel"
                data-state="pendiente"
            >
                <div class="reconciliation-compare-icon">
                    <i class="fa-solid fa-code-compare" id="conciliationComparisonIcon"></i>
                </div>
                <div class="reconciliation-compare-copy">
                    <span>CONTROL DE CAMBIOS</span>
                    <strong id="conciliationComparisonTitle">
                        Comparar con la última conciliación
                    </strong>
                    <p id="conciliationComparisonText">
                        Busca una referencia del mismo restaurante y fecha antes de guardar.
                    </p>
                </div>
                <button
                    type="button"
                    class="btn btn-secondary reconciliation-compare-button"
                    id="btnCompararConciliacion"
                >
                    <i class="fa-solid fa-magnifying-glass-chart"></i>
                    Comparar ahora
                </button>
            </section>

            <!-- FILTRO POR TIENDA Y POR NUM DE TIENDA -->
            <div class="filters-container">
                <div class="form-group">
                    <label>Tienda</label>
                    <select id="filterStore" class="form-select">
                        <option value="">Todas las tiendas</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Nombre tienda</label>
                    <input
                        type="text"
                        id="filterStoreName"
                        class="form-input"
                        placeholder="Buscar sucursal..."
                    />
                </div>
            </div>

            <div class="sheet-tabs-panel">
                <div
                    id="tacoBellTabs"
                    class="tabs-container"
                    style="display:none;"
                >
                    <button class="tab-btn active" data-tab="dailySales">
                        Daily Sales
                    </button>
                    <button class="tab-btn" data-tab="dailySalesRed">
                        Daily Sales RED
                    </button>
                    <button class="tab-btn" data-tab="taxReview">
                        Tax Review
                    </button>
                    <button class="tab-btn" data-tab="statisticalDelivery">
                        Statistical Delivery
                    </button>
                    <button class="tab-btn" data-tab="dailySales0314">
                        Daily Sales 03-14
                    </button>
                    <button class="tab-btn" data-tab="dailySales0310">
                        Daily Sales 03-10
                    </button>
                </div>

                <div
                    id="popeyesTabs"
                    class="tabs-container"
                    style="display:none;"
                >
                    <button
                        class="tab-btn popeyes-tab-btn active"
                        data-tab="conciliation"
                    >
                        Conciliation
                    </button>
                    <button
                        class="tab-btn popeyes-tab-btn"
                        data-tab="taxReview"
                    >
                        Tax Review
                    </button>
                    <button
                        class="tab-btn popeyes-tab-btn"
                        data-tab="dailySalesRed"
                    >
                        Daily Sales Popeyes Red
                    </button>
                    <button
                        class="tab-btn popeyes-tab-btn"
                        data-tab="dailySales0404"
                    >
                        Daily Sales Popeyes 04-04-2026
                    </button>
                </div>

                <div
                    id="burgerKingTabs"
                    class="tabs-container"
                    style="display:none;"
                >
                    <button class="tab-btn active" data-tab="summary">
                        Summary
                    </button>

                    <button class="tab-btn" data-tab="conciliation">
                        Conciliation
                    </button>

                    <button class="tab-btn" data-tab="taxAnalysis">
                        Tax Analysis
                    </button>

                    <button class="tab-btn" data-tab="discrepancies">
                        Discrepancies
                    </button>

                    <button class="tab-btn" data-tab="templateCsv">
                        Template to CSV
                    </button>
                </div>
            </div>

            <section
                class="bk-tax-store-panel"
                id="popeyesTaxStorePanel"
                style="display:none;"
            >
                <div class="bk-tax-store-panel-copy">
                    <span>POPEYES</span>
                    <strong>Tax Rate por tienda</strong>
                    <small>El Tax Review usa rates locales; CDTFA se actualiza manualmente.</small>
                </div>
                <button class="btn btn-secondary" type="button" id="pyTaxOpenModal">
                    <i class="fa-solid fa-store"></i>
                    Administrar tiendas
                </button>
            </section>

            <dialog
                id="popeyesTaxStoreDialog"
                class="bk-tax-store-dialog"
                aria-labelledby="pyTaxStoreDialogTitle"
            >
                <section class="bk-tax-store-window">
                    <header class="bk-tax-store-header">
                        <div>
                            <span>POPEYES</span>
                            <h3 id="pyTaxStoreDialogTitle">Tiendas y tax rate</h3>
                            <p>
                                Administra el listado local de tiendas que usa la conciliacion.
                                CDTFA se actualiza solo cuando presionas el boton de actualizar.
                            </p>
                        </div>
                        <div class="bk-tax-store-meta">
                            <strong id="pyTaxStoreCount">0 tiendas configuradas</strong>
                            <small id="pyTaxStoreStatus" data-type="info">
                                Listo para trabajar con rates locales.
                            </small>
                        </div>
                        <button
                            type="button"
                            id="pyTaxCloseModal"
                            class="bk-tax-modal-close"
                            aria-label="Cerrar catálogo de tiendas Popeyes"
                        >
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </header>

                    <div class="bk-tax-store-form">
                        <div class="bk-tax-form-head">
                            <strong>Datos de tienda</strong>
                            <small id="pyTaxFormMode">Nueva tienda</small>
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreNumber">Tienda</label>
                            <input id="pyTaxStoreNumber" class="form-input" type="text" placeholder="2902" />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreAddress">Direccion</label>
                            <input id="pyTaxStoreAddress" class="form-input" type="text" placeholder="Direccion" />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreCity">Ciudad</label>
                            <input id="pyTaxStoreCity" class="form-input" type="text" placeholder="Ciudad" />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreZip">Zip</label>
                            <input id="pyTaxStoreZip" class="form-input" type="text" placeholder="95823" />
                        </div>

                        <div class="form-group bk-tax-coordinates">
                            <label for="pyTaxStoreCoordinates">Coordenadas</label>
                            <input id="pyTaxStoreCoordinates" class="form-input" type="text" placeholder="38.494835, -121.427995" />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreRate">Tax Rate</label>
                            <input id="pyTaxStoreRate" class="form-input" type="text" placeholder="7.75% o 0.0775" />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreJurisdiction">Jurisdiccion</label>
                            <input id="pyTaxStoreJurisdiction" class="form-input" type="text" placeholder="Opcional" />
                        </div>

                        <div class="bk-tax-form-actions">
                            <button class="btn btn-primary bk-tax-form-action" type="button" id="pyTaxSaveStore">
                                <i class="fa-solid fa-floppy-disk"></i>
                                Guardar tienda
                            </button>

                            <button class="btn btn-secondary bk-tax-form-action" type="button" id="pyTaxClearStore">
                                Cancelar
                            </button>
                        </div>
                    </div>

                    <div class="bk-tax-store-toolbar">
                        <button class="btn btn-primary bk-tax-add-store" type="button" id="pyTaxAddStore">
                            <i class="fa-solid fa-plus"></i>
                            Agregar tienda
                        </button>

                        <button class="btn btn-secondary" type="button" id="pyTaxRefreshRates">
                            <i class="fa-solid fa-arrows-rotate"></i>
                            Actualizar rates CDTFA
                        </button>

                        <button class="btn btn-danger" type="button" id="pyTaxResetStores">
                            Restaurar catalogo
                        </button>
                    </div>

                    <div class="bk-tax-store-table">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Tienda</th>
                                    <th>Ubicacion</th>
                                    <th>Zip</th>
                                    <th>Coordenadas</th>
                                    <th>Override</th>
                                    <th>Tax Rate</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="pyTaxStoreBody"></tbody>
                        </table>
                    </div>

                    <footer class="bk-tax-store-footer">
                        <small>Los cambios se guardan en este navegador con localStorage.</small>
                        <button class="btn btn-primary" type="button" id="pyTaxCloseFooter">
                            Listo
                        </button>
                    </footer>
                </section>
            </dialog>

            <section
                class="bk-tax-store-panel"
                id="tacoBellTaxStorePanel"
                style="display:none;"
            >
                <div class="bk-tax-store-panel-copy">
                    <span>TACO BELL</span>
                    <strong>Tax Rate por tienda</strong>
                    <small>CDTFA actualiza tiendas CA; otras tiendas usan rate manual/local.</small>
                </div>
                <button class="btn btn-secondary" type="button" id="tbTaxOpenModal">
                    <i class="fa-solid fa-store"></i>
                    Administrar tiendas
                </button>
            </section>

            <dialog
                id="tacoBellTaxStoreDialog"
                class="bk-tax-store-dialog"
                aria-labelledby="tbTaxStoreDialogTitle"
            >
                <section class="bk-tax-store-window">
                    <header class="bk-tax-store-header">
                        <div>
                            <span>TACO BELL</span>
                            <h3 id="tbTaxStoreDialogTitle">Tiendas y tax rate</h3>
                            <p>
                                Administra el listado local de tiendas que usa la conciliacion.
                                CDTFA se actualiza solo cuando presionas el boton de actualizar.
                            </p>
                        </div>
                        <div class="bk-tax-store-meta">
                            <strong id="tbTaxStoreCount">0 tiendas configuradas</strong>
                            <small id="tbTaxStoreStatus" data-type="info">
                                Listo para trabajar con rates locales.
                            </small>
                        </div>
                        <button
                            type="button"
                            id="tbTaxCloseModal"
                            class="bk-tax-modal-close"
                            aria-label="Cerrar catálogo de tiendas Taco Bell"
                        >
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </header>

                    <div class="bk-tax-store-form">
                        <div class="bk-tax-form-head">
                            <strong>Datos de tienda</strong>
                            <small id="tbTaxFormMode">Nueva tienda</small>
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreNumber">Tienda</label>
                            <input id="tbTaxStoreNumber" class="form-input" type="text" placeholder="28841" />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreAddress">Direccion</label>
                            <input id="tbTaxStoreAddress" class="form-input" type="text" placeholder="Direccion" />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreCity">Ciudad</label>
                            <input id="tbTaxStoreCity" class="form-input" type="text" placeholder="Ciudad" />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreState">Estado</label>
                            <input id="tbTaxStoreState" class="form-input" type="text" placeholder="CA" />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreZip">Zip</label>
                            <input id="tbTaxStoreZip" class="form-input" type="text" placeholder="95688" />
                        </div>

                        <div class="form-group bk-tax-coordinates">
                            <label for="tbTaxStoreCoordinates">Coordenadas</label>
                            <input id="tbTaxStoreCoordinates" class="form-input" type="text" placeholder="38.363685, -121.968236" />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreRate">Tax Rate</label>
                            <input id="tbTaxStoreRate" class="form-input" type="text" placeholder="8.125% o 0.08125" />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreJurisdiction">Jurisdiccion</label>
                            <input id="tbTaxStoreJurisdiction" class="form-input" type="text" placeholder="Opcional" />
                        </div>

                        <div class="bk-tax-form-actions">
                            <button class="btn btn-primary bk-tax-form-action" type="button" id="tbTaxSaveStore">
                                <i class="fa-solid fa-floppy-disk"></i>
                                Guardar tienda
                            </button>

                            <button class="btn btn-secondary bk-tax-form-action" type="button" id="tbTaxClearStore">
                                Cancelar
                            </button>
                        </div>
                    </div>

                    <div class="bk-tax-store-toolbar">
                        <button class="btn btn-primary bk-tax-add-store" type="button" id="tbTaxAddStore">
                            <i class="fa-solid fa-plus"></i>
                            Agregar tienda
                        </button>

                        <button class="btn btn-secondary" type="button" id="tbTaxRefreshRates">
                            <i class="fa-solid fa-arrows-rotate"></i>
                            Actualizar rates CDTFA
                        </button>

                        <button class="btn btn-danger" type="button" id="tbTaxResetStores">
                            Restaurar catalogo
                        </button>
                    </div>

                    <div class="bk-tax-store-table">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Tienda</th>
                                    <th>Ubicacion</th>
                                    <th>Estado</th>
                                    <th>Zip</th>
                                    <th>Coordenadas</th>
                                    <th>Override</th>
                                    <th>Tax Rate</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="tbTaxStoreBody"></tbody>
                        </table>
                    </div>

                    <footer class="bk-tax-store-footer">
                        <small>Los cambios se guardan en este navegador con localStorage.</small>
                        <button class="btn btn-primary" type="button" id="tbTaxCloseFooter">
                            Listo
                        </button>
                    </footer>
                </section>
            </dialog>

            <section
                class="bk-tax-store-panel"
                id="burgerKingTaxStorePanel"
                style="display:none;"
            >
                <div class="bk-tax-store-panel-copy">
                    <span>BURGER KING</span>
                    <strong>Tax Rate por tienda</strong>
                    <small>La conciliación usa rates locales. CDTFA solo se actualiza manualmente.</small>
                </div>
                <button class="btn btn-secondary" type="button" id="bkTaxOpenModal">
                    <i class="fa-solid fa-store"></i>
                    Administrar tiendas
                </button>
            </section>

            <dialog
                id="burgerKingTaxStoreDialog"
                class="bk-tax-store-dialog"
                aria-labelledby="bkTaxStoreDialogTitle"
            >
                <section class="bk-tax-store-window">
                    <header class="bk-tax-store-header">
                        <div>
                            <span>BURGER KING</span>
                            <h3 id="bkTaxStoreDialogTitle">Tiendas y tax rate</h3>
                            <p>
                                Administra el listado local de tiendas que usa la conciliacion.
                                CDTFA se actualiza solo cuando presionas el boton de actualizar.
                            </p>
                        </div>
                        <div class="bk-tax-store-meta">
                            <strong id="bkTaxStoreCount">0 tiendas configuradas</strong>
                            <small id="bkTaxStoreStatus" data-type="info">
                                Listo para trabajar con rates locales.
                            </small>
                        </div>
                        <button
                            type="button"
                            id="bkTaxCloseModal"
                            class="bk-tax-modal-close"
                            aria-label="Cerrar catálogo de tiendas"
                        >
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </header>

                    <div class="bk-tax-store-form">
                        <div class="bk-tax-form-head">
                            <strong>Datos de tienda</strong>
                            <small id="bkTaxFormMode">Nueva tienda</small>
                        </div>

                        <div class="form-group">
                            <label for="bkTaxStoreNumber">Tienda</label>
                            <input
                                id="bkTaxStoreNumber"
                                class="form-input"
                                type="text"
                                placeholder="3917"
                            />
                        </div>

                        <div class="form-group">
                            <label for="bkTaxStoreAddress">Direccion</label>
                            <input
                                id="bkTaxStoreAddress"
                                class="form-input"
                                type="text"
                                placeholder="Direccion"
                            />
                        </div>

                        <div class="form-group">
                            <label for="bkTaxStoreCity">Ciudad</label>
                            <input
                                id="bkTaxStoreCity"
                                class="form-input"
                                type="text"
                                placeholder="Ciudad"
                            />
                        </div>

                        <div class="form-group">
                            <label for="bkTaxStoreZip">Zip</label>
                            <input
                                id="bkTaxStoreZip"
                                class="form-input"
                                type="text"
                                placeholder="94585"
                            />
                        </div>

                        <div class="form-group bk-tax-coordinates">
                            <label for="bkTaxStoreCoordinates">Coordenadas</label>
                            <input
                                id="bkTaxStoreCoordinates"
                                class="form-input"
