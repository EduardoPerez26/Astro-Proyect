---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Reconciliation" includeSheetJS={true}>
    <div class="page-container reconciliation-page">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Sales reconciliation ledger</h1>
                <p>
                    Load operational sources, validate differences, and prepare
                    the entry for accounting review.
                </p>
            </div>
        </div>

        <!-- Restaurant and template selector -->
        <div class="conciliacion-config">
            <div class="section-heading">
                <span class="step-badge">1</span>
                <div>
                    <h2>Selection</h2>
                    <p>Define restaurant and template.</p>
                </div>
            </div>
            <div class="config-card">
                <div class="config-row">
                    <div class="form-group">
                        <label for="selectRestaurant">Restaurant</label>
                        <select id="selectRestaurant" class="form-select">
                            <option value="">Select a restaurant...</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="selectTemplate">Template</label>
                        <select
                            id="selectTemplate"
                            class="form-select"
                            disabled
                        >
                            <option value="">Select a restaurant first</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Upload area -->
        <div class="upload-section" id="uploadSection">
            <div class="section-heading">
                <span class="step-badge">2</span>
                <div>
                    <h2>Files</h2>
                    <p>Fields change based on the selected restaurant.</p>
                </div>
                <span class="mode-badge" id="uploadModeBadge"
                    >Select restaurant</span
                >
            </div>

            <div class="multi-upload-container">
                <div class="upload-card" id="salesUploadCard">
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-file-excel"></i>
                            Main file
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill required">Required</span>
                            <button
                                class="upload-remove-btn"
                                id="removeSalesFile"
                                type="button"
                                title="Remove main file"
                                aria-label="Remove main file"
                                hidden
                            >
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </span>
                    </div>

                    <label class="reconciliation-dropzone" for="salesFile">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <strong>Drag and drop file here</strong>
                        <span>or click to browse</span>
                    </label>

                    <small class="upload-format-hint">
                        Accepted formats: .csv, .xlsx
                    </small>

                    <input
                        type="file"
                        id="salesFile"
                        class="reconciliation-file-input"
                        accept=".xlsx,.xls,.csv"
                    />

                    <select
                        id="salesDateFilter"
                        class="form-select upload-date-filter"
                    >
                        <option value="">All dates</option>
                    </select>
                    <div class="upload-status" id="salesUploadStatus">
                        No file selected
                    </div>

                    <div
                        class="taco-bell-saved-reconciliation taco-bell-extra-control"
                        style="display:none;"
                    >
                        <label
                            class="ebt-saved-label"
                            for="savedTbReconciliationSelect"
                        >
                            Saved Taco Bell reconciliation
                        </label>

                        <select
                            id="savedTbReconciliationSelect"
                            class="form-select ebt-saved-select"
                            disabled
                        >
                            <option value=""
                                >Select a saved reconciliation...</option
                            >
                        </select>

                        <div class="ebt-upload-tools">
                            <button
                                type="button"
                                class="btn btn-secondary btn-sm"
                                id="btnLoadTbReconciliation"
                            >
                                <i class="fa-solid fa-folder-open"></i>
                                Load reconciliation
                            </button>

                            <button
                                type="button"
                                class="btn btn-outline btn-sm"
                                id="btnRefreshTbReconciliations"
                                title="Refresh saved reconciliations"
                                aria-label="Refresh saved reconciliations"
                            >
                                <i class="fa-solid fa-rotate"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div
                    class="upload-card taco-bell-extra-upload"
                    id="salesDetailUploadCard"
                    style="display:none;"
                >
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-table-list"></i>
                            Sales Detail Export
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill">Taco Bell</span>
                            <button
                                class="upload-remove-btn"
                                id="removeSalesDetailFile"
                                type="button"
                                title="Remove Sales Detail Export"
                                aria-label="Remove Sales Detail Export"
                                hidden
                            >
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </span>
                    </div>

                    <label
                        class="reconciliation-dropzone"
                        for="salesDetailFile"
                    >
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <strong>Drag and drop file here</strong>
                        <span>or click to browse</span>
                    </label>

                    <small class="upload-format-hint">
                        Accepted formats: .csv, .xlsx
                    </small>

                    <input
                        type="file"
                        id="salesDetailFile"
                        class="reconciliation-file-input"
                        accept=".xlsx,.xls"
                    />

                    <select
                        id="salesDetailDateFilter"
                        class="form-select upload-date-filter"
                    >
                        <option value="">All dates</option>
                    </select>
                </div>

                <div
                    class="upload-card taco-bell-extra-upload"
                    id="ebtUploadCard"
                    style="display:none;"
                >
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-credit-card"></i>
                            EBT file
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill optional">Optional</span>
                            <button
                                class="upload-remove-btn"
                                id="removeEbtFile"
                                type="button"
                                title="Remove EBT file"
                                aria-label="Remove EBT file"
                                hidden
                            >
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </span>
                    </div>

                    <label class="reconciliation-dropzone" for="ebtFile">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <strong>Drag and drop file here</strong>
                        <span>or click to browse</span>
                    </label>

                    <small class="upload-format-hint">
                        Accepted formats: .csv, .xlsx
                    </small>

                    <input
                        type="file"
                        id="ebtFile"
                        class="reconciliation-file-input"
                        accept=".xlsx,.xls"
                    />

                    <select
                        id="ebtDateFilter"
                        class="form-select upload-date-filter"
                    >
                        <option value="">All dates</option>
                    </select>

                    <div class="upload-status" id="ebtUploadStatus">
                        No EBT file selected
                    </div>

                    <label class="ebt-saved-label" for="savedEbtFileSelect">
                        Saved EBT file
                    </label>

                    <select
                        id="savedEbtFileSelect"
                        class="form-select ebt-saved-select"
                        disabled
                    >
                        <option value="">Select a saved EBT file...</option>
                    </select>

                    <div class="ebt-upload-tools ebt-save-tools">
                        <button
                            type="button"
                            class="btn btn-secondary btn-sm"
                            id="btnUploadEbtOnly"
                        >
                            <i class="fa-solid fa-cloud-arrow-up"></i>
                            Save EBT
                        </button>

                        <button
                            type="button"
                            class="btn btn-outline btn-sm"
                            id="btnRefreshEbtFiles"
                            title="Refresh saved EBT files"
                            aria-label="Refresh saved EBT files"
                        >
                            <i class="fa-solid fa-rotate"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Loaded file -->
            <div class="file-loaded" id="fileLoaded" style="display: none;">
                <div class="file-loaded-info">
                    <div class="file-loaded-icon">
                        <i class="fa-solid fa-file-excel"></i>
                    </div>
                    <div class="file-loaded-details">
                        <span class="file-loaded-name" id="fileName"
                            >file.xlsx</span
                        >
                        <span class="file-loaded-size" id="fileSize">0 KB</span>
                    </div>
                </div>
                <button class="btn btn-danger btn-sm" id="btnRemoveFile">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
        </div>

        <!-- Reconciliation table -->
        <div
            class="conciliacion-results"
            id="resultsSection"
            style="display: none;"
        >
            <!-- Summary -->
            <div class="section-heading results-heading">
                <span class="step-badge">3</span>
                <div>
                    <h2>Review</h2>
                    <p>Review totals, filter stores, and export the result.</p>
                </div>
            </div>

            <div class="results-summary">
                <div class="summary-card total">
                    <div class="summary-icon">
                        <i class="fa-solid fa-list-check"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="totalConcepts">0</span>
                        <span class="summary-label">Concepts</span>
                    </div>
                </div>
                <div class="summary-card success">
                    <div class="summary-icon">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="conceptosOk">0</span>
                        <span class="summary-label">Correct</span>
                    </div>
                </div>
                <div class="summary-card warning">
                    <div class="summary-icon">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="conceptosDiferencia"
                            >0</span
                        >
                        <span class="summary-label">With difference</span>
                    </div>
                </div>
                <div class="summary-card status is-clear" id="osStatusCard">
                    <div class="summary-icon">
                        <i class="fa-solid fa-scale-balanced" id="osStatusIcon"
                        ></i>
                    </div>
                    <div class="summary-info">
                        <span
                            class="summary-value summary-status-value"
                            id="osDifferenceStatus">No differences</span
                        >
                        <span class="summary-label" id="osDifferenceMeta"
                            >Balanced O/S</span
                        >
                    </div>
                </div>
                <div class="summary-card danger">
                    <div class="summary-icon">
                        <i class="fa-solid fa-dollar-sign"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="totalDiferencia"
                            >$0.00</span
                        >
                        <span class="summary-label">Total difference</span>
                    </div>
                </div>
            </div>

            <section
                class="reconciliation-compare-panel"
                id="conciliationComparisonPanel"
                data-state="pendiente"
            >
                <div class="reconciliation-compare-icon">
                    <i
                        class="fa-solid fa-code-compare"
                        id="conciliationComparisonIcon"></i>
                </div>
                <div class="reconciliation-compare-copy">
                    <span>CHANGE CONTROL</span>
                    <strong id="conciliationComparisonTitle">
                        Compare with the latest reconciliation
                    </strong>
                    <p id="conciliationComparisonText">
                        Find a reference for the same restaurant and date before
                        saving.
                    </p>
                </div>
                <button
                    type="button"
                    class="btn btn-secondary reconciliation-compare-button"
                    id="btnCompararConciliacion"
                >
                    <i class="fa-solid fa-magnifying-glass-chart"></i>
                    Compare now
                </button>
            </section>

            <!-- FILTRO POR TIENDA Y POR NUM DE TIENDA -->
            <div class="filters-container">
                <div class="form-group">
                    <label>Store</label>
                    <select id="filterStore" class="form-select">
                        <option value="">All stores</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Store name</label>
                    <input
                        type="text"
                        id="filterStoreName"
                        class="form-input"
                        placeholder="Search branch..."
                    />
                </div>
            </div>

            <div class="sheet-tabs-panel">
                <div
                    id="tacoBellTabs"
                    class="tabs-container"
                    style="display:none;"
                >
                    <button class="tab-btn active" data-tab="dailySales">
                        Conciliation
                    </button>
                    <button class="tab-btn" data-tab="dailySalesRed">
                        Daily Sales RED
                    </button>
                    <button class="tab-btn" data-tab="taxReview">
                        Tax Review
                    </button>
                    <button class="tab-btn" data-tab="statisticalDelivery">
                        Statistical Delivery
                    </button>
                    <button class="tab-btn" data-tab="dailySales0314">
                        Template POS
                    </button>
                    <button class="tab-btn" data-tab="dailySales0310">
                        Template Delivery
                    </button>
                </div>

                <div
                    id="popeyesTabs"
                    class="tabs-container"
                    style="display:none;"
                >
                    <button
                        class="tab-btn popeyes-tab-btn active"
                        data-tab="conciliation"
                    >
                        Conciliation
                    </button>
                    <button
                        class="tab-btn popeyes-tab-btn"
                        data-tab="taxReview"
                    >
                        Tax Review
                    </button>
                    <button
                        class="tab-btn popeyes-tab-btn"
                        data-tab="dailySalesRed"
                    >
                        Daily Sales Popeyes Red
                    </button>
                    <button
                        class="tab-btn popeyes-tab-btn"
                        data-tab="dailySales0404"
                    >
                        Template POS
                    </button>
                </div>

                <div
                    id="burgerKingTabs"
                    class="tabs-container"
                    style="display:none;"
                >
                    <button class="tab-btn active" data-tab="summary">
                        Summary
                    </button>

                    <button class="tab-btn" data-tab="conciliation">
                        Conciliation
                    </button>

                    <button class="tab-btn" data-tab="taxAnalysis">
                        Tax Analysis
                    </button>

                    <button class="tab-btn" data-tab="discrepancies">
                        Discrepancies
                    </button>

                    <button class="tab-btn" data-tab="templateCsv">
                        Template POS
                    </button>
                </div>
            </div>

            <section
                class="bk-tax-store-panel"
                id="popeyesTaxStorePanel"
                style="display:none;"
            >
                <div class="bk-tax-store-panel-copy">
                    <span>POPEYES</span>
                    <strong>Tax Rate by store</strong>
                    <small id="pyTaxPanelStatus" data-type="info"
                        >Tax Review uses local rates. CDTFA updates only when
                        refreshed manually.</small
                    >
                    <small id="pyTaxPanelCount"></small>
                </div>
                <div class="bk-tax-store-panel-actions">
                    <button
                        class="btn btn-secondary"
                        type="button"
                        id="pyTaxPanelRefreshRates"
                    >
                        <i class="fa-solid fa-arrows-rotate"></i>
                        Refresh rates
                    </button>
                    <button
                        class="btn btn-secondary"
                        type="button"
                        id="pyTaxOpenModal"
                    >
                        <i class="fa-solid fa-store"></i>
                        Manage stores
                    </button>
                </div>
            </section>

            <dialog
                id="popeyesTaxStoreDialog"
                class="bk-tax-store-dialog"
                aria-labelledby="pyTaxStoreDialogTitle"
            >
                <section class="bk-tax-store-window">
                    <header class="bk-tax-store-header">
                        <div>
                            <span>POPEYES</span>
                            <h3 id="pyTaxStoreDialogTitle">
                                Stores and tax rate
                            </h3>
                            <p>
                                Manage the local store list used by
                                reconciliation. CDTFA updates only when you
                                press refresh.
                            </p>
                        </div>
                        <div class="bk-tax-store-meta">
                            <strong id="pyTaxStoreCount"
                                >0 configured stores</strong
                            >
                            <small id="pyTaxStoreStatus" data-type="info">
                                Ready to work with local rates.
                            </small>
                        </div>
                        <button
                            type="button"
                            id="pyTaxCloseModal"
                            class="bk-tax-modal-close"
                            aria-label="Close Popeyes store catalog"
                        >
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </header>

                    <div class="bk-tax-store-form">
                        <div class="bk-tax-form-head">
                            <strong>Store details</strong>
                            <small id="pyTaxFormMode">New store</small>
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreNumber">Store</label>
                            <input
                                id="pyTaxStoreNumber"
                                class="form-input"
                                type="text"
                                placeholder="2902"
                            />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreAddress">Address</label>
                            <input
                                id="pyTaxStoreAddress"
                                class="form-input"
                                type="text"
                                placeholder="Address"
                            />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreCity">City</label>
                            <input
                                id="pyTaxStoreCity"
                                class="form-input"
                                type="text"
                                placeholder="City"
                            />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreZip">Zip</label>
                            <input
                                id="pyTaxStoreZip"
                                class="form-input"
                                type="text"
                                placeholder="95823"
                            />
                        </div>

                        <div class="form-group bk-tax-coordinates">
                            <label for="pyTaxStoreCoordinates"
                                >Coordinates</label
                            >
                            <input
                                id="pyTaxStoreCoordinates"
                                class="form-input"
                                type="text"
                                placeholder="38.494835, -121.427995"
                            />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreRate">Tax Rate</label>
                            <input
                                id="pyTaxStoreRate"
                                class="form-input"
                                type="text"
                                placeholder="7.75% or 0.0775"
                            />
                        </div>

                        <div class="form-group">
                            <label for="pyTaxStoreJurisdiction"
                                >Jurisdiction</label
                            >
                            <input
                                id="pyTaxStoreJurisdiction"
                                class="form-input"
                                type="text"
                                placeholder="Optional"
                            />
                        </div>

                        <div class="bk-tax-form-actions">
                            <button
                                class="btn btn-primary bk-tax-form-action"
                                type="button"
                                id="pyTaxSaveStore"
                            >
                                <i class="fa-solid fa-floppy-disk"></i>
                                Save store
                            </button>

                            <button
                                class="btn btn-secondary bk-tax-form-action"
                                type="button"
                                id="pyTaxClearStore"
                            >
                                Cancel
                            </button>
                        </div>
                    </div>

                    <div class="bk-tax-store-toolbar">
                        <button
                            class="btn btn-primary bk-tax-add-store"
                            type="button"
                            id="pyTaxAddStore"
                        >
                            <i class="fa-solid fa-plus"></i>
                            Add store
                        </button>

                        <button
                            class="btn btn-secondary"
                            type="button"
                            id="pyTaxRefreshRates"
                        >
                            <i class="fa-solid fa-arrows-rotate"></i>
                            Refresh CDTFA rates
                        </button>

                        <button
                            class="btn btn-danger"
                            type="button"
                            id="pyTaxResetStores"
                        >
                            Restore catalog
                        </button>
                    </div>

                    <div class="bk-tax-store-table">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Store</th>
                                    <th>Location</th>
                                    <th>Zip</th>
                                    <th>Coordinates</th>
                                    <th>Override</th>
                                    <th>Tax Rate</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="pyTaxStoreBody"></tbody>
                        </table>
                    </div>

                    <footer class="bk-tax-store-footer">
                        <small
                            >Changes are saved to the shared database.</small
                        >
                        <button
                            class="btn btn-primary"
                            type="button"
                            id="pyTaxCloseFooter"
                        >
                            Done
                        </button>
                    </footer>
                </section>
            </dialog>

            <section
                class="bk-tax-store-panel"
                id="tacoBellTaxStorePanel"
                style="display:none;"
            >
                <div class="bk-tax-store-panel-copy">
                    <span>TACO BELL</span>
                    <strong>Tax Rate by store</strong>
                    <small id="tbTaxPanelStatus" data-type="info"
                        >CDTFA updates CA stores; other stores use manual/local
                        rates.</small
                    >
                    <small id="tbTaxPanelCount"></small>
                </div>
                <div class="bk-tax-store-panel-actions">
                    <button
                        class="btn btn-secondary"
                        type="button"
                        id="tbTaxPanelRefreshRates"
                    >
                        <i class="fa-solid fa-arrows-rotate"></i>
                        Refresh rates
                    </button>
                    <button
                        class="btn btn-secondary"
                        type="button"
                        id="tbTaxOpenModal"
                    >
                        <i class="fa-solid fa-store"></i>
                        Manage stores
                    </button>
                </div>
            </section>

            <dialog
                id="tacoBellTaxStoreDialog"
                class="bk-tax-store-dialog"
                aria-labelledby="tbTaxStoreDialogTitle"
            >
                <section class="bk-tax-store-window">
                    <header class="bk-tax-store-header">
                        <div>
                            <span>TACO BELL</span>
                            <h3 id="tbTaxStoreDialogTitle">
                                Stores and tax rate
                            </h3>
                            <p>
                                Manage the local store list used by
                                reconciliation. CDTFA updates only when you
                                press refresh.
                            </p>
                        </div>
                        <div class="bk-tax-store-meta">
                            <strong id="tbTaxStoreCount"
                                >0 configured stores</strong
                            >
                            <small id="tbTaxStoreStatus" data-type="info">
                                Ready to work with local rates.
                            </small>
                        </div>
                        <button
                            type="button"
                            id="tbTaxCloseModal"
                            class="bk-tax-modal-close"
                            aria-label="Close Taco Bell store catalog"
                        >
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </header>

                    <div class="bk-tax-store-form">
                        <div class="bk-tax-form-head">
                            <strong>Store details</strong>
                            <small id="tbTaxFormMode">New store</small>
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreNumber">Store</label>
                            <input
                                id="tbTaxStoreNumber"
                                class="form-input"
                                type="text"
                                placeholder="28841"
                            />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreAddress">Address</label>
                            <input
                                id="tbTaxStoreAddress"
                                class="form-input"
                                type="text"
                                placeholder="Address"
                            />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreCity">City</label>
                            <input
                                id="tbTaxStoreCity"
                                class="form-input"
                                type="text"
                                placeholder="City"
                            />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreState">State</label>
                            <input
                                id="tbTaxStoreState"
                                class="form-input"
                                type="text"
                                placeholder="CA"
                            />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreZip">Zip</label>
                            <input
                                id="tbTaxStoreZip"
                                class="form-input"
                                type="text"
                                placeholder="95688"
                            />
                        </div>

                        <div class="form-group bk-tax-coordinates">
                            <label for="tbTaxStoreCoordinates"
                                >Coordinates</label
                            >
                            <input
                                id="tbTaxStoreCoordinates"
                                class="form-input"
                                type="text"
                                placeholder="38.363685, -121.968236"
                            />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreRate">Tax Rate</label>
                            <input
                                id="tbTaxStoreRate"
                                class="form-input"
                                type="text"
                                placeholder="8.125% or 0.08125"
                            />
                        </div>

                        <div class="form-group">
                            <label for="tbTaxStoreJurisdiction"
                                >Jurisdiction</label
                            >
                            <input
                                id="tbTaxStoreJurisdiction"
                                class="form-input"
                                type="text"
                                placeholder="Optional"
                            />
