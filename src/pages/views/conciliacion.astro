---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Conciliacion">
    <div class="page-container">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Conciliacion de Ventas</h1>
                <p>Sube un archivo Excel para extraer y conciliar los datos</p>
            </div>
            <div class="header-actions">
                <button class="btn btn-secondary" id="btnHistorial">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    Historial
                </button>
            </div>
        </div>

        <!-- Selector de Restaurante y Fecha -->
        <div class="conciliacion-config">
            <div class="config-card">
                <div class="config-row">
                    <div class="form-group">
                        <label for="selectRestaurante">Restaurante</label>
                        <select id="selectRestaurante" class="form-select">
                            <option value=""
                                >Selecciona un restaurante...</option
                            >
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="selectTemplate">Template</label>
                        <select
                            id="selectTemplate"
                            class="form-select"
                            disabled
                        >
                            <option value=""
                                >Selecciona primero un restaurante</option
                            >
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Fecha</label>

                        <select id="fechaConciliacion" class="form-select">
                            <option value=""> Selecciona una fecha </option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Zona de Upload -->
        <div class="upload-section" id="uploadSection">
            <!-- Zona de Upload -->
            <div class="upload-section" id="uploadSection">
                <!-- Inputs separados -->
                <div class="multi-upload-container">
                    <div class="upload-card">
                        <h4>
                            <i class="fa-solid fa-file-excel"></i>
                            Archivo Sales *
                        </h4>

                        <input type="file" id="salesFile" accept=".xlsx,.xls" />

                        <select
                            id="salesDateFilter"
                            class="form-select"
                            style="margin-top:10px;"
                        >
                            <option value=""> Todas las fechas </option>
                        </select>
                    </div>

                    <div class="upload-card">
                        <h4>
                            <i class="fa-solid fa-credit-card"></i>
                            Archivo EBT (Opcional)
                        </h4>

                        <input type="file" id="ebtFile" accept=".xlsx,.xls" />

                        <select
                            id="ebtDateFilter"
                            class="form-select"
                            style="margin-top:10px;"
                        >
                            <option value=""> Todas las fechas </option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Archivo cargado -->
            <div class="file-loaded" id="fileLoaded" style="display: none;">
                <div class="file-loaded-info">
                    <div class="file-loaded-icon">
                        <i class="fa-solid fa-file-excel"></i>
                    </div>
                    <div class="file-loaded-details">
                        <span class="file-loaded-name" id="fileName"
                            >archivo.xlsx</span
                        >
                        <span class="file-loaded-size" id="fileSize">0 KB</span>
                    </div>
                </div>
                <button class="btn btn-danger btn-sm" id="btnRemoveFile">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
        </div>

        <!-- Tabla de Conciliacion -->
        <div
            class="conciliacion-results"
            id="resultsSection"
            style="display: none;"
        >
            <!-- Resumen -->
            <div class="results-summary">
                <div class="summary-card total">
                    <div class="summary-icon">
                        <i class="fa-solid fa-list-check"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="totalConceptos">0</span>
                        <span class="summary-label">Conceptos</span>
                    </div>
                </div>
                <div class="summary-card success">
                    <div class="summary-icon">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="conceptosOk">0</span>
                        <span class="summary-label">Correctos</span>
                    </div>
                </div>
                <div class="summary-card warning">
                    <div class="summary-icon">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="conceptosDiferencia"
                            >0</span
                        >
                        <span class="summary-label">Con Diferencia</span>
                    </div>
                </div>
                <div class="summary-card danger">
                    <div class="summary-icon">
                        <i class="fa-solid fa-dollar-sign"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="totalDiferencia"
                            >$0.00</span
                        >
                        <span class="summary-label">Total Diferencia</span>
                    </div>
                </div>
            </div>

            <!-- FILTRO POR TIENDA Y POR NUM DE TIENDA -->
            <div class="filters-container">
                <div class="form-group">
                    <label>Tienda</label>
                    <select id="filterStore" class="form-select">
                        <option value="">Todas las tiendas</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Nombre tienda</label>
                    <input
                        type="text"
                        id="filterStoreName"
                        class="form-input"
                        placeholder="Buscar sucursal..."
                    />
                </div>
            </div>

            <!-- Tabla -->
            <div class="table-container">
                <div class="table-header">
                    <h3>Detalle de Conciliacion</h3>
                </div>
                <div class="table-responsive">
                    <div
                        id="tacoBellTabs"
                        class="tabs-container"
                        style="display:none;"
                    >
                        <button class="tab-btn active" data-tab="dailySales">
                            Daily Sales
                        </button>

                        <button class="tab-btn" data-tab="dailySalesRed">
                            Daily Sales RED
                        </button>

                        <button class="tab-btn" data-tab="taxReview">
                            Tax Review
                        </button>

                        <button class="tab-btn" data-tab="statisticalDelivery">
                            Statistical Delivery
                        </button>

                        <button class="tab-btn" data-tab="dailySales0314">
                            Daily Sales 03-14
                        </button>

                        <button class="tab-btn" data-tab="dailySales0310">
                            Daily Sales 03-10
                        </button>
                    </div>

                    <div
                        id="popeyesTabs"
                        class="tabs-container"
                        style="display:none;"
                    >
                        <button
                            class="tab-btn popeyes-tab-btn active"
                            data-tab="conciliation"
                        >
                            Conciliation
                        </button>

                        <button class="tab-btn popeyes-tab-btn" data-tab="taxReview">
                            Tax Review
                        </button>

                        <button
                            class="tab-btn popeyes-tab-btn"
                            data-tab="dailySalesRed"
                        >
                            Daily Sales Popeyes Red
                        </button>

                        <button
                            class="tab-btn popeyes-tab-btn"
                            data-tab="dailySales0404"
                        >
                            Daily Sales Popeyes 04-04-2026
                        </button>
                    </div>

                    <table class="data-table conciliacion-table">
                        <thead id="conciliacionTableHead">
                            <!-- JS generará las columnas -->
                        </thead>

                        <tbody id="conciliacionBody"></tbody>
                    </table>
                </div>
            </div>

            <!-- Notas y acciones -->
            <div class="notes-section">
                <div class="conciliacion-actions">
                    <button class="btn btn-secondary" id="btnExportCsv">
                        <i class="fa-solid fa-file-csv"></i>
                        Exportar CSV
                    </button>
                    <button class="btn btn-primary" id="btnGuardar">
                        <i class="fa-solid fa-floppy-disk"></i>
                        Guardar conciliacion
                    </button>
                </div>
            </div>
        </div>

        <!-- Scripts -->
        <script
            is:inline
            src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"
        ></script>
        <script src="/js/config.js" is:inline></script>
        <script is:inline src="/js/restaurant-configs.js"></script>

        <script is:inline src="/js/conciliacion-tacobell.js"></script>
        <script is:inline src="/js/conciliacion-popeyes.js"></script>

        <script is:inline src="/js/conciliacion.js"></script>
    </div>

    <style>
        /* Configuracion de conciliacion */
        .conciliacion-config {
            margin-bottom: 24px;
        }

        .config-card {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
        }

        .config-row {
            display: grid;
            grid-template-columns: 2fr 2fr 1fr;
            gap: 20px;
            align-items: end;
        }

        /* Upload Section */
        .upload-section {
            margin-bottom: 24px;
        }

        .upload-zone {
            background: var(--white);
            border: 2px dashed var(--gray-300);
            border-radius: var(--radius-lg);
            padding: 48px 24px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
        }

        .upload-zone:hover,
        .upload-zone.dragover {
            border-color: var(--primary);
            background: var(--primary-light);
        }

        .upload-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 16px;
            background: var(--gray-100);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: var(--gray-400);
            transition: var(--transition);
        }

        .upload-zone:hover .upload-icon {
            background: var(--primary);
            color: var(--white);
        }

        .upload-zone h3 {
            font-size: 18px;
            font-weight: 600;
            color: var(--gray-800);
            margin: 0 0 8px 0;
        }

        .upload-zone p {
            font-size: 14px;
            color: var(--gray-500);
            margin: 0 0 12px 0;
        }

        .upload-hint {
            font-size: 12px;
            color: var(--gray-400);
        }

        /* File Loaded */
        .file-loaded {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 16px 20px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--success);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .file-loaded-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .file-loaded-icon {
            width: 48px;
            height: 48px;
            background: rgba(16, 185, 129, 0.1);
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: var(--success);
        }

        .file-loaded-details {
            display: flex;
            flex-direction: column;
        }

        .file-loaded-name {
            font-weight: 600;
            color: var(--gray-800);
        }

        .file-loaded-size {
            font-size: 13px;
            color: var(--gray-500);
        }

        /* Results Summary */
        .results-summary {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .summary-card {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 20px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .summary-icon {
            width: 48px;
            height: 48px;
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .summary-card.total .summary-icon {
            background: rgba(59, 130, 246, 0.1);
            color: #3b82f6;
        }

        .summary-card.success .summary-icon {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        .summary-card.warning .summary-icon {
            background: rgba(245, 158, 11, 0.1);
            color: #f59e0b;
        }

        .summary-card.danger .summary-icon {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

        .summary-info {
            display: flex;
            flex-direction: column;
        }

        .summary-value {
            font-size: 24px;
            font-weight: 700;
            color: var(--gray-900);
            line-height: 1;
        }

        .summary-label {
            font-size: 13px;
            color: var(--gray-500);
            margin-top: 4px;
        }

        /* Conciliacion Table */
        .conciliacion-table td {
            padding: 14px 16px;
        }

        .conciliacion-table .text-right {
            text-align: right;
        }

        .conciliacion-table .text-center {
            text-align: center;
        }

        .valor-excel {
            font-family: "SF Mono", "Consolas", monospace;
            font-weight: 500;
        }

        .valor-esperado {
            font-family: "SF Mono", "Consolas", monospace;
            color: var(--gray-600);
        }

        .valor-diferencia {
            font-family: "SF Mono", "Consolas", monospace;
            font-weight: 600;
        }

        .valor-diferencia.positivo {
            color: #10b981;
        }

        .valor-diferencia.negativo {
            color: #ef4444;
        }

        .valor-diferencia.cero {
            color: var(--gray-400);
        }

        .estado-icon {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        .estado-icon.ok {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        .estado-icon.diferencia {
            background: rgba(245, 158, 11, 0.1);
            color: #f59e0b;
        }

        .totals-row {
            background: var(--gray-50);
            border-top: 2px solid var(--gray-200);
        }

        .totals-row td {
            padding: 16px;
        }

        /* Notes Section */
        .notes-section {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
            margin-top: 24px;
        }

        .notes-section label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: var(--gray-700);
            margin-bottom: 8px;
        }

        .conciliacion-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 16px;
        }

        .form-textarea {
            width: 100%;
            padding: 12px 14px;
            font-size: 14px;
            border: 1px solid var(--gray-300);
            border-radius: var(--radius);
            resize: vertical;
            transition: var(--transition);
        }

        .form-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px var(--primary-light);
        }

        /* Form Elements */
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-group label {
            font-size: 13px;
            font-weight: 500;
            color: var(--gray-700);
        }

        .form-select,
        .form-input {
            padding: 10px 14px;
            font-size: 14px;
            border: 1px solid var(--gray-300);
            border-radius: var(--radius);
            background: var(--white);
            transition: var(--transition);
        }

        .form-select:focus,
        .form-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px var(--primary-light);
        }

        .form-select:disabled {
            background: var(--gray-100);
            cursor: not-allowed;
        }

        /* Table Responsive */
        .table-responsive {
            overflow-x: auto;
        }

        .multi-upload-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 1rem;
        }

        .upload-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 1rem;
        }

        .upload-card h4 {
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
            font-weight: 600;
            color: #1f2937;
        }

        .upload-card input[type="file"] {
            width: 100%;
            border: 1px dashed #cbd5e1;
            border-radius: 8px;
            padding: 12px;
            background: #f8fafc;
            cursor: pointer;
        }

        .upload-card input[type="file"]:hover {
            background: #f1f5f9;
        }

        .table-container {
            position: relative;
            z-index: 1;
        }

        .table-header {
            position: relative;
            z-index: 100;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .table-actions {
            position: relative;
            z-index: 1000;
        }

        .table-actions .btn {
            position: relative;
            z-index: 9999;
            pointer-events: auto;
        }

        .table-responsive {
            overflow-x: auto;
            overflow-y: auto;
            max-height: 600px;
            position: relative;
            z-index: 1;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .config-row {
                grid-template-columns: 1fr 1fr;
            }

            .results-summary {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .config-row {
                grid-template-columns: 1fr;
            }

            .results-summary {
                grid-template-columns: 1fr;
            }
        }

        .upload-zone {
            pointer-events: auto;
        }

        .multi-upload-container {
            position: relative;
            z-index: 999;
        }

        .upload-card input[type="file"] {
            display: block !important;
            width: 100% !important;
            height: auto !important;
            min-height: 42px !important;
            opacity: 1 !important;
            visibility: visible !important;
            position: static !important;
            pointer-events: auto !important;
            cursor: pointer !important;
        }
        .conciliacion-table thead {
            position: sticky;
            top: 0;
            z-index: 20;
        }

        .conciliacion-table thead th {
            background: #ffffff;
            position: sticky;
            top: 0;
            white-space: nowrap;
            padding: 14px 16px;
            font-weight: 700;
            border-bottom: 2px solid #e5e7eb;
        }

        .conciliacion-table {
            min-width: max-content;
        }

        .filters-container {
            display: grid;
            grid-template-columns: 250px 1fr;
            gap: 16px;
            margin-bottom: 16px;
            padding: 16px;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
        }

        .filters-container input {
            width: 100%;
        }

        .tabs-container {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .tab-btn {
            border: 1px solid #d1d5db;
            background: #fff;
            padding: 10px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }

        .tab-btn.active {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }

        .popeyes-tab-btn {
            border: 1px solid #d1d5db;
            background: #fff;
            padding: 10px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }

        .popeyes-tab-btn.active {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }
    </style>
</DashboardLayout>
