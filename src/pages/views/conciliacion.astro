---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Conciliacion">
    <div class="page-container">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Libro de conciliación de ventas</h1>
                <p>
                    Carga fuentes operativas, valida diferencias y prepara el
                    asiento para revisión contable.
                </p>
            </div>
        </div>

        <!-- Selector de Restaurante y Fecha -->
        <div class="conciliacion-config">
            <div class="section-heading">
                <span class="step-badge">1</span>
                <div>
                    <h2>Seleccion</h2>
                    <p>Define restaurante, template y fecha de trabajo.</p>
                </div>
            </div>
            <div class="config-card">
                <div class="config-row">
                    <div class="form-group">
                        <label for="selectRestaurante">Restaurante</label>
                        <select id="selectRestaurante" class="form-select">
                            <option value=""
                                >Selecciona un restaurante...</option
                            >
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="selectTemplate">Template</label>
                        <select
                            id="selectTemplate"
                            class="form-select"
                            disabled
                        >
                            <option value=""
                                >Selecciona primero un restaurante</option
                            >
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Fecha</label>

                        <select id="fechaConciliacion" class="form-select">
                            <option value=""> Selecciona una fecha </option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Zona de Upload -->
        <div class="upload-section" id="uploadSection">
            <div class="section-heading">
                <span class="step-badge">2</span>
                <div>
                    <h2>Archivos</h2>
                    <p>Los campos cambian segun el restaurante seleccionado.</p>
                </div>
                <span class="mode-badge" id="uploadModeBadge"
                    >Selecciona restaurante</span
                >
            </div>

            <div class="multi-upload-container">
                <div class="upload-card" id="salesUploadCard">
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-file-excel"></i>
                            Archivo principal
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill required">Requerido</span>
                            <button
                                class="upload-remove-btn"
                                id="removeSalesFile"
                                type="button"
                                title="Eliminar archivo principal"
                                aria-label="Eliminar archivo principal"
                                hidden
                            >
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </span>
                    </div>

                    <input
                        type="file"
                        id="salesFile"
                        accept=".xlsx,.xls,.csv"
                    />

                    <select
                        id="salesDateFilter"
                        class="form-select upload-date-filter"
                    >
                        <option value="">Todas las fechas</option>
                    </select>
                </div>

                <div
                    class="upload-card taco-bell-extra-upload"
                    id="salesDetailUploadCard"
                    style="display:none;"
                >
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-table-list"></i>
                            Sales Detail Export
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill">Taco Bell</span>
                            <button
                                class="upload-remove-btn"
                                id="removeSalesDetailFile"
                                type="button"
                                title="Eliminar Sales Detail Export"
                                aria-label="Eliminar Sales Detail Export"
                                hidden
                            >
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </span>
                    </div>

                    <input
                        type="file"
                        id="salesDetailFile"
                        accept=".xlsx,.xls"
                    />

                    <select
                        id="salesDetailDateFilter"
                        class="form-select upload-date-filter"
                    >
                        <option value="">Todas las fechas</option>
                    </select>
                </div>

                <div
                    class="upload-card taco-bell-extra-upload"
                    id="ebtUploadCard"
                    style="display:none;"
                >
                    <div class="upload-card-title">
                        <span>
                            <i class="fa-solid fa-credit-card"></i>
                            Archivo EBT
                        </span>
                        <span class="upload-card-actions">
                            <span class="upload-pill optional">Opcional</span>
                            <button
                                class="upload-remove-btn"
                                id="removeEbtFile"
                                type="button"
                                title="Eliminar archivo EBT"
                                aria-label="Eliminar archivo EBT"
                                hidden
                            >
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </span>
                    </div>

                    <input type="file" id="ebtFile" accept=".xlsx,.xls" />

                    <select
                        id="ebtDateFilter"
                        class="form-select upload-date-filter"
                    >
                        <option value="">Todas las fechas</option>
                    </select>
                </div>
            </div>

            <!-- Archivo cargado -->
            <div class="file-loaded" id="fileLoaded" style="display: none;">
                <div class="file-loaded-info">
                    <div class="file-loaded-icon">
                        <i class="fa-solid fa-file-excel"></i>
                    </div>
                    <div class="file-loaded-details">
                        <span class="file-loaded-name" id="fileName"
                            >archivo.xlsx</span
                        >
                        <span class="file-loaded-size" id="fileSize">0 KB</span>
                    </div>
                </div>
                <button class="btn btn-danger btn-sm" id="btnRemoveFile">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
        </div>

        <!-- Tabla de Conciliacion -->
        <div
            class="conciliacion-results"
            id="resultsSection"
            style="display: none;"
        >
            <!-- Resumen -->
            <div class="section-heading results-heading">
                <span class="step-badge">3</span>
                <div>
                    <h2>Revision</h2>
                    <p>
                        Revisa totales, filtra tiendas y exporta el resultado.
                    </p>
                </div>
            </div>

            <div class="results-summary">
                <div class="summary-card total">
                    <div class="summary-icon">
                        <i class="fa-solid fa-list-check"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="totalConceptos">0</span>
                        <span class="summary-label">Conceptos</span>
                    </div>
                </div>
                <div class="summary-card success">
                    <div class="summary-icon">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="conceptosOk">0</span>
                        <span class="summary-label">Correctos</span>
                    </div>
                </div>
                <div class="summary-card warning">
                    <div class="summary-icon">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="conceptosDiferencia"
                            >0</span
                        >
                        <span class="summary-label">Con Diferencia</span>
                    </div>
                </div>
                <div class="summary-card status is-clear" id="osStatusCard">
                    <div class="summary-icon">
                        <i class="fa-solid fa-scale-balanced" id="osStatusIcon"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value summary-status-value" id="osDifferenceStatus">Sin diferencias</span>
                        <span class="summary-label" id="osDifferenceMeta">O/S balanceado</span>
                    </div>
                </div>
                <div class="summary-card danger">
                    <div class="summary-icon">
                        <i class="fa-solid fa-dollar-sign"></i>
                    </div>
                    <div class="summary-info">
                        <span class="summary-value" id="totalDiferencia"
                            >$0.00</span
                        >
                        <span class="summary-label">Total Diferencia</span>
                    </div>
                </div>
            </div>

            <!-- FILTRO POR TIENDA Y POR NUM DE TIENDA -->
            <div class="filters-container">
                <div class="form-group">
                    <label>Tienda</label>
                    <select id="filterStore" class="form-select">
                        <option value="">Todas las tiendas</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Nombre tienda</label>
                    <input
                        type="text"
                        id="filterStoreName"
                        class="form-input"
                        placeholder="Buscar sucursal..."
                    />
                </div>
            </div>

            <div class="sheet-tabs-panel">
                <div
                    id="tacoBellTabs"
                    class="tabs-container"
                    style="display:none;"
                >
                    <button class="tab-btn active" data-tab="dailySales">
                        Daily Sales
                    </button>
                    <button class="tab-btn" data-tab="dailySalesRed">
                        Daily Sales RED
                    </button>
                    <button class="tab-btn" data-tab="taxReview">
                        Tax Review
                    </button>
                    <button class="tab-btn" data-tab="statisticalDelivery">
                        Statistical Delivery
                    </button>
                    <button class="tab-btn" data-tab="dailySales0314">
                        Daily Sales 03-14
                    </button>
                    <button class="tab-btn" data-tab="dailySales0310">
                        Daily Sales 03-10
                    </button>
                </div>

                <div
                    id="popeyesTabs"
                    class="tabs-container"
                    style="display:none;"
                >
                    <button
                        class="tab-btn popeyes-tab-btn active"
                        data-tab="conciliation"
                    >
                        Conciliation
                    </button>
                    <button
                        class="tab-btn popeyes-tab-btn"
                        data-tab="taxReview"
                    >
                        Tax Review
                    </button>
                    <button
                        class="tab-btn popeyes-tab-btn"
                        data-tab="dailySalesRed"
                    >
                        Daily Sales Popeyes Red
                    </button>
                    <button
                        class="tab-btn popeyes-tab-btn"
                        data-tab="dailySales0404"
                    >
                        Daily Sales Popeyes 04-04-2026
                    </button>
                </div>

                <div
                    id="burgerKingTabs"
                    class="tabs-container"
                    style="display:none;"
                >
                    <button class="tab-btn active" data-tab="summary">
                        Summary
                    </button>

                    <button class="tab-btn" data-tab="conciliation">
                        Conciliation
                    </button>

                    <button class="tab-btn" data-tab="taxAnalysis">
                        Tax Analysis
                    </button>

                    <button class="tab-btn" data-tab="discrepancies">
                        Discrepancies
                    </button>

                    <button class="tab-btn" data-tab="templateCsv">
                        Template to CSV
                    </button>
                </div>
            </div>

            <!-- Tabla -->
            <div class="table-container">
                <div class="table-header">
                    <h3>Detalle de Conciliacion</h3>
                </div>
                <div class="table-responsive">
                    <table class="data-table conciliacion-table">
                        <thead id="conciliacionTableHead">
                            <!-- JS generará las columnas -->
                        </thead>

                        <tbody id="conciliacionBody"></tbody>
                    </table>
                </div>
            </div>

            <!-- Notas y acciones -->
            <div class="notes-section">
                <div class="conciliacion-actions">
                    <button class="btn btn-secondary" id="btnExportCsv">
                        <i class="fa-solid fa-file-csv"></i>
                        Exportar CSV
                    </button>
                    <button class="btn btn-primary" id="btnGuardar">
                        <i class="fa-solid fa-floppy-disk"></i>
                        Guardar conciliacion
                    </button>
                </div>
            </div>
        </div>

        <!-- Scripts -->
        <script
            is:inline
            src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"
        ></script>
        <script src="/js/config.js" is:inline></script>
        <script is:inline src="/js/restaurant-configs.js"></script>

        <script is:inline src="/js/conciliacion-tacobell.js"></script>
        <script is:inline src="/js/conciliacion-popeyes.js"></script>
        <script is:inline src="/js/conciliacion-burgerking.js"></script>

        <script is:inline src="/js/conciliacion.js"></script>
    </div>

    <style>
        /* Configuracion de conciliacion */
        .conciliacion-config {
            margin-bottom: 24px;
        }

        .section-heading {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .section-heading h2 {
            margin: 0;
            font-size: 16px;
            line-height: 1.2;
            color: var(--gray-900);
        }

        .section-heading p {
            margin: 3px 0 0;
            font-size: 14px;
            color: var(--gray-500);
        }

        .step-badge {
            width: 30px;
            height: 30px;
            border-radius: var(--radius);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            background: var(--primary-light);
            color: var(--primary-dark);
            font-weight: 800;
            font-size: 13px;
        }

        .mode-badge {
            margin-left: auto;
            display: inline-flex;
            align-items: center;
            min-height: 30px;
            padding: 6px 10px;
            border-radius: var(--radius);
            background: var(--gray-100);
            color: var(--gray-600);
            border: 1px solid var(--gray-200);
            font-size: 12px;
            font-weight: 800;
        }

        .mode-badge[data-mode="taco-bell"] {
            background: var(--info-light);
            color: var(--info);
            border-color: rgba(37, 99, 235, 0.22);
        }

        .mode-badge[data-mode="popeyes"] {
            background: var(--accent-light);
            color: var(--accent);
            border-color: rgba(194, 65, 12, 0.22);
        }

        .config-card {
            background: var(--white);
            border-radius: var(--radius-xl);
            padding: 20px 24px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
        }

        .config-row {
            display: grid;
            grid-template-columns: 2fr 2fr 1fr;
            gap: 20px;
            align-items: end;
        }

        /* Upload Section */
        .upload-section {
            margin-bottom: 24px;
            padding: 18px;
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-xl);
            background: rgba(255, 255, 255, 0.76);
            box-shadow: var(--shadow-sm);
        }

        .upload-zone {
            background: var(--white);
            border: 2px dashed var(--gray-300);
            border-radius: var(--radius-lg);
            padding: 48px 24px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
        }

        .upload-zone:hover,
        .upload-zone.dragover {
            border-color: var(--primary);
            background: var(--primary-light);
        }

        .upload-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 16px;
            background: var(--gray-100);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: var(--gray-400);
            transition: var(--transition);
        }

        .upload-zone:hover .upload-icon {
            background: var(--primary);
            color: var(--white);
        }

        .upload-zone h3 {
            font-size: 18px;
            font-weight: 600;
            color: var(--gray-800);
            margin: 0 0 8px 0;
        }

        .upload-zone p {
            font-size: 14px;
            color: var(--gray-500);
            margin: 0 0 12px 0;
        }

        .upload-hint {
            font-size: 12px;
            color: var(--gray-400);
        }

        /* File Loaded */
        .file-loaded {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 16px 20px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--success);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .file-loaded-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .file-loaded-icon {
            width: 48px;
            height: 48px;
            background: rgba(16, 185, 129, 0.1);
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: var(--success);
        }

        .file-loaded-details {
            display: flex;
            flex-direction: column;
        }

        .file-loaded-name {
            font-weight: 600;
            color: var(--gray-800);
        }

        .file-loaded-size {
            font-size: 13px;
            color: var(--gray-500);
        }

        /* Results Summary */
        .results-summary {
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .summary-card {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 20px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .summary-icon {
            width: 48px;
            height: 48px;
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .summary-card.total .summary-icon {
            background: rgba(59, 130, 246, 0.1);
            color: var(--info);
        }

        .summary-card.success .summary-icon {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .summary-card.warning .summary-icon {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }

        .summary-card.danger .summary-icon {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
        }

        .summary-card.status {
            transition: border-color .2s ease, background .2s ease;
        }

        .summary-card.status.is-clear {
            border-color: rgba(21, 128, 61, .22);
            background: linear-gradient(180deg, #fff 0%, #f5fcf7 100%);
        }

        .summary-card.status.is-clear .summary-icon {
            color: var(--success);
            background: var(--success-light);
        }

        .summary-card.status.has-difference {
            border-color: rgba(185, 28, 28, .28);
            background: linear-gradient(180deg, #fff 0%, #fff5f5 100%);
        }

        .summary-card.status.has-difference .summary-icon {
            color: var(--danger);
            background: var(--danger-light);
        }

        .summary-status-value {
            font-size: 16px;
            line-height: 1.15;
        }

        .summary-info {
            display: flex;
            flex-direction: column;
        }

        .summary-value {
            font-size: 24px;
            font-weight: 700;
            color: var(--gray-900);
            line-height: 1;
        }

        .summary-label {
            font-size: 13px;
            color: var(--gray-500);
            margin-top: 4px;
        }

        /* Conciliacion Table */
        .conciliacion-table td {
            padding: 14px 16px;
        }

        .conciliacion-table .text-right {
            text-align: right;
        }

        .conciliacion-table .text-center {
            text-align: center;
        }

        .conciliacion-table th.os-column-header {
            color: #8f1d1d;
            background: #fff7f7;
        }

        .conciliacion-table td.os-difference {
            color: #a51515 !important;
            background: #fff0f0 !important;
            box-shadow: inset 3px 0 0 #dc2626;
            font-weight: 800;
        }

        .conciliacion-table td.os-balanced {
            color: #52667a;
        }

        .valor-excel {
            font-family: "SF Mono", "Consolas", monospace;
            font-weight: 500;
        }

        .valor-esperado {
            font-family: "SF Mono", "Consolas", monospace;
            color: var(--gray-600);
        }

        .valor-diferencia {
            font-family: "SF Mono", "Consolas", monospace;
            font-weight: 600;
        }

        .valor-diferencia.positivo {
            color: var(--success);
        }

        .valor-diferencia.negativo {
            color: var(--danger);
        }

        .valor-diferencia.cero {
            color: var(--gray-400);
        }

        .estado-icon {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        .estado-icon.ok {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .estado-icon.diferencia {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }

        .totals-row {
            background: var(--gray-50);
            border-top: 2px solid var(--gray-200);
        }

        .totals-row td {
            padding: 16px;
        }

        /* Notes Section */
        .notes-section {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
            margin-top: 24px;
        }

        .notes-section label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: var(--gray-700);
            margin-bottom: 8px;
        }

        .conciliacion-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 16px;
        }

        .form-textarea {
            width: 100%;
            padding: 12px 14px;
            font-size: 14px;
            border: 1px solid var(--gray-300);
            border-radius: var(--radius);
            resize: vertical;
            transition: var(--transition);
        }

        .form-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px var(--primary-light);
        }

        /* Form Elements */
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-group label {
            font-size: 13px;
            font-weight: 500;
            color: var(--gray-700);
        }

        .form-select,
        .form-input {
            padding: 10px 14px;
            font-size: 14px;
            border: 1px solid var(--gray-300);
            border-radius: var(--radius);
            background: var(--white);
            transition: var(--transition);
        }

        .form-select:focus,
        .form-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px var(--primary-light);
        }

        .form-select:disabled {
            background: var(--gray-100);
            cursor: not-allowed;
        }

        /* Table Responsive */
        .table-responsive {
            overflow-x: auto;
        }

        .multi-upload-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .upload-card {
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-xl);
            padding: 16px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
        }

        .upload-card:hover {
            border-color: rgba(16, 42, 67, 0.32);
            box-shadow: var(--shadow-md);
        }

        .upload-card[data-status="loaded"] {
            border-color: rgba(16, 42, 67, 0.45);
            background: linear-gradient(
                180deg,
                var(--white),
                rgba(230, 238, 246, 0.62)
            );
        }

        .upload-card[data-status="error"] {
            border-color: rgba(185, 28, 28, 0.45);
            background: linear-gradient(
                180deg,
                var(--white),
                rgba(254, 226, 226, 0.34)
            );
        }

        .upload-card-title {
            min-height: 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 12px;
