---
// Componente StoreCard - Tarjeta de tienda/restaurante
interface Props {
  id: number;
  name: string;
  description: string;
  icon: string;
  colorClass: string;
  restaurant: string;
}

const { id, name, description, icon, colorClass, restaurant } = Astro.props;
---

<div class="card store-card">
    <div class="card-body">
        <div class="store-card-header">
            <div class={`store-icon bg-${colorClass}`}>
                <i class={`fa-solid ${icon}`}></i>
            </div>
            <div class="store-info">
                <h3>{name}</h3>
                <p>{description}</p>
            </div>
        </div>
        <a class="btn btn-primary btn-block" href={`/views/conciliacion?restaurante=${id}`}>
            <i class="fa-solid fa-file-excel"></i>
            Conciliacion
        </a>
    </div>
</div>

<style>
.store-card {
    transition: transform 0.2s, box-shadow 0.2s;
}

.store-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
}

.store-card-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
}

.store-icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
}

.store-icon.bg-primary {
    background: var(--primary-light);
    color: var(--primary);
}

.store-icon.bg-warning {
    background: var(--warning-light);
    color: var(--warning);
}

.store-icon.bg-danger {
    background: var(--danger-light);
    color: var(--danger);
}

.store-icon.bg-success {
    background: var(--success-light);
    color: var(--success);
}

.store-info h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--gray-800);
    margin: 0 0 4px 0;
}

.store-info p {
    font-size: 13px;
    color: var(--gray-500);
    margin: 0;
}

.btn-block {
    width: 100%;
    justify-content: center;
}
</style>
