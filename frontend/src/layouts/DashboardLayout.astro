---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';

interface Props {
  title: string;
  includeSheetJS?: boolean;
}

const { title, includeSheetJS = false } = Astro.props;
---

<BaseLayout title={title} includeSheetJS={includeSheetJS}>
    <Sidebar />
    <main class="main" id="mainContent">
        <Topbar />
        <slot />
    </main>
    <script is:inline src="/js/sidebar-loader.js"></script>
</BaseLayout>
