/* =========================================================
   XBFS — VIEW STANDARDIZATION V1
   Standard shell sizing for all application views.
   Loaded after page-specific styles so width and spacing stay consistent.
   ========================================================= */

:root {
    /*
     * Change only this value if the project should be wider or narrower.
     * 1680px keeps large screens administrative and uses nearly all of
     * 1440px/1600px screens after the sidebar.
     */
    --xbfs-view-max-width: 1680px;
    --xbfs-view-gutter-x: clamp(16px, 1.75vw, 28px);
    --xbfs-view-gutter-y: clamp(16px, 1.4vw, 24px);
    --xbfs-view-bottom-space: 34px;

    --xbfs-view-section-gap: 22px;
    --xbfs-view-radius: 20px;

    --xbfs-view-hero-min-height: 188px;
    --xbfs-view-hero-padding-x: clamp(24px, 2.2vw, 36px);
    --xbfs-view-hero-padding-y: clamp(26px, 2vw, 34px);

    --xbfs-view-panel-min-height: 0px;
}

/* ---------------------------------------------------------
   1. MAIN CONTENT AREA
   --------------------------------------------------------- */

html body .main {
    min-width: 0 !important;
    overflow-x: clip;
}

/*
 * These are the first-level wrappers used by the project.
 * The rule does not modify internal tables, dialogs, or form widths.
 */
html body .main > :is(
    .page-container,
    .stores-page,
    .schedule-dashboard,
    .prepaid-page,
    .operations-admin,
    .property-management-page,
    .admin-dashboard-page,
    .admin-users-page,
    .documents-page,
    .comparison-history-page,
    .system-errors-page,
    .profile-page
) {
    width: min(100%, var(--xbfs-view-max-width)) !important;
    max-width: var(--xbfs-view-max-width) !important;
    min-width: 0 !important;
    margin-inline: auto !important;
    padding:
        var(--xbfs-view-gutter-y)
        var(--xbfs-view-gutter-x)
        var(--xbfs-view-bottom-space) !important;
    box-sizing: border-box !important;
}

/*
 * Several wrappers carry both page-container and a page class.
 * This prevents duplicated padding from old page-level rules.
 */
html body .main > .page-container:is(
    .property-management-page,
    .admin-dashboard-page,
    .admin-users-page,
    .documents-page,
    .comparison-history-page,
    .system-errors-page,
    .profile-page
) {
    padding:
        var(--xbfs-view-gutter-y)
        var(--xbfs-view-gutter-x)
        var(--xbfs-view-bottom-space) !important;
}

/* The reconciliation view uses the shared page-container shell. */
html body .main > .reconciliation-page,
html body .main > .permissions-page {
    width: min(100%, var(--xbfs-view-max-width)) !important;
    max-width: var(--xbfs-view-max-width) !important;
    margin-inline: auto !important;
}

/* ---------------------------------------------------------
   2. STANDARD PRIMARY HEADERS / HEROES
   --------------------------------------------------------- */

html body .main :is(
    .page-header,
    .stores-hero,
    .profile-settings-hero,
    .documents-system-hero,
    .comparison-history-hero,
    .admin-dashboard-header,
    .operations-header,
    .system-errors-hero,
    .schedule-header,
    .prepaid-hero
) {
    width: 100% !important;
    min-width: 0 !important;
    min-height: var(--xbfs-view-hero-min-height) !important;
    margin: 0 0 var(--xbfs-view-section-gap) !important;
    padding:
        var(--xbfs-view-hero-padding-y)
        var(--xbfs-view-hero-padding-x) !important;
    box-sizing: border-box !important;
    border-radius: var(--xbfs-view-radius) !important;
}

/* Keep hero content vertically balanced without changing its layout mode. */
html body .main :is(
    .page-header,
    .stores-hero,
    .profile-settings-hero,
    .documents-system-hero,
    .comparison-history-hero,
    .admin-dashboard-header,
    .operations-header,
    .system-errors-hero,
    .schedule-header,
    .prepaid-hero
) > * {
    min-width: 0;
}

/* Standard title scale for the main view title only. */
html body .main :is(
    .page-header,
    .stores-hero,
    .profile-settings-hero,
    .documents-system-hero,
    .comparison-history-hero,
    .admin-dashboard-header,
    .operations-header,
    .system-errors-hero,
    .schedule-header,
    .prepaid-hero
) h1 {
    font-size: clamp(34px, 3.15vw, 50px) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.04em !important;
}

/* Standard readable description width and size. */
html body .main :is(
    .page-header,
    .stores-hero,
    .profile-settings-hero,
    .documents-system-hero,
    .comparison-history-hero,
    .admin-dashboard-header,
    .operations-header,
    .system-errors-hero,
    .schedule-header,
    .prepaid-hero
) p {
    max-width: 760px;
    font-size: 14px !important;
    line-height: 1.58 !important;
}

/* ---------------------------------------------------------
   3. STANDARD SECTION WIDTHS AND VERTICAL RHYTHM
   --------------------------------------------------------- */

html body .main > :is(
    .page-container,
    .stores-page,
    .schedule-dashboard,
    .prepaid-page,
    .operations-admin
) > :is(
    section,
    .filters-bar,
    .admin-view-tabs,
    .stats-grid,
    .store-grid,
    .permissions-container
) {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
}

/* Give primary white panels the same corner radius without flattening cards. */
html body .main :is(
    .admin-dashboard-panel,
    .documents-table-container,
    .history-container,
    .comparison-history-panel,
    .system-errors-panel,
    .operations-panel,
    .permissions-container,
    .prepaid-panel,
    .profile-shell,
    .schedule-option-card,
    .property-documents-table-shell
) {
    min-width: 0;
    border-radius: var(--xbfs-view-radius);
    box-sizing: border-box;
}

/* ---------------------------------------------------------
   4. KPI / SUMMARY ROW CONSISTENCY
   --------------------------------------------------------- */

html body .main :is(
    .stats-grid,
    .admin-metrics,
    .system-error-metrics,
    .schedule-metrics,
    .prepaid-kpis,
    .operations-summary,
    .comparison-summary-grid
) {
    width: 100% !important;
    min-width: 0 !important;
    gap: 14px !important;
    margin-bottom: var(--xbfs-view-section-gap) !important;
    box-sizing: border-box !important;
}

html body .main :is(
    .stat-card,
    .admin-metric-card,
    .system-error-metric,
    .schedule-metric-card,
    .prepaid-kpi-card,
    .operations-summary article,
    .comparison-summary-card
) {
    min-height: 104px;
    box-sizing: border-box;
}

/* ---------------------------------------------------------
   5. TABLE / FILTER CONTAINERS
   --------------------------------------------------------- */

html body .main :is(
    .filters-bar,
    .comparison-history-filters,
    .system-errors-toolbar,
    .documents-filters,
    .property-documents-filters
) {
    width: 100% !important;
    min-width: 0 !important;
    box-sizing: border-box !important;
}

html body .main :is(
    .table-container,
    .prepaid-table-wrap,
    .system-errors-table-wrap,
    .documents-table-wrap,
    .comparison-table-wrap
) {
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
    box-sizing: border-box !important;
}

/* ---------------------------------------------------------
   6. SPECIAL APPLICATION VIEWS
   --------------------------------------------------------- */

/*
 * Chat is an application canvas rather than a normal dashboard page.
 * It uses the same horizontal alignment but keeps its full-height layout.
 */
html body .main > .chat-page {
    width: min(
        calc(100% - (var(--xbfs-view-gutter-x) * 2)),
        var(--xbfs-view-max-width)
    ) !important;
    max-width: var(--xbfs-view-max-width) !important;
    min-width: 0 !important;
    margin:
        var(--xbfs-view-gutter-y)
        auto
        var(--xbfs-view-bottom-space) !important;
    box-sizing: border-box !important;
}

/* Login does not use DashboardLayout and remains intentionally independent. */

/* ---------------------------------------------------------
   7. RESPONSIVE STANDARD
   --------------------------------------------------------- */

@media (max-width: 1024px) {
    :root {
        --xbfs-view-gutter-x: 18px;
        --xbfs-view-gutter-y: 18px;
        --xbfs-view-bottom-space: 28px;
        --xbfs-view-hero-min-height: 170px;
        --xbfs-view-section-gap: 18px;
    }

    html body .main :is(
        .page-header,
        .stores-hero,
        .profile-settings-hero,
        .documents-system-hero,
        .comparison-history-hero,
        .admin-dashboard-header,
        .operations-header,
        .system-errors-hero,
        .schedule-header,
        .prepaid-hero
    ) {
        min-height: var(--xbfs-view-hero-min-height) !important;
    }
}

@media (max-width: 760px) {
    :root {
        --xbfs-view-gutter-x: 12px;
        --xbfs-view-gutter-y: 14px;
        --xbfs-view-bottom-space: 22px;
        --xbfs-view-hero-min-height: auto;
        --xbfs-view-hero-padding-x: 20px;
        --xbfs-view-hero-padding-y: 24px;
        --xbfs-view-radius: 16px;
    }

    html body .main > :is(
        .page-container,
        .stores-page,
        .schedule-dashboard,
        .prepaid-page,
        .operations-admin,
        .property-management-page,
        .admin-dashboard-page,
        .admin-users-page,
        .documents-page,
        .comparison-history-page,
        .system-errors-page,
        .profile-page
    ) {
        padding:
            var(--xbfs-view-gutter-y)
            var(--xbfs-view-gutter-x)
            var(--xbfs-view-bottom-space) !important;
    }

    html body .main :is(
        .page-header,
        .stores-hero,
        .profile-settings-hero,
        .documents-system-hero,
        .comparison-history-hero,
        .admin-dashboard-header,
        .operations-header,
        .system-errors-hero,
        .schedule-header,
        .prepaid-hero
    ) h1 {
        font-size: clamp(30px, 9vw, 40px) !important;
    }

    html body .main > .chat-page {
        width: calc(100% - 24px) !important;
        margin: 14px auto 22px !important;
    }
}

/* Accessibility: sizing must not depend on animation. */
@media (prefers-reduced-motion: reduce) {
    html body .main > :is(
        .page-container,
        .stores-page,
        .schedule-dashboard,
        .prepaid-page,
        .operations-admin,
        .chat-page
    ) {
        scroll-behavior: auto !important;
    }
}


