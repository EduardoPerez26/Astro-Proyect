/* Toasts */
html body .swal2-container.xbfs-toast-container {
    width: auto !important;
    max-width: calc(100vw - 18px) !important;
    padding: 14px !important;
    background: transparent !important;
    pointer-events: none !important;
}

html body .swal2-popup.xbfs-toast-popup {
    --xbfs-alert-accent: var(--xbfs-alert-blue);
    --xbfs-alert-accent-soft: var(--xbfs-alert-blue-soft);
    position: relative !important;
    display: grid !important;
    grid-template-columns: 34px minmax(0, 1fr) auto !important;
    grid-template-rows: auto auto !important;
    column-gap: 12px !important;
    row-gap: 2px !important;
    width: min(390px, calc(100vw - 28px)) !important;
    min-height: 70px !important;
    padding: 14px 16px 15px 14px !important;
    border: 1px solid var(--xbfs-alert-border) !important;
    border-left: 5px solid var(--xbfs-alert-accent) !important;
    border-radius: 15px !important;
    background: rgba(255, 255, 255, 0.98) !important;
    color: var(--xbfs-alert-text) !important;
