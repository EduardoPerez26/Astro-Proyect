/* ============================================================
   XBFS GLOBAL ALERT SYSTEM
   Unified SweetAlert2 presentation for the entire application.
   ============================================================ */

:root {
    --xbfs-alert-navy: #0f172a;
    --xbfs-alert-navy-soft: #eaf1f8;
    --xbfs-alert-blue: #2563eb;
    --xbfs-alert-blue-soft: #eaf2ff;
    --xbfs-alert-green: #15803d;
    --xbfs-alert-green-soft: #eaf8ef;
    --xbfs-alert-amber: #b45309;
    --xbfs-alert-amber-soft: #fff5df;
    --xbfs-alert-red: #c2413b;
    --xbfs-alert-red-soft: #fff0ef;
    --xbfs-alert-violet: #6d4aff;
    --xbfs-alert-violet-soft: #f1edff;
    --xbfs-alert-text: #132238;
    --xbfs-alert-muted: #64748b;
    --xbfs-alert-border: #dbe4ee;
    --xbfs-alert-surface: #ffffff;
    --xbfs-alert-surface-soft: #f7faff;
    --xbfs-alert-shadow: 0 30px 85px -34px rgba(15, 23, 42, 0.58);
}

@keyframes xbfs-alert-in {
    from {
        opacity: 0;
        transform: translate3d(0, 10px, 0) scale(0.975);
    }
    to {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1);
    }
}

@keyframes xbfs-alert-out {
    from {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1);
    }
    to {
        opacity: 0;
        transform: translate3d(0, 6px, 0) scale(0.985);
    }
}

@keyframes xbfs-alert-toast-in {
    from {
        opacity: 0;
        transform: translate3d(16px, 0, 0);
    }
    to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
    }
}

@keyframes xbfs-alert-toast-out {
    from {
        opacity: 1;
        transform: translate3d(0, 0, 0);
    }
    to {
        opacity: 0;
        transform: translate3d(12px, 0, 0);
    }
}

.xbfs-swal-enter {
    animation: xbfs-alert-in 190ms cubic-bezier(0.16, 1, 0.3, 1) both !important;
}

.xbfs-swal-exit {
    animation: xbfs-alert-out 145ms ease-in both !important;
}

.xbfs-toast-enter {
    animation: xbfs-alert-toast-in 210ms cubic-bezier(0.16, 1, 0.3, 1) both !important;
}

.xbfs-toast-exit {
    animation: xbfs-alert-toast-out 160ms ease-in both !important;
}

html body .swal2-container.xbfs-swal-container,
html body .swal2-container.xbfs-toast-container {
    z-index: 2147483000 !important;
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
}

html body .swal2-container.xbfs-swal-container {
    padding: 22px !important;
    background: rgba(15, 23, 42, 0.54) !important;
    backdrop-filter: blur(5px) saturate(112%);
    -webkit-backdrop-filter: blur(5px) saturate(112%);
}

html body .swal2-container.xbfs-swal-container.swal2-backdrop-hide {
    background: rgba(15, 23, 42, 0) !important;
}

html body .swal2-popup.xbfs-swal-popup {
    --xbfs-alert-accent: var(--xbfs-alert-blue);
    --xbfs-alert-accent-soft: var(--xbfs-alert-blue-soft);
    position: relative !important;
    max-width: calc(100vw - 28px) !important;
    border: 1px solid var(--xbfs-alert-border) !important;
    border-radius: 20px !important;
    background: var(--xbfs-alert-surface) !important;
    color: var(--xbfs-alert-text) !important;
    box-shadow: var(--xbfs-alert-shadow) !important;
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    overflow: hidden !important;
}

html body .swal2-popup.xbfs-swal-popup::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 5px;
    background: var(--xbfs-alert-accent);
    z-index: 3;
}

html body .swal2-popup.xbfs-alert-success {
    --xbfs-alert-accent: var(--xbfs-alert-green);
    --xbfs-alert-accent-soft: var(--xbfs-alert-green-soft);
}

html body .swal2-popup.xbfs-alert-error {
    --xbfs-alert-accent: var(--xbfs-alert-red);
    --xbfs-alert-accent-soft: var(--xbfs-alert-red-soft);
}

html body .swal2-popup.xbfs-alert-warning {
    --xbfs-alert-accent: var(--xbfs-alert-amber);
    --xbfs-alert-accent-soft: var(--xbfs-alert-amber-soft);
}

html body .swal2-popup.xbfs-alert-question {
    --xbfs-alert-accent: var(--xbfs-alert-violet);
    --xbfs-alert-accent-soft: var(--xbfs-alert-violet-soft);
}

html body .swal2-popup.xbfs-alert-info,
html body .swal2-popup.xbfs-alert-neutral {
    --xbfs-alert-accent: var(--xbfs-alert-blue);
    --xbfs-alert-accent-soft: var(--xbfs-alert-blue-soft);
}

html body .swal2-popup.xbfs-alert-simple,
html body .swal2-popup.xbfs-alert-confirm,
html body .swal2-popup.xbfs-alert-loading {
