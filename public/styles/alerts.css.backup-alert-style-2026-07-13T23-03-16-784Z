    width: 100% !important;
    margin: 0 !important;
    padding: 0 10px !important;
    box-sizing: border-box !important;
    text-align: center !important;
}

html body .swal2-popup.xbfs-alert-form:not(.xbfs-alert-preserve-layout) > .swal2-html-container.xbfs-swal-html {
    width: 100% !important;
    margin: 9px 0 0 !important;
