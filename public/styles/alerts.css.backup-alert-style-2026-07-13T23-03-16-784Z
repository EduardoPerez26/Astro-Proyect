/*
 * Form alerts use their own contained layout. SweetAlert2 input dialogs do not
 * receive the padding used by simple alerts, which previously left titles and
 * textareas touching the popup edges.
 */
html body .swal2-popup.xbfs-alert-form:not(.xbfs-alert-preserve-layout) {
    width: min(520px, calc(100vw - 28px)) !important;
    padding: 30px 30px 26px !important;
    grid-template-columns: minmax(0, 1fr) !important;
    row-gap: 0 !important;
}

html body .swal2-popup.xbfs-alert-form:not(.xbfs-alert-preserve-layout) > * {
    grid-column: 1 !important;
    min-width: 0 !important;
}

