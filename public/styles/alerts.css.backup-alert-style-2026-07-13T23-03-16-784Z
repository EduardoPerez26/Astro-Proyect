html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-icon.xbfs-swal-icon {
    width: 62px !important;
    height: 62px !important;
    margin: 6px auto 18px !important;
    border-width: 0 !important;
    border-radius: 18px !important;
    background: var(--xbfs-alert-accent-soft) !important;
    color: var(--xbfs-alert-accent) !important;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--xbfs-alert-accent) 18%, transparent) !important;
}

/*
 * SweetAlert2 draws success and error icons with absolutely positioned
 * internal lines sized for its default 5em circle. Resizing that circle caused
 * the success check to overlap and look like an X. The guard now replaces the
 * internal drawing with one stable glyph, and these rules style that glyph.
 */
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-icon.xbfs-swal-icon {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    overflow: hidden !important;
}

