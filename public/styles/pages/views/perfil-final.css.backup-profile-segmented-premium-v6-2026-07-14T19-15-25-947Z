/* =========================================================
   PROFILE & SECURITY — FINAL VISUAL FIX V4
   Loaded after all global styles to prevent cascade conflicts.
   ========================================================= */

html body .main .profile-page.profile-professional-v3 {
    width: min(100%, 1560px) !important;
    max-width: 1560px !important;
    gap: 20px !important;
    padding-top: 20px !important;
}

/* ---------------- HERO: balanced, no awkward overlap ---------------- */

html body .main .profile-page.profile-professional-v3 > .profile-account-hero {
    grid-template-areas: "avatar identity summary" !important;
    grid-template-columns: 150px minmax(0, 1fr) 360px !important;
    align-items: center !important;
    gap: 26px !important;
    min-height: 210px !important;
    padding: 28px 30px !important;
    overflow: hidden !important;
    border-radius: 22px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-hero-avatar-wrap {
    grid-area: avatar !important;
    align-self: center !important;
    width: 144px !important;
    height: 144px !important;
    margin: 0 !important;
}

html body .main .profile-page.profile-professional-v3 .profile-avatar-preview {
    width: 136px !important;
    height: 136px !important;
    min-width: 136px !important;
    min-height: 136px !important;
    border-width: 5px !important;
    font-size: 34px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-avatar-action {
    right: 0 !important;
    bottom: 0 !important;
    width: 40px !important;
    height: 40px !important;
    border-width: 3px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-hero-identity {
    grid-area: identity !important;
    text-align: left !important;
}

html body .main .profile-page.profile-professional-v3 .profile-hero-identity h1 {
    margin: 14px 0 7px !important;
    font-size: clamp(38px, 3.1vw, 50px) !important;
    line-height: 1 !important;
}

html body .main .profile-page.profile-professional-v3 .profile-hero-identity > p {
    font-size: 14px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-hero-security {
    justify-content: flex-start !important;
    margin-top: 15px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-hero-summary {
    grid-area: summary !important;
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    width: 360px !important;
    min-width: 360px !important;
    max-width: 360px !important;
    gap: 10px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-hero-summary article {
    min-height: 72px !important;
    padding: 12px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-hero-summary article strong {
    font-size: 14px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-hero-readiness {
    min-height: 68px !important;
}

/* ---------------- WORKSPACE: larger, cleaner, easier to scan ---------------- */

html body .main .profile-page.profile-professional-v3 .profile-workspace {
    margin-top: 0 !important;
    border-radius: 20px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-workspace-header {
    padding: 24px 26px 18px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-workspace-header h2 {
    font-size: 25px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-workspace-header p {
    font-size: 13px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-connection-note {
    min-width: 270px !important;
}

/* ---------------- TABS: three real section cards ---------------- */

html body .main .profile-page.profile-professional-v3 .profile-settings-tabs {
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    gap: 12px !important;
    padding: 18px 26px 0 !important;
}

html body .main .profile-page.profile-professional-v3 .profile-settings-tab {
    grid-template-columns: 28px 44px minmax(0, 1fr) !important;
    min-height: 78px !important;
    padding: 13px 15px !important;
    border-radius: 15px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-tab-copy strong {
    font-size: 16px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-tab-copy small {
    font-size: 11px !important;
}

/* ---------------- PANEL: remove oversized empty space ---------------- */

html body .main .profile-page.profile-professional-v3 .profile-settings-tab-panels {
    padding: 18px 26px 0 !important;
}

html body .main .profile-page.profile-professional-v3 .profile-panel {
    min-height: 0 !important;
    gap: 18px !important;
    padding: 20px !important;
    border-radius: 17px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-panel-heading h3 {
    font-size: 22px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-panel-heading p {
    font-size: 13px !important;
}

/* ---------------- CARDS AND FORMS: improve hierarchy ---------------- */

html body .main .profile-page.profile-professional-v3 .profile-content-grid--profile {
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.75fr) !important;
    gap: 16px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-content-grid--password {
    grid-template-columns: minmax(0, 1.2fr) minmax(330px, 0.8fr) !important;
    gap: 16px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-card {
    padding: 20px !important;
    border-radius: 16px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-card-header h4,
html body .main .profile-page.profile-professional-v3 .profile-card--guidance h4 {
    font-size: 18px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-field-grid {
    gap: 16px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-input-shell {
    min-height: 50px !important;
    border-radius: 12px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-input-shell .form-control {
    height: 48px !important;
    font-size: 14px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-field .form-label,
html body .main .profile-page.profile-professional-v3 .profile-label-row .form-label {
    font-size: 12px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-assignment-list article {
    min-height: 64px !important;
    padding: 13px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-assignment-list strong {
    font-size: 14px !important;
}

/* ---------------- MFA ---------------- */

html body .main .profile-page.profile-professional-v3 .profile-security-overview,
html body .main .profile-page.profile-professional-v3 .profile-mfa-card {
    padding: 18px !important;
}

html body .main .profile-page.profile-professional-v3 .profile-mfa-benefits article {
    min-height: 76px !important;
}

/* ---------------- FOOTER ---------------- */

html body .main .profile-page.profile-professional-v3 .profile-actions {
    margin-top: 18px !important;
    padding: 16px 26px 20px !important;
}

/* ---------------- RESPONSIVE ---------------- */

@media (max-width: 1180px) {
    html body .main .profile-page.profile-professional-v3 > .profile-account-hero {
        grid-template-areas:
            "avatar identity"
            "summary summary" !important;
        grid-template-columns: 150px minmax(0, 1fr) !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-hero-summary {
        width: 100% !important;
        min-width: 0 !important;
        max-width: none !important;
        grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-hero-readiness {
        grid-column: auto !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-content-grid--profile,
    html body .main .profile-page.profile-professional-v3 .profile-content-grid--password {
        grid-template-columns: 1fr !important;
    }
}

@media (max-width: 820px) {
    html body .main .profile-page.profile-professional-v3 > .profile-account-hero {
        grid-template-areas:
            "avatar"
            "identity"
            "summary" !important;
        grid-template-columns: 1fr !important;
        justify-items: center !important;
        text-align: center !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-hero-identity {
        text-align: center !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-hero-security {
        justify-content: center !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-hero-summary {
        grid-template-columns: 1fr !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-workspace-header {
        flex-direction: column !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-connection-note {
        width: 100% !important;
        min-width: 0 !important;
        max-width: none !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-settings-tabs {
        grid-template-columns: 1fr !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-mfa-benefits {
        grid-template-columns: 1fr !important;
    }
}

@media (max-width: 600px) {
    html body .main .profile-page.profile-professional-v3 > .profile-account-hero {
        padding: 24px 18px !important;
    }

    html body .main .profile-page.profile-professional-v3 .profile-workspace-header,
    html body .main .profile-page.profile-professional-v3 .profile-settings-tabs,
    html body .main .profile-page.profile-professional-v3 .profile-settings-tab-panels,
    html body .main .profile-page.profile-professional-v3 .profile-actions {
        padding-left: 15px !important;
        padding-right: 15px !important;
    }
}
