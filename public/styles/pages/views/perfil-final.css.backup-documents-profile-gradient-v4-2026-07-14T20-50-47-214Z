/* Sliding active segment. */
html body .main .profile-page.profile-professional-v3 .profile-settings-tabs::before {
    content: "" !important;
    position: absolute !important;
    z-index: 0 !important;
    top: 6px !important;
    bottom: 6px !important;
    left: 6px !important;
    width: calc((100% - 24px) / 3) !important;
    border: 1px solid rgba(255, 255, 255, 0.13) !important;
    border-radius: 15px !important;
    background:
        radial-gradient(
            circle at 88% 5%,
            rgba(116, 228, 220, 0.20),
            transparent 32%
        ),
        linear-gradient(
            135deg,
            #0b1834 0%,
            #112b52 53%,
            #0d6171 100%
        ) !important;
    box-shadow:
        0 18px 34px -22px rgba(4, 18, 40, 0.92),
        inset 0 1px 0 rgba(255, 255, 255, 0.08) !important;
    transform:
        translateX(
            calc(
                var(--profile-active-index) *
                (100% + 6px)
            )
        ) !important;
    transition:
        transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 220ms ease !important;
    pointer-events: none !important;
}

/* Fine highlight on the premium active card. */
