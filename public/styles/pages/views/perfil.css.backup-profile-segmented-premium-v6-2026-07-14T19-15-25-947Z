/* =========================================================
   PROFILE & SECURITY — PROFESSIONAL REDESIGN V3
   ========================================================= */

html body .main .profile-page.profile-professional-v3 {
    display: grid;
    gap: 0;
    width: min(100%, 1680px) !important;
    max-width: 1680px !important;
    margin-inline: auto !important;
}

/* -------------------- HERO -------------------- */

html body .main .profile-page.profile-professional-v3 > .profile-account-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 210px 390px;
    align-items: center;
    gap: 28px;
    min-height: 224px;
    padding: 30px 34px 42px;
    overflow: visible;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    background:
        radial-gradient(circle at 86% 22%, rgba(255, 255, 255, 0.16), transparent 22%),
        radial-gradient(circle at 4% 120%, rgba(45, 212, 191, 0.18), transparent 36%),
        linear-gradient(124deg, #071d31 0%, #0d4166 58%, #0f766e 100%);
    box-shadow: 0 32px 74px -52px rgba(3, 18, 31, 0.98);
    color: #ffffff;
}

html body .main .profile-page.profile-professional-v3 > .profile-account-hero::after {
    content: "";
    position: absolute;
    right: -86px;
    bottom: -164px;
    z-index: 0;
    width: 350px;
    height: 350px;
    border: 48px solid rgba(255, 255, 255, 0.052);
    border-radius: 50%;
    pointer-events: none;
}

.profile-hero-identity,
.profile-hero-avatar-wrap,
.profile-hero-summary {
    position: relative;
    z-index: 2;
    min-width: 0;
}

.profile-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 28px;
    padding: 0 11px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.11);
    color: #f2f9fd;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.085em;
    text-transform: uppercase;
}

.profile-hero-identity h1 {
    margin: 16px 0 7px;
    color: #ffffff !important;
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(36px, 3.2vw, 52px) !important;
    font-weight: 950 !important;
    letter-spacing: -0.045em !important;
    line-height: 1 !important;
    text-shadow: 0 2px 14px rgba(2, 16, 28, 0.22);
}

.profile-hero-identity > p {
    margin: 0;
    color: #dcebf5 !important;
    font-size: 15px;
    font-weight: 650;
}

.profile-hero-security {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
}

.profile-hero-security span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 31px;
    padding: 0 11px;
    border: 1px solid rgba(255, 255, 255, 0.17);
    border-radius: 999px;
    background: rgba(5, 24, 39, 0.30);
    color: #edf8fd;
    font-size: 11px;
    font-weight: 800;
}

.profile-hero-security span:first-child i {
    color: #65e19a;
}

.profile-hero-avatar-wrap {
    align-self: end;
    display: grid;
    place-items: center;
    width: 190px;
    height: 190px;
    margin: 0 auto -90px;
}

.profile-avatar-preview {
    display: grid;
    width: 174px;
    height: 174px;
    place-items: center;
    overflow: hidden;
    border: 6px solid #ffffff;
    border-radius: 50%;
    background:
        linear-gradient(135deg, #dce9f2 0%, #edf4f8 100%);
    box-shadow:
        0 24px 44px -24px rgba(1, 12, 22, 0.86),
        0 0 0 3px rgba(198, 220, 235, 0.9);
    color: #41647f;
    font-size: 40px;
    font-weight: 900;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
}

.profile-avatar-preview.has-image {
    color: transparent;
}

.profile-avatar-action {
    position: absolute;
    right: 5px;
    bottom: 4px;
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border: 4px solid #ffffff;
    border-radius: 50%;
    background: #0b3555;
    color: #ffffff;
    cursor: pointer;
    box-shadow: 0 12px 24px -14px rgba(3, 18, 31, 0.9);
    transition: transform 160ms ease, background-color 160ms ease;
}

.profile-avatar-action:hover {
    transform: translateY(-2px) scale(1.03);
    background: #145681;
}

.profile-hero-summary {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 11px;
}

.profile-hero-summary article {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    align-items: center;
    gap: 11px;
    min-height: 78px;
    padding: 13px 14px;
    border: 1px solid rgba(255, 255, 255, 0.20);
    border-radius: 16px;
    background: rgba(5, 24, 39, 0.38);
    color: #ffffff;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
}

.profile-hero-summary-icon {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: 13px;
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
}

.profile-hero-summary small,
.profile-hero-readiness-head span,
.profile-hero-readiness > small {
    display: block;
    color: #d8eaf6;
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.07em;
    line-height: 1.2;
    text-transform: uppercase;
}

.profile-hero-summary article strong {
    display: block;
    margin-top: 4px;
    overflow: hidden;
    color: #ffffff;
    font-size: 16px;
    font-weight: 900;
    line-height: 1.16;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.profile-hero-readiness {
    grid-column: 1 / -1;
    display: block !important;
    min-height: 76px !important;
}

.profile-hero-readiness-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
}

.profile-hero-readiness-head strong {
    margin: 0 !important;
    font-size: 16px !important;
}

.profile-completion-track {
    height: 7px;
    margin: 10px 0 8px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.15);
}

.profile-completion-track span {
    display: block;
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #74e6af 0%, #8ee4ff 100%);
    transition: width 200ms ease;
}

/* -------------------- WORKSPACE -------------------- */

.profile-workspace {
    position: relative;
    z-index: 3;
    margin-top: 64px;
    overflow: hidden;
    border: 1px solid #d6e3ed;
    border-radius: 22px;
    background: #ffffff;
    box-shadow: 0 28px 60px -48px rgba(7, 27, 45, 0.62);
}

.profile-workspace-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 28px 20px;
    border-bottom: 1px solid #dce7ef;
}

.profile-section-kicker {
    display: block;
    margin-bottom: 6px;
    color: #5f7c94;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.profile-workspace-header h2 {
    margin: 0 0 7px;
    color: #102b46;
    font-size: 24px;
    font-weight: 920;
    letter-spacing: -0.025em;
}

.profile-workspace-header p {
    max-width: 760px;
    margin: 0;
    color: #60798f;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.5;
}

.profile-connection-note {
    display: flex;
    align-items: center;
    gap: 11px;
    max-width: 320px;
    min-height: 54px;
    padding: 10px 14px;
    border: 1px solid #cde4da;
    border-radius: 14px;
    background: #f2faf6;
    color: #176044;
}

.profile-connection-note > i {
    font-size: 17px;
}

.profile-connection-note span {
    display: grid;
    gap: 2px;
    font-size: 11px;
    font-weight: 650;
    line-height: 1.35;
}

.profile-connection-note strong {
    font-size: 12px;
    font-weight: 900;
}

.profile-settings-tabs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    padding: 18px 28px 0;
}

.profile-settings-tab {
    position: relative;
    display: grid;
    grid-template-columns: 28px 42px minmax(0, 1fr);
    align-items: center;
    gap: 11px;
    min-height: 76px;
    padding: 12px 14px;
    border: 1px solid #d5e2ec;
    border-radius: 16px;
    background: #f7fafc;
    color: #15314d;
    cursor: pointer;
    text-align: left;
    transition:
        transform 160ms ease,
        border-color 160ms ease,
        background-color 160ms ease,
        box-shadow 160ms ease;
}

.profile-settings-tab:hover {
    transform: translateY(-1px);
    border-color: #a9c7dc;
    box-shadow: 0 14px 26px -24px rgba(9, 50, 82, 0.65);
}

.profile-settings-tab.is-active {
    border-color: transparent;
    background: linear-gradient(135deg, #0d3d61 0%, #0b2b47 100%);
    color: #ffffff;
    box-shadow: 0 18px 34px -25px rgba(4, 25, 42, 0.80);
}

.profile-tab-number {
    color: #89a0b4;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.08em;
}

.profile-settings-tab.is-active .profile-tab-number {
    color: rgba(255, 255, 255, 0.60);
}

.profile-tab-icon {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: 13px;
    background: #e7f1f7;
    color: #16608b;
}

.profile-settings-tab.is-active .profile-tab-icon {
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
}

.profile-tab-copy strong {
    display: block;
    color: inherit;
    font-size: 15px;
    font-weight: 900;
    line-height: 1.15;
}

.profile-tab-copy small {
    display: block;
    margin-top: 4px;
    color: #668198;
    font-size: 11px;
    font-weight: 700;
    line-height: 1.25;
}

.profile-settings-tab.is-active .profile-tab-copy small {
    color: rgba(255, 255, 255, 0.76);
}

.profile-settings-tab-panels {
    padding: 18px 28px 0;
}

.profile-panel {
    display: grid;
    gap: 20px;
    min-height: 430px;
    padding: 22px;
    border: 1px solid #d9e5ee;
    border-radius: 18px;
    background:
        linear-gradient(180deg, #fbfdff 0%, #f7fafc 100%);
}

.profile-panel[hidden] {
    display: none !important;
}

.profile-panel-heading {
    display: flex;
    align-items: flex-start;
    gap: 14px;
}

.profile-panel-heading-icon {
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    flex: 0 0 46px;
    border: 1px solid #d3e1eb;
    border-radius: 14px;
    background: #ffffff;
    color: #155a84;
    font-size: 18px;
}

.profile-panel-heading h3 {
    margin: 1px 0 6px;
    color: #102c47;
    font-size: 21px;
    font-weight: 920;
    letter-spacing: -0.02em;
}

.profile-panel-heading p {
    margin: 0;
    color: #627c93;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.45;
}

.profile-content-grid {
    display: grid;
    gap: 16px;
    align-items: stretch;
}

.profile-content-grid--profile {
    grid-template-columns: minmax(0, 1.45fr) minmax(300px, 0.75fr);
}

.profile-content-grid--password {
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.75fr);
}

.profile-card {
    min-width: 0;
    padding: 19px;
    border: 1px solid #d8e4ed;
    border-radius: 17px;
    background: #ffffff;
    box-shadow: 0 14px 30px -30px rgba(7, 27, 45, 0.45);
}

.profile-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 17px;
}

.profile-card-header h4,
.profile-card--guidance h4 {
    margin: 0;
    color: #12304c;
    font-size: 17px;
    font-weight: 900;
}

.profile-card-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 28px;
    padding: 0 9px;
    border: 1px solid #c9dfeb;
    border-radius: 999px;
    background: #eff7fb;
    color: #1b5d84;
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.035em;
    text-transform: uppercase;
}

.profile-card-badge--managed {
    border-color: #d9e0e8;
    background: #f5f7f9;
    color: #5a7185;
}

.profile-field-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 15px;
}

.profile-field {
    display: grid;
    gap: 7px;
}

.profile-field .form-label,
.profile-label-row .form-label {
    color: #314e68;
    font-size: 12px;
    font-weight: 850;
}

.profile-input-shell {
    display: flex;
    align-items: center;
    min-height: 48px;
    padding: 0 13px;
    border: 1px solid #bfd1df;
    border-radius: 13px;
    background: #ffffff;
    transition: border-color 150ms ease, box-shadow 150ms ease;
}

.profile-input-shell:focus-within {
    border-color: #4d8ab6;
    box-shadow: 0 0 0 4px rgba(65, 131, 179, 0.12);
}

.profile-input-shell.is-readonly {
    background: #f4f8fb;
}

.profile-input-shell > i:first-child {
    width: 18px;
    margin-right: 9px;
    color: #67839a;
    text-align: center;
}

.profile-input-shell .form-control {
    width: 100%;
    min-width: 0;
    height: 44px;
    padding: 0;
    border: none !important;
    outline: none !important;
    background: transparent !important;
    box-shadow: none !important;
    color: #18334e;
    font-size: 13px;
    font-weight: 750;
}

.profile-input-shell .profile-readonly {
    color: #668198;
}

.profile-field-lock {
    color: #718a9f;
}

.profile-field small {
    color: #6b849a;
    font-size: 11px;
    font-weight: 600;
    line-height: 1.42;
}

.profile-photo-guidance,
.profile-managed-note,
.profile-security-tip {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 16px;
    padding: 13px 14px;
    border: 1px solid #d6e5ee;
    border-radius: 13px;
    background: #f4f9fc;
    color: #55738d;
    font-size: 11px;
    font-weight: 650;
    line-height: 1.4;
}

.profile-photo-guidance i,
.profile-managed-note i,
.profile-security-tip i {
    margin-top: 2px;
    color: #2877a5;
}

.profile-photo-guidance div {
    display: grid;
    gap: 2px;
}

.profile-photo-guidance strong {
    color: #1c4565;
    font-size: 12px;
}

.profile-assignment-list {
    display: grid;
    gap: 10px;
}

.profile-assignment-list article {
    display: grid;
    grid-template-columns: 40px minmax(0, 1fr);
    align-items: center;
    gap: 11px;
    padding: 12px;
    border: 1px solid #dce6ee;
    border-radius: 14px;
    background: #f9fbfd;
}

.profile-assignment-icon {
    display: grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border-radius: 12px;
    background: #e9f3f8;
    color: #1b6088;
}

.profile-assignment-list small {
    display: block;
    color: #6a8399;
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-transform: uppercase;
}

.profile-assignment-list strong {
    display: block;
    margin-top: 3px;
    color: #16324e;
    font-size: 13px;
    font-weight: 850;
    line-height: 1.3;
    word-break: break-word;
}

.profile-hidden-system-fields {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
}

.profile-password-fields {
    display: grid;
    gap: 14px;
}

.profile-password-shell button {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    flex: 0 0 34px;
    border: none;
    border-radius: 10px;
    background: transparent;
    color: #658097;
    cursor: pointer;
}

.profile-password-shell button:hover {
    background: #edf5fa;
    color: #175e88;
}

.profile-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

#profilePasswordMatchStatus {
    color: #71899d;
    font-size: 10px;
    font-weight: 850;
}

#profilePasswordMatchStatus[data-state="match"] {
    color: #16814c;
}

#profilePasswordMatchStatus[data-state="mismatch"] {
    color: #b64a33;
}

.profile-password-strength {
    margin-top: 18px;
    padding: 14px;
    border: 1px solid #d8e4ed;
    border-radius: 14px;
    background: #f7fafc;
}

.profile-password-strength > div:first-child {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.profile-password-strength span {
    color: #678096;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.profile-password-strength strong {
    color: #19364f;
    font-size: 12px;
    font-weight: 900;
}

.profile-password-strength-track {
    height: 7px;
    margin-top: 10px;
    overflow: hidden;
    border-radius: 999px;
    background: #dce6ed;
}

.profile-password-strength-track span {
    display: block;
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: #8ca0b1;
    transition: width 180ms ease, background-color 180ms ease;
}

.profile-password-strength[data-level="weak"] .profile-password-strength-track span {
    background: #d64545;
}

.profile-password-strength[data-level="fair"] .profile-password-strength-track span {
    background: #d78b25;
}

.profile-password-strength[data-level="good"] .profile-password-strength-track span {
    background: #c7a119;
}

.profile-password-strength[data-level="strong"] .profile-password-strength-track span,
.profile-password-strength[data-level="excellent"] .profile-password-strength-track span {
    background: #19965b;
}

.profile-card--guidance {
    background:
        radial-gradient(circle at 100% 0%, rgba(53, 132, 178, 0.10), transparent 32%),
        #f9fcfe;
}

.profile-guidance-icon {
    display: grid;
    width: 46px;
    height: 46px;
    margin-bottom: 13px;
    place-items: center;
    border-radius: 14px;
    background: #0f3d60;
    color: #ffffff;
    font-size: 18px;
}

.profile-card--guidance > p {
    margin: 7px 0 17px;
    color: #607b91;
    font-size: 12px;
    line-height: 1.5;
}

.profile-password-rules {
    display: grid;
    gap: 9px;
    margin: 0;
    padding: 0;
    list-style: none;
}

.profile-password-rules li {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #627b90;
    font-size: 11px;
    font-weight: 700;
}

.profile-password-rules li i {
    color: #9baebd;
}

.profile-password-rules li.is-met {
    color: #18794c;
}

.profile-password-rules li.is-met i {
    color: #23a667;
}

.profile-security-overview {
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr) auto;
    align-items: center;
    gap: 14px;
    padding: 16px;
    border: 1px solid #cfe1ec;
    border-radius: 16px;
    background:
        radial-gradient(circle at 100% 0%, rgba(42, 121, 169, 0.12), transparent 34%),
        linear-gradient(135deg, #f8fcfe 0%, #edf6fb 100%);
}

.profile-security-overview-icon {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border-radius: 14px;
    background: #0e456d;
    color: #ffffff;
    font-size: 18px;
}

.profile-security-overview > div > span {
    color: #607e95;
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-transform: uppercase;
}

.profile-security-overview h4 {
    margin: 4px 0 4px;
    color: #12314e;
    font-size: 17px;
    font-weight: 900;
}

.profile-security-overview p {
    margin: 0;
    color: #617c92;
    font-size: 11px;
    font-weight: 650;
}

.profile-security-status-dot {
    width: 11px;
    height: 11px;
    border: 3px solid #ffffff;
    border-radius: 50%;
    background: #df8a20;
    box-shadow: 0 0 0 1px #d7b47e;
}

.profile-security-status-dot.is-enabled {
    background: #24a468;
    box-shadow: 0 0 0 1px #8fcdae;
}

.profile-mfa-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 20px;
    border: 1px solid #d6e3ed;
    border-radius: 17px;
    background: #ffffff;
}

.profile-mfa-copy {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
}

.profile-mfa-icon {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    flex: 0 0 48px;
    border-radius: 14px;
    background: #0e456d;
    color: #ffffff;
    font-size: 18px;
}

.profile-mfa-copy h4 {
    margin: 2px 0 5px;
    color: #12314e;
    font-size: 17px;
    font-weight: 900;
}

.profile-mfa-copy p {
    margin: 0;
    color: #617b91;
    font-size: 11px;
    font-weight: 650;
}

.profile-mfa-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 9px;
    flex-wrap: wrap;
}

.profile-mfa-status {
    display: inline-flex;
    align-items: center;
    min-height: 31px;
    padding: 0 10px;
    border: 1px solid #d7e1e8;
    border-radius: 999px;
    background: #f6f8fa;
    color: #5f7588;
    font-size: 10px;
    font-weight: 900;
}

.profile-mfa-status.is-enabled {
    border-color: #bce2cb;
    background: #eaf8ef;
    color: #18784a;
}

.profile-mfa-benefits {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 11px;
}

.profile-mfa-benefits article {
    display: grid;
    grid-template-columns: 38px minmax(0, 1fr);
    gap: 10px;
    align-items: center;
    padding: 13px;
    border: 1px solid #dae5ed;
    border-radius: 14px;
    background: #ffffff;
}

.profile-mfa-benefits article > i {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border-radius: 11px;
    background: #edf5f9;
    color: #1c668f;
}

.profile-mfa-benefits strong {
    display: block;
    color: #17334f;
    font-size: 11px;
    font-weight: 900;
}

.profile-mfa-benefits span {
    display: block;
    margin-top: 3px;
    color: #698297;
    font-size: 10px;
    font-weight: 600;
    line-height: 1.35;
}

.profile-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 18px;
    padding: 17px 28px 20px;
    border-top: 1px solid #dce7ef;
    background: #fbfdfe;
}

.profile-actions > div {
    display: flex;
    gap: 9px;
    flex-wrap: wrap;
}

.profile-action-note {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #627c92;
    font-size: 11px;
    font-weight: 700;
}

.profile-professional-v3 .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 42px;
    padding: 0 15px;
    border: 1px solid transparent;
    border-radius: 12px;
    font-family: inherit;
    font-size: 12px;
    font-weight: 850;
    cursor: pointer;
    transition: transform 150ms ease, box-shadow 150ms ease, background-color 150ms ease;
}

.profile-professional-v3 .btn:hover {
    transform: translateY(-1px);
}

.profile-professional-v3 .btn-primary {
    background: #0d2d49;
    color: #ffffff;
    box-shadow: 0 14px 28px -20px rgba(4, 25, 42, 0.82);
}

.profile-professional-v3 .btn-secondary {
    border-color: #cbdbe7;
    background: #ffffff;
    color: #25445f;
}

/* -------------------- PHOTO CROP MODAL -------------------- */

.profile-crop-modal[hidden] {
    display: none !important;
}

.profile-crop-modal {
    position: fixed;
    inset: 0;
    z-index: 100000;
    display: grid;
    place-items: center;
    padding: 18px;
}

.profile-crop-backdrop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    background: rgba(7, 18, 31, 0.72);
    backdrop-filter: blur(7px);
}

.profile-crop-dialog {
    position: relative;
    z-index: 2;
    width: min(520px, calc(100vw - 28px));
    overflow: hidden;
    border: 1px solid #d6e2ec;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 34px 80px rgba(1, 12, 22, 0.34);
}

.profile-crop-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    border-bottom: 1px solid #dce7ef;
}

.profile-crop-header span {
    display: block;
    color: #668095;
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.profile-crop-header strong {
    display: block;
    margin-top: 3px;
    color: #15314c;
    font-size: 18px;
    font-weight: 900;
}

.profile-crop-close {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border: 1px solid #d3e0e9;
    border-radius: 11px;
    background: #ffffff;
    color: #536f86;
    cursor: pointer;
}

.profile-crop-stage {
    position: relative;
    width: min(360px, calc(100vw - 80px));
    aspect-ratio: 1;
    margin: 24px auto;
    overflow: hidden;
    border-radius: 18px;
    background: #0d2438;
    touch-action: none;
    cursor: grab;
}

.profile-crop-stage:active {
    cursor: grabbing;
}

.profile-crop-stage img {
    position: absolute;
    top: 50%;
    left: 50%;
    max-width: none;
    transform-origin: center;
    user-select: none;
    pointer-events: none;
}

.profile-crop-ring {
    position: absolute;
    inset: 8%;
    border: 3px solid #ffffff;
    border-radius: 50%;
    box-shadow: 0 0 0 999px rgba(4, 17, 29, 0.52);
    pointer-events: none;
}

.profile-crop-controls {
    display: grid;
    gap: 8px;
    padding: 0 22px 18px;
}

.profile-crop-controls label {
    color: #38556f;
    font-size: 11px;
    font-weight: 850;
}

.profile-crop-controls input {
    width: 100%;
}

.profile-crop-actions {
    display: flex;
    justify-content: flex-end;
    gap: 9px;
    padding: 16px 20px 20px;
    border-top: 1px solid #dce7ef;
    background: #f8fbfd;
}

/* -------------------- RESPONSIVE -------------------- */

@media (max-width: 1180px) {
    html body .main .profile-page.profile-professional-v3 > .profile-account-hero {
        grid-template-columns: minmax(0, 1fr) 190px;
    }

    .profile-hero-summary {
        grid-column: 1 / -1;
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .profile-hero-readiness {
        grid-column: auto;
    }

    .profile-content-grid--profile,
    .profile-content-grid--password {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 860px) {
    html body .main .profile-page.profile-professional-v3 > .profile-account-hero {
        grid-template-columns: 1fr;
        padding-bottom: 26px;
        text-align: center;
    }

    .profile-hero-security {
        justify-content: center;
    }

    .profile-hero-avatar-wrap {
        order: -1;
        align-self: center;
        margin: 0 auto;
    }

    .profile-hero-summary {
        grid-template-columns: 1fr;
        width: 100%;
    }

    .profile-workspace {
        margin-top: 18px;
    }

    .profile-workspace-header,
    .profile-actions,
    .profile-mfa-card {
        align-items: stretch;
        flex-direction: column;
    }

    .profile-connection-note {
        max-width: none;
    }

    .profile-settings-tabs {
        grid-template-columns: 1fr;
    }

    .profile-mfa-benefits {
        grid-template-columns: 1fr;
    }

    .profile-mfa-actions {
        justify-content: flex-start;
    }
}

@media (max-width: 620px) {
    .profile-workspace-header,
    .profile-settings-tabs,
    .profile-settings-tab-panels,
    .profile-actions {
        padding-left: 16px;
        padding-right: 16px;
    }

    .profile-panel {
        min-height: 0;
        padding: 17px;
    }

    .profile-settings-tab {
        grid-template-columns: 24px 40px minmax(0, 1fr);
    }

    .profile-security-overview {
        grid-template-columns: 44px minmax(0, 1fr);
    }

    .profile-security-status-dot {
        display: none;
    }

    .profile-actions > div,
    .profile-actions .btn,
    .profile-mfa-actions,
    .profile-mfa-actions .btn {
        width: 100%;
    }

    .profile-actions .btn,
    .profile-mfa-actions .btn {
        flex: 1 1 100%;
    }
}

.sr-only {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
}
