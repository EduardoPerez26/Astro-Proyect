/* Extracted from pages/views/tiendas.astro. Keep page/component-specific styling here. */
.stores-page {
            width: 100%;
            min-width: 0;
            padding-bottom: 16px;
        }

        .stores-hero {
            position: relative;
            display: grid;
            grid-template-columns: minmax(0, 1.5fr) minmax(310px, .8fr);
            gap: 44px;
            align-items: end;
            overflow: hidden;
            padding: 40px;
            border-radius: 20px;
            color: #fff;
            background:
                radial-gradient(circle at 88% 10%, rgba(97, 153, 204, .26), transparent 32%),
                linear-gradient(135deg, #091f35 0%, #102f50 56%, #174a75 100%);
            box-shadow: 0 28px 60px -42px rgba(5, 25, 45, .9);
        }

        .stores-hero::after {
            content: '';
            position: absolute;
            right: -80px;
            bottom: -155px;
            width: 330px;
            height: 330px;
            border: 1px solid rgba(255, 255, 255, .12);
            border-radius: 50%;
            box-shadow: 0 0 0 42px rgba(255, 255, 255, .025), 0 0 0 84px rgba(255, 255, 255, .02);
        }

        .stores-hero-copy,
        .stores-hero-metrics { position: relative; z-index: 1; }

        .stores-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 15px;
            color: #b9d6ef;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .12em;
            text-transform: uppercase;
        }

        .stores-hero h1 {
            max-width: 720px;
            margin: 0;
            font-family: 'Inter', sans-serif;
            font-size: clamp(34px, 4vw, 52px);
            font-weight: 600;
            line-height: 1.03;
            letter-spacing: -.025em;
        }

        .stores-hero p {
            max-width: 690px;
            margin: 18px 0 0;
            color: #cfdeeb;
            font-size: 14px;
            line-height: 1.75;
        }

        .stores-hero-metrics {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, .16);
            border-radius: 14px;
            background: rgba(255, 255, 255, .08);
            backdrop-filter: blur(8px);
        }

        .stores-hero-metrics > div {
            min-height: 105px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 18px;
            background: rgba(5, 25, 45, .22);
        }

        .stores-hero-metrics strong {
            font-family: 'Inter', sans-serif;
            font-size: 32px;
            line-height: 1;
        }

        .stores-hero-metrics span {
            margin-top: 7px;
            color: #c7d9e8;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

        .stores-operational-status {
            grid-column: 1 / -1;
            min-height: 48px !important;
            flex-direction: row !important;
            align-items: center;
            justify-content: flex-start !important;
            gap: 9px;
        }

        .status-pulse {
            width: 8px;
            height: 8px;
            margin: 0 !important;
            border-radius: 50%;
            background: #6fe49b;
            box-shadow: 0 0 0 5px rgba(111, 228, 155, .13);
        }

        .store-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 20px;
            width: 100%;
            min-width: 0;
            margin-top: 40px;
        }

        .stores-empty {
            padding: 54px 24px;
            border: 1px dashed #c9d5e1;
            border-radius: 16px;
            color: #718096;
            background: rgba(255, 255, 255, .7);
            text-align: center;
        }

        .stores-empty i { margin-bottom: 14px; color: var(--primary); font-size: 24px; }
        .stores-empty h2 { margin: 0 0 6px; color: #243b53; font-size: 18px; }
        .stores-empty p { margin: 0; font-size: 12px; }

        .stores-footer-note {
            display: flex;
            align-items: center;
            gap: 9px;
            margin-top: 20px;
            padding: 0 4px;
            color: #718096;
            font-size: 11px;
        }

        .stores-footer-note i { color: var(--primary); }

        @media (max-width: 1100px) {
            .stores-hero { grid-template-columns: 1fr; align-items: start; }
            .stores-hero-metrics { max-width: 520px; }
            .store-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @media (max-width: 780px) {
            .stores-hero { padding: 30px 24px; border-radius: 16px; }
            .store-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 480px) {
            .stores-hero h1 { font-size: 32px; }
            .stores-hero-metrics { grid-template-columns: 1fr 1fr; }
        }

        /* Apariencia de modulo contable */
        .stores-hero {
            grid-template-columns: minmax(0, 1fr) minmax(390px, 500px);
            gap: 28px;
            align-items: center;
            padding: 24px 28px;
            border: 1px solid #234864;
            border-radius: 6px;
            background: #102a43;
            box-shadow: none;
        }

        .stores-hero::after { display: none; }
        .stores-eyebrow {
            margin-bottom: 8px;
            color: #9fc3df;
            font-size: 11px;
            letter-spacing: .11em;
        }

        .stores-hero h1 {
            font-family: 'Inter', sans-serif;
            font-size: clamp(28px, 2.5vw, 34px);
            font-weight: 700;
            line-height: 1.15;
            letter-spacing: -.02em;
        }

        .stores-hero p {
            max-width: 650px;
            margin-top: 9px;
            color: #c7d8e6;
            font-size: 13px;
            line-height: 1.6;
        }

        .stores-hero-metrics {
            border-radius: 4px;
            background: #163753;
            backdrop-filter: none;
        }

        .stores-hero-metrics > div {
            min-height: 62px;
            padding: 12px 14px;
            background: transparent;
        }

        .stores-hero-metrics strong {
            font-family: 'Inter', sans-serif;
            font-size: 26px;
            font-weight: 700;
        }

        .stores-hero-metrics span {
            margin-top: 4px;
            font-size: 10px;
            letter-spacing: .06em;
        }

        .stores-operational-status { min-height: 34px !important; }
        .status-pulse { width: 6px; height: 6px; box-shadow: none; }

        .store-grid {
            gap: 14px;
            margin-top: 24px;
        }

        .stores-footer-note {
            margin-top: 14px;
            padding-top: 12px;
            border-top: 1px solid #d7e0e9;
            font-size: 11px;
        }

        @media (max-width: 1100px) {
            .stores-hero { grid-template-columns: 1fr; }
        }

        @media (max-width: 780px) {
            .stores-hero { padding: 20px; border-radius: 5px; }
        }
