/* Secondary actions become graphite rather than blue. */
html body :is(
    .btn-secondary,
    .secondary-btn,
    .secondary-button,
    .pm-secondary-button,
    .cancel-button,
    .reset-button,
    .replacement-file-cancel-button,
    .source-amortization-cancel-btn,
    .source-concept-cancel-btn
) {
    border: 1px solid #d2d2d2 !important;
    background:
        linear-gradient(
            180deg,
            #ffffff 0%,
            #eeeeee 100%
        ) !important;
    color: #171717 !important;
}

html body :is(
    .btn-secondary,
    .secondary-btn,
    .secondary-button,
    .pm-secondary-button,
    .cancel-button,
    .reset-button,
    .replacement-file-cancel-button,
    .source-amortization-cancel-btn,
    .source-concept-cancel-btn
):hover:not(:disabled) {
    border-color: #bcbcbc !important;
    background:
        linear-gradient(
            180deg,
            #f4f4f4 0%,
            #dcdcdc 100%
        ) !important;
    color: #000000 !important;
}

/* Generic administrative action buttons. */
html body :is(
    .action-btn,
    .action-button,
    .pm-card-action,
    .pm-table-action,
    .store-action,
    .permission-action,
    .view-toggle-btn
):not(
    .danger,
    .delete,
    .btn-danger,
    .comparison-delete-button
) {
    border-color: #303030 !important;
    background:
        linear-gradient(
            180deg,
            #1c1c1c 0%,
            #090909 100%
        ) !important;
    color: #ffffff !important;
}

/* Disabled state. */
html body button:disabled,
html body .btn:disabled,
html body [aria-disabled="true"] {
    opacity: 0.48 !important;
    cursor: not-allowed !important;
    transform: none !important;
}

/* Danger and success controls retain semantic meaning. */
html body :is(
    .btn-danger,
    .danger-button,
    .comparison-delete-button,
    .delete-button
) {
    color: #ffffff !important;
}

html body :is(
    .btn-success,
    .success-button
) {
    color: #ffffff !important;
}
