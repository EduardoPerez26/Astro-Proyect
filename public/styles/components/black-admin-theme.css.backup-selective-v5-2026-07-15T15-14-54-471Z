/* =========================================================
   XBFS — BLACK ADMIN THEME V3
   Applies a black/graphite visual system to:
   - main page headers / heroes
   - primary and secondary buttons
   - header action buttons
   Semantic warning, danger and success states remain identifiable.
   ========================================================= */

:root {
    --xbfs-black-0: #000000;
    --xbfs-black-1: #050505;
    --xbfs-black-2: #0d0d0d;
    --xbfs-black-3: #171717;
    --xbfs-black-4: #222222;

    --xbfs-black-border: rgba(255, 255, 255, 0.14);
    --xbfs-black-border-hover: rgba(255, 255, 255, 0.25);
    --xbfs-black-text: #ffffff;
    --xbfs-black-muted: #c7c7c7;
    --xbfs-black-soft: #969696;

    --xbfs-hero-bg-start: #030303;
    --xbfs-hero-bg-middle: #0b0b0b;
    --xbfs-hero-bg-end: #1a1a1a;

    --xbfs-sidebar-hero-start: #030303;
    --xbfs-sidebar-hero-middle: #0b0b0b;
    --xbfs-sidebar-hero-end: #1a1a1a;
}

/* ---------------------------------------------------------
   PAGE HEADERS / HEROES
   --------------------------------------------------------- */

html body .main :is(
    .xbfs-page-hero,
    .page-container > .page-header,
    .documents-system-hero,
    .comparison-history-hero,
    .stores-hero,
    .schedule-header,
    .admin-dashboard-header,
    .admin-users-hero,
    .operations-header,
    .system-errors-hero,
    .prepaid-hero,
    .pm-hero,
    .property-management-hero,
    .property-documents-hero,
    .profile-settings-hero,
    .profile-account-hero,
    .reconciliation-hero
) {
    border-color: rgba(255, 255, 255, 0.10) !important;
    background:
        radial-gradient(
            circle at 88% 12%,
            rgba(255, 255, 255, 0.105),
            transparent 28%
        ),
        radial-gradient(
            circle at 6% 120%,
            rgba(255, 255, 255, 0.055),
            transparent 39%
        ),
        linear-gradient(
            132deg,
            #020202 0%,
            #0a0a0a 54%,
            #1b1b1b 100%
        ) !important;
    color: #ffffff !important;
    box-shadow:
        0 30px 66px -48px rgba(0, 0, 0, 0.98),
        inset 0 1px 0 rgba(255, 255, 255, 0.045) !important;
}

