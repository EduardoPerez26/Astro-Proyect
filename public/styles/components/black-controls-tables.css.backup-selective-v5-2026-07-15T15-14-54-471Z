    .tab-button,
    .documents-type-tab,
    .profile-settings-tab,
    .admin-view-tab,
    .pagination-btn,
    .clear-filters,
    .store-action,
    .bk-tax-form-action,
    .bk-tax-add-store,
    .popeyes-tab-btn,
    .pm-filter-reset,
    .pm-card-action,
    .pm-table-action,
    .pm-full-action,
    .pm-qc-button,
    .reconciliation-compare-button,
    .comparison-export-button,
    .comparison-clear-button,
    .system-errors-action-primary,
    .system-error-clear,
    .system-errors-action-link,
    .operations-refresh,
    .chat-new-icon-btn,
    .chat-send-btn
):hover:not(:disabled):not([aria-disabled="true"]),
html body .main.main.main :is(
    button,
    [role="button"],
    a.btn,
    a.button,
    .btn,
    .button,
    .action-btn,
    .action-button,
    .tab-btn,
    .tab-button,
    .documents-type-tab,
    .profile-settings-tab,
    .admin-view-tab,
    .pagination-btn,
    .clear-filters,
    .store-action,
    .bk-tax-form-action,
    .bk-tax-add-store,
    .popeyes-tab-btn,
    .pm-filter-reset,
    .pm-card-action,
    .pm-table-action,
    .pm-full-action,
    .pm-qc-button,
    .reconciliation-compare-button,
    .comparison-export-button,
    .comparison-clear-button,
    .system-errors-action-primary,
    .system-error-clear,
    .system-errors-action-link,
    .operations-refresh,
    .chat-new-icon-btn,
    .chat-send-btn
