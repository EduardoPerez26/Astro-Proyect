            #111111 100%
        ) !important;
    color: #ffffff !important;
    box-shadow:
        0 15px 28px -20px rgba(0, 0, 0, 1),
        0 0 0 3px rgba(0, 0, 0, 0.10),
        inset 0 1px 0 rgba(255, 255, 255, 0.11) !important;
    transform: translateY(-1px) !important;
    outline: none !important;
}

/* Active tabs and toggles use a lighter black, not an accent color. */
html body .main.main.main :is(
    button,
    [role="button"],
    .btn,
    .button,
    .tab-btn,
    .tab-button,
    .documents-type-tab,
    .profile-settings-tab,
    .admin-view-tab,
    .pagination-btn,
    .popeyes-tab-btn
):is(
    .active,
    .is-active,
    [aria-selected="true"],
    [aria-pressed="true"],
    [aria-current="page"]
) {
    border-color: #606060 !important;
    background:
        linear-gradient(
            180deg,
            #3a3a3a 0%,
            #141414 100%
        ) !important;
    color: #ffffff !important;
    box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.13),
        0 14px 28px -22px rgba(0, 0, 0, 1) !important;
}

/* Disabled buttons. */
html body .main.main.main :is(
    button,
    [role="button"],
    .btn,
    .button
):is(:disabled, [aria-disabled="true"]) {
    border-color: #353535 !important;
    background:
        linear-gradient(
            180deg,
            #252525 0%,
            #151515 100%
        ) !important;
    color: #858585 !important;
    box-shadow: none !important;
    opacity: 0.68 !important;
    cursor: not-allowed !important;
    transform: none !important;
}

/* Icons inherit the button color unless a semantic rule follows. */
html body .main.main.main :is(
    button,
    [role="button"],
    .btn,
    .button,
    .action-btn,
    .action-button
) :is(i, svg) {
    color: currentColor !important;
    fill: currentColor;
}

