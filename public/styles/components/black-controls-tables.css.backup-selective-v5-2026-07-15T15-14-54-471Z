html body .main.main.main :is(
    table,
    .data-table,
    .conciliacion-table,
    .admin-table,
    .prepaid-table,
    .prepaid-source-table,
    .prepaid-schedule-matrix,
    .pm-documents-table,
    .pm-schedule-table,
    .pm-entities-table,
