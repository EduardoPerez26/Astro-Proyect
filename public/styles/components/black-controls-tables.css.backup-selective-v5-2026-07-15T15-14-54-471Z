            var(--xbfs-table-head-end) 0%,
            var(--xbfs-table-head-start) 100%
        ) !important;
}

html body .main.main.main :is(
    table,
    .data-table,
    .conciliacion-table,
    .admin-table,
    .prepaid-table,
    .prepaid-source-table,
    .prepaid-schedule-matrix,
    .pm-documents-table,
    .pm-schedule-table,
    .pm-entities-table,
    .pm-quarter-modal-table,
    .preview-excel-table,
    .system-errors-table
) thead th,
html body :is(
    .modal,
    .modal-overlay,
    .pm-modal,
    .pm-schedule-modal,
    .bk-tax-modal
) table thead th {
    border-top: 0 !important;
    border-right: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-bottom: 1px solid #000000 !important;
    background:
        linear-gradient(
            180deg,
            #1c1c1c 0%,
            #050505 100%
        ) !important;
    color: #ffffff !important;
    font-size: 10px !important;
    font-weight: 850 !important;
    letter-spacing: 0.045em !important;
    line-height: 1.25 !important;
    text-transform: uppercase !important;
    text-shadow: none !important;
}

/* Sticky table headers use the same black background. */
html body .main.main.main table thead th,
html body .main.main.main .sticky-table-header,
html body .main.main.main .floating-table-header {
    background-color: #090909 !important;
    background-image:
        linear-gradient(
            180deg,
            #1c1c1c 0%,
            #050505 100%
        ) !important;
    color: #ffffff !important;
}

/* Header corners. */
html body .main.main.main table thead tr:first-child th:first-child {
    border-top-left-radius: 13px !important;
}

html body .main.main.main table thead tr:first-child th:last-child {
    border-top-right-radius: 13px !important;
    border-right: 0 !important;
}

/* Body cells. */
html body .main.main.main table tbody tr,
html body :is(
    .modal,
    .modal-overlay,
    .pm-modal,
    .pm-schedule-modal,
    .bk-tax-modal
) table tbody tr {
    background: var(--xbfs-table-row) !important;
    color: var(--xbfs-table-text) !important;
    transition:
        background-color 130ms ease,
        box-shadow 130ms ease !important;
}

html body .main.main.main table tbody tr:nth-child(even),
html body :is(
    .modal,
    .modal-overlay,
    .pm-modal,
    .pm-schedule-modal,
    .bk-tax-modal
) table tbody tr:nth-child(even) {
    background: var(--xbfs-table-row-alt) !important;
}

html body .main.main.main table tbody tr:hover,
html body :is(
    .modal,
    .modal-overlay,
    .pm-modal,
    .pm-schedule-modal,
    .bk-tax-modal
) table tbody tr:hover {
    background: var(--xbfs-table-row-hover) !important;
    box-shadow:
        inset 3px 0 0 #181818 !important;
}

html body .main.main.main table tbody :is(td, th),
html body :is(
    .modal,
    .modal-overlay,
    .pm-modal,
    .pm-schedule-modal,
    .bk-tax-modal
) table tbody :is(td, th) {
    border-right: 1px solid #edf0f3 !important;
    border-bottom: 1px solid var(--xbfs-table-border) !important;
    background: inherit !important;
    color: var(--xbfs-table-text) !important;
    vertical-align: middle !important;
}

html body .main.main.main table tbody tr:last-child :is(td, th) {
    border-bottom: 0 !important;
}

html body .main.main.main table tbody tr:last-child td:first-child {
    border-bottom-left-radius: 13px !important;
}

html body .main.main.main table tbody tr:last-child td:last-child {
    border-bottom-right-radius: 13px !important;
}

/* Sticky first/last columns keep the correct row background. */
html body .main.main.main table tbody :is(
    td:first-child,
    th:first-child,
    td:last-child,
    th:last-child
)[style*="sticky"],
html body .main.main.main table tbody :is(
    .sticky-column,
    .sticky-left,
    .sticky-right,
    .actions-column
) {
    background: inherit !important;
}

/* Selected, active and flagged rows. */
html body .main.main.main table tbody tr:is(
    .selected,
    .is-selected,
    .active,
    [aria-selected="true"]
) {
    background: #e4e7ea !important;
    box-shadow:
        inset 4px 0 0 #050505 !important;
}

/* Table footer and totals. */
html body .main.main.main table tfoot :is(td, th) {
    border-top: 2px solid #1a1a1a !important;
    border-bottom: 0 !important;
    background:
        linear-gradient(
            180deg,
            #262626 0%,
            #0b0b0b 100%
        ) !important;
    color: #ffffff !important;
    font-weight: 800 !important;
}

