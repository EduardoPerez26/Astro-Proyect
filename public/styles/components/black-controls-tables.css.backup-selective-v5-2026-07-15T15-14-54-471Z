/* =========================================================
   XBFS — FULL BLACK BUTTONS & TABLES V4

   Global visual layer for all application views.
   It intentionally uses high-specificity selectors and !important
   because several Astro pages contain scoped component styles.

   Scope:
   - all application buttons outside the sidebar
   - table action buttons
   - tabs and pagination buttons
   - modal and SweetAlert actions
   - all application tables
   - table filters, search and pagination controls

   Semantic meaning is preserved through text/icon/border accents,
   while every action keeps the same black/graphite background.
   ========================================================= */

:root {
    --xbfs-control-black-0: #030303;
    --xbfs-control-black-1: #090909;
    --xbfs-control-black-2: #141414;
    --xbfs-control-black-3: #232323;
    --xbfs-control-black-4: #343434;

    --xbfs-control-white: #ffffff;
    --xbfs-control-text: #f7f7f7;
    --xbfs-control-muted: #b9b9b9;

    --xbfs-table-head-start: #030303;
    --xbfs-table-head-end: #181818;
    --xbfs-table-border: #d8dde3;
    --xbfs-table-row: #ffffff;
    --xbfs-table-row-alt: #f7f8fa;
    --xbfs-table-row-hover: #eceff2;
    --xbfs-table-text: #203247;
    --xbfs-table-muted: #687b8d;

    --xbfs-semantic-danger: #ff8d8d;
    --xbfs-semantic-success: #6bd7a2;
    --xbfs-semantic-warning: #f4c96a;
    --xbfs-semantic-info: #b9d7f1;
}

/* ---------------------------------------------------------
   GLOBAL BUTTON SYSTEM
   --------------------------------------------------------- */

/*
 * Main application buttons. The repeated .main class deliberately
 * raises specificity above Astro scoped selectors.
 */
html body .main.main.main :is(
    button,
    [role="button"],
    a.btn,
    a.button,
    .btn,
    .button,
    .action-btn,
    .action-button,
    .tab-btn,
    .tab-button,
    .documents-type-tab,
    .profile-settings-tab,
    .admin-view-tab,
    .pagination-btn,
    .clear-filters,
    .store-action,
    .bk-tax-form-action,
    .bk-tax-add-store,
    .popeyes-tab-btn,
    .pm-filter-reset,
    .pm-card-action,
    .pm-table-action,
    .pm-full-action,
    .pm-qc-button,
    .reconciliation-compare-button,
    .comparison-export-button,
    .comparison-clear-button,
    .system-errors-action-primary,
    .system-error-clear,
    .system-errors-action-link,
    .operations-refresh,
    .chat-new-icon-btn,
    .chat-send-btn
) {
    border: 1px solid #303030 !important;
    border-radius: 11px !important;
    background:
        linear-gradient(
            180deg,
            var(--xbfs-control-black-3) 0%,
            var(--xbfs-control-black-1) 100%
        ) !important;
    color: var(--xbfs-control-text) !important;
    box-shadow:
        0 12px 24px -20px rgba(0, 0, 0, 0.95),
        inset 0 1px 0 rgba(255, 255, 255, 0.08) !important;
    text-decoration: none !important;
    text-shadow: none !important;
    transition:
        transform 150ms ease,
        border-color 150ms ease,
        background-color 150ms ease,
        box-shadow 150ms ease !important;
}

/* Hover and focus remain graphite, never blue. */
html body .main.main.main :is(
