/* ============================================================
   XBFS ALERTS V5 — GRAPHITE + WHITE SYSTEM

   Matches the current application:
   - graphite sidebar and primary actions
   - white administrative surfaces
   - light gray borders
   - semantic colors used only as accents
   ============================================================ */

:root {
    --xbfs-alert-navy: #0a0a0a;
    --xbfs-alert-navy-hover: #252525;

    --xbfs-alert-blue: #262626;
    --xbfs-alert-blue-soft: #f0f1f2;

    --xbfs-alert-green: #17845f;
    --xbfs-alert-green-soft: #edf8f3;

    --xbfs-alert-amber: #b87512;
    --xbfs-alert-amber-soft: #fff7e7;

    --xbfs-alert-red: #c53b34;
    --xbfs-alert-red-soft: #fff1f0;

    --xbfs-alert-text: #20262d;
    --xbfs-alert-text-strong: #101317;
    --xbfs-alert-muted: #69737d;

    --xbfs-alert-border: #d7dce1;
    --xbfs-alert-border-soft: #e8ebee;
    --xbfs-alert-page: #f5f6f7;
    --xbfs-alert-white: #ffffff;

    --xbfs-alert-shadow:
        0 38px 90px -48px rgba(0, 0, 0, 0.86),
        0 16px 42px -34px rgba(0, 0, 0, 0.44);
}

/* Dark neutral backdrop. */
html body .swal2-container.xbfs-swal-container {
    background: rgba(0, 0, 0, 0.54) !important;
    backdrop-filter: blur(6px) saturate(92%) !important;
    -webkit-backdrop-filter: blur(6px) saturate(92%) !important;
}

html body .swal2-container.xbfs-swal-container.swal2-backdrop-hide {
    background: rgba(0, 0, 0, 0) !important;
}

/* Main white administrative card. */
html body .swal2-popup.xbfs-swal-popup {
    border: 1px solid #d5dadd !important;
    border-radius: 18px !important;
    background:
        radial-gradient(
            circle at 96% 4%,
            rgba(0, 0, 0, 0.025),
            transparent 27%
        ),
        linear-gradient(
            180deg,
            #ffffff 0%,
            #fcfcfd 100%
        ) !important;
    color: var(--xbfs-alert-text) !important;
    box-shadow: var(--xbfs-alert-shadow) !important;
}

/*
 * Graphite top line with a short semantic section.
 * Success/error/warning remain recognizable without turning
 * the full alert into a strongly colored card.
 */
html body .swal2-popup.xbfs-swal-popup::before {
    height: 5px !important;
    background:
        linear-gradient(
            90deg,
            var(--xbfs-alert-accent) 0 72px,
            #090909 72px 100%
        ) !important;
}

/* Compact administrative layout. */
html body .swal2-popup.xbfs-alert-simple:not(.xbfs-alert-preserve-layout),
html body .swal2-popup.xbfs-alert-confirm:not(.xbfs-alert-preserve-layout),
html body .swal2-popup.xbfs-alert-loading:not(.xbfs-alert-preserve-layout),
html body .swal2-popup.xbfs-alert-form:not(.xbfs-alert-preserve-layout) {
    grid-template-columns: 52px minmax(0, 1fr) !important;
    column-gap: 16px !important;
    padding: 29px 27px 21px !important;
}

html body .swal2-popup.xbfs-alert-confirm:not(.xbfs-alert-preserve-layout),
html body .swal2-popup.xbfs-alert-form:not(.xbfs-alert-preserve-layout) {
    width: min(530px, calc(100vw - 28px)) !important;
}

/* Graphite icon tile with semantic glyph. */
html body .swal2-popup:not(.xbfs-alert-preserve-layout)
.swal2-icon.xbfs-swal-icon {
    width: 50px !important;
    height: 50px !important;
    margin-top: 0 !important;

    border: 1px solid #292929 !important;
    border-radius: 14px !important;

    background:
        radial-gradient(
            circle at 27% 18%,
            rgba(255, 255, 255, 0.14),
            transparent 32%
        ),
        linear-gradient(
            145deg,
            #303030 0%,
            #151515 58%,
            #070707 100%
        ) !important;

    color: var(--xbfs-alert-accent) !important;

    box-shadow:
        0 16px 28px -22px rgba(0, 0, 0, 0.86),
        inset 0 1px 0 rgba(255, 255, 255, 0.10) !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout)
.swal2-icon.xbfs-swal-icon
.xbfs-alert-glyph {
    color: var(--xbfs-alert-accent) !important;
    text-shadow: 0 2px 11px rgba(0, 0, 0, 0.42) !important;
}

/* Neutral/info glyphs remain white on graphite. */
html body .swal2-popup.xbfs-alert-info:not(.xbfs-alert-preserve-layout)
.xbfs-alert-glyph,
html body .swal2-popup.xbfs-alert-question:not(.xbfs-alert-preserve-layout)
.xbfs-alert-glyph,
html body .swal2-popup.xbfs-alert-neutral:not(.xbfs-alert-preserve-layout)
.xbfs-alert-glyph {
    color: #ffffff !important;
}

/* Titles and content. */
html body .swal2-popup:not(.xbfs-alert-preserve-layout)
> .swal2-title.xbfs-swal-title {
    color: #111418 !important;
    font-size: 21px !important;
    font-weight: 900 !important;
    letter-spacing: -0.025em !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout)
> .swal2-html-container.xbfs-swal-html {
    margin-top: 6px !important;
    color: #68727c !important;
    font-size: 13px !important;
    line-height: 1.58 !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout)
.swal2-html-container.xbfs-swal-html strong {
    color: #20262d !important;
}

/* Form labels and inputs. */
html body .swal2-popup:not(.xbfs-alert-preserve-layout)
.swal2-input-label {
    color: #343b43 !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout)
:is(
    .swal2-input.xbfs-swal-input,
    .swal2-textarea.xbfs-swal-input,
    .swal2-select.xbfs-swal-input
