}

/* Primary confirm button: graphite. */
html body .swal2-popup:not(.xbfs-alert-preserve-layout)
.swal2-confirm.xbfs-swal-confirm {
    border-color: #202020 !important;
    background:
        linear-gradient(
            180deg,
