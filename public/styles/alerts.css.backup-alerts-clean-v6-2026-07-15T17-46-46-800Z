    border-color: #2d3237 !important;
    background: #ffffff !important;
    box-shadow:
        0 0 0 4px rgba(0, 0, 0, 0.075),
        inset 0 1px 0 rgba(255, 255, 255, 1) !important;
}

/* Radio and checkbox form panels. */
html body .swal2-popup:not(.xbfs-alert-preserve-layout)
:is(.swal2-radio, .swal2-checkbox) {
    border-color: #d9dde1 !important;
    background: #f6f7f8 !important;
    color: #313840 !important;
