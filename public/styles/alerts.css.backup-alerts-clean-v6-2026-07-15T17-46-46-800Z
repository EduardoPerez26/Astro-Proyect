    border: 1px solid #cfd5da !important;
    border-radius: 11px !important;
    background:
        linear-gradient(
            180deg,
            #ffffff 0%,
            #f8f9fa 100%
        ) !important;
    color: #18212a !important;
    box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.95) !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout)
:is(
    .swal2-input.xbfs-swal-input,
    .swal2-textarea.xbfs-swal-input,
    .swal2-select.xbfs-swal-input
