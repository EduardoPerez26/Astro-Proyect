/* ============================================================
   XBFS ALERTS — PROJECT-ALIGNED SWEETALERT2 THEME
   Administrative, compact and consistent with the application UI.
   ============================================================ */

:root {
    --xbfs-alert-navy: #0d1123;
    --xbfs-alert-navy-hover: #171c34;
    --xbfs-alert-blue: #1d5f9f;
    --xbfs-alert-blue-soft: #eef7ff;
    --xbfs-alert-green: #0f766e;
    --xbfs-alert-green-soft: #e8f7f5;
    --xbfs-alert-amber: #a16207;
    --xbfs-alert-amber-soft: #fff7e6;
    --xbfs-alert-red: #b42318;
    --xbfs-alert-red-soft: #fff1f1;
    --xbfs-alert-text: #102a43;
    --xbfs-alert-text-strong: #061d33;
    --xbfs-alert-muted: #61768a;
    --xbfs-alert-border: #cfdeeb;
    --xbfs-alert-border-soft: #e4edf5;
    --xbfs-alert-page: #f7fafc;
    --xbfs-alert-white: #ffffff;
    --xbfs-alert-shadow: 0 28px 76px -42px rgba(6, 29, 51, 0.78);
}

@keyframes xbfs-alert-in {
    from { opacity: 0; transform: translate3d(0, 8px, 0) scale(.985); }
    to { opacity: 1; transform: translate3d(0, 0, 0) scale(1); }
}

@keyframes xbfs-alert-out {
    from { opacity: 1; transform: translate3d(0, 0, 0) scale(1); }
    to { opacity: 0; transform: translate3d(0, 5px, 0) scale(.99); }
}

@keyframes xbfs-toast-in {
    from { opacity: 0; transform: translate3d(12px, 0, 0); }
    to { opacity: 1; transform: translate3d(0, 0, 0); }
}

@keyframes xbfs-toast-out {
    from { opacity: 1; transform: translate3d(0, 0, 0); }
    to { opacity: 0; transform: translate3d(10px, 0, 0); }
}

.xbfs-swal-enter { animation: xbfs-alert-in 180ms cubic-bezier(.16, 1, .3, 1) both !important; }
.xbfs-swal-exit { animation: xbfs-alert-out 130ms ease-in both !important; }
.xbfs-toast-enter { animation: xbfs-toast-in 190ms cubic-bezier(.16, 1, .3, 1) both !important; }
.xbfs-toast-exit { animation: xbfs-toast-out 140ms ease-in both !important; }

html body .swal2-container.xbfs-swal-container,
html body .swal2-container.xbfs-toast-container {
    z-index: 2147483000 !important;
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
}

html body .swal2-container.xbfs-swal-container {
    padding: 20px !important;
    background: rgba(6, 29, 51, .48) !important;
    backdrop-filter: blur(4px) saturate(108%);
    -webkit-backdrop-filter: blur(4px) saturate(108%);
}

html body .swal2-container.xbfs-swal-container.swal2-backdrop-hide {
    background: rgba(6, 29, 51, 0) !important;
}

/* Base shell. Rich application dialogs retain their own internal layout. */
html body .swal2-popup.xbfs-swal-popup {
    --xbfs-alert-accent: var(--xbfs-alert-blue);
    --xbfs-alert-accent-soft: var(--xbfs-alert-blue-soft);
    position: relative !important;
    max-width: calc(100vw - 28px) !important;
    border: 1px solid var(--xbfs-alert-border) !important;
    border-radius: 14px !important;
    background: var(--xbfs-alert-white) !important;
    color: var(--xbfs-alert-text) !important;
    box-shadow: var(--xbfs-alert-shadow) !important;
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    overflow: hidden !important;
}

html body .swal2-popup.xbfs-swal-popup::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    background: var(--xbfs-alert-accent);
    z-index: 4;
}

html body .swal2-popup.xbfs-alert-success {
    --xbfs-alert-accent: var(--xbfs-alert-green);
    --xbfs-alert-accent-soft: var(--xbfs-alert-green-soft);
}

html body .swal2-popup.xbfs-alert-error {
    --xbfs-alert-accent: var(--xbfs-alert-red);
    --xbfs-alert-accent-soft: var(--xbfs-alert-red-soft);
}

html body .swal2-popup.xbfs-alert-warning {
    --xbfs-alert-accent: var(--xbfs-alert-amber);
    --xbfs-alert-accent-soft: var(--xbfs-alert-amber-soft);
}

html body .swal2-popup.xbfs-alert-question,
html body .swal2-popup.xbfs-alert-info,
html body .swal2-popup.xbfs-alert-neutral {
    --xbfs-alert-accent: var(--xbfs-alert-blue);
    --xbfs-alert-accent-soft: var(--xbfs-alert-blue-soft);
}

/* Standard administrative alert layout. */
html body .swal2-popup.xbfs-alert-simple:not(.xbfs-alert-preserve-layout),
html body .swal2-popup.xbfs-alert-confirm:not(.xbfs-alert-preserve-layout),
html body .swal2-popup.xbfs-alert-loading:not(.xbfs-alert-preserve-layout),
html body .swal2-popup.xbfs-alert-form:not(.xbfs-alert-preserve-layout) {
    width: min(470px, calc(100vw - 28px)) !important;
    display: grid !important;
    grid-template-columns: 48px minmax(0, 1fr) !important;
    grid-template-areas:
        "icon title"
        "icon content"
        "label label"
        "input input"
        "validation validation"
        "actions actions"
        "footer footer" !important;
    column-gap: 15px !important;
    row-gap: 0 !important;
    padding: 25px 24px 20px !important;
    text-align: left !important;
}

html body .swal2-popup.xbfs-alert-confirm:not(.xbfs-alert-preserve-layout),
html body .swal2-popup.xbfs-alert-form:not(.xbfs-alert-preserve-layout) {
    width: min(520px, calc(100vw - 28px)) !important;
}

html body .swal2-popup.xbfs-alert-form-textarea:not(.xbfs-alert-preserve-layout) {
    width: min(560px, calc(100vw - 28px)) !important;
}

html body .swal2-popup.xbfs-alert-no-icon:not(.xbfs-alert-preserve-layout) {
    grid-template-columns: minmax(0, 1fr) !important;
    grid-template-areas:
        "title"
        "content"
        "label"
        "input"
        "validation"
        "actions"
        "footer" !important;
}

html body .swal2-popup.xbfs-alert-complex:not(.xbfs-alert-preserve-layout) {
    min-width: 0 !important;
}

/* Stable status icon: compact square, matching project cards and action controls. */
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-icon.xbfs-swal-icon {
    grid-area: icon !important;
    align-self: start !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 46px !important;
    height: 46px !important;
    margin: 1px 0 0 !important;
    overflow: hidden !important;
    border: 0 !important;
    border-radius: 10px !important;
    background: var(--xbfs-alert-accent-soft) !important;
    color: var(--xbfs-alert-accent) !important;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--xbfs-alert-accent) 18%, transparent) !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-icon.xbfs-swal-icon.xbfs-icon-rendered > *:not(.xbfs-alert-glyph) {
    display: none !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-icon.xbfs-swal-icon .xbfs-alert-glyph {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    height: 100% !important;
    color: var(--xbfs-alert-accent) !important;
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 28px !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    user-select: none;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .xbfs-alert-glyph-success {
    font-size: 29px !important;
    transform: translateY(-1px);
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .xbfs-alert-glyph-error {
    font-size: 33px !important;
    font-weight: 500 !important;
    transform: translateY(-2px);
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .xbfs-alert-glyph-warning,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .xbfs-alert-glyph-info,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .xbfs-alert-glyph-question {
    font-size: 24px !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) > .swal2-title.xbfs-swal-title {
    grid-area: title !important;
    align-self: end !important;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    color: var(--xbfs-alert-text-strong) !important;
    font-family: inherit !important;
    font-size: 20px !important;
    line-height: 1.25 !important;
    font-weight: 850 !important;
    letter-spacing: -.02em !important;
    text-align: left !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) > .swal2-html-container.xbfs-swal-html {
    grid-area: content !important;
    align-self: start !important;
    width: 100% !important;
    margin: 5px 0 0 !important;
    padding: 0 !important;
    color: var(--xbfs-alert-muted) !important;
    font-family: inherit !important;
    font-size: 13px !important;
    line-height: 1.55 !important;
    text-align: left !important;
    overflow-wrap: anywhere;
}

html body .swal2-popup.xbfs-alert-no-icon:not(.xbfs-alert-preserve-layout) > .swal2-title.xbfs-swal-title,
html body .swal2-popup.xbfs-alert-no-icon:not(.xbfs-alert-preserve-layout) > .swal2-html-container.xbfs-swal-html {
    grid-column: 1 !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-html-container.xbfs-swal-html p {
    margin: 0 0 8px !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-html-container.xbfs-swal-html p:last-child {
    margin-bottom: 0 !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-html-container.xbfs-swal-html strong {
    color: var(--xbfs-alert-text) !important;
    font-weight: 800 !important;
}

/* Inputs and form alerts. */
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-input-label {
    grid-area: label !important;
    display: block !important;
    justify-self: stretch !important;
    width: 100% !important;
    margin: 20px 0 7px !important;
    padding: 0 !important;
    color: #40586f !important;
    font-family: inherit !important;
    font-size: 11px !important;
    line-height: 1.3 !important;
    font-weight: 850 !important;
    letter-spacing: .045em !important;
    text-align: left !important;
    text-transform: uppercase !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-input.xbfs-swal-input,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-textarea.xbfs-swal-input,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-select.xbfs-swal-input,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-file.xbfs-swal-input {
    grid-area: input !important;
    display: block !important;
    justify-self: stretch !important;
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    box-sizing: border-box !important;
    border: 1px solid #cfddea !important;
    border-radius: 8px !important;
    background: #ffffff !important;
    color: var(--xbfs-alert-text) !important;
    box-shadow: 0 1px 0 rgba(16, 42, 67, .025) !important;
    font-family: inherit !important;
    font-size: 13px !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-input.xbfs-swal-input,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-select.xbfs-swal-input,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-file.xbfs-swal-input {
    height: 46px !important;
    padding: 0 13px !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-textarea.xbfs-swal-input {
    min-height: 116px !important;
    max-height: 260px !important;
    padding: 12px 13px !important;
    line-height: 1.5 !important;
    resize: vertical !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-input.xbfs-swal-input::placeholder,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-textarea.xbfs-swal-input::placeholder {
    color: #7d92a6 !important;
    opacity: 1 !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-input.xbfs-swal-input:focus,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-textarea.xbfs-swal-input:focus,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-select.xbfs-swal-input:focus,
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-file.xbfs-swal-input:focus {
    border-color: #6d9fcf !important;
    outline: 0 !important;
    box-shadow: 0 0 0 4px rgba(29, 95, 159, .12) !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-validation-message.xbfs-swal-validation {
    grid-area: validation !important;
    width: 100% !important;
    margin: 12px 0 0 !important;
    padding: 10px 12px !important;
    border: 1px solid #efbbb6 !important;
    border-radius: 8px !important;
    background: var(--xbfs-alert-red-soft) !important;
    color: #9f1c14 !important;
    font-family: inherit !important;
    font-size: 12px !important;
    line-height: 1.4 !important;
    font-weight: 750 !important;
    text-align: left !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-validation-message.xbfs-swal-validation::before {
    color: var(--xbfs-alert-red) !important;
}

/* Footer/action bar mirrors project modal footers. */
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-actions.xbfs-swal-actions {
    grid-area: actions !important;
    display: flex !important;
    width: auto !important;
    margin: 22px -24px -20px !important;
    padding: 15px 24px 16px !important;
    gap: 9px !important;
    align-items: center !important;
    justify-content: flex-end !important;
    border-top: 1px solid var(--xbfs-alert-border-soft) !important;
    background: var(--xbfs-alert-page) !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-actions.xbfs-swal-actions button {
    min-width: 112px !important;
    min-height: 41px !important;
    margin: 0 !important;
    padding: 0 16px !important;
    border: 1px solid transparent !important;
    border-radius: 8px !important;
    font-family: inherit !important;
    font-size: 12.5px !important;
    line-height: 1 !important;
    font-weight: 850 !important;
    box-shadow: none !important;
    transition: transform 150ms ease, background 150ms ease, border-color 150ms ease, box-shadow 150ms ease !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-actions.xbfs-swal-actions button:hover:not(:disabled) {
    transform: translateY(-1px) !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-actions.xbfs-swal-actions button:focus-visible {
    outline: 0 !important;
    box-shadow: 0 0 0 4px rgba(29, 95, 159, .14) !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-confirm.xbfs-swal-confirm {
    border-color: var(--xbfs-alert-navy) !important;
    background: var(--xbfs-alert-navy) !important;
    color: #ffffff !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-confirm.xbfs-swal-confirm:hover:not(:disabled) {
    border-color: var(--xbfs-alert-navy-hover) !important;
    background: var(--xbfs-alert-navy-hover) !important;
    box-shadow: 0 12px 22px -17px rgba(13, 17, 35, .78) !important;
}

html body .swal2-popup.xbfs-alert-danger-action:not(.xbfs-alert-preserve-layout) .swal2-confirm.xbfs-swal-confirm {
    border-color: var(--xbfs-alert-red) !important;
    background: var(--xbfs-alert-red) !important;
}

html body .swal2-popup.xbfs-alert-danger-action:not(.xbfs-alert-preserve-layout) .swal2-confirm.xbfs-swal-confirm:hover:not(:disabled) {
    border-color: #961d14 !important;
    background: #961d14 !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-deny.xbfs-swal-deny {
    border-color: #c5d8e9 !important;
    background: #eef6fc !important;
    color: #174d7a !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-cancel.xbfs-swal-cancel {
    border-color: #cfddea !important;
    background: #ffffff !important;
    color: #40586f !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-cancel.xbfs-swal-cancel:hover:not(:disabled),
html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-deny.xbfs-swal-deny:hover:not(:disabled) {
    border-color: #aec4d8 !important;
    background: #edf4fa !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-close.xbfs-swal-close {
    top: 12px !important;
    right: 12px !important;
    width: 34px !important;
    height: 34px !important;
    border: 1px solid #d6e2ed !important;
    border-radius: 8px !important;
    background: #f5f9fc !important;
    color: #5a7085 !important;
    font-size: 22px !important;
    line-height: 1 !important;
    box-shadow: none !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-close.xbfs-swal-close:hover {
    border-color: #bfcfdd !important;
    background: #edf4fa !important;
    color: #173f64 !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-loader.xbfs-swal-loader {
    grid-column: 1 / -1 !important;
    width: 42px !important;
    height: 42px !important;
    margin: 18px auto 0 !important;
    border-width: 4px !important;
    border-color: var(--xbfs-alert-blue) transparent var(--xbfs-alert-blue) transparent !important;
}

html body .swal2-popup.xbfs-alert-loading:not(.xbfs-alert-preserve-layout) .swal2-icon {
    display: none !important;
}

html body .swal2-popup.xbfs-alert-loading:not(.xbfs-alert-preserve-layout) {
    grid-template-columns: minmax(0, 1fr) !important;
    grid-template-areas: "title" "content" "actions" !important;
    text-align: center !important;
}

html body .swal2-popup.xbfs-alert-loading:not(.xbfs-alert-preserve-layout) > .swal2-title,
html body .swal2-popup.xbfs-alert-loading:not(.xbfs-alert-preserve-layout) > .swal2-html-container {
    text-align: center !important;
}

html body .swal2-popup:not(.xbfs-alert-preserve-layout) .swal2-timer-progress-bar.xbfs-swal-progress {
    height: 3px !important;
    background: var(--xbfs-alert-accent) !important;
    opacity: .88 !important;
}

/* Toast notifications. */
html body .swal2-container.xbfs-toast-container {
    width: auto !important;
    max-width: calc(100vw - 18px) !important;
    padding: 14px !important;
    background: transparent !important;
    pointer-events: none !important;
}

html body .swal2-popup.xbfs-toast-popup {
    --xbfs-alert-accent: var(--xbfs-alert-blue);
    --xbfs-alert-accent-soft: var(--xbfs-alert-blue-soft);
    position: relative !important;
    display: grid !important;
