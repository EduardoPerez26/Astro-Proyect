    overflow: hidden !important;
}

html body .swal2-popup.xbfs-toast-popup::before { display: none !important; }
html body .swal2-popup.xbfs-toast-popup.xbfs-alert-success { --xbfs-alert-accent: var(--xbfs-alert-green); --xbfs-alert-accent-soft: var(--xbfs-alert-green-soft); }
html body .swal2-popup.xbfs-toast-popup.xbfs-alert-error { --xbfs-alert-accent: var(--xbfs-alert-red); --xbfs-alert-accent-soft: var(--xbfs-alert-red-soft); }
html body .swal2-popup.xbfs-toast-popup.xbfs-alert-warning { --xbfs-alert-accent: var(--xbfs-alert-amber); --xbfs-alert-accent-soft: var(--xbfs-alert-amber-soft); }

html body .swal2-popup.xbfs-toast-popup .swal2-icon.xbfs-swal-icon {
    grid-column: 1 !important;
    grid-row: 1 / span 2 !important;
    align-self: center !important;
    width: 34px !important;
    height: 34px !important;
    margin: 0 !important;
    border-radius: 8px !important;
}

html body .swal2-popup.xbfs-toast-popup .xbfs-alert-glyph { font-size: 20px !important; }
html body .swal2-popup.xbfs-toast-popup .xbfs-alert-glyph-error { font-size: 24px !important; }

html body .swal2-popup.xbfs-toast-popup .swal2-title.xbfs-swal-title {
    grid-column: 2 !important;
    grid-row: 1 !important;
    align-self: end !important;
    margin: 0 !important;
    padding: 0 !important;
    color: var(--xbfs-alert-text-strong) !important;
    font-size: 13px !important;
    line-height: 1.35 !important;
    font-weight: 850 !important;
