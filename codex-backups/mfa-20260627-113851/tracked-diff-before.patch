+}
+
+.profile-settings-tab i {
+    color: #0f5f59;
+}
+
+.profile-settings-tab-panels {
+    padding: 20px 22px 22px;
+}
+
+.profile-tab-panel {
+    border: 0;
+    border-top: 0;
+    border-radius: 0;
+    background: transparent;
+    box-shadow: none;
+    overflow: visible;
+}
+
+.profile-tab-panel[hidden] {
+    display: none !important;
+}
+
+.profile-tab-panel .profile-panel-header {
+    padding: 0 0 16px;
+    border: 0;
+    background: transparent;
+}
+
+.profile-tab-panel .profile-panel-header h2 {
+    font-size: 20px;
+}
+
+.profile-tab-panel .profile-panel-header > i {
+    border: 1px solid #d8e5ef;
+    background: #eef4f9;
+}
+
+.profile-tab-panel .profile-panel-body {
+    padding: 0;
+}
+
+.profile-panel .form-label {
+    color: #344f67;
+}
+
+.profile-panel .form-control {
+    min-height: 46px;
+    border-color: #bfd0df;
+}
+
+.profile-actions {
+    position: static;
+    justify-content: flex-end;
+    padding: 16px 22px;
+    border-top: 1px solid #d8e5ef;
+    background: #fbfdff;
+}
+
+.profile-actions .btn {
+    min-height: 42px;
+}
+
+@media (max-width: 980px) {
+    .profile-settings-hero {
+        background: #ffffff;
+    }
+
+    .profile-shell {
+        grid-template-columns: 1fr;
+    }
+}
+
+@media (max-width: 640px) {
+    .profile-form-intro {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+
+    .profile-form-intro p {
+        text-align: left;
+    }
+
+    .profile-settings-tabs {
+        display: grid;
+        grid-template-columns: 1fr;
+        padding: 8px;
+    }
+
+    .profile-settings-tab {
+        justify-content: flex-start;
+        border-bottom: 0;
+        border-left: 3px solid transparent;
+        border-radius: 6px;
+        padding: 0 14px;
+    }
+
+    .profile-settings-tab.is-active {
+        border-left-color: #0f766e;
+    }
+
+    .profile-settings-tab-panels,
+    .profile-actions {
+        padding: 18px;
+    }
 }
