---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Documents">
    <div class="page-container documents-page">
        <!-- Header -->
        <div class="documents-system-hero">
            <div class="page-header-info">
                <h1>Documents</h1>
                <p>All Excel files uploaded to the system</p>
            </div>
            <div class="documents-system-actions">
                <button
                    class="documents-system-action-primary"
                    type="button"
                    onclick="exportarCSV()"
                    data-permission-module="documentos"
                    data-permission-action="exportar"
                >
                    <i class="fa-solid fa-download" aria-hidden="true"></i>
                    Export
                </button>
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-bar documents-filters">
            <div class="filter-group search-filter">
                <label for="searchInput">Search file</label>
                <div class="search-field">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"
                    ></i>
                    <input
                        type="search"
                        id="searchInput"
                        placeholder="Name or restaurant..."
                        autocomplete="off"
                    />
                </div>
            </div>

            <div class="filter-group">
                <label>Restaurant:</label>
                <select id="filterRestaurant">
                    <option value="">All</option>
                    <option value="taco-bell">Taco Bell</option>
                    <option value="burger-king">Burger King</option>
                    <option value="popeyes">Popeyes</option>
                    <option value="kfc">KFC</option>
                </select>
            </div>

            <div class="filter-group">
                <label>Status:</label>
                <select id="filterStatus">
                    <option value="">All</option>
                    <option value="pendiente">Pending</option>
                    <option value="validado">Validated</option>
                    <option value="con_errores">With errors</option>
                    <option value="procesado">Processed</option>
                </select>
            </div>

            <div class="filter-group">
                <label>From:</label>
                <input type="date" id="filterFechaDesde" />
            </div>

            <div class="filter-group">
                <label>To:</label>
                <input type="date" id="filterFechaHasta" />
            </div>

            <button
                type="button"
                class="btn btn-secondary btn-sm clear-filters"
                onclick="limpiarFiltros()"
            >
                <i class="fa-solid fa-times"></i>
                Clear
            </button>
        </div>

        <div class="documents-type-tabs" role="tablist" aria-label="Document categories">
            <button
                type="button"
                class="documents-type-tab active"
                data-document-tab="reconciliations"
                role="tab"
                aria-selected="true"
            >
                <span class="documents-type-icon">
                    <i class="fa-solid fa-file-circle-check" aria-hidden="true"></i>
                </span>
                <span class="documents-type-copy">
                    <strong>Reconciliation files</strong>
                    <small>Generated and uploaded reconciliation documents</small>
                </span>
                <span class="documents-type-count" id="reconciliationFilesCount">0</span>
            </button>

            <button
                type="button"
                class="documents-type-tab"
                data-document-tab="ebt"
                role="tab"
                aria-selected="false"
            >
                <span class="documents-type-icon">
                    <i class="fa-solid fa-credit-card" aria-hidden="true"></i>
                </span>
                <span class="documents-type-copy">
                    <strong>EBT files</strong>
                    <small>EBT documents kept apart for later use</small>
                </span>
                <span class="documents-type-count" id="ebtFilesCount">0</span>
            </button>
        </div>

        <!-- Documents table -->
        <div class="table-container">
            <div class="table-header">
                <h3 id="documentsTableTitle">Reconciliation files</h3>
                <div class="table-actions">
                    <button
                        class="btn btn-secondary btn-sm"
                        onclick="exportarCSV()"
                        data-permission-module="documentos"
                        data-permission-action="exportar"
                    >
                        <i class="fa-solid fa-download"></i>
                        Export
                    </button>
                </div>
            </div>

            <table class="data-table" id="documentosTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>File</th>
                        <th>Restaurant</th>
                        <th>Size</th>
                        <th>Status</th>
                        <th>Uploaded by</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="documentosBody">
                    <!-- Se llena con JavaScript -->
                </tbody>
            </table>

            <div id="emptyState" class="empty-state" style="display: none;">
                <i class="fa-solid fa-folder-open"></i>
                <h4 id="documentsEmptyTitle">No reconciliation files</h4>
                <p>
                    <span id="documentsEmptyText">No reconciliation files match the selected filters</span>
                </p>
            </div>

            <div id="loadingState" class="empty-state">
                <i class="fa-solid fa-spinner fa-spin"></i>
                <h4>Loading...</h4>
                <p>Fetching documents from the server</p>
            </div>

            <!-- Paginacion -->
            <div class="pagination" id="pagination" style="display: none;">
                <div class="pagination-info">
                    Showing <span id="showingFrom">1</span> - <span
                        id="showingTo">10</span
                    > of <span id="totalItems">0</span> <span id="paginationItemsLabel">reconciliation files</span>
                </div>
                <div class="pagination-buttons">
                    <button
                        class="pagination-btn"
                        id="btnPrev"
                        onclick="cambiarPagina(-1)"
                    >
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <span class="pagination-btn active" id="currentPage">1</span
                    >
                    <button
                        class="pagination-btn"
                        id="btnNext"
                        onclick="cambiarPagina(1)"
                    >
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="modalDetalles" class="modal-overlay">
        <div class="modal modal-lg document-detail-modal">
            <div class="modal-header document-detail-modal-header">
                <div>
                    <span>DIGITAL FILE</span>
                    <h3 id="modalTitulo">Document detail</h3>
                    <p>Information and traceability for the selected file</p>
                </div>
                <button class="modal-close" onclick="cerrarModal()">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
            <div class="modal-body" id="modalBody"></div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="cerrarModal()"
                    >Close</button
                >
                <button
                    class="btn btn-primary"
                    id="btnDownload"
                    onclick="downloadSelectedDocument()"
                    data-permission-module="documentos"
                    data-permission-action="exportar"
                >
                    <i class="fa-solid fa-download"></i>
                    Download
                </button>
            </div>
        </div>
    </div>

    <!-- Excel preview modal -->
    <div id="modalPreviewExcel" class="modal-overlay">
        <div class="modal modal-xl document-preview-modal">
            <div class="modal-header document-detail-modal-header">
                <div>
                    <span>PREVIEW</span>
                    <h3 id="previewTitulo">Reconciliation view</h3>
                    <p>Review the file without downloading it</p>
                </div>
                <button class="modal-close" onclick="cerrarPreviewExcel()">
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>

            <div class="modal-body preview-excel-body">
                <div id="previewSheetTabs" class="preview-sheet-tabs"></div>

                <div class="preview-table-wrapper">
                    <table class="data-table preview-excel-table">
                        <thead id="previewExcelHead"></thead>
                        <tbody id="previewExcelBody"></tbody>
                    </table>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="cerrarPreviewExcel()"
                    >Close</button
                >
                <button
                    class="btn btn-primary"
                    onclick="downloadSelectedDocument()"
                    data-permission-module="documentos"
                    data-permission-action="exportar"
                >
                    <i class="fa-solid fa-download"></i>
                    Download
                </button>
            </div>
        </div>
    </div>

    <script src="/js/config.js" is:inline></script>

   <script is:inline src="/js/vendor/xlsx.full.min.js"></script>

    <script is:inline src="/js/documentos.js?v=20260701-compact-document-tables"></script>

    <style is:inline>
        .documents-filters {
            display: grid;
            grid-template-columns:
                minmax(260px, 1.6fr) repeat(4, minmax(130px, 0.72fr))
                auto;
            gap: 12px;
            align-items: end;
            margin-bottom: 18px;
            padding: 14px;
            border: 1px solid #cfd9e3;
            border-radius: 5px;
            background: #fff;
            box-shadow: none;
        }

        @media (max-width: 1024px) {
            .documents-filters {
                grid-template-columns: repeat(2, 1fr) auto;
                gap: 10px;
            }
        }

        @media (max-width: 768px) {
            .documents-filters {
                grid-template-columns: 1fr;
                gap: 10px;
            }
        }

        .documents-filters .filter-group {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .documents-filters label {
            color: #52667a;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.045em;
            text-transform: uppercase;
        }

        .search-field {
            position: relative;
            width: 100%;
        }

        .search-field i {
            position: absolute;
            top: 50%;
            left: 12px;
            z-index: 1;
            transform: translateY(-50%);
            color: #718096;
            font-size: 13px;
            pointer-events: none;
        }

        .search-field input,
        .documents-filters select,
        .documents-filters input[type="date"] {
            width: 100%;
            height: 40px;
            min-height: 40px;
            border: 1px solid #cbd6e1;
            border-radius: 4px;
            color: #243b53;
            background: #fff;
            font-size: 13px;
        }

        .search-field input {
            padding: 0 12px 0 36px;
        }
        .documents-filters select,
        .documents-filters input[type="date"] {
            padding: 0 10px;
        }

        .search-field input:focus,
        .documents-filters select:focus,
        .documents-filters input[type="date"]:focus {
            outline: 0;
            border-color: #174a75;
            box-shadow: 0 0 0 3px rgba(23, 74, 117, 0.11);
        }

        .clear-filters {
            height: 40px;
            white-space: nowrap;
        }

        .documents-type-tabs {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        .documents-type-tab {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            align-items: center;
            gap: 12px;
            min-height: 78px;
            padding: 13px 15px;
            border: 1px solid #cfd9e3;
            border-radius: 7px;
            background: #fff;
            color: #173a59;
            text-align: left;
            cursor: pointer;
            transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .documents-type-tab:hover,
        .documents-type-tab:focus-visible {
            border-color: #174a75;
            outline: 0;
            box-shadow: 0 12px 26px -24px rgba(8, 31, 51, 0.75);
        }

        .documents-type-tab.active {
            border-color: #102a43;
            background: #f8fbfd;
            box-shadow: inset 0 0 0 1px #102a43;
        }

        .documents-type-icon {
            display: grid;
            width: 42px;
            height: 42px;
            place-items: center;
            border-radius: 7px;
            background: #e8eff5;
            color: #123b5e;
            font-size: 16px;
        }

        .documents-type-tab.active .documents-type-icon {
            background: #102a43;
            color: #fff;
        }

        .documents-type-copy {
            min-width: 0;
        }

        .documents-type-copy strong {
            display: block;
            color: #082033;
            font-size: 15px;
            font-weight: 850;
            line-height: 1.2;
        }

        .documents-type-copy small {
            display: block;
            margin-top: 4px;
            color: #4f667a;
            font-size: 12px;
            font-weight: 650;
            line-height: 1.3;
        }

        .documents-type-count {
            display: inline-flex;
            min-width: 34px;
            height: 30px;
            align-items: center;
            justify-content: center;
            padding: 0 9px;
            border: 1px solid #cbd6e1;
            border-radius: 999px;
            background: #fff;
            color: #102a43;
            font-size: 13px;
            font-weight: 850;
        }

        .documents-type-tab.active .documents-type-count {
            border-color: #102a43;
            background: #102a43;
            color: #fff;
        }

        .document-detail-modal {
            max-width: 780px !important;
            border-radius: 10px;
        }
        .document-detail-modal-header {
            align-items: flex-start;
            padding: 20px 23px;
            color: #fff;
            border-bottom: 0;
            background: linear-gradient(115deg, #0b2943, #174d78);
        }
        .document-detail-modal-header > div > span {
            color: #d2ecff;
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 0.1em;
        }
        .document-detail-modal-header h3 {
            margin: 4px 0 2px;
            color: #fff;
            font-family: "Inter", sans-serif;
            font-size: 22px;
        }
        .document-detail-modal-header p {
            margin: 0;
            color: #e2eff7;
            font-size: 11px;
            font-weight: 650;
        }
        .document-detail-modal-header .modal-close {
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.28);
            background: rgba(255, 255, 255, 0.07);
        }
        .document-detail-modal .modal-body {
            padding: 18px;
            background: #f3f6f9;
        }
        .document-detail-modal .modal-footer {
            padding: 13px 18px;
            background: #fff;
        }
        .document-detail-overview {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            align-items: center;
            gap: 13px;
            margin-bottom: 13px;
            padding: 15px;
            border: 1px solid #d2dee8;
            border-radius: 7px;
            background: #fff;
        }
        .document-detail-file-icon {
            display: grid;
            width: 46px;
            height: 46px;
            place-items: center;
            border-radius: 7px;
            color: #12835a;
            background: #e2f5ec;
            font-size: 20px;
        }
        .document-detail-file-copy {
            min-width: 0;
        }
        .document-detail-file-copy > span {
            color: #465f75;
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 0.07em;
        }
        .document-detail-file-copy h4 {
            overflow: hidden;
            margin: 4px 0 2px;
            color: #163b5c;
            font-size: 15px;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .document-detail-file-copy p {
            margin: 0;
            color: #4f667a;
            font-size: 10px;
            font-weight: 650;
        }
        .document-detail-status {
            align-self: flex-start;
        }
        .document-detail-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 9px;
            margin-bottom: 13px;
        }
        .document-detail-grid article {
            display: flex;
            align-items: center;
            gap: 9px;
            min-width: 0;
            padding: 11px;
            border: 1px solid #d4dfe8;
            border-radius: 6px;
            background: #fff;
        }
        .document-detail-card-icon {
            display: grid;
            width: 30px;
            height: 30px;
            flex: 0 0 auto;
            place-items: center;
            border-radius: 5px;
            color: #315f84;
            background: #e8eff5;
            font-size: 12px;
        }
        .document-detail-grid article > div {
            min-width: 0;
        }
        .document-detail-grid small {
            display: block;
            color: #465f75;
            font-size: 8px;
            font-weight: 800;
            text-transform: uppercase;
        }
        .document-detail-grid strong {
            display: block;
            overflow: hidden;
            margin-top: 3px;
            color: #1f415e;
            font-size: 10px;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .document-detail-section {
            overflow: hidden;
            border: 1px solid #d4dfe8;
            border-radius: 7px;
            background: #fff;
        }
        .document-detail-section > header {
            padding: 11px 14px;
            border-bottom: 1px solid #e0e7ed;
            background: #f8fafb;
        }
        .document-detail-section > header span {
            color: #465f75;
            font-size: 8px;
            font-weight: 800;
            letter-spacing: 0.07em;
        }
        .document-detail-section > header h4 {
            margin: 2px 0 0;
            color: #193c5b;
            font-size: 13px;
        }
        .document-detail-list {
            margin: 0;
        }
        .document-detail-list > div {
            display: grid;
            grid-template-columns: minmax(140px, 0.35fr) minmax(0, 1fr);
            gap: 15px;
            padding: 10px 14px;
            border-bottom: 1px solid #e7edf2;
        }
        .document-detail-list > div:last-child {
            border-bottom: 0;
        }
        .document-detail-list dt {
            color: #415a70;
            font-size: 10px;
            font-weight: 800;
        }
        .document-detail-list dd {
            margin: 0;
            color: #173a59;
            font-size: 10px;
            font-weight: 650;
            text-align: right;
            overflow-wrap: anywhere;
        }
        .document-detail-note {
            display: flex;
            gap: 10px;
            margin-top: 12px;
            padding: 11px 13px;
            border: 1px solid #e3d4af;
            border-radius: 6px;
            color: #765318;
            background: #fff9eb;
        }
        .document-detail-note span {
            font-size: 8px;
            font-weight: 800;
            letter-spacing: 0.07em;
        }
        .document-detail-note p {
            margin: 3px 0 0;
            font-size: 10px;
        }

        @media (max-width: 1250px) {
            .documents-filters {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
            .search-filter {
                grid-column: span 2;
            }
        }

        @media (max-width: 760px) {
            .documents-filters {
                grid-template-columns: 1fr;
            }
            .documents-type-tabs {
                grid-template-columns: 1fr;
            }
            .search-filter {
                grid-column: auto;
            }
            .clear-filters {
                width: 100%;
            }
            .document-detail-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
            .document-detail-overview {
                grid-template-columns: auto minmax(0, 1fr);
            }
            .document-detail-status {
                grid-column: 1 / -1;
                justify-self: start;
            }
        }

        /* ================================
   VISTA PREVIA EXCEL
================================ */

        .document-preview-modal {
            width: min(1180px, 96vw) !important;
            max-width: 96vw !important;
            height: 88vh !important;
            max-height: 88vh !important;
            display: flex !important;
            flex-direction: column !important;
            overflow: hidden !important;
        }

        .document-preview-modal .modal-header {
            flex: 0 0 auto;
        }

        .document-preview-modal .modal-body {
            flex: 1 1 auto;
            overflow: hidden !important;
            padding: 16px !important;
            background: #f3f6f9 !important;
        }

        .document-preview-modal .modal-footer {
            flex: 0 0 auto;
            background: #fff;
        }

        /* Pestañas de hojas */
        .preview-sheet-tabs {
            display: flex !important;
            flex-wrap: nowrap !important;
            gap: 8px !important;
            margin-bottom: 12px !important;
            padding-bottom: 8px !important;
            overflow-x: auto !important;
            border-bottom: 1px solid #d7e1ea !important;
        }

        .preview-sheet-tab {
            flex: 0 0 auto !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            min-height: 34px !important;
            padding: 8px 13px !important;
            border: 1px solid #cbd6e1 !important;
            border-radius: 999px !important;
            background: #fff !important;
            color: #183b59 !important;
            font-size: 12px !important;
            font-weight: 700 !important;
            white-space: nowrap !important;
            cursor: pointer !important;
        }

        .preview-sheet-tab:hover {
            border-color: #174a75 !important;
        }

        .preview-sheet-tab.active {
            color: #fff !important;
            border-color: #174a75 !important;
            background: #174a75 !important;
        }

        /* Table */
        .preview-table-wrapper {
            width: 100% !important;
            height: calc(88vh - 210px) !important;
            overflow: auto !important;
            border: 1px solid #d4dfe8 !important;
            border-radius: 7px !important;
            background: #fff !important;
        }

        .preview-excel-table {
            width: max-content !important;
            min-width: 100% !important;
            border-collapse: separate !important;
            border-spacing: 0 !important;
            background: #fff !important;
        }

        .preview-excel-table th,
        .preview-excel-table td {
            min-width: 130px !important;
            max-width: 280px !important;
            padding: 9px 12px !important;
            border-right: 1px solid #dfe7ee !important;
            border-bottom: 1px solid #dfe7ee !important;
            font-size: 12px !important;
            line-height: 1.35 !important;
            white-space: nowrap !important;
            text-align: left !important;
        }

        .preview-excel-table th {
            position: sticky !important;
            top: 0 !important;
            z-index: 3 !important;
            color: #fff !important;
            background: #0b2943 !important;
            font-weight: 800 !important;
            text-transform: uppercase !important;
        }

        .preview-excel-table td {
            color: #294763 !important;
            background: #fff !important;
        }

        .preview-excel-table tbody tr:nth-child(even) td {
            background: #f7fafc !important;
        }

        /* ================================
   SCROLL HORIZONTAL Y VERTICAL EXCEL
================================ */

        .document-preview-modal {
            width: min(1180px, 96vw) !important;
            max-width: 96vw !important;
            height: 88vh !important;
            max-height: 88vh !important;
            display: flex !important;
            flex-direction: column !important;
            overflow: hidden !important;
        }

        .document-preview-modal .modal-body,
        .preview-excel-body {
            flex: 1 1 auto !important;
            min-height: 0 !important;
            display: flex !important;
            flex-direction: column !important;
            overflow: hidden !important;
            padding: 16px !important;
        }

        .preview-sheet-tabs {
            flex: 0 0 auto !important;
            display: flex !important;
            flex-wrap: nowrap !important;
            gap: 8px !important;
            margin-bottom: 12px !important;
            padding-bottom: 8px !important;
            overflow-x: auto !important;
        }

        /* Este es el contenedor que debe tener el scroll */
        .preview-table-wrapper {
            flex: 1 1 auto !important;
            min-height: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
            overflow-x: auto !important;
            overflow-y: auto !important;
            border: 1px solid #d4dfe8 !important;
            border-radius: 7px !important;
            background: #fff !important;
            padding-bottom: 8px !important;
        }

        /* The table must be able to grow to the right */
        .preview-excel-table {
