---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Property Schedules">
    <section class="schedule-dashboard" aria-labelledby="scheduleDashboardTitle">
        <header class="schedule-header">
            <div class="schedule-header-copy">
                <span class="schedule-eyebrow">
                    <i class="fa-solid fa-building" aria-hidden="true"></i>
                    Property Management
                </span>

                <h1 id="scheduleDashboardTitle">Property schedules</h1>

                <p>
                    Select a workspace to manage standard schedules or prepaid amortization.
                </p>
            </div>

            <div class="schedule-header-summary">
                <div>
                    <strong id="scheduleMetricTotal">0</strong>
                    <span>Saved schedules</span>
                </div>
                <div>
                    <strong id="scheduleMetricPeriod">-</strong>
                    <span>Latest period</span>
                </div>
            </div>
        </header>

        <section class="schedule-metrics" aria-label="Schedule metrics">
            <article>
                <span>Saved schedules</span>
                <strong id="scheduleMetricTotalCard">0</strong>
                <small id="scheduleMetricLatest">Loading activity...</small>
            </article>

            <article>
                <span>Latest period</span>
                <strong id="scheduleMetricPeriodCard">-</strong>
                <small id="scheduleMetricPeriodMeta">No saved period yet</small>
            </article>

            <article>
                <span>Stores covered</span>
                <strong id="scheduleMetricStores">0</strong>
                <small>Across saved schedule versions</small>
            </article>

            <article>
                <span>Total balance</span>
                <strong id="scheduleMetricBalance">$0.00</strong>
                <small>Sum of saved balances</small>
            </article>
        </section>

        <section class="schedule-options" aria-label="Available property schedule modules">
            <a class="schedule-option" href="/views/departments/property-management">
                <div class="schedule-option-top">
                    <span class="schedule-option-icon">
                        <i class="fa-solid fa-file-excel" aria-hidden="true"></i>
                    </span>

                    <span class="schedule-status">
                        <i class="fa-solid fa-circle" aria-hidden="true"></i>
                        Available
                    </span>
                </div>

                <div class="schedule-option-copy">
                    <span>Schedule module</span>
                    <h2>Property schedule</h2>
                    <p>
                        Create and maintain the standard monthly property schedule.
                    </p>
                </div>

                <div class="schedule-option-footer">
                    <small>Standard schedule workflow</small>
                    <span>
                        Open module
                        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                    </span>
                </div>
            </a>

            <a class="schedule-option" href="/views/departments/prepaid-amortization">
                <div class="schedule-option-top">
                    <span class="schedule-option-icon is-green">
                        <i class="fa-solid fa-file-invoice-dollar" aria-hidden="true"></i>
                    </span>

                    <span class="schedule-status">
                        <i class="fa-solid fa-circle" aria-hidden="true"></i>
                        Available
                    </span>
                </div>

                <div class="schedule-option-copy">
                    <span>Prepaid module</span>
                    <h2>Prepaid bills</h2>
                    <p>
                        Import paid bills, generate amortization, and validate monthly GL activity.
                    </p>
                </div>

                <div class="schedule-option-footer">
                    <small>Prepaid amortization workflow</small>
                    <span>
                        Open module
                        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                    </span>
                </div>
            </a>
        </section>

        <footer class="schedule-note">
            <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
            Schedule totals are calculated from saved property schedule versions.
        </footer>
    </section>

    <style is:global>
        .schedule-dashboard {
            display: grid;
            gap: 18px;
            width: 100%;
            min-width: 0;
            padding: 2px 0 24px;
        }

        .schedule-header,
        .schedule-metrics article,
        .schedule-option {
            border: 1px solid #d9e4ef;
            background: #ffffff;
            box-shadow: none;
        }

        .schedule-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            gap: 28px;
            padding: 26px 28px;
            border-radius: 12px;
        }

        .schedule-eyebrow,
        .schedule-metrics span,
        .schedule-option-copy > span {
            display: flex;
            align-items: center;
            gap: 7px;
            color: #647b91;
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 0.07em;
            text-transform: uppercase;
        }

        .schedule-header h1 {
            margin: 10px 0 0;
            color: #10253a;
            font-size: clamp(32px, 4vw, 44px);
            line-height: 1;
            font-weight: 950;
            letter-spacing: -0.03em;
        }

        .schedule-header p {
            max-width: 720px;
            margin: 12px 0 0;
            color: #61778c;
            font-size: 14px;
            line-height: 1.55;
            font-weight: 650;
        }

        .schedule-header-summary {
            display: grid;
            grid-template-columns: repeat(2, minmax(130px, 1fr));
            gap: 10px;
        }

        .schedule-header-summary > div {
            min-width: 130px;
            padding: 14px 16px;
            border-radius: 12px;
            background: #f6f9fc;
        }

        .schedule-header-summary strong,
        .schedule-header-summary span {
            display: block;
        }

        .schedule-header-summary strong {
            color: #10253a;
            font-size: 26px;
            line-height: 1;
            font-weight: 950;
        }

        .schedule-header-summary span {
            margin-top: 8px;
            color: #6a8095;
            font-size: 10px;
            font-weight: 850;
            text-transform: uppercase;
        }

        .schedule-metrics {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
        }

        .schedule-metrics article {
            min-width: 0;
            padding: 17px 18px;
            border-radius: 12px;
        }

        .schedule-metrics strong {
            display: block;
            margin-top: 10px;
            overflow: hidden;
            color: #12395f;
            font-size: 29px;
            line-height: 1;
            font-weight: 950;
            white-space: nowrap;
            text-overflow: ellipsis;
        }

        .schedule-metrics small {
            display: block;
            margin-top: 9px;
            color: #6c8296;
            font-size: 12px;
            line-height: 1.4;
            font-weight: 700;
        }

        .schedule-options {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }

        .schedule-option {
            display: flex;
            flex-direction: column;
            min-height: 300px;
            padding: 26px;
            border-radius: 12px;
            color: inherit;
            text-decoration: none;
            transition: border-color 0.16s ease, transform 0.16s ease, box-shadow 0.16s ease;
        }

        .schedule-option:hover {
            transform: translateY(-2px);
            border-color: #b9cfe2;
            box-shadow: 0 18px 42px -36px rgba(15, 43, 68, 0.75);
        }

        .schedule-option-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .schedule-option-icon {
            display: grid;
            place-items: center;
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: #edf5fc;
            color: #155b92;
            font-size: 20px;
        }

        .schedule-option-icon.is-green {
            background: #e9f7f3;
            color: #0f766e;
        }

        .schedule-status {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 7px 10px;
            border-radius: 999px;
            background: #edf8f1;
            color: #167347;
            font-size: 11px;
            font-weight: 850;
        }

        .schedule-status i {
            font-size: 7px;
        }

        .schedule-option-copy {
            margin-top: 34px;
        }

        .schedule-option h2 {
            margin: 10px 0 0;
            color: #10253a;
            font-size: 27px;
            line-height: 1.1;
            font-weight: 950;
        }

        .schedule-option p {
            max-width: 560px;
            margin: 12px 0 0;
            color: #63798e;
            font-size: 14px;
            line-height: 1.55;
            font-weight: 650;
        }

        .schedule-option-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            margin-top: auto;
            padding-top: 24px;
        }

        .schedule-option-footer small {
            color: #71869a;
            font-size: 11px;
            font-weight: 750;
        }

        .schedule-option-footer > span {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 38px;
            padding: 0 14px;
            border-radius: 9px;
            background: #101122;
            color: #ffffff;
            font-size: 12px;
            font-weight: 900;
        }

        .schedule-option:hover .schedule-option-footer > span i {
            transform: translateX(3px);
        }

        .schedule-option-footer > span i {
            transition: transform 0.16s ease;
        }

        .schedule-note {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #6a8095;
            font-size: 11px;
            font-weight: 650;
        }

        .schedule-note i {
            color: #155b92;
        }

        @media (max-width: 1100px) {
            .schedule-header {
                grid-template-columns: 1fr;
            }

            .schedule-header-summary {
                width: 100%;
            }

            .schedule-metrics {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 760px) {
            .schedule-options,
            .schedule-metrics {
                grid-template-columns: 1fr;
            }

            .schedule-option {
                min-height: 250px;
            }
        }

        @media (max-width: 520px) {
            .schedule-header {
                padding: 22px;
            }

            .schedule-header-summary {
                grid-template-columns: 1fr;
            }

            .schedule-option {
                padding: 22px;
            }

            .schedule-option-footer {
                align-items: flex-start;
                flex-direction: column;
            }
        }
    </style>

    <script src="/js/config.js" is:inline></script>
    <script is:inline>
        const MONTH_NAMES = [
            "",
            "January",
            "February",
            "March",
            "April",
            "May",
            "June",
            "July",
            "August",
            "September",
            "October",
            "November",
            "December",
        ];

        document.addEventListener("DOMContentLoaded", loadScheduleDashboard);

        async function loadScheduleDashboard() {
            try {
                const schedules = await fetchSchedules();
                renderScheduleDashboard(schedules);
            } catch (error) {
                console.error(error);
                renderScheduleDashboardError(error);
            }
        }

        async function fetchSchedules() {
            const apiBase = String(window.API_URL || "").replace(/\/$/, "");
            const token = localStorage.getItem("token");

            if (!apiBase) throw new Error("API_URL is not configured");
            if (!token) throw new Error("Your session token was not found. Sign in again.");

            const response = await fetch(`${apiBase}/property-management/schedules`, {
                headers: { Authorization: `Bearer ${token}` },
            });

            const data = await response.json();

            if (!response.ok || data.success === false) {
                throw new Error(data.message || "Schedules could not be loaded");
            }

            return Array.isArray(data.schedules) ? data.schedules : [];
        }

        function renderScheduleDashboard(schedules) {
            const stats = buildDashboardStats(schedules);

            setText("scheduleMetricTotal", formatInteger(stats.totalSchedules));
            setText("scheduleMetricTotalCard", formatInteger(stats.totalSchedules));
            setText("scheduleMetricStores", formatInteger(stats.totalStores));
            setText("scheduleMetricBalance", formatCurrency(stats.totalBalance));
            setText("scheduleMetricPeriod", stats.latestPeriodShort || "-");
            setText("scheduleMetricPeriodCard", stats.latestPeriodShort || "-");
            setText(
                "scheduleMetricLatest",
                stats.latest
                    ? `Latest update: ${formatShortDate(stats.latest.fecha_actualizacion || stats.latest.fecha_creacion)}`
                    : "No schedules saved yet"
            );
            setText(
                "scheduleMetricPeriodMeta",
                stats.periodCount
                    ? `${formatInteger(stats.periodCount)} saved period${stats.periodCount === 1 ? "" : "s"}`
                    : "No saved period yet"
            );
        }

        function buildDashboardStats(schedules) {
            const periods = new Set();
            let totalStores = 0;
            let totalBalance = 0;

            schedules.forEach((schedule) => {
                const stores = Number(schedule.total_tiendas || 0);
                const balance = Number(schedule.balance_total || 0);
                const period = getPeriodKey(schedule);

                totalStores += Number.isFinite(stores) ? stores : 0;
                totalBalance += Number.isFinite(balance) ? balance : 0;

                if (period) periods.add(period);
            });

            const latestPeriodKey = Array.from(periods).sort().reverse()[0] || "";

            return {
                totalSchedules: schedules.length,
                totalStores,
                totalBalance,
                periodCount: periods.size,
                latestPeriodShort: latestPeriodKey ? formatPeriodKey(latestPeriodKey) : "",
                latest: schedules[0] || null,
            };
        }

        function renderScheduleDashboardError(error) {
            setText("scheduleMetricLatest", error?.message || "Schedules could not be loaded");
            setText("scheduleMetricPeriodMeta", "Unavailable");
        }

        function getPeriodKey(schedule) {
            const year = Number(schedule.periodo_anio || 0);
            const month = Number(schedule.periodo_mes || 0);

            if (!year || !month) return "";

            return `${year}-${String(month).padStart(2, "0")}`;
        }

        function formatPeriodKey(key) {
            const [year, month] = key.split("-");
            return `${MONTH_NAMES[Number(month)] || month} ${year}`;
        }

        function formatShortDate(value) {
            if (!value) return "No date";

            const date = new Date(value);

            if (Number.isNaN(date.getTime())) return "No date";

            return new Intl.DateTimeFormat("en-US", {
                month: "short",
                day: "2-digit",
                year: "numeric",
            }).format(date);
        }

        function formatCurrency(value) {
            const number = Number(value || 0);

            return new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: "USD",
                maximumFractionDigits: 2,
            }).format(Number.isFinite(number) ? number : 0);
        }

        function formatInteger(value) {
            const number = Number(value || 0);

            return new Intl.NumberFormat("en-US").format(
                Number.isFinite(number) ? number : 0
            );
        }

        function setText(id, value) {
            const element = document.getElementById(id);

            if (element) element.textContent = value;
        }
    </script>
</DashboardLayout>
