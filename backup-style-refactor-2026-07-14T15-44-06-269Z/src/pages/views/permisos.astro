---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Permissions">
    <div class="page-container">
        <!-- Header -->
        <div class="page-header">
            <div class="page-header-info">
                <h1>Permission settings</h1>
                <p>Assign section access for this user</p>
            </div>
            <button class="btn btn-secondary" onclick="window.history.back()">
                <i class="fa-solid fa-arrow-left"></i>
                Back
            </button>
        </div>

        <!-- Info User -->
        <div class="permissions-container" id="userInfoCard">
            <div class="permissions-header">
                <div class="permissions-user-avatar" id="userAvatar">--</div>
                <div class="permissions-user-info">
                    <h2 id="permUserName">Loading...</h2>
                    <p id="permUserEmail">---</p>
                    <span class="status-badge" id="permUserRole">---</span>
                </div>
            </div>

            <!-- Permissions Grid -->
            <div class="permissions-grid" id="permissionsList">
                <!-- Se genera dinamicamente -->
            </div>

            <div class="permission-start-panel">
                <div class="permission-start-icon">
                    <i class="fa-solid fa-house-laptop"></i>
                </div>
                <div class="permission-start-copy">
                    <strong>Initial window</strong>
                    <span
                        >Select the screen this user sees after signing in.</span
                    >
                </div>
                <select
                    id="initialWindow"
                    class="form-control"
                    onchange="changeInitialWindow(this.value)"></select>
            </div>
        </div>

        <!-- Actions -->
        <div class="permission-actions">
            <button class="btn btn-secondary" onclick="resetPermissions()">
                <i class="fa-solid fa-rotate-left"></i>
                Reset
            </button>
            <button class="btn btn-primary" onclick="savePermissions()">
                <i class="fa-solid fa-floppy-disk"></i>
                Save permissions
            </button>
        </div>
    </div>
    <style is:global>
        .page-container {
            min-height: 100vh;
            padding: 24px;
            background: #f6f9fc;
        }

        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 20px;
        }

        .page-header-info h1 {
            margin: 0;
            color: #0b2943;
            font-size: 24px;
            font-weight: 800;
        }

        .page-header-info p {
            margin: 4px 0 0;
            color: #61758a;
            font-size: 14px;
        }

        .permissions-container {
            overflow: hidden;
            border: 1px solid #d7e3ee;
            border-radius: 12px;
            background: #ffffff;
            box-shadow: 0 18px 44px -40px rgba(8, 31, 51, 0.65);
        }

        .permissions-header {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 22px 24px;
            border-bottom: 1px solid #e2ebf3;
            background:
                linear-gradient(90deg, rgba(16, 42, 67, 0.08), transparent 46%),
                #ffffff;
        }

        .permissions-user-avatar {
            display: grid;
            width: 54px;
            height: 54px;
            place-items: center;
            border-radius: 10px;
            background: #0b2943;
            color: #ffffff;
            font-size: 17px;
            font-weight: 800;
        }

        .permissions-user-info h2 {
            margin: 0;
            color: #0b2943;
            font-size: 20px;
            font-weight: 800;
        }

        .permissions-user-info p {
            margin: 4px 0 8px;
            color: #61758a;
            font-size: 13px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            width: fit-content;
            padding: 4px 10px;
            border-radius: 999px;
            background: #edf5ff;
            color: #0b4778;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .permissions-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            padding: 20px;
            background: #f6f9fc;
        }

        .permission-group {
            display: grid;
            grid-template-columns: 1fr;
            gap: 6px;
        }

        .permission-group-header {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 0;
            border: 0;
            background: transparent;
        }

        .permission-group-header span {
            color: #102f4c;
            font-size: 15px;
            font-weight: 500;
        }

        .permission-group-header strong {
            color: #0b2943;
            font-size: 15px;
            font-weight: 900;
        }

        .permission-group-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2px;
        }

        .permission-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            min-height: 74px;
            padding: 16px;
            border: 1px solid #d5e2ee;
            border-radius: 8px;
            background: #ffffff;
            transition:
                border-color 0.18s ease,
                box-shadow 0.18s ease,
                background 0.18s ease;
        }

        .permission-card:hover {
            border-color: #b9c8d6;
            background: #fbfdff;
            box-shadow: 0 16px 36px -34px rgba(8, 31, 51, 0.58);
        }

        .permission-info {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .permission-icon {
            display: grid;
            width: 40px;
            height: 40px;
            min-width: 40px;
            place-items: center;
            border-radius: 8px;
            color: #173a59;
            background: #eef4f9;
            font-size: 16px;
        }

        .permission-details {
            min-width: 0;
        }

        .permission-details h4 {
            margin: 0;
            color: #0b2943;
            font-size: 14px;
            font-weight: 800;
        }

        .permission-details p {
            margin: 4px 0 0;
            color: #58708a;
            font-size: 12px;
            line-height: 1.35;
        }

        .permission-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 8px;
        }

        .permission-tags span {
            display: inline-flex;
            align-items: center;
            height: 20px;
            padding: 0 8px;
            border: 1px solid #d7e1ea;
            border-radius: 999px;
            background: #f7fafc;
            color: #244156;
            font-size: 10px;
            font-weight: 800;
        }

        .permission-action-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(72px, 1fr));
            gap: 6px;
            min-width: min(100%, 430px);
        }

        .permission-action {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            min-height: 34px;
            padding: 6px 8px;
            border: 1px solid #d5e2ee;
            border-radius: 7px;
            background: #f8fbfe;
            color: #38536b;
            cursor: pointer;
            font-size: 10px;
            font-weight: 800;
        }

        .permission-action:has(input:checked) {
            border-color: #8db5d8;
            background: #eaf4fc;
            color: #0b4778;
        }

        .permission-action:has(input:disabled) {
            cursor: not-allowed;
            opacity: 0.6;
        }

        .permission-action input {
            width: 14px;
            height: 14px;
            margin: 0;
            accent-color: #0b4778;
        }

        .toggle-switch {
            position: relative;
            display: inline-block;
            width: 46px;
            height: 26px;
            min-width: 46px;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-slider {
            position: absolute;
            inset: 0;
            cursor: pointer;
            border-radius: 999px;
            background: #b9cbdc;
            transition: 0.2s ease;
        }

        .toggle-slider::before {
            content: "";
            position: absolute;
            width: 20px;
            height: 20px;
            left: 3px;
            top: 3px;
            border-radius: 50%;
            background: #ffffff;
            box-shadow: 0 2px 5px rgba(15, 23, 42, 0.25);
            transition: 0.2s ease;
        }

        .toggle-switch input:checked + .toggle-slider {
            background: #0b4778;
        }

        .toggle-switch input:checked + .toggle-slider::before {
            transform: translateX(20px);
        }

        .toggle-switch input:disabled + .toggle-slider {
            cursor: not-allowed;
            opacity: 0.55;
        }

        .permission-start-panel {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) minmax(220px, 300px);
            align-items: center;
            gap: 14px;
            margin: 20px;
            padding: 18px;
            border: 1px solid #cbd8e5;
            border-left: 4px solid #173f67;
            border-radius: 8px;
            background: #ffffff;
        }

        .permission-start-icon {
            display: grid;
            width: 42px;
            height: 42px;
            place-items: center;
            border-radius: 7px;
            background: #e4edf6;
            color: #123a5c;
        }

        .permission-start-copy strong {
            display: block;
            color: #102f4c;
            font-size: 14px;
        }

        .permission-start-copy span {
            display: block;
            margin-top: 3px;
            color: #65798d;
            font-size: 12px;
        }

        .form-control {
            width: 100%;
            min-height: 40px;
            padding: 8px 10px;
            border: 1px solid #cbd8e5;
            border-radius: 7px;
            background: #ffffff;
            color: #102f4c;
            font-size: 13px;
        }

        .permission-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 18px;
        }

        @media (max-width: 720px) {
            .page-container {
                padding: 16px;
            }

            .page-header {
                align-items: flex-start;
                flex-direction: column;
            }

            .permission-card {
                align-items: stretch;
                flex-direction: column;
            }

            .permission-action-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
                min-width: 0;
            }

            .permission-card {
                align-items: flex-start;
            }

            .permission-info {
                align-items: flex-start;
            }

            .permission-start-panel {
                grid-template-columns: auto 1fr;
            }

            .permission-start-panel select {
                grid-column: 1 / -1;
            }

            .permission-actions {
                flex-direction: column;
            }

            .permission-actions .btn {
                width: 100%;
            }
        }
    </style>
    <script src="/js/config.js" is:inline></script>
    <script is:inline src="/js/permisos.js?v=20260707-chat-permissions"
    ></script>
</DashboardLayout>
