---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="System errors">
    <div class="page-container system-errors-page">
        <header class="system-errors-hero">
            <div class="system-errors-hero-copy">
                <span class="system-errors-eyebrow">
                    <i class="fa-solid fa-shield-halved"></i>
                    ADMIN MONITORING
                </span>
                <h1>System error center</h1>
                <p>Track backend incidents, inspect failure context, and document resolutions from one admin console.</p>
            </div>

            <div class="system-errors-actions">
                <span id="systemErrorsUpdated">Not refreshed</span>
                <a class="system-errors-action-link" href="/views/dashboard-admin">
                    <i class="fa-solid fa-arrow-left"></i>
                    Admin dashboard
                </a>
                <button class="system-errors-action-primary" id="refreshSystemErrors" type="button">
                    <i class="fa-solid fa-rotate"></i>
                    Refresh
                </button>
            </div>
        </header>

        <section class="system-error-metrics" aria-label="System error summary">
            <article class="system-error-card is-open">
                <span class="system-error-card-icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
                <div>
                    <small>Requires review</small>
                    <strong id="systemErrorsOpen">0</strong>
                    <span>Open errors</span>
                </div>
            </article>

            <article class="system-error-card is-critical">
                <span class="system-error-card-icon"><i class="fa-solid fa-fire-flame-curved"></i></span>
                <div>
                    <small>HTTP 500+</small>
                    <strong id="systemErrorsCritical">0</strong>
                    <span>Critical open</span>
                </div>
            </article>

            <article class="system-error-card is-total">
                <span class="system-error-card-icon"><i class="fa-solid fa-database"></i></span>
                <div>
                    <small>All logged incidents</small>
                    <strong id="systemErrorsTotal">0</strong>
                    <span>Total logged</span>
                </div>
            </article>

            <article class="system-error-card is-resolved">
                <span class="system-error-card-icon"><i class="fa-solid fa-circle-check"></i></span>
                <div>
                    <small>Closed incidents</small>
                    <strong id="systemErrorsResolved">0</strong>
                    <span>Resolved</span>
                </div>
            </article>
        </section>

        <section class="system-errors-panel">
            <header class="system-errors-panel-header">
                <div>
                    <span>INCIDENT LOG</span>
                    <h2>Backend failures</h2>
                    <p>Use filters to isolate the exact route, method, user, IP, or error hash.</p>
                </div>

                <label class="system-errors-autorefresh">
                    <input type="checkbox" id="systemErrorsAutoRefresh" />
                    <span>Auto-refresh</span>
                </label>
            </header>

            <div class="system-errors-toolbar">
                <label class="system-error-filter system-error-filter-search">
                    <span>Search</span>
                    <input id="systemErrorsSearch" type="search" placeholder="Route, message, user, IP, hash..." autocomplete="off" />
                </label>

                <label class="system-error-filter">
                    <span>Status</span>
                    <select id="systemErrorsStatus">
                        <option value="open">Open</option>
                        <option value="resolved">Resolved</option>
                        <option value="all">All</option>
                    </select>
                </label>

                <label class="system-error-filter">
                    <span>Severity</span>
                    <select id="systemErrorsSeverity">
                        <option value="all">All</option>
                        <option value="critical">Critical</option>
                        <option value="server">Server</option>
                        <option value="upload">Upload</option>
                        <option value="client">Client</option>
                    </select>
                </label>

                <label class="system-error-filter">
                    <span>Method</span>
                    <select id="systemErrorsMethod">
                        <option value="">All</option>
                        <option value="GET">GET</option>
                        <option value="POST">POST</option>
                        <option value="PUT">PUT</option>
                        <option value="PATCH">PATCH</option>
                        <option value="DELETE">DELETE</option>
                    </select>
                </label>

                <label class="system-error-filter">
                    <span>Limit</span>
                    <select id="systemErrorsLimit">
                        <option value="25">25</option>
                        <option value="50" selected>50</option>
                        <option value="100">100</option>
                    </select>
                </label>

                <button class="system-error-clear" id="clearSystemErrorFilters" type="button">
                    <i class="fa-solid fa-filter-circle-xmark"></i>
                    Clear
                </button>
            </div>

            <div class="system-errors-table-wrap">
                <table class="system-errors-table">
                    <thead>
                        <tr>
                            <th>Severity</th>
                            <th>Route</th>
                            <th>Error</th>
                            <th>User / IP</th>
                            <th>Occurrences</th>
                            <th>Last seen</th>
                            <th>Status / resolution</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="systemErrorsBody">
                        <tr><td colspan="8" class="system-errors-loading">Loading errors...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <style is:inline>
        .system-errors-page {
            --se-navy: #071b2d;
            --se-blue: #113d61;
            --se-muted: #64748b;
            --se-line: #dbe5ef;
            --se-panel: #ffffff;
            --se-soft: #f4f7fb;
            --se-red: #b42318;
            --se-red-soft: #fff1f0;
            --se-amber: #b54708;
            --se-amber-soft: #fff7e6;
            --se-green: #067647;
            --se-green-soft: #ecfdf3;
            --se-shadow: 0 20px 50px -42px rgba(7, 27, 45, .7);
            color: var(--se-navy);
        }

        .system-errors-hero {
            position: relative;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 20px;
            overflow: hidden;
            margin-bottom: 18px;
            padding: 28px;
            border: 1px solid rgba(255,255,255,.16);
            border-radius: 22px;
            color: #fff;
            background:
                radial-gradient(circle at 88% 10%, rgba(255, 255, 255, .16), transparent 28%),
                linear-gradient(135deg, #071b2d 0%, #0e395c 54%, #8f1d1d 100%);
            box-shadow: var(--se-shadow);
        }

        .system-errors-hero::after {
            content: "";
            position: absolute;
            inset: auto -80px -110px auto;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: rgba(255, 255, 255, .11);
            pointer-events: none;
        }

        .system-errors-hero-copy {
            position: relative;
            z-index: 1;
            max-width: 720px;
        }

        .system-errors-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 12px;
            padding: 7px 10px;
            border: 1px solid rgba(255,255,255,.22);
            border-radius: 999px;
            color: #ffe3e3;
            background: rgba(255,255,255,.11);
            font-size: 11px;
            font-weight: 900;
            letter-spacing: .09em;
        }

        .system-errors-hero h1 {
            margin: 0;
            font-size: clamp(28px, 3vw, 44px);
            line-height: 1;
            letter-spacing: -.04em;
        }

        .system-errors-hero p {
            max-width: 680px;
            margin: 12px 0 0;
            color: rgba(255,255,255,.78);
            font-size: 14px;
            line-height: 1.55;
        }

        .system-errors-actions {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            flex-direction: column;
            gap: 10px;
            min-width: 250px;
        }

        .system-errors-actions > span {
            color: rgba(255,255,255,.68);
            font-size: 11px;
            font-weight: 800;
        }

        .system-errors-action-link,
        .system-errors-action-primary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 40px;
            padding: 0 14px;
            border: 1px solid rgba(255,255,255,.22);
            border-radius: 12px;
            color: #fff;
            background: rgba(255,255,255,.11);
            text-decoration: none;
            font-size: 12px;
            font-weight: 900;
            cursor: pointer;
            transition: transform .16s ease, background .16s ease, border-color .16s ease;
        }

        .system-errors-action-primary {
            background: #fff;
            color: #102f4c;
            border-color: #fff;
        }

        .system-errors-action-link:hover,
        .system-errors-action-primary:hover {
            transform: translateY(-1px);
            background: rgba(255,255,255,.20);
        }

        .system-errors-action-primary:hover {
            background: #f3f7fb;
        }

        .system-error-metrics {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
            margin-bottom: 18px;
        }

        .system-error-card {
            position: relative;
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            gap: 14px;
            align-items: center;
            min-height: 112px;
            overflow: hidden;
            padding: 18px;
            border: 1px solid var(--se-line);
            border-radius: 18px;
            background: linear-gradient(180deg, #fff, #f8fbfe);
            box-shadow: var(--se-shadow);
        }

        .system-error-card::before {
            content: "";
            position: absolute;
            left: 0;
            top: 14px;
            bottom: 14px;
            width: 4px;
            border-radius: 0 999px 999px 0;
            background: #8aa4bb;
        }

        .system-error-card.is-open::before { background: var(--se-amber); }
        .system-error-card.is-critical::before { background: var(--se-red); }
        .system-error-card.is-total::before { background: #2563eb; }
        .system-error-card.is-resolved::before { background: var(--se-green); }

        .system-error-card-icon {
            display: grid;
            width: 46px;
            height: 46px;
            place-items: center;
            border-radius: 15px;
            font-size: 18px;
        }

        .system-error-card.is-open .system-error-card-icon { color: var(--se-amber); background: var(--se-amber-soft); }
        .system-error-card.is-critical .system-error-card-icon { color: var(--se-red); background: var(--se-red-soft); }
        .system-error-card.is-total .system-error-card-icon { color: #175cd3; background: #eff8ff; }
        .system-error-card.is-resolved .system-error-card-icon { color: var(--se-green); background: var(--se-green-soft); }

        .system-error-card small {
            display: block;
            margin-bottom: 8px;
            color: var(--se-muted);
            font-size: 10px;
            font-weight: 900;
            letter-spacing: .07em;
            text-transform: uppercase;
        }

        .system-error-card strong {
            display: block;
            color: var(--se-navy);
            font-size: 30px;
            line-height: 1;
        }

        .system-error-card span:not(.system-error-card-icon) {
            display: block;
            margin-top: 6px;
            color: #334155;
            font-size: 12px;
            font-weight: 900;
        }

        .system-errors-panel {
            overflow: hidden;
            border: 1px solid var(--se-line);
            border-radius: 20px;
            background: var(--se-panel);
            box-shadow: var(--se-shadow);
        }

        .system-errors-panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 20px;
            border-bottom: 1px solid var(--se-line);
            background:
                linear-gradient(180deg, rgba(248, 251, 254, .95), rgba(255,255,255,.95));
        }

        .system-errors-panel-header span:not(.system-errors-autorefresh span) {
            color: #667085;
            font-size: 10px;
            font-weight: 900;
            letter-spacing: .1em;
        }

        .system-errors-panel-header h2 {
            margin: 4px 0 0;
            color: var(--se-navy);
            font-size: 20px;
            letter-spacing: -.02em;
        }

        .system-errors-panel-header p {
            margin: 5px 0 0;
            color: var(--se-muted);
            font-size: 12px;
        }

        .system-errors-autorefresh {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            min-height: 38px;
            padding: 0 12px;
            border: 1px solid var(--se-line);
            border-radius: 999px;
            color: #344054;
            background: #fff;
            font-size: 12px;
            font-weight: 900;
            cursor: pointer;
            user-select: none;
        }

        .system-errors-autorefresh input {
            accent-color: #102f4c;
        }

        .system-errors-toolbar {
            display: grid;
            grid-template-columns: minmax(280px, 1.6fr) repeat(4, minmax(130px, .75fr)) auto;
            gap: 12px;
            align-items: end;
            padding: 16px;
            border-bottom: 1px solid var(--se-line);
            background: #f8fafc;
        }

        .system-error-filter {
            display: grid;
            gap: 6px;
            min-width: 0;
        }

        .system-error-filter span {
            color: #64748b;
            font-size: 10px;
            font-weight: 900;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .system-error-filter input,
        .system-error-filter select {
            width: 100%;
            min-height: 40px;
            padding: 8px 12px;
            border: 1px solid #cfdce8;
            border-radius: 12px;
            outline: none;
            background: #fff;
            color: #102f4c;
            font-size: 12px;
            font-weight: 700;
        }

        .system-error-filter input:focus,
        .system-error-filter select:focus {
            border-color: #7aa7ca;
            box-shadow: 0 0 0 4px rgba(23, 92, 145, .11);
        }

        .system-error-clear {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 40px;
            padding: 0 13px;
            border: 1px solid #cfdce8;
            border-radius: 12px;
            background: #fff;
            color: #113d61;
            font-size: 12px;
            font-weight: 900;
            cursor: pointer;
            white-space: nowrap;
            transition: background .16s ease, transform .16s ease;
        }

        .system-error-clear:hover {
            transform: translateY(-1px);
            background: #eef5fb;
        }

        .system-errors-table-wrap {
            max-height: 640px;
            overflow: auto;
            background: #fff;
            scrollbar-width: thin;
            scrollbar-color: #9fb1c2 #edf2f6;
        }

        .system-errors-table-wrap::-webkit-scrollbar { width: 9px; height: 9px; }
        .system-errors-table-wrap::-webkit-scrollbar-track { background: #edf2f6; }
        .system-errors-table-wrap::-webkit-scrollbar-thumb { background: #9fb1c2; border-radius: 999px; }

        .system-errors-table {
            width: 100%;
            min-width: 1120px;
            border-collapse: separate;
            border-spacing: 0;
            table-layout: fixed;
            font-size: 12px;
        }

        .system-errors-table th {
            position: sticky;
            top: 0;
            z-index: 2;
            padding: 13px 14px;
            color: #dbeafe;
            background: #071b2d;
            border-bottom: 1px solid #071b2d;
            text-align: left;
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

        .system-errors-table th:nth-child(1) { width: 125px; }
        .system-errors-table th:nth-child(2) { width: 230px; }
        .system-errors-table th:nth-child(3) { width: auto; }
        .system-errors-table th:nth-child(4) { width: 170px; }
        .system-errors-table th:nth-child(5) { width: 112px; }
        .system-errors-table th:nth-child(6) { width: 158px; }
        .system-errors-table th:nth-child(7) { width: 190px; }
        .system-errors-table th:nth-child(8) { width: 136px; }

        .system-errors-table td {
            padding: 14px;
            border-bottom: 1px solid #edf2f7;
            color: #344054;
            vertical-align: middle;
        }

        .system-errors-table tbody tr {
            transition: background .14s ease;
        }

        .system-errors-table tbody tr:hover {
            background: #f8fbff;
        }

        .system-errors-loading {
            padding: 42px !important;
            color: #667085 !important;
            text-align: center !important;
        }

        .system-error-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            min-height: 28px;
            padding: 5px 9px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .system-error-pill.is-critical { color: var(--se-red); background: var(--se-red-soft); }
        .system-error-pill.is-server { color: #b42318; background: #fff1f0; }
        .system-error-pill.is-upload { color: var(--se-amber); background: var(--se-amber-soft); }
        .system-error-pill.is-client { color: #175cd3; background: #eff8ff; }

        .system-error-route strong,
        .system-error-copy strong {
            display: block;
            overflow: hidden;
            color: var(--se-navy);
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .system-error-route small,
        .system-error-copy small {
            display: block;
            overflow: hidden;
            margin-top: 4px;
            color: var(--se-muted);
            font-size: 10px;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .system-error-message {
            display: -webkit-box;
            max-height: 42px;
            overflow: hidden;
            color: #344054;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            line-height: 1.45;
        }

        .system-error-actions-cell {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .system-error-table-action {
            display: inline-grid;
            width: 34px;
            height: 34px;
            place-items: center;
            border: 1px solid #d8e3ed;
            border-radius: 11px;
            color: #113d61;
            background: #fff;
            cursor: pointer;
            transition: background .16s ease, border-color .16s ease, transform .16s ease;
        }

        .system-error-table-action:hover {
            transform: translateY(-1px);
            border-color: #a8c2d8;
            background: #eef5fb;
        }

        .system-error-table-action.is-resolve { color: var(--se-green); }
        .system-error-table-action.is-reopen { color: var(--se-amber); }
        .system-error-table-action:disabled { cursor: wait; opacity: .65; }

        .system-error-status {
            display: inline-flex;
            align-items: center;
            min-height: 26px;
            padding: 4px 9px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 900;
            white-space: nowrap;
        }

        .system-error-status.is-open { color: var(--se-red); background: var(--se-red-soft); }
        .system-error-status.is-resolved { color: var(--se-green); background: var(--se-green-soft); }

        .system-error-resolution {
            display: grid;
            gap: 3px;
            margin-top: 7px;
            color: #667085;
            font-size: 10px;
            font-weight: 800;
            line-height: 1.25;
        }

        .system-error-resolution small {
            display: block;
            max-width: 170px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .system-error-resolution-confirm {
            display: grid;
            gap: 6px;
            text-align: center;
        }

        .system-error-resolution-confirm span {
            color: #667085;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .05em;
        }

        .system-error-resolution-confirm strong {
            color: var(--se-navy);
            font-size: 18px;
        }

        .system-error-resolution-confirm small {
            color: #667085;
            font-weight: 700;
        }

        @media (max-width: 1240px) {
            .system-error-metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .system-errors-toolbar { grid-template-columns: repeat(3, minmax(0, 1fr)); }
            .system-error-filter-search { grid-column: 1 / -1; }
            .system-error-clear { width: 100%; }
        }

        @media (max-width: 760px) {
            .system-errors-hero {
                grid-template-columns: 1fr;
                padding: 22px;
            }

            .system-errors-actions {
                align-items: stretch;
                min-width: 0;
            }

            .system-errors-action-link,
            .system-errors-action-primary {
                width: 100%;
            }

            .system-error-metrics { grid-template-columns: 1fr; }
            .system-errors-panel-header {
                align-items: flex-start;
                flex-direction: column;
            }

            .system-errors-toolbar { grid-template-columns: 1fr; }
        }
    </style>

    <script src="/js/config.js" is:inline></script>
    <script src="/js/system-errors.js?v=20260713-system-error-custom-modal" is:inline></script>
</DashboardLayout>
