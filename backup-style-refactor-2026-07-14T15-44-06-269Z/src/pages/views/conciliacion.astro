        ></script>
        <script is:inline src="/js/conciliacion-burgerking.js"></script>

        <script
            is:inline
            src="/js/conciliacion.js?v=20260702-main-file-width-fixed"></script>
        <script is:inline>
            (() => {
                if (window.__taxStoreModalDelegateReady) return;
                window.__taxStoreModalDelegateReady = true;

                const configs = [
                    {
                        dialogId: "popeyesTaxStoreDialog",
                        addId: "pyTaxAddStore",
                        saveId: "pyTaxSaveStore",
                        clearId: "pyTaxClearStore",
                        numberId: "pyTaxStoreNumber",
                        formModeId: "pyTaxFormMode",
                        editSelector: "[data-py-tax-edit]",
                        editDataset: "pyTaxEdit",
                        clearFn: "limpiarFormularioStoreTaxPopeyes",
                        loadFn: "cargarFormularioStoreTaxPopeyes",
                        readFn: "leerFormularioStoreTaxPopeyes",
                        upsertFn: "upsertStoreTaxPopeyes",
                        renderFn: "renderStoresTaxPopeyes",
                        statusFn: "mostrarStatusTaxPopeyes",
                        recalcFn: "recalcularTaxReviewPopeyesSiAplica",
                    },
                    {
                        dialogId: "tacoBellTaxStoreDialog",
                        addId: "tbTaxAddStore",
                        saveId: "tbTaxSaveStore",
                        clearId: "tbTaxClearStore",
                        numberId: "tbTaxStoreNumber",
                        formModeId: "tbTaxFormMode",
                        editSelector: "[data-tb-tax-edit]",
                        editDataset: "tbTaxEdit",
                        clearFn: "limpiarFormularioStoreTaxTacoBell",
                        loadFn: "cargarFormularioStoreTaxTacoBell",
                        readFn: "leerFormularioStoreTaxTacoBell",
                        upsertFn: "upsertStoreTaxTacoBell",
                        renderFn: "renderStoresTaxTacoBell",
                        statusFn: "mostrarStatusTaxTacoBell",
                        recalcFn: "recalcularTaxReviewTacoBellSiAplica",
                    },
                    {
                        dialogId: "burgerKingTaxStoreDialog",
                        addId: "bkTaxAddStore",
                        saveId: "bkTaxSaveStore",
                        clearId: "bkTaxClearStore",
                        numberId: "bkTaxStoreNumber",
                        formModeId: "bkTaxFormMode",
                        editSelector: "[data-bk-tax-edit]",
                        editDataset: "bkTaxEdit",
                        clearFn: "limpiarFormularioStoreTaxBurgerKing",
                        loadFn: "cargarFormularioStoreTaxBurgerKing",
                        readFn: "leerFormularioStoreTaxBurgerKing",
                        upsertFn: "upsertStoreTaxBurgerKing",
                        renderFn: "renderStoresTaxBurgerKing",
                        statusFn: "mostrarStatusTaxBurgerKing",
                    },
                ];

                const callTaxFn = (name, ...args) => {
                    const fn = window[name];
                    return typeof fn === "function" ? fn(...args) : undefined;
                };

                const setTaxFormOpen = (config, isOpen) => {
                    const dialog = document.getElementById(config.dialogId);
                    const form = dialog?.querySelector(".bk-tax-store-form");

                    dialog?.classList.toggle("is-form-open", isOpen);

                    if (form) {
                        form.style.display = isOpen ? "grid" : "";
                    }

                    if (isOpen) {
                        requestAnimationFrame(() => {
                            document.getElementById(config.numberId)?.focus();
                        });
                    }
                };

                const setTaxFormMode = (config, text) => {
                    const mode = document.getElementById(config.formModeId);

                    if (mode) {
                        mode.textContent = text;
                    }
                };

                document.addEventListener(
                    "click",
                    (event) => {
                        const target =
                            event.target instanceof Element
                                ? event.target
                                : null;

                        if (!target) return;

                        for (const config of configs) {
                            const addButton = target.closest(
                                `#${config.addId}`,
                            );
                            const saveButton = target.closest(
                                `#${config.saveId}`,
                            );
                            const clearButton = target.closest(
                                `#${config.clearId}`,
                            );
                            const editButton = target.closest(
                                config.editSelector,
                            );

                            if (
                                !addButton &&
                                !saveButton &&
                                !clearButton &&
                                !editButton
                            ) {
                                continue;
                            }

                            event.preventDefault();
                            event.stopPropagation();
                            event.stopImmediatePropagation();

                            if (addButton) {
                                callTaxFn(config.clearFn);
                                setTaxFormMode(config, "New store");
                                setTaxFormOpen(config, true);
                                callTaxFn(
                                    config.statusFn,
                                    "Capture the new store details.",
                                );
                                return;
                            }

                            if (editButton) {
                                const store =
                                    editButton.dataset[config.editDataset];
                                callTaxFn(config.loadFn, store);
                                setTaxFormMode(
                                    config,
                                    `Editing store ${store}`,
                                );
                                setTaxFormOpen(config, true);
                                callTaxFn(
                                    config.statusFn,
                                    "Editing the selected store.",
                                );
                                return;
                            }

                            if (clearButton) {
                                callTaxFn(config.clearFn);
                                setTaxFormMode(config, "New store");
                                setTaxFormOpen(config, false);
                                callTaxFn(config.statusFn, "Edit cancelled.");
                                return;
                            }

                            if (saveButton) {
                                try {
                                    const storeData = callTaxFn(config.readFn);
                                    callTaxFn(config.upsertFn, storeData);
                                    callTaxFn(config.renderFn);
                                    callTaxFn(config.recalcFn);
                                    callTaxFn(
                                        config.statusFn,
                                        "Store saved successfully.",
                                        "success",
                                    );
                                    callTaxFn(config.clearFn);
                                    setTaxFormMode(config, "New store");
                                    setTaxFormOpen(config, false);
                                } catch (error) {
                                    callTaxFn(
                                        config.statusFn,
                                        error.message,
                                        "error",
                                    );

                                    if (window.Swal) {
                                        Swal.fire(
                                            "Review the store",
                                            error.message,
                                            "warning",
                                        );
                                    }
                                }

                                return;
                            }
                        }
                    },
                    true,
                );
            })();
        </script>
