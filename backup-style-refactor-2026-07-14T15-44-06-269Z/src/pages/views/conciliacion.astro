            font-family: "Inter", sans-serif;
            font-weight: 500;
        }

        .valor-esperado {
            font-family: "Inter", sans-serif;
            color: var(--gray-600);
        }

        .valor-diferencia {
            font-family: "Inter", sans-serif;
            font-weight: 600;
        }

        .valor-diferencia.positivo {
            color: var(--success);
        }

        .valor-diferencia.negativo {
            color: var(--danger);
        }

        .valor-diferencia.cero {
            color: var(--gray-400);
        }

        .estado-icon {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        .estado-icon.ok {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .estado-icon.diferencia {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }

        .totals-row {
            background: var(--gray-50);
            border-top: 2px solid var(--gray-200);
        }

        .totals-row td {
            padding: 16px;
        }

        /* Notes Section */
        .notes-section {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
            margin-top: 24px;
        }

        .notes-section label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: var(--gray-700);
            margin-bottom: 8px;
        }

        .conciliacion-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 16px;
        }

        .reconciliation-compare-panel {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            align-items: center;
            gap: 16px;
            margin: 20px 0 24px;
            padding: 18px 20px;
            border: 1px solid #cbd9e8;
            border-left: 4px solid #173f67;
            border-radius: 10px;
            background: #f8fafc;
        }

        .reconciliation-compare-icon {
            display: grid;
            width: 44px;
            height: 44px;
            place-items: center;
            border-radius: 8px;
            background: #e7eef6;
            color: #123554;
            font-size: 18px;
        }

        .reconciliation-compare-copy {
            min-width: 0;
        }

        .reconciliation-compare-copy > span {
            display: block;
            margin-bottom: 3px;
            color: #5a7189;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.08em;
        }

        .reconciliation-compare-copy > strong {
            display: block;
            color: #102f4c;
            font-size: 16px;
        }

        .reconciliation-compare-copy > p {
            margin: 4px 0 0;
            color: #5e7185;
            font-size: 13px;
        }

        .reconciliation-compare-button {
            white-space: nowrap;
        }

        .reconciliation-compare-panel[data-state="cargando"] {
            border-left-color: #2563a6;
        }

        .reconciliation-compare-panel[data-state="igual"] {
            border-color: #acd7bd;
            border-left-color: #16834b;
            background: #f5fbf7;
        }

        .reconciliation-compare-panel[data-state="igual"]
            .reconciliation-compare-icon {
            background: #dcf4e5;
            color: #147644;
        }

        .reconciliation-compare-panel[data-state="cambios"] {
            border-color: #edb5b5;
            border-left-color: #b4232f;
            background: #fff8f8;
        }

        .reconciliation-compare-panel[data-state="cambios"]
            .reconciliation-compare-icon {
            background: #fee2e2;
            color: #b4232f;
        }

        .reconciliation-compare-panel[data-state="error"] {
            border-color: #edb5b5;
            border-left-color: #b4232f;
            background: #fff8f8;
        }

        .reconciliation-compare-panel[data-state="error"]
            .reconciliation-compare-icon {
            background: #fee2e2;
            color: #b4232f;
        }

        .reconciliation-compare-panel[data-state="primera"] {
            border-left-color: #a46612;
            background: #fffaf1;
        }

        .reconciliation-compare-panel[data-state="primera"]
            .reconciliation-compare-icon {
            background: #fdf0d4;
            color: #925d12;
        }

        .form-textarea {
            width: 100%;
            padding: 12px 14px;
            font-size: 14px;
            border: 1px solid var(--gray-300);
            border-radius: var(--radius);
            resize: vertical;
            transition: var(--transition);
        }

        .form-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px var(--primary-light);
        }

        /* Form Elements */
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-group label {
            font-size: 13px;
            font-weight: 500;
            color: var(--gray-700);
        }

        .form-select,
        .form-input {
            padding: 10px 14px;
            font-size: 14px;
            border: 1px solid var(--gray-300);
            border-radius: var(--radius);
            background: var(--white);
            transition: var(--transition);
        }

        .form-select:focus,
        .form-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px var(--primary-light);
        }

        .form-select:disabled {
            background: var(--gray-100);
            cursor: not-allowed;
        }

        /* Table Responsive */
        .table-responsive {
            overflow-x: auto;
        }

        .multi-upload-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .upload-card {
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-xl);
            padding: 16px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
        }

        .upload-card:hover {
            border-color: rgba(16, 42, 67, 0.32);
            box-shadow: var(--shadow-md);
        }

        .upload-card[data-status="loaded"] {
            border-color: rgba(16, 42, 67, 0.45);
            background: linear-gradient(
                180deg,
                var(--white),
                rgba(230, 238, 246, 0.62)
            );
        }

        .upload-card[data-status="error"] {
            border-color: rgba(185, 28, 28, 0.45);
            background: linear-gradient(
                180deg,
                var(--white),
                rgba(254, 226, 226, 0.34)
            );
        }

        .upload-card-title {
            min-height: 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 12px;
            color: var(--gray-900);
            font-size: 14px;
            font-weight: 800;
        }

        .upload-card-title span:first-child {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-width: 0;
        }

        .upload-card-title i {
            color: var(--primary);
        }

        .upload-card-actions {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            flex: 0 0 auto;
        }

        .upload-remove-btn {
            width: 28px;
            height: 28px;
            padding: 0;
            border: 1px solid var(--gray-200);
            border-radius: var(--radius);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--white);
            color: var(--gray-500);
            cursor: pointer;
            transition: var(--transition);
        }

        .upload-remove-btn:hover {
            border-color: rgba(185, 28, 28, 0.3);
            background: var(--danger-light);
            color: var(--danger);
        }

        .upload-remove-btn i {
            color: currentColor;
        }

        .upload-remove-btn[hidden] {
            display: none;
        }

        .upload-pill {
            flex: 0 0 auto;
            padding: 4px 8px;
            border-radius: var(--radius);
            border: 1px solid var(--gray-200);
            background: var(--gray-50);
            color: var(--gray-600);
            font-size: 12px;
            font-weight: 800;
        }

        .upload-pill.required {
            background: var(--primary-light);
            color: var(--primary-dark);
            border-color: rgba(16, 42, 67, 0.18);
        }

        .upload-pill.optional {
            background: var(--warning-light);
            color: var(--warning);
            border-color: rgba(180, 83, 9, 0.18);
        }

        .upload-card input[type="file"] {
            width: 100%;
            border: 1px dashed var(--gray-300);
            border-radius: var(--radius);
            padding: 12px;
            background: var(--gray-50);
            cursor: pointer;
        }

        .upload-card input[type="file"]:hover {
            background: var(--gray-100);
        }

        .upload-date-filter {
            margin-top: 10px;
            width: 100%;
        }

        .taco-bell-saved-reconciliation {
            display: grid;
            gap: 8px;
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid var(--gray-200);
        }

        /* INICIO CAMBIO EBT INDEPENDIENTE */

        .ebt-upload-tools {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 8px;
            margin-top: 10px;
        }

        .ebt-upload-tools .btn {
            min-height: 36px;
            justify-content: center;
            white-space: nowrap;
        }

        .ebt-saved-label {
            display: block;
            margin-top: 10px;
            color: var(--gray-600);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .ebt-saved-select {
            margin-top: 6px;
            width: 100%;
        }

        @media (max-width: 720px) {
            .ebt-upload-tools {
                grid-template-columns: 1fr;
            }

            .ebt-upload-tools .btn {
                width: 100%;
            }
        }

        /* FIN CAMBIO EBT INDEPENDIENTE */

        .upload-status {
            min-height: 18px;
            margin-top: 10px;
            color: var(--gray-500);
            font-size: 12px;
            font-weight: 700;
            word-break: break-word;
        }

        .upload-card[data-status="loaded"] .upload-status {
            color: var(--primary);
        }

        .upload-card[data-status="error"] .upload-status {
            color: var(--danger);
        }

        .comparison-status {
            display: grid;
            grid-template-columns: 28px minmax(0, 1fr);
            align-items: center;
            gap: 10px;
            margin-top: 10px;
            padding: 10px 12px;
            border: 1px solid #cbd8e5;
            border-radius: 4px;
            background: #f6f9fc;
            color: #17324d;
        }

        .comparison-status > i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 28px;
            height: 28px;
            color: #174a73;
        }

        .comparison-status > span {
            display: flex;
            min-width: 0;
            flex-direction: column;
            gap: 2px;
        }

        .comparison-status strong {
            font-size: 12px;
            line-height: 1.25;
        }

        .comparison-status small {
            color: #60758a;
            font-size: 11px;
            line-height: 1.35;
        }

        .upload-card[data-comparison="igual"] .comparison-status {
            border-color: #a7d7bd;
            background: #f0f9f4;
            color: #166534;
        }

        .upload-card[data-comparison="igual"] .comparison-status > i {
            color: #15803d;
        }

        .upload-card[data-comparison="actualizado"] .comparison-status,
        .upload-card[data-comparison="primero"] .comparison-status {
            border-color: #adc9df;
            background: #eef5fb;
        }

        .upload-card[data-comparison="aviso"] .comparison-status {
            border-color: #f1cf8a;
            background: #fff8e8;
            color: #854d0e;
        }

        .upload-card[data-comparison="aviso"] .comparison-status > i {
            color: #b45309;
        }

        .file-comparison-dialog {
            position: fixed;
            inset: 0;
            margin: auto;

            width: min(860px, calc(100vw - 40px));
            max-width: none;
            max-height: calc(100vh - 40px);

            padding: 0;
            overflow: hidden;

            border: 1px solid #cbd8e5;
            border-top: 5px solid #102f4a;
            border-radius: 12px;

            background: #fff;
            box-shadow: 0 30px 90px -42px rgba(7, 27, 44, 0.74);
        }

        .file-comparison-dialog[data-size="compacto"] {
            width: min(660px, calc(100vw - 40px));
        }

        .file-comparison-dialog[data-size="compacto"]
            .file-comparison-window-header {
            padding: 16px 20px 14px;
        }

        .file-comparison-dialog[data-size="compacto"]
            .file-comparison-window-header
            h2 {
            font-size: 23px;
        }

        .file-comparison-dialog[data-size="compacto"]
            .file-comparison-window-header
            p {
            font-size: 11px;
        }

        .file-comparison-dialog[data-size="compacto"]
            .file-comparison-window-content {
            padding: 18px 20px 12px;
        }

        .file-comparison-dialog[data-size="compacto"]
            .file-comparison-window-footer {
            justify-content: flex-end;
            padding: 12px 20px 18px;
            border-top: 0;
            background: #fff;
        }

        .file-comparison-dialog[data-size="compacto"]
            .file-comparison-window-footer
            > p {
            display: none;
        }

        .file-comparison-dialog::backdrop {
            background: rgba(8, 27, 44, 0.64);
            backdrop-filter: blur(5px);
        }

        .file-comparison-window {
            display: grid;
            max-height: calc(100vh - 40px);
            grid-template-rows: auto minmax(0, 1fr) auto;
        }

        .file-comparison-window-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 18px 20px 16px;
            border-bottom: 1px solid #dbe5ef;
            background: linear-gradient(180deg, #fff 0%, #f7fafc 100%);
            color: #102a43;
        }

        .file-comparison-window-header span {
            color: #2c6b9e;
            font-size: 10px;
            font-weight: 900;
            letter-spacing: 0.12em;
        }

        .file-comparison-window-header h2 {
            margin: 3px 0 2px;
            color: #102a43;
            font-family: "Inter", sans-serif;
            font-size: 25px;
            line-height: 1.05;
        }

        .file-comparison-window-header p {
            margin: 0;
            color: #5f7488;
            font-size: 12px;
        }

        .file-comparison-close {
            width: 34px;
            height: 34px;
            flex: 0 0 auto;
            border: 1px solid #c9d8e6;
            border-radius: 7px;
            background: #fff;
            color: #244966;
            cursor: pointer;
        }

        .file-comparison-close:hover {
            border-color: #9fb7ce;
            background: #eef4f9;
        }

        .file-comparison-window-content {
            padding: 20px 22px;
            overflow-y: auto;
        }

        .file-comparison-window-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            padding: 14px 22px;
            border-top: 1px solid #c5d2de;
            background: #fff;
        }

        .file-comparison-window-footer > p {
            display: flex;
            align-items: center;
            gap: 7px;
            margin: 0;
            color: #60758a;
            font-size: 11px;
        }

        .file-comparison-window-footer > div {
            display: flex;
            gap: 8px;
        }

        :global(.file-comparison-view) {
            color: #243b53;
            text-align: left;
        }

        :global(.file-comparison-result) {
            display: grid;
            grid-template-columns: max-content minmax(0, 1fr);
            align-items: center;
            gap: 5px 13px;
            margin-bottom: 14px;
            padding: 14px 15px;
            border: 1px solid #d4e1ed;
            border-radius: 9px;
            background: #f7fafc;
        }

        :global(.file-comparison-result span) {
            grid-row: 1 / span 2;
            padding: 6px 9px;
            border-radius: 6px;
            background: #123b5d;
            color: #fff;
            font-size: 9px;
            font-weight: 900;
            letter-spacing: 0.08em;
        }

        :global(.file-comparison-result strong) {
            display: flex;
            align-items: center;
            gap: 7px;
            color: #102a43;
            font-size: 15px;
        }

        :global(.file-comparison-result p) {
            margin: 0;
            color: #52667a;
            font-size: 12px;
        }

        :global(
            .file-comparison-view[data-result="igual"] .file-comparison-result
        ) {
            border-color: #b8dec7;
            background: #f2fbf5;
        }

        :global(
            .file-comparison-view[data-result="igual"]
                .file-comparison-result
                span
        ) {
            background: #166534;
        }

        :global(
            .file-comparison-view[data-result="actualizado"]
                .file-comparison-result
        ) {
            border-color: #efcf9d;
            background: #fff9ed;
        }

        :global(
            .file-comparison-view[data-result="actualizado"]
                .file-comparison-result
                span
        ) {
            background: #92400e;
        }

        :global(.file-comparison-grid) {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 34px minmax(0, 1fr);
            align-items: stretch;
            gap: 10px;
        }

        :global(.file-comparison-arrow) {
            display: flex;
            align-items: center;
            justify-content: center;
            color: #54738e;
        }

        :global(.file-compare-card) {
            display: flex;
            min-width: 0;
            min-height: 150px;
            flex-direction: column;
            gap: 10px;
            padding: 14px;
            border: 1px solid #ccd8e4;
            border-radius: 5px;
            background: #fff;
        }

        :global(.file-compare-card.is-empty) {
            align-items: center;
            justify-content: center;
            color: #61788d;
            text-align: center;
        }

        :global(.file-compare-card.is-empty > i) {
            color: #8aa1b5;
            font-size: 24px;
        }

        :global(.file-compare-eyebrow) {
            color: #60758a;
            font-size: 10px;
            font-weight: 900;
            letter-spacing: 0.07em;
            text-transform: uppercase;
        }

        :global(.file-compare-name) {
            display: flex;
            min-width: 0;
            align-items: center;
            gap: 8px;
        }

        :global(.file-compare-name i) {
            color: #15803d;
        }

        :global(.file-compare-name strong) {
            overflow: hidden;
            color: #102a43;
            font-size: 13px;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        :global(.file-compare-card dl) {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
            margin: auto 0 0;
        }

        :global(.file-compare-card dl div) {
            padding: 8px;
            border: 1px solid #e0e8f0;
            border-radius: 3px;
            background: #f7f9fb;
        }

        :global(.file-compare-card dt) {
            color: #6b7f92;
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
        }

        :global(.file-compare-card dd) {
            margin: 2px 0 0;
            color: #102a43;
            font-family: "Inter", sans-serif;
            font-size: 14px;
            font-weight: 800;
        }

        :global(.file-compare-card small) {
            color: #70869a;
            font-size: 10px;
        }

        :global(.file-comparison-changes) {
            margin-top: 14px;
            padding: 12px 14px;
            border: 1px solid #d6e0ea;
            border-radius: 5px;
            background: #f8fafc;
        }

        :global(.file-comparison-changes h4) {
            margin: 0 0 8px;
            color: #102a43;
            font-size: 12px;
        }

        :global(.file-compare-change) {
            display: grid;
            grid-template-columns: minmax(110px, 1fr) minmax(130px, auto) 78px;
            align-items: center;
            gap: 10px;
            padding: 7px 0;
            border-top: 1px solid #e2e8f0;
            font-size: 11px;
        }

        :global(.file-compare-change strong) {
            color: #243b53;
            font-family: "Inter", sans-serif;
            text-align: right;
        }

        :global(.file-compare-change em) {
            color: #166534;
            font-style: normal;
            font-weight: 800;
            text-align: right;
        }

        :global(.file-compare-change.is-changed em) {
            color: #b45309;
        }

        :global(.file-comparison-legacy-note) {
            display: flex;
            gap: 8px;
            margin-top: 14px;
            padding: 10px 12px;
            border: 1px solid #d6e0ea;
            border-radius: 4px;
            background: #f8fafc;
            color: #52667a;
            font-size: 11px;
            line-height: 1.45;
        }

        :global(.reconciliation-comparison-summary) {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 8px;
            margin-bottom: 12px;
        }

        :global(.reconciliation-comparison-summary > div) {
            display: flex;
            min-height: 62px;
            flex-direction: column;
            justify-content: center;
            padding: 10px 11px;
            border: 1px solid #d7e2ec;
            border-radius: 8px;
            background: #fff;
        }

        :global(.reconciliation-comparison-summary strong) {
            color: #102a43;
            font-family: "Inter", sans-serif;
            font-size: 18px;
        }

        :global(.reconciliation-comparison-summary span) {
            margin-top: 2px;
            color: #60758a;
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        :global(.reconciliation-comparison-context) {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
            padding: 10px;
            border: 1px solid #d7e2ec;
            border-radius: 9px;
            background: #f8fafc;
        }

        :global(.reconciliation-comparison-context > div) {
            min-width: 0;
            padding: 9px 10px;
            border-radius: 7px;
            background: #fff;
        }

        :global(.reconciliation-comparison-context span) {
            display: block;
            color: #6c8093;
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
        }

        :global(.reconciliation-comparison-context strong) {
            display: block;
            overflow: hidden;
            margin-top: 3px;
            color: #163b59;
            font-size: 13px;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        :global(.reconciliation-comparison-context > i) {
            color: #59748b;
        }

        :global(.reconciliation-comparison-guide) {
            margin-top: 13px;
            padding: 12px 14px;
            border: 1px solid #d5e0e9;
            border-radius: 6px;
            background: #f8fafc;
        }

        :global(.reconciliation-comparison-guide > strong) {
            color: #173b59;
            font-size: 11px;
        }

        :global(.reconciliation-comparison-guide ol) {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 9px;
            margin: 10px 0 0;
            padding: 0;
            list-style: none;
        }

        :global(.reconciliation-comparison-guide li) {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            gap: 7px;
            align-items: start;
            color: #526b80;
            font-size: 10px;
            line-height: 1.4;
        }

        :global(.reconciliation-comparison-guide li span) {
            display: grid;
            width: 20px;
            height: 20px;
            place-items: center;
            border-radius: 50%;
            color: #fff;
            background: #174a75;
            font-size: 9px;
            font-weight: 800;
        }

        :global(.reconciliation-comparison-next-step) {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            align-items: start;
            gap: 10px;
            margin-top: 10px;
            padding: 10px 12px;
            border: 1px solid #d6e2ed;
            border-radius: 8px;
            color: #35536c;
            background: #f8fafc;
        }

        :global(.reconciliation-comparison-next-step > i) {
            margin-top: 2px;
            color: #25608a;
        }

        :global(.reconciliation-comparison-next-step strong) {
            display: block;
            color: #173b59;
            font-size: 11px;
        }

        :global(.reconciliation-comparison-next-step p) {
            margin: 3px 0 0;
            color: #61778a;
            font-size: 10px;
            line-height: 1.4;
        }

        :global(.reconciliation-reading-guide) {
            display: grid;
            grid-template-columns:
                minmax(0, 1fr) auto minmax(0, 1fr)
                auto minmax(0, 1fr);
            align-items: center;
            gap: 9px;
            margin-bottom: 12px;
            padding: 10px 12px;
            border: 1px solid #d5e0e9;
            border-radius: 6px;
            background: #f8fafc;
        }

        :global(.reconciliation-reading-guide div) {
            min-width: 0;
        }

        :global(.reconciliation-reading-guide span) {
            color: #173f64;
            font-size: 9px;
            font-weight: 900;
            letter-spacing: 0.06em;
        }

        :global(.reconciliation-reading-guide p) {
            margin: 3px 0 0;
            color: #687d90;
            font-size: 9px;
            line-height: 1.35;
        }

        :global(.reconciliation-reading-guide > i) {
            color: #7890a4;
            font-size: 10px;
        }

        :global(.reconciliation-diff-wrapper) {
            max-height: 360px;
            overflow: auto;
            border: 1px solid #bdcbd8;
            border-radius: 4px;
            background: #fff;
        }

        :global(.reconciliation-diff-table) {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }

        :global(.reconciliation-diff-table th) {
            position: sticky;
            top: 0;
            z-index: 1;
            padding: 9px 10px;
            border-bottom: 1px solid #294f6f;
            background: #163b59;
            color: #fff;
            font-size: 10px;
            letter-spacing: 0.04em;
            text-align: left;
            text-transform: uppercase;
        }

        :global(.reconciliation-diff-table td) {
            padding: 8px 10px;
            border-bottom: 1px solid #e1e8ef;
            color: #334e68;
        }

        :global(.reconciliation-diff-table td:nth-child(n + 3)) {
            font-family: "Inter", sans-serif;
            text-align: right;
        }

        :global(.reconciliation-diff-table td:last-child) {
            color: #b42318;
            background: #fff6f5;
            font-weight: 800;
        }

        :global(.reconciliation-diff-more) {
            margin: 8px 0 0;
            color: #60758a;
            font-size: 10px;
            text-align: right;
        }

        @media (max-width: 680px) {
            .file-comparison-dialog {
                width: calc(100vw - 18px);
                max-height: calc(100vh - 18px);
            }

            .file-comparison-window {
                max-height: calc(100vh - 18px);
            }

            .file-comparison-window-header,
            .file-comparison-window-content,
            .file-comparison-window-footer {
                padding-right: 14px;
                padding-left: 14px;
            }

            .file-comparison-window-footer {
                align-items: stretch;
                flex-direction: column;
            }

            .file-comparison-window-footer > div {
                display: grid;
                grid-template-columns: 1fr 1fr;
            }

            .file-comparison-dialog[data-size="compacto"]
                .file-comparison-window-footer
                > div {
                grid-template-columns: 1fr;
                width: 100%;
            }

            :global(.file-comparison-result) {
                grid-template-columns: 1fr;
            }

            :global(.file-comparison-result span) {
                grid-row: auto;
                justify-self: start;
            }

            :global(.file-comparison-grid) {
                grid-template-columns: 1fr;
            }

            :global(.reconciliation-comparison-summary) {
                grid-template-columns: 1fr;
            }

            :global(.reconciliation-comparison-context) {
                grid-template-columns: 1fr;
            }

            :global(.reconciliation-comparison-context > i) {
                transform: rotate(90deg);
                justify-self: center;
            }

            :global(.reconciliation-comparison-guide ol) {
                grid-template-columns: 1fr;
            }

            :global(.reconciliation-reading-guide) {
                grid-template-columns: 1fr;
            }

            :global(.reconciliation-reading-guide > i) {
                transform: rotate(90deg);
                justify-self: center;
            }

            :global(.file-comparison-arrow) {
                transform: rotate(90deg);
            }

            :global(.file-compare-change) {
                grid-template-columns: 1fr auto;
            }

            :global(.file-compare-change em) {
                grid-column: 2;
            }
        }

